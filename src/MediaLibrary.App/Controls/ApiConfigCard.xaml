<UserControl x:Class="MediaLibrary.App.Controls.ApiConfigCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:MediaLibrary.App.Helpers"
             x:Name="Root">
    <UserControl.Resources>
        <Storyboard x:Key="ApiStatusLightStoryboard"
                    AutoReverse="True"
                    RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0.42"
                             To="1"
                             Duration="0:0:1.05" />
        </Storyboard>
    </UserControl.Resources>

    <Border Style="{StaticResource CompactCardStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                               FontSize="18"
                               Text="{Binding Title, ElementName=Root}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding Description, ElementName=Root}"
                               TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource BodyTextStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Description, ElementName=Root}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <Border Grid.Column="1"
                        Margin="16,0,0,0"
                        Padding="11,5"
                        VerticalAlignment="Top"
                        BorderThickness="1"
                        CornerRadius="4">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{DynamicResource BrushWarningBackground}" />
                            <Setter Property="BorderBrush" Value="{DynamicResource BrushWarningBorder}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StatusText, ElementName=Root}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding StatusKind, ElementName=Root}" Value="success">
                                    <Setter Property="Background" Value="{DynamicResource BrushSuccessBackground}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource BrushSuccessBorder}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding StatusKind, ElementName=Root}" Value="failure">
                                    <Setter Property="Background" Value="{DynamicResource BrushErrorBackground}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource BrushErrorBorder}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="10"
                                 Height="10"
                                 Margin="0,0,8,0"
                                 VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#B7791F" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding StatusKind, ElementName=Root}" Value="success">
                                            <Setter Property="Fill" Value="#15803D" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding StatusKind, ElementName=Root}" Value="failure">
                                            <Setter Property="Fill" Value="#B91C1C" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                    <BeginStoryboard Storyboard="{StaticResource ApiStatusLightStoryboard}" />
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                        <TextBlock helpers:TrimmedTextToolTipBehavior.FullText="{Binding StatusText, ElementName=Root}"
                                   FontSize="13"
                                   Style="{StaticResource BadgeTextStyle}"
                                   Text="{Binding StatusText, ElementName=Root}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,18,0,0"
                    Padding="16,14"
                    CornerRadius="{StaticResource RadiusCompactCard}"
                    Background="{DynamicResource BrushSurfaceAlt}"
                    BorderBrush="{DynamicResource BrushBorder}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ContentPresenter Content="{Binding FieldsContent, ElementName=Root}" />

                    <Grid Grid.Row="1" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock VerticalAlignment="Center"
                                   Text="{Binding FeedbackText, ElementName=Root}"
                                   TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FeedbackText, ElementName=Root}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ContentPresenter Grid.Column="1"
                                          Margin="18,0,0,0"
                                          HorizontalAlignment="Right"
                                          Content="{Binding ActionsContent, ElementName=Root}">
                            <ContentPresenter.Style>
                                <Style TargetType="ContentPresenter">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActionsContent, ElementName=Root}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ContentPresenter.Style>
                        </ContentPresenter>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
