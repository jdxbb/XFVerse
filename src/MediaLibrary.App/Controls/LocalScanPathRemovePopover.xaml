<UserControl x:Class="MediaLibrary.App.Controls.LocalScanPathRemovePopover"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Grid>
        <Button x:Name="RemoveButton"
                Content="{Binding ButtonText, ElementName=Root}"
                IsEnabled="{Binding IsActionEnabled, ElementName=Root}"
                Click="RemoveButton_Click"
                Style="{StaticResource SecondaryButtonStyle}" />

        <Popup x:Name="ConfirmPopup"
               AllowsTransparency="True"
               IsOpen="{Binding IsOpen, ElementName=Root, Mode=TwoWay}"
               Opened="ConfirmPopup_Opened"
               Placement="Bottom"
               PlacementTarget="{Binding ElementName=RemoveButton}"
               PopupAnimation="Fade"
               StaysOpen="False">
            <Border Margin="0,8,0,0"
                    PreviewKeyDown="Popover_PreviewKeyDown"
                    Style="{StaticResource LightweightConfirmPopoverStyle}">
                <StackPanel MinWidth="280">
                    <TextBlock Text="{Binding Title, ElementName=Root}"
                               Style="{StaticResource SectionTitleTextStyle}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding Message, ElementName=Root}"
                               Style="{StaticResource DialogBodyStyle}" />
                    <StackPanel Margin="0,16,0,0"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                        <Button x:Name="CancelButton"
                                Content="取消"
                                Click="CancelButton_Click"
                                Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Margin="10,0,0,0"
                                Content="{Binding ConfirmButtonText, ElementName=Root}"
                                Click="ConfirmButton_Click"
                                IsEnabled="{Binding IsActionEnabled, ElementName=Root}"
                                Style="{StaticResource WarningButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
