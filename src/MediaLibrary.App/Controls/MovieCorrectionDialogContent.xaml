<UserControl x:Class="MediaLibrary.App.Controls.MovieCorrectionDialogContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MediaLibrary.App.Controls"
             xmlns:helpers="clr-namespace:MediaLibrary.App.Helpers">
    <UserControl.Resources>
        <Style x:Key="CorrectionClearButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SmallIconButtonStyle}">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Content" Value="x" />
            <Setter Property="ContentTemplate" Value="{StaticResource PhosphorSmallIconContentTemplate}" />
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <Trigger Property="Tag" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
                <Trigger Property="Tag" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CorrectionToolbarButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource GlassSecondaryButtonStyle}">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="MaxHeight" Value="36" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="CorrectionTextBoxStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource TextBoxStyle}">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="10,5,28,5" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="CorrectionToolbarIconStyle" TargetType="{x:Type controls:PhosphorIcon}">
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
        </Style>

        <Style x:Key="CorrectionResultActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource GlassPrimaryButtonStyle}">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="MaxHeight" Value="36" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="CorrectionInlineMetaIconStyle" TargetType="{x:Type controls:PhosphorIcon}">
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource BrushForegroundMuted}" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="-1" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CorrectionResultItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0,0,10,0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="0,1,0,1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CorrectionModernScrollThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border Width="6"
                                Background="{DynamicResource BrushForegroundMuted}"
                                CornerRadius="3"
                                Opacity="0.58" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CorrectionModernScrollRepeatButtonStyle" TargetType="{x:Type RepeatButton}">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CorrectionModernScrollBarStyle" TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="6" />
            <Setter Property="MinWidth" Value="6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Width="{TemplateBinding Width}" Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}"
                                                  Style="{StaticResource CorrectionModernScrollRepeatButtonStyle}" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource CorrectionModernScrollThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}"
                                                  Style="{StaticResource CorrectionModernScrollRepeatButtonStyle}" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
                <Trigger Property="IsMouseCaptureWithin" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=(helpers:ScrollBarAutoRevealBehavior.IsRevealed)}"
                             Value="True">
                    <Setter Property="Opacity" Value="1" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CorrectionResultListStyle"
               TargetType="ListBox"
               BasedOn="{StaticResource SectionListBoxStyle}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Margin" Value="0,0,-16,0" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Visible" />
            <Setter Property="VirtualizingPanel.ScrollUnit" Value="Pixel" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource CorrectionResultItemStyle}" />
        </Style>

        <Style x:Key="CorrectionMovieResultItemStyle"
               TargetType="ListBoxItem"
               BasedOn="{StaticResource CorrectionResultItemStyle}">
            <Setter Property="Padding" Value="20,0,10,0" />
        </Style>

        <Style x:Key="CorrectionMovieResultListStyle"
               TargetType="ListBox"
               BasedOn="{StaticResource CorrectionResultListStyle}">
            <Setter Property="Margin" Value="-20,0,-16,0" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource CorrectionMovieResultItemStyle}" />
        </Style>

        <Style x:Key="CorrectionTrimmedTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource BodyMutedTextStyle}">
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="helpers:TrimmedTextToolTipBehavior.FullText"
                    Value="{Binding RelativeSource={RelativeSource Self}, Path=Text}" />
        </Style>

        <Style x:Key="CorrectionInfoLabelStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource BodyMutedTextStyle}">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="CorrectionInfoValueStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource CorrectionTrimmedTextStyle}">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="CorrectionNestedRowBorderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="{DynamicResource BrushDivider}" />
            <Setter Property="BorderThickness" Value="0,1,0,0" />
        </Style>

        <Style x:Key="CorrectionModePanelStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed" />
        </Style>

        <Style x:Key="CorrectionRowExpanderStyle" TargetType="Expander">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Expander}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <ToggleButton x:Name="HeaderSite"
                                          HorizontalContentAlignment="Stretch"
                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Content="{TemplateBinding Header}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Grid Background="Transparent">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="18" />
                                            </Grid.ColumnDefinitions>
                                            <ContentPresenter HorizontalAlignment="Stretch"
                                                              Content="{TemplateBinding Content}" />
                                            <controls:PhosphorIcon x:Name="Arrow"
                                                                   Grid.Column="1"
                                                                   Width="12"
                                                                   Height="12"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource BrushForegroundMuted}"
                                                                   Icon="caret-down" />
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Arrow" Property="Icon" Value="caret-up" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ExpandSite"
                                              Grid.Row="1"
                                              Visibility="Collapsed"
                                              ContentSource="Content" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <helpers:CachedShadowBorder Height="548"
            Padding="16"
            ClipToBounds="False"
            Style="{StaticResource GlassInlinePanelStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid IsEnabled="{Binding IsCorrectionInteractionEnabled}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="172" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <ComboBox ItemsSource="{Binding CorrectionTargetOptions}"
                          PreviewMouseWheel="CorrectionTargetComboBox_PreviewMouseWheel"
                          SelectedItem="{Binding SelectedCorrectionTarget}"
                          Style="{StaticResource CorrectionDialogComboBoxStyle}" />

                <Grid Grid.Column="2">
                    <Grid.Style>
                        <Style TargetType="Grid" BasedOn="{StaticResource CorrectionModePanelStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCorrectionTargetMovie}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.62*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="260" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="102" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="138" />
                    </Grid.ColumnDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center"
                                   Style="{StaticResource CorrectionInfoLabelStyle}"
                                   Text="电影名称" />
                        <Grid Grid.Column="2">
                            <TextBox x:Name="MovieSearchTextBox"
                                     helpers:TextBoxPlaceholderBehavior.IsEnabled="True"
                                     helpers:TextBoxPlaceholderBehavior.PlaceholderText="请输入电影名称"
                                     PreviewKeyDown="CorrectionSearchTextBox_PreviewKeyDown"
                                     Style="{StaticResource CorrectionTextBoxStyle}"
                                     Text="{Binding ManualSearchQuery, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Margin="0,0,4,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Command="{Binding ClearManualSearchQueryCommand}"
                                    Tag="{Binding ManualSearchQuery}"
                                    Style="{StaticResource CorrectionClearButtonStyle}" />
                        </Grid>
                    </Grid>
                    <Grid Grid.Column="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center"
                                   Style="{StaticResource CorrectionInfoLabelStyle}"
                                   Text="上映年份（可选）" />
                        <Grid Grid.Column="2">
                            <TextBox x:Name="MovieYearTextBox"
                                     helpers:TextBoxPlaceholderBehavior.IsEnabled="True"
                                     helpers:TextBoxPlaceholderBehavior.PlaceholderText="请输入上映年份"
                                     PreviewKeyDown="CorrectionSearchTextBox_PreviewKeyDown"
                                     Style="{StaticResource CorrectionTextBoxStyle}"
                                     Text="{Binding ManualSearchYear, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Margin="0,0,4,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Command="{Binding ClearManualSearchYearCommand}"
                                    Tag="{Binding ManualSearchYear}"
                                    Style="{StaticResource CorrectionClearButtonStyle}" />
                        </Grid>
                    </Grid>
                    <Button Grid.Column="4"
                            Command="{Binding SearchCandidatesCommand}"
                            Style="{StaticResource CorrectionToolbarButtonStyle}">
                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                            <controls:PhosphorIcon Icon="magnifying-glass"
                                                   Style="{StaticResource CorrectionToolbarIconStyle}" />
                            <TextBlock Margin="7,0,0,0" VerticalAlignment="Center" Text="TMDB" />
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="6"
                            Command="{Binding AiSuggestSearchCommand}"
                            Style="{StaticResource CorrectionToolbarButtonStyle}">
                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                            <controls:PhosphorIcon Icon="sparkle"
                                                   Style="{StaticResource CorrectionToolbarIconStyle}" />
                            <TextBlock Margin="7,0,0,0" VerticalAlignment="Center" Text="AI辅助识别" />
                        </StackPanel>
                    </Button>
                </Grid>

                <Grid Grid.Column="2">
                    <Grid.Style>
                        <Style TargetType="Grid" BasedOn="{StaticResource CorrectionModePanelStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCorrectionTargetTvEpisode}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.54*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="176" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="176" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="102" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="138" />
                    </Grid.ColumnDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center"
                                   Style="{StaticResource CorrectionInfoLabelStyle}"
                                   Text="电视剧名称" />
                        <Grid Grid.Column="2">
                            <TextBox x:Name="TvSearchTextBox"
                                     helpers:TextBoxPlaceholderBehavior.IsEnabled="True"
                                     helpers:TextBoxPlaceholderBehavior.PlaceholderText="请输入电视剧名称"
                                     PreviewKeyDown="CorrectionSearchTextBox_PreviewKeyDown"
                                     Style="{StaticResource CorrectionTextBoxStyle}"
                                     Text="{Binding TvCorrectionQuery, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Margin="0,0,4,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Command="{Binding ClearTvCorrectionQueryCommand}"
                                    Tag="{Binding TvCorrectionQuery}"
                                    Style="{StaticResource CorrectionClearButtonStyle}" />
                        </Grid>
                    </Grid>
                    <Grid Grid.Column="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center"
                                   Style="{StaticResource CorrectionInfoLabelStyle}"
                                   Text="季号" />
                        <Grid Grid.Column="2">
                            <TextBox x:Name="SeasonNumberTextBox"
                                     helpers:TextBoxPlaceholderBehavior.IsEnabled="True"
                                     helpers:TextBoxPlaceholderBehavior.PlaceholderText="季号"
                                     PreviewKeyDown="CorrectionSearchTextBox_PreviewKeyDown"
                                     Style="{StaticResource CorrectionTextBoxStyle}"
                                     Text="{Binding CorrectionSeasonNumber, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Margin="0,0,4,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Command="{Binding ClearCorrectionSeasonNumberCommand}"
                                    Tag="{Binding CorrectionSeasonNumber}"
                                    Style="{StaticResource CorrectionClearButtonStyle}" />
                        </Grid>
                    </Grid>
                    <Grid Grid.Column="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center"
                                   Style="{StaticResource CorrectionInfoLabelStyle}"
                                   Text="集号" />
                        <Grid Grid.Column="2">
                            <TextBox x:Name="EpisodeNumberTextBox"
                                     helpers:TextBoxPlaceholderBehavior.IsEnabled="True"
                                     helpers:TextBoxPlaceholderBehavior.PlaceholderText="集号"
                                     PreviewKeyDown="CorrectionSearchTextBox_PreviewKeyDown"
                                     Style="{StaticResource CorrectionTextBoxStyle}"
                                     Text="{Binding CorrectionEpisodeNumber, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Margin="0,0,4,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Command="{Binding ClearCorrectionEpisodeNumberCommand}"
                                    Tag="{Binding CorrectionEpisodeNumber}"
                                    Style="{StaticResource CorrectionClearButtonStyle}" />
                        </Grid>
                    </Grid>
                    <Button Grid.Column="6"
                            Command="{Binding SearchCandidatesCommand}"
                            Style="{StaticResource CorrectionToolbarButtonStyle}">
                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                            <controls:PhosphorIcon Icon="magnifying-glass"
                                                   Style="{StaticResource CorrectionToolbarIconStyle}" />
                            <TextBlock Margin="7,0,0,0" VerticalAlignment="Center" Text="TMDB" />
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="8"
                            Command="{Binding AiSuggestSearchCommand}"
                            Style="{StaticResource CorrectionToolbarButtonStyle}">
                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                            <controls:PhosphorIcon Icon="sparkle"
                                                   Style="{StaticResource CorrectionToolbarIconStyle}" />
                            <TextBlock Margin="7,0,0,0" VerticalAlignment="Center" Text="AI辅助识别" />
                        </StackPanel>
                    </Button>
                </Grid>

                <Grid Grid.Column="2">
                    <Grid.Style>
                        <Style TargetType="Grid" BasedOn="{StaticResource CorrectionModePanelStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCorrectionTargetUnknownSeason}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="192" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="158" />
                    </Grid.ColumnDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center"
                                   Style="{StaticResource CorrectionInfoLabelStyle}"
                                   Text="集号" />
                        <Grid Grid.Column="2">
                            <TextBox x:Name="UnknownSeasonEpisodeNumberTextBox"
                                     helpers:TextBoxPlaceholderBehavior.IsEnabled="True"
                                     helpers:TextBoxPlaceholderBehavior.PlaceholderText="集号"
                                     Style="{StaticResource CorrectionTextBoxStyle}"
                                     Text="{Binding UnknownSeasonEpisodeNumber, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Margin="0,0,4,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Command="{Binding ClearUnknownSeasonEpisodeNumberCommand}"
                                    Tag="{Binding UnknownSeasonEpisodeNumber}"
                                    Style="{StaticResource CorrectionClearButtonStyle}" />
                        </Grid>
                    </Grid>
                    <Button Grid.Column="2"
                            Height="36"
                            Margin="0,0,26,0"
                            VerticalAlignment="Center"
                            Command="{Binding ApplyUnknownSeasonCorrectionCommand}"
                            Content="加入到该季"
                            Style="{StaticResource CorrectionToolbarButtonStyle}" />
                </Grid>
            </Grid>

            <TextBlock Grid.Row="1"
                       Margin="0,10,0,0"
                       Text="{Binding StatusMessage}"
                       TextWrapping="Wrap">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding StatusMessage}" Value="">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <Grid Grid.Row="3">
                <TextBlock HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Text="搜索后会在这里显示电影候选。">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsCorrectionTargetMovie}" Value="True" />
                                        <Condition Binding="{Binding HasSearchCandidates}" Value="False" />
                                        <Condition Binding="{Binding IsCorrectionBusy}" Value="False" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <ListBox ItemsSource="{Binding SearchCandidates}">
                    <ListBox.Style>
                        <Style TargetType="ListBox" BasedOn="{StaticResource CorrectionMovieResultListStyle}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCorrectionTargetMovie}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.Style>
                    <ListBox.Resources>
                        <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource CorrectionModernScrollBarStyle}" />
                        <Style TargetType="{x:Type ScrollViewer}">
                            <Setter Property="helpers:ScrollBarAutoRevealBehavior.IsEnabled" Value="True" />
                        </Style>
                    </ListBox.Resources>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid MinHeight="144" Margin="0,9,0,9">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="82" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="3*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                 <Grid Width="82"
                                       Height="123"
                                       VerticalAlignment="Center">
                                    <Canvas ClipToBounds="False" IsHitTestVisible="False">
                                        <Image x:Name="MovieCandidatePosterPaletteShadowHost"
                                               Width="122"
                                               Height="163"
                                               Canvas.Left="-20"
                                               Canvas.Top="-20"
                                               helpers:PosterCachedShadowBehavior.BlurRadius="18"
                                               helpers:PosterCachedShadowBehavior.CardHeight="123"
                                               helpers:PosterCachedShadowBehavior.CardWidth="82"
                                               helpers:PosterCachedShadowBehavior.CornerRadius="10"
                                               helpers:PosterCachedShadowBehavior.IsEnabled="True"
                                               helpers:PosterCachedShadowBehavior.Opacity="0.36"
                                               helpers:PosterCachedShadowBehavior.Padding="20"
                                               helpers:PosterCachedShadowBehavior.QuantizeColor="True"
                                               helpers:PosterCachedShadowBehavior.ShadowDepth="5"
                                               Stretch="Fill" />
                                    </Canvas>
                                    <helpers:CachedShadowBorder Background="{DynamicResource BrushGlassSurface}"
                                                                CornerRadius="10"
                                                                Effect="{x:Null}"
                                                                ShadowBlurRadius="16"
                                                                ShadowColor="{DynamicResource ColorCachedShadowCompact}"
                                                                ShadowDepth="4"
                                                                ShadowOpacity="0.12"
                                                                ShadowPadding="24" />
                                    <Border x:Name="MovieCandidatePosterClipMask"
                                            Background="White"
                                            CornerRadius="10"
                                            IsHitTestVisible="False" />
                                    <Grid>
                                        <Grid.OpacityMask>
                                            <VisualBrush Visual="{Binding ElementName=MovieCandidatePosterClipMask}" />
                                        </Grid.OpacityMask>
                                        <Control IsHitTestVisible="False" Template="{StaticResource PosterPlaceholderTemplate}" />
                                         <Image helpers:PosterCacheImageBehavior.DecodePixelWidth="220"
                                                helpers:PosterCacheImageBehavior.Source="{Binding PosterRemoteUrl}"
                                                helpers:PosterPaletteShadowBehavior.TargetElement="{Binding ElementName=MovieCandidatePosterPaletteShadowHost}"
                                                helpers:PosterPaletteShadowBehavior.TargetName="MovieCandidatePosterPaletteShadowHost"
                                                RenderOptions.BitmapScalingMode="HighQuality"
                                                Stretch="UniformToFill" />
                                        <Border BorderBrush="#42FFFFFF"
                                                BorderThickness="1"
                                                CornerRadius="10">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Offset="0" Color="#24FFFFFF" />
                                                    <GradientStop Offset="0.46" Color="#00000000" />
                                                    <GradientStop Offset="1" Color="#16000000" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                     </Grid>
                                 </Grid>
                                 <Grid Grid.Column="2"
                                       Height="123"
                                       VerticalAlignment="Center">
                                     <Grid.RowDefinitions>
                                         <RowDefinition Height="Auto" />
                                         <RowDefinition Height="7" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                     <StackPanel Margin="0,5,0,0"
                                                 VerticalAlignment="Top"
                                                 Orientation="Horizontal">
                                        <TextBlock FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource BrushForegroundPrimary}"
                                                   Text="{Binding Title}" />
                                        <TextBlock Margin="10,0,0,1"
                                                   VerticalAlignment="Bottom"
                                                   Style="{StaticResource BodyMutedTextStyle}"
                                                   Text="{Binding OriginalTitleDisplayText}" />
                                    </StackPanel>
                                    <ScrollViewer Grid.Row="2"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Auto"
                                                  helpers:ScrollBarAutoRevealBehavior.IsEnabled="True"
                                                  helpers:TextScrollOverflowCueBehavior.IsEnabled="True"
                                                  PreviewMouseWheel="ResultOverviewScrollViewer_PreviewMouseWheel">
                                        <ScrollViewer.Resources>
                                            <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource CorrectionModernScrollBarStyle}" />
                                        </ScrollViewer.Resources>
                                        <TextBlock FontSize="12"
                                                   Foreground="{DynamicResource BrushForegroundSecondary}"
                                                   TextWrapping="Wrap">
                                            <Run FontWeight="SemiBold" Text="简介  " />
                                            <Run Text="{Binding OverviewDisplayText, Mode=OneWay}" />
                                        </TextBlock>
                                    </ScrollViewer>
                                </Grid>
                                 <StackPanel Grid.Column="4" VerticalAlignment="Center">
                                     <StackPanel Orientation="Horizontal">
                                         <controls:PhosphorIcon Width="16" Height="16" VerticalAlignment="Center" Foreground="{DynamicResource BrushForegroundMuted}" Icon="calendar-blank" />
                                         <TextBlock Margin="7,0,0,0" VerticalAlignment="Center" Style="{StaticResource BodyMutedTextStyle}" Text="{Binding ReleaseDateText}" />
                                         <controls:PhosphorIcon Width="16" Height="16" Margin="14,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource BrushForegroundMuted}" Icon="clock" />
                                         <TextBlock Margin="7,0,0,0" VerticalAlignment="Center" Style="{StaticResource BodyMutedTextStyle}" Text="{Binding RuntimeText}" />
                                     </StackPanel>
                                     <Grid Margin="0,9,0,0">
                                         <Grid.ColumnDefinitions>
                                             <ColumnDefinition Width="82" />
                                             <ColumnDefinition Width="*" />
                                         </Grid.ColumnDefinitions>
                                         <Grid.RowDefinitions>
                                             <RowDefinition Height="Auto" />
                                             <RowDefinition Height="6" />
                                             <RowDefinition Height="Auto" />
                                             <RowDefinition Height="6" />
                                             <RowDefinition Height="Auto" />
                                         </Grid.RowDefinitions>
                                         <TextBlock Style="{StaticResource CorrectionInfoLabelStyle}" Text="导演" />
                                         <TextBlock Grid.Column="1" Style="{StaticResource CorrectionInfoValueStyle}" Text="{Binding DirectorDisplayText}" />
                                         <TextBlock Grid.Row="2" Style="{StaticResource CorrectionInfoLabelStyle}" Text="国家/地区" />
                                         <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource CorrectionInfoValueStyle}" Text="{Binding CountryDisplayText}" />
                                         <TextBlock Grid.Row="4" Style="{StaticResource CorrectionInfoLabelStyle}" Text="语言" />
                                         <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource CorrectionInfoValueStyle}" Text="{Binding LanguageDisplayText}" />
                                     </Grid>
                                 </StackPanel>
                                <Button Grid.Column="6"
                                        MinWidth="92"
                                        VerticalAlignment="Center"
                                        Command="{Binding DataContext.ApplyManualMatchCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource GlassPrimaryButtonStyle}">
                                            <Setter Property="Content" Value="修正为TA" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCurrentMatchedMovie}" Value="True">
                                                    <Setter Property="Content" Value="已为该影片" />
                                                    <Setter Property="IsEnabled" Value="False" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Text="搜索后会在这里显示电视剧候选。">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsCorrectionTargetTvEpisode}" Value="True" />
                                        <Condition Binding="{Binding HasTvSearchCandidates}" Value="False" />
                                        <Condition Binding="{Binding IsCorrectionBusy}" Value="False" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <ListBox ItemsSource="{Binding TvSeriesCandidateGroups}">
                    <ListBox.Style>
                        <Style TargetType="ListBox" BasedOn="{StaticResource CorrectionResultListStyle}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCorrectionTargetTvEpisode}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.Style>
                    <ListBox.Resources>
                        <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource CorrectionModernScrollBarStyle}" />
                        <Style TargetType="{x:Type ScrollViewer}">
                            <Setter Property="helpers:ScrollBarAutoRevealBehavior.IsEnabled" Value="True" />
                        </Style>
                    </ListBox.Resources>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Expander Style="{StaticResource CorrectionRowExpanderStyle}">
                                <Expander.Header>
                                    <Grid Margin="0,12,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="14" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="7" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                             <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                                 <TextBlock VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource BrushForegroundPrimary}" Text="{Binding SeriesTitle}" />
                                                 <TextBlock Margin="9,0,0,0" VerticalAlignment="Center" Style="{StaticResource BodyMutedTextStyle}" Text="{Binding OriginalSeriesTitleDisplayText}" />
                                                 <Border Width="1"
                                                         Height="14"
                                                         Margin="12,2,12,0"
                                                         VerticalAlignment="Center"
                                                         Background="{DynamicResource BrushBorder}" />
                                                 <Grid Width="16" Height="16" VerticalAlignment="Center">
                                                     <controls:PhosphorIcon Icon="calendar-blank" Style="{StaticResource CorrectionInlineMetaIconStyle}" />
                                                 </Grid>
                                                 <TextBlock Margin="7,0,0,0" VerticalAlignment="Center" Style="{StaticResource BodyMutedTextStyle}" Text="{Binding FirstAirDateDisplayText}" />
                                                 <Grid Width="16" Height="16" Margin="14,0,0,0" VerticalAlignment="Center">
                                                     <controls:PhosphorIcon Icon="television" Style="{StaticResource CorrectionInlineMetaIconStyle}" />
                                                 </Grid>
                                                 <TextBlock Margin="7,0,0,0" VerticalAlignment="Center" Style="{StaticResource BodyMutedTextStyle}" Text="{Binding SeasonCountText}" />
                                             </StackPanel>
                                             <Grid Grid.Row="2">
                                                 <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="300" />
                                                        <ColumnDefinition Width="1.74*" />
                                                        <ColumnDefinition Width="0.58*" />
                                                        <ColumnDefinition Width="0.58*" />
                                                </Grid.ColumnDefinitions>
                                                 <TextBlock Margin="0,0,28,0" Style="{StaticResource CorrectionTrimmedTextStyle}" Text="{Binding DirectorText, StringFormat=导演  {0}}" />
                                                 <TextBlock Grid.Column="1" Margin="0,0,24,0" Style="{StaticResource CorrectionTrimmedTextStyle}" Text="{Binding GenresDisplayText, StringFormat=类型  {0}}" />
                                                 <TextBlock Grid.Column="2" Margin="0,0,2,0" Style="{StaticResource CorrectionTrimmedTextStyle}" Text="{Binding CountryDisplayText, StringFormat=国家/地区  {0}}" />
                                                 <TextBlock Grid.Column="3" Style="{StaticResource CorrectionTrimmedTextStyle}" Text="{Binding LanguageDisplayText, StringFormat=语言  {0}}" />
                                             </Grid>
                                        </Grid>
                                        <Button Grid.Column="2"
                                                Width="96"
                                                Margin="0,0,26,0"
                                                VerticalAlignment="Center"
                                                Command="{Binding DataContext.SelectTvEpisodeCorrectionTargetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Content="修正到剧"
                                                Style="{StaticResource CorrectionResultActionButtonStyle}" />
                                    </Grid>
                                </Expander.Header>
                                <Border Margin="22,0,44,0"
                                        BorderBrush="{DynamicResource BrushDivider}"
                                        BorderThickness="0">
                                    <ItemsControl ItemsSource="{Binding Seasons}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource CorrectionNestedRowBorderStyle}">
                                                    <Grid Margin="0,9,0,9">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="12" />
                                                    <ColumnDefinition Width="14" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="14" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Ellipse Width="7" Height="7" VerticalAlignment="Center" Fill="{DynamicResource BrushForegroundPrimary}" />
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                    <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource BrushForegroundPrimary}" Text="{Binding SeriesAndSeasonTitle}" />
                                                    <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
                                                        <Grid Width="16" Height="16" VerticalAlignment="Center">
                                                            <controls:PhosphorIcon Icon="calendar-blank" Style="{StaticResource CorrectionInlineMetaIconStyle}" />
                                                        </Grid>
                                                        <TextBlock Margin="7,0,0,0" VerticalAlignment="Center" Style="{StaticResource BodyMutedTextStyle}" Text="{Binding AirDateDisplayText}" />
                                                        <Grid Width="16" Height="16" Margin="14,0,0,0" VerticalAlignment="Center">
                                                            <controls:PhosphorIcon Icon="television" Style="{StaticResource CorrectionInlineMetaIconStyle}" />
                                                        </Grid>
                                                        <TextBlock Margin="7,0,0,0" VerticalAlignment="Center" Style="{StaticResource BodyMutedTextStyle}" Text="{Binding EpisodeCountText}" />
                                                    </StackPanel>
                                                </StackPanel>
                                                <Button Grid.Column="4"
                                                        Width="96"
                                                        VerticalAlignment="Center"
                                                        Command="{Binding DataContext.SelectTvEpisodeCorrectionTargetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="修正到季"
                                                        Style="{StaticResource CorrectionResultActionButtonStyle}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                            </Expander>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Text="没有可选择的已有未识别季。">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsCorrectionTargetUnknownSeason}" Value="True" />
                                        <Condition Binding="{Binding HasUnknownSeasonTargets}" Value="False" />
                                        <Condition Binding="{Binding IsCorrectionBusy}" Value="False" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <ListBox ItemsSource="{Binding UnknownSeasonSeriesGroups}">
                    <ListBox.Style>
                        <Style TargetType="ListBox" BasedOn="{StaticResource CorrectionResultListStyle}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCorrectionTargetUnknownSeason}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.Style>
                    <ListBox.Resources>
                        <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource CorrectionModernScrollBarStyle}" />
                        <Style TargetType="{x:Type ScrollViewer}">
                            <Setter Property="helpers:ScrollBarAutoRevealBehavior.IsEnabled" Value="True" />
                        </Style>
                    </ListBox.Resources>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Expander Style="{StaticResource CorrectionRowExpanderStyle}">
                                <Expander.Header>
                                    <StackPanel Margin="0,12,0,12"
                                                VerticalAlignment="Center"
                                                Orientation="Horizontal">
                                        <TextBlock VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource BrushForegroundPrimary}" Text="{Binding SeriesTitle}" />
                                        <Grid Width="16" Height="16" Margin="14,0,0,0" VerticalAlignment="Center">
                                            <controls:PhosphorIcon Icon="television" Style="{StaticResource CorrectionInlineMetaIconStyle}" />
                                        </Grid>
                                        <TextBlock Margin="7,0,0,0" VerticalAlignment="Center" Style="{StaticResource BodyMutedTextStyle}" Text="{Binding SeasonCountText}" />
                                    </StackPanel>
                                </Expander.Header>
                                <Border Margin="22,0,26,0"
                                        BorderBrush="{DynamicResource BrushDivider}"
                                        BorderThickness="0">
                                    <ItemsControl ItemsSource="{Binding Seasons}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource CorrectionNestedRowBorderStyle}">
                                                    <Grid Margin="0,9,0,9">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="12" />
                                                    <ColumnDefinition Width="14" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="14" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Ellipse Width="7" Height="7" VerticalAlignment="Center" Fill="{DynamicResource BrushForegroundPrimary}" />
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                    <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource BrushForegroundPrimary}" Text="{Binding SeriesAndSeasonTitle}" />
                                                    <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
                                                        <Grid Width="16" Height="16" VerticalAlignment="Center">
                                                            <controls:PhosphorIcon Icon="file-video" Style="{StaticResource CorrectionInlineMetaIconStyle}" />
                                                        </Grid>
                                                        <TextBlock Margin="7,0,0,0" VerticalAlignment="Center" Style="{StaticResource BodyMutedTextStyle}" Text="{Binding SourceCountText}" />
                                                    </StackPanel>
                                                </StackPanel>
                                                <Button Grid.Column="4"
                                                        Width="96"
                                                        VerticalAlignment="Center"
                                                        Command="{Binding DataContext.SelectUnknownSeasonTargetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="选择该季"
                                                        Style="{StaticResource CorrectionResultActionButtonStyle}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                            </Expander>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Grid.Row="0"
                        Grid.RowSpan="5"
                        Panel.ZIndex="20"
                        Background="Transparent"
                        IsHitTestVisible="True">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCorrectionBusy}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <ContentControl Width="34"
                                        Height="34"
                                        HorizontalAlignment="Center"
                                        Template="{StaticResource PhosphorLoadingSpinnerTemplate}" />
                        <TextBlock Margin="0,10,0,0"
                                   HorizontalAlignment="Center"
                                   Style="{StaticResource BodyMutedTextStyle}"
                                   Text="正在处理，请稍候..." />
                    </StackPanel>
                </Border>
            </Grid>

            <StackPanel Grid.Row="4"
                        Margin="0,12,0,0"
                        HorizontalAlignment="Center"
                        IsEnabled="{Binding IsCorrectionInteractionEnabled}"
                        Orientation="Horizontal">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCorrectionTargetTvEpisode}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <Button MinWidth="104"
                        Command="{Binding PreviewTvEpisodeCorrectionCommand}"
                        Content="确认修正"
                        Style="{StaticResource GlassPrimaryButtonStyle}" />
                <Button MinWidth="84"
                        Margin="36,0,0,0"
                        Command="{Binding CancelCorrectionCommand}"
                        Content="取消"
                        Style="{StaticResource GlassSecondaryButtonStyle}" />
            </StackPanel>
        </Grid>
    </helpers:CachedShadowBorder>
</UserControl>
