<UserControl x:Class="MediaLibrary.App.Controls.SensitiveSettingInput"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MediaLibrary.App.Controls"
             xmlns:helpers="clr-namespace:MediaLibrary.App.Helpers"
             x:Name="Root">
    <Grid Height="28">
        <TextBox MaxLength="{Binding MaxLength, ElementName=Root}"
                 Text="{Binding Text, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
            <TextBox.Style>
                <Style TargetType="TextBox" BasedOn="{StaticResource FormTextBoxStyle}">
                    <Setter Property="Height" Value="28" />
                    <Setter Property="MinHeight" Value="28" />
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="Padding" Value="10,3,38,3" />
                    <Setter Property="FontSize" Value="12" />
                    <Setter Property="VerticalContentAlignment" Value="Center" />
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsRevealed, ElementName=Root}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBox.Style>
        </TextBox>

        <PasswordBox MaxLength="{Binding MaxLength, ElementName=Root}"
                     helpers:PasswordBoxBindingHelper.BindPassword="True"
                     helpers:PasswordBoxBindingHelper.BoundPassword="{Binding Text, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
            <PasswordBox.Style>
                <Style TargetType="PasswordBox" BasedOn="{StaticResource FormPasswordBoxStyle}">
                    <Setter Property="Height" Value="28" />
                    <Setter Property="MinHeight" Value="28" />
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="Padding" Value="10,3,38,3" />
                    <Setter Property="FontSize" Value="12" />
                    <Setter Property="VerticalContentAlignment" Value="Center" />
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsRevealed, ElementName=Root}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </PasswordBox.Style>
        </PasswordBox>

        <Button Width="28"
                Height="24"
                Margin="0,0,4,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Click="ToggleReveal_Click">
            <Button.Style>
                <Style TargetType="Button" BasedOn="{StaticResource SmallIconButtonStyle}">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderBrush" Value="Transparent" />
                    <Setter Property="ToolTip" Value="显示敏感字段" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsRevealed, ElementName=Root}" Value="True">
                            <Setter Property="ToolTip" Value="隐藏敏感字段" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
            <Grid Width="16" Height="16" IsHitTestVisible="False">
                <controls:PhosphorIcon Icon="eye"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}">
                    <controls:PhosphorIcon.Style>
                        <Style TargetType="controls:PhosphorIcon" BasedOn="{StaticResource PhosphorSmallIconStyle}">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRevealed, ElementName=Root}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </controls:PhosphorIcon.Style>
                </controls:PhosphorIcon>
                <controls:PhosphorIcon Icon="eye-slash"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}">
                    <controls:PhosphorIcon.Style>
                        <Style TargetType="controls:PhosphorIcon" BasedOn="{StaticResource PhosphorSmallIconStyle}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRevealed, ElementName=Root}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </controls:PhosphorIcon.Style>
                </controls:PhosphorIcon>
            </Grid>
        </Button>
    </Grid>
</UserControl>
