<UserControl x:Class="MediaLibrary.App.Controls.SensitiveSettingInput"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:MediaLibrary.App.Helpers"
             x:Name="Root">
    <Grid Height="28">
        <TextBox MaxLength="{Binding MaxLength, ElementName=Root}"
                 Text="{Binding Text, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
            <TextBox.Style>
                <Style TargetType="TextBox" BasedOn="{StaticResource FormTextBoxStyle}">
                    <Setter Property="Height" Value="28" />
                    <Setter Property="MinHeight" Value="28" />
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="Padding" Value="10,3,38,3" />
                    <Setter Property="FontSize" Value="12" />
                    <Setter Property="VerticalContentAlignment" Value="Center" />
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsRevealed, ElementName=Root}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBox.Style>
        </TextBox>

        <PasswordBox MaxLength="{Binding MaxLength, ElementName=Root}"
                     helpers:PasswordBoxBindingHelper.BindPassword="True"
                     helpers:PasswordBoxBindingHelper.BoundPassword="{Binding Text, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
            <PasswordBox.Style>
                <Style TargetType="PasswordBox" BasedOn="{StaticResource FormPasswordBoxStyle}">
                    <Setter Property="Height" Value="28" />
                    <Setter Property="MinHeight" Value="28" />
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="Padding" Value="10,3,38,3" />
                    <Setter Property="FontSize" Value="12" />
                    <Setter Property="VerticalContentAlignment" Value="Center" />
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsRevealed, ElementName=Root}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </PasswordBox.Style>
        </PasswordBox>

        <Button Width="28"
                Height="24"
                Margin="0,0,4,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Click="ToggleReveal_Click">
            <Button.Style>
                <Style TargetType="Button" BasedOn="{StaticResource SmallIconButtonStyle}">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderBrush" Value="Transparent" />
                    <Setter Property="ToolTip" Value="显示敏感字段" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsRevealed, ElementName=Root}" Value="True">
                            <Setter Property="ToolTip" Value="隐藏敏感字段" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
            <Grid Width="16" Height="16" IsHitTestVisible="False">
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRevealed, ElementName=Root}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Path Data="M1.7,8 C3.2,5.25 5.45,3.85 8,3.85 C10.55,3.85 12.8,5.25 14.3,8 C12.8,10.75 10.55,12.15 8,12.15 C5.45,12.15 3.2,10.75 1.7,8 Z"
                          Fill="Transparent"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          StrokeStartLineCap="Round"
                          StrokeThickness="1.35" />
                    <Ellipse Width="3.6"
                             Height="3.6"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                </Grid>

                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRevealed, ElementName=Root}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Path Data="M2.2,8.15 C3.9,10.35 5.9,11.45 8,11.45 C10.1,11.45 12.1,10.35 13.8,8.15"
                          Fill="Transparent"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          StrokeStartLineCap="Round"
                          StrokeThickness="1.45" />
                    <Path Data="M4.15,10.05 L3.15,11.75 M8,11.45 L8,13.25 M11.85,10.05 L12.85,11.75"
                          Fill="Transparent"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          StrokeStartLineCap="Round"
                          StrokeThickness="1.25" />
                </Grid>
            </Grid>
        </Button>
    </Grid>
</UserControl>
