<UserControl x:Class="MediaLibrary.App.Controls.ScanLogCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:MediaLibrary.App.Helpers">
    <UserControl.Resources>
        <Style x:Key="ScanLogStatusBadgeStyle" TargetType="Border" BasedOn="{StaticResource StatusBadgeStyle}">
            <Setter Property="MinWidth" Value="58" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding StatusText}" Value="已完成">
                    <Setter Property="Background" Value="{DynamicResource BrushSuccessBackground}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushSuccessBorder}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusText}" Value="部分完成">
                    <Setter Property="Background" Value="{DynamicResource BrushWarningBackground}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushWarningBorder}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusText}" Value="失败">
                    <Setter Property="Background" Value="{DynamicResource BrushErrorBackground}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushErrorBorder}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusText}" Value="已取消">
                    <Setter Property="Background" Value="{DynamicResource BrushWarningBackground}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushWarningBorder}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusText}" Value="扫描中">
                    <Setter Property="Background" Value="{DynamicResource BrushInfoBackground}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushInfoBorder}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ScanLogMetricTextStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="ScanLogMetricValueStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyTextStyle}">
            <Setter Property="Margin" Value="0,2,0,0" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
        </Style>

        <Style x:Key="ScanLogMetricCellStyle" TargetType="Border">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Margin" Value="0,0,6,6" />
            <Setter Property="Background" Value="{DynamicResource BrushSurfaceRaised}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="9" />
        </Style>
    </UserControl.Resources>

    <Border Margin="0,0,0,12"
            Padding="12"
            CornerRadius="{StaticResource RadiusCompactCard}"
            Background="{DynamicResource BrushSurfaceAlt}"
            BorderBrush="{DynamicResource BrushBorder}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock VerticalAlignment="Center"
                           helpers:TrimmedTextToolTipBehavior.FullText="{Binding ScanPathDisplayName}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Style="{StaticResource LongFieldTextBlockStyle}"
                           Text="{Binding ScanPathDisplayName}" />

                <Border Grid.Column="2" Style="{StaticResource ScanLogStatusBadgeStyle}">
                    <TextBlock HorizontalAlignment="Center"
                               Text="{Binding StatusText}"
                               Style="{StaticResource BadgeTextStyle}" />
                </Border>
            </Grid>

            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock helpers:TrimmedTextToolTipBehavior.FullText="{Binding TargetText}"
                           Style="{StaticResource LongFieldTextBlockStyle}"
                           Text="{Binding TargetText}" />

                <WrapPanel Grid.Row="2">
                    <Border Margin="0,0,8,0" Style="{StaticResource SmallPillStyle}">
                        <TextBlock Text="{Binding SourceText}" Style="{StaticResource BadgeTextStyle}" />
                    </Border>
                    <TextBlock Margin="0,2,10,0"
                               Text="{Binding StartedAtText, StringFormat=开始 {0}}"
                               Style="{StaticResource BodyMutedTextStyle}" />
                    <TextBlock Margin="0,2,10,0"
                               Text="{Binding EndedAtText, StringFormat=结束 {0}}"
                               Style="{StaticResource BodyMutedTextStyle}" />
                    <TextBlock Margin="0,2,0,0"
                               Text="{Binding DurationText, StringFormat=耗时 {0}}"
                               Style="{StaticResource BodyMutedTextStyle}" />
                </WrapPanel>
            </Grid>

            <UniformGrid Grid.Row="4" Columns="3">
                <Border Style="{StaticResource ScanLogMetricCellStyle}">
                    <StackPanel>
                        <TextBlock Text="扫描" Style="{StaticResource ScanLogMetricTextStyle}" />
                        <TextBlock Text="{Binding ScannedCount}" Style="{StaticResource ScanLogMetricValueStyle}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource ScanLogMetricCellStyle}">
                    <StackPanel>
                        <TextBlock Text="新增" Style="{StaticResource ScanLogMetricTextStyle}" />
                        <TextBlock Text="{Binding NewFileCount}" Style="{StaticResource ScanLogMetricValueStyle}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource ScanLogMetricCellStyle}">
                    <StackPanel>
                        <TextBlock Text="更新" Style="{StaticResource ScanLogMetricTextStyle}" />
                        <TextBlock Text="{Binding UpdatedFileCount}" Style="{StaticResource ScanLogMetricValueStyle}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource ScanLogMetricCellStyle}">
                    <StackPanel>
                        <TextBlock Text="忽略" Style="{StaticResource ScanLogMetricTextStyle}" />
                        <TextBlock Text="{Binding IgnoredFileCount}" Style="{StaticResource ScanLogMetricValueStyle}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource ScanLogMetricCellStyle}">
                    <StackPanel>
                        <TextBlock Text="错误" Style="{StaticResource ScanLogMetricTextStyle}" />
                        <TextBlock Text="{Binding ErrorCount}" Style="{StaticResource ScanLogMetricValueStyle}" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <StackPanel Grid.Row="5" Margin="0,10,0,0">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasReasonSummary}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <TextBlock Text="{Binding ReasonSummaryText}"
                           TextWrapping="Wrap"
                           Style="{StaticResource BodyMutedTextStyle}" />
                <TextBlock Margin="0,4,0,0"
                           Text="{Binding TopReasonSummaryText}"
                           TextWrapping="Wrap"
                           Style="{StaticResource BodyMutedTextStyle}" />
            </StackPanel>

            <TextBlock Grid.Row="6"
                       Margin="0,10,0,0"
                       Text="{Binding ErrorMessage}"
                       TextWrapping="Wrap">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasErrorMessage}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>
    </Border>
</UserControl>
