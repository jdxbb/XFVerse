<UserControl x:Class="MediaLibrary.App.Controls.ScanLogCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:MediaLibrary.App.Helpers">
    <UserControl.Resources>
        <Storyboard x:Key="ScanLogStatusLightStoryboard"
                    AutoReverse="True"
                    RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0.42"
                             To="1"
                             Duration="0:0:1.05" />
        </Storyboard>

        <Style x:Key="ScanLogStatusBadgeStyle" TargetType="Border">
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Background" Value="{DynamicResource BrushWarningBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushWarningBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding StatusKind}" Value="success">
                    <Setter Property="Background" Value="{DynamicResource BrushSuccessBackground}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushSuccessBorder}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusKind}" Value="failure">
                    <Setter Property="Background" Value="{DynamicResource BrushErrorBackground}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushErrorBorder}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusKind}" Value="running">
                    <Setter Property="Background" Value="{DynamicResource BrushInfoBackground}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushInfoBorder}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ScanLogStatusDotStyle" TargetType="Ellipse">
            <Setter Property="Width" Value="10" />
            <Setter Property="Height" Value="10" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Fill" Value="#B7791F" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding StatusKind}" Value="success">
                    <Setter Property="Fill" Value="#15803D" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusKind}" Value="failure">
                    <Setter Property="Fill" Value="#B91C1C" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusKind}" Value="running">
                    <Setter Property="Fill" Value="#2563EB" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ScanLogInfoTextStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
            <Setter Property="Margin" Value="0,0,0,5" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="ScanLogResultTextStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
            <Setter Property="Margin" Value="0,2,0,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </UserControl.Resources>

    <Border Margin="0,0,0,10"
            Padding="12"
            CornerRadius="6"
            Background="{DynamicResource BrushSurfaceAlt}"
            BorderBrush="{DynamicResource BrushBorder}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock VerticalAlignment="Center"
                           helpers:TrimmedTextToolTipBehavior.FullText="{Binding TitleText}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Style="{StaticResource LongFieldTextBlockStyle}"
                           Text="{Binding TitleText}" />

                <Border Grid.Column="2" Style="{StaticResource ScanLogStatusBadgeStyle}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Style="{StaticResource ScanLogStatusDotStyle}">
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                    <BeginStoryboard Storyboard="{StaticResource ScanLogStatusLightStoryboard}" />
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                        <TextBlock Text="{Binding StatusText}" Style="{StaticResource BadgeTextStyle}" />
                    </StackPanel>
                </Border>
            </Grid>

            <StackPanel Grid.Row="2">
                <TextBlock Text="{Binding BaseUrlText, StringFormat=BaseUrl：{0}}"
                           helpers:TrimmedTextToolTipBehavior.FullText="{Binding BaseUrlText}"
                           Style="{StaticResource ScanLogInfoTextStyle}" />
                <TextBlock Text="{Binding UsernameText, StringFormat=用户名：{0}}"
                           helpers:TrimmedTextToolTipBehavior.FullText="{Binding UsernameText}"
                           Style="{StaticResource ScanLogInfoTextStyle}" />
                <TextBlock Text="{Binding StatusText, StringFormat=扫描状态：{0}}"
                           Style="{StaticResource ScanLogInfoTextStyle}" />
                <TextBlock Text="{Binding StartedAtText, StringFormat=开始时间：{0}}"
                           Style="{StaticResource ScanLogInfoTextStyle}" />
                <TextBlock Text="{Binding EndedAtText, StringFormat=结束时间：{0}}"
                           Style="{StaticResource ScanLogInfoTextStyle}" />

                <UniformGrid Columns="3" Margin="0,0,0,5">
                    <TextBlock Text="{Binding ScannedCount, StringFormat=扫描：{0}}"
                               Style="{StaticResource ScanLogInfoTextStyle}" />
                    <TextBlock Text="{Binding NewFileCount, StringFormat=新增：{0}}"
                               Style="{StaticResource ScanLogInfoTextStyle}" />
                    <TextBlock Text="{Binding UpdatedFileCount, StringFormat=更新：{0}}"
                               Style="{StaticResource ScanLogInfoTextStyle}" />
                </UniformGrid>

                <UniformGrid Columns="3" Margin="0,0,0,5">
                    <TextBlock Text="{Binding IgnoredFileCount, StringFormat=忽略：{0}}"
                               Style="{StaticResource ScanLogInfoTextStyle}" />
                    <TextBlock Text="{Binding ErrorCount, StringFormat=错误：{0}}"
                               Style="{StaticResource ScanLogInfoTextStyle}" />
                    <TextBlock Text="{Binding DurationText, StringFormat=耗时：{0}}"
                               Style="{StaticResource ScanLogInfoTextStyle}" />
                </UniformGrid>

                <TextBlock Text="{Binding ScanResultText}"
                           helpers:TrimmedTextToolTipBehavior.FullText="{Binding ScanResultText}"
                           Style="{StaticResource ScanLogResultTextStyle}" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
