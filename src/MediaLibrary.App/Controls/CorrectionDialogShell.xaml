<UserControl x:Class="MediaLibrary.App.Controls.CorrectionDialogShell"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MediaLibrary.App.Controls"
             x:Name="Root">
    <UserControl.Style>
        <Style TargetType="{x:Type local:CorrectionDialogShell}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <Trigger Property="IsOpen" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Style>

    <Grid Background="#99000000">
        <Border Width="{Binding DialogWidth, ElementName=Root}"
                MaxHeight="{Binding DialogMaxHeight, ElementName=Root}"
                Padding="22"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Style="{StaticResource PageCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardTitleTextStyle}"
                                   Text="{Binding Title, ElementName=Root}" />
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource BodyMutedTextStyle}"
                                   Text="{Binding Summary, ElementName=Root}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Width="38"
                            Command="{Binding CloseCommand, ElementName=Root}"
                            Content="&#xE711;"
                            Style="{StaticResource DetailBackButtonStyle}"
                            ToolTip="关闭" />
                </Grid>

                <ScrollViewer Grid.Row="2"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <ContentPresenter Content="{Binding DialogContent, ElementName=Root}" />
                </ScrollViewer>

                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center"
                               Style="{StaticResource BodyMutedTextStyle}"
                               Text="{Binding StatusText, ElementName=Root}"
                               TextWrapping="Wrap" />
                    <ContentPresenter Grid.Column="1"
                                      HorizontalAlignment="Right"
                                      Content="{Binding FooterContent, ElementName=Root}">
                        <ContentPresenter.Style>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding UseDefaultActions, ElementName=Root}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ContentPresenter.Style>
                    </ContentPresenter>
                    <Button Grid.Column="1"
                            Command="{Binding CancelCommand, ElementName=Root}"
                            Content="{Binding CancelText, ElementName=Root}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding UseDefaultActions, ElementName=Root}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
