<UserControl x:Class="MediaLibrary.App.Controls.SeasonCorrectionDialogContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:MediaLibrary.App.Helpers">
    <UserControl.Resources>
        <Style x:Key="SeasonCorrectionClearButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SmallIconButtonStyle}">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Content" Value="&#xE711;" />
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <Trigger Property="Tag" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
                <Trigger Property="Tag" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SeasonCorrectionToolbarButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource GlassSecondaryButtonStyle}">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="MaxHeight" Value="36" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="SeasonCorrectionPrimaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource GlassPrimaryButtonStyle}">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="MaxHeight" Value="36" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="SeasonCorrectionTextBoxStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource TextBoxStyle}">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="10,5,28,5" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="SeasonMappingEpisodeTextBoxStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource TextBoxStyle}">
            <Setter Property="Width" Value="62" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="InputChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="InputChrome" Property="BorderBrush" Value="{DynamicResource BrushInputFocusBorder}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="InputChrome" Property="Background" Value="{DynamicResource BrushDisabledBackground}" />
                                <Setter TargetName="InputChrome" Property="BorderBrush" Value="{DynamicResource BrushDisabledBorder}" />
                                <Setter Property="Foreground" Value="{DynamicResource BrushDisabledForeground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SeasonCorrectionToolbarIconStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
        </Style>

        <Style x:Key="SeasonCorrectionInlineIconStyle" TargetType="TextBlock">
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource BrushForegroundMuted}" />
            <Setter Property="LineHeight" Value="16" />
            <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="-1" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SeasonCorrectionTrimmedTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource BodyMutedTextStyle}">
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="helpers:TrimmedTextToolTipBehavior.FullText"
                    Value="{Binding RelativeSource={RelativeSource Self}, Path=Text}" />
        </Style>

        <Style x:Key="SeasonCorrectionResultItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0,0,10,0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="0,1,0,1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SeasonMappingItemStyle"
               TargetType="ListBoxItem"
               BasedOn="{StaticResource SeasonCorrectionResultItemStyle}">
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="SeasonCorrectionModernScrollThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border Width="6"
                                Background="{DynamicResource BrushForegroundMuted}"
                                CornerRadius="3"
                                Opacity="0.58" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SeasonCorrectionModernScrollRepeatButtonStyle" TargetType="{x:Type RepeatButton}">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SeasonCorrectionModernScrollBarStyle" TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="6" />
            <Setter Property="MinWidth" Value="6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Width="{TemplateBinding Width}" Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}"
                                                  Style="{StaticResource SeasonCorrectionModernScrollRepeatButtonStyle}" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SeasonCorrectionModernScrollThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}"
                                                  Style="{StaticResource SeasonCorrectionModernScrollRepeatButtonStyle}" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
                <Trigger Property="IsMouseCaptureWithin" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=(helpers:ScrollBarAutoRevealBehavior.IsRevealed)}"
                             Value="True">
                    <Setter Property="Opacity" Value="1" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SeasonCorrectionResultListStyle"
               TargetType="ListBox"
               BasedOn="{StaticResource SectionListBoxStyle}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Margin" Value="0,0,-16,0" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Visible" />
            <Setter Property="VirtualizingPanel.ScrollUnit" Value="Pixel" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource SeasonCorrectionResultItemStyle}" />
        </Style>

        <Style x:Key="SeasonMappingListStyle"
               TargetType="ListBox"
               BasedOn="{StaticResource SeasonCorrectionResultListStyle}">
            <Setter Property="Margin" Value="0,-1,0,0" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource SeasonMappingItemStyle}" />
        </Style>

        <Style x:Key="SeasonCorrectionNestedRowBorderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="{DynamicResource BrushDivider}" />
            <Setter Property="BorderThickness" Value="0,1,0,0" />
        </Style>

        <Style x:Key="SeasonCorrectionModePanelStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed" />
        </Style>

        <Style x:Key="SeasonCorrectionRowExpanderStyle" TargetType="Expander">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Expander}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <ToggleButton x:Name="HeaderSite"
                                          HorizontalContentAlignment="Stretch"
                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Content="{TemplateBinding Header}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Grid Background="Transparent">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="18" />
                                            </Grid.ColumnDefinitions>
                                            <ContentPresenter HorizontalAlignment="Stretch"
                                                              Content="{TemplateBinding Content}" />
                                            <TextBlock x:Name="Arrow"
                                                       Grid.Column="1"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource BrushForegroundMuted}"
                                                       Text="&#xE70D;" />
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Arrow" Property="Text" Value="&#xE70E;" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ExpandSite"
                                              Grid.Row="1"
                                              Visibility="Collapsed"
                                              ContentSource="Content" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Height="548"
            Padding="16"
            ClipToBounds="False"
            Style="{StaticResource GlassInlinePanelStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid IsHitTestVisible="{Binding IsSeasonCorrectionBaseInteractionEnabled}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="172" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <ComboBox ItemsSource="{Binding SeasonCorrectionTargetOptions}"
                          PreviewMouseWheel="CorrectionTargetComboBox_PreviewMouseWheel"
                          SelectedItem="{Binding SelectedSeasonCorrectionTarget}"
                          Style="{StaticResource CorrectionDialogComboBoxStyle}" />

                <Grid Grid.Column="2">
                    <Grid.Style>
                        <Style TargetType="Grid" BasedOn="{StaticResource SeasonCorrectionModePanelStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSeasonCorrectionTargetRecognized}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.54*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="176" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="102" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="138" />
                    </Grid.ColumnDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center"
                                   Style="{StaticResource BodyMutedTextStyle}"
                                   Text="电视剧名称" />
                        <Grid Grid.Column="2">
                            <TextBox x:Name="SeasonCorrectionSearchTextBox"
                                     helpers:TextBoxPlaceholderBehavior.IsEnabled="True"
                                     helpers:TextBoxPlaceholderBehavior.PlaceholderText="请输入电视剧名称"
                                     PreviewKeyDown="SeasonCorrectionSearchTextBox_PreviewKeyDown"
                                     Style="{StaticResource SeasonCorrectionTextBoxStyle}"
                                     Text="{Binding SeasonCorrectionSearchQuery, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Margin="0,0,4,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Command="{Binding ClearSeasonCorrectionSearchQueryCommand}"
                                    Tag="{Binding SeasonCorrectionSearchQuery}"
                                    Style="{StaticResource SeasonCorrectionClearButtonStyle}" />
                        </Grid>
                    </Grid>
                    <Grid Grid.Column="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center"
                                   Style="{StaticResource BodyMutedTextStyle}"
                                   Text="季号" />
                        <Grid Grid.Column="2">
                            <TextBox x:Name="SeasonCorrectionSeasonNumberTextBox"
                                     helpers:TextBoxPlaceholderBehavior.IsEnabled="True"
                                     helpers:TextBoxPlaceholderBehavior.PlaceholderText="季号"
                                     PreviewKeyDown="SeasonCorrectionSearchTextBox_PreviewKeyDown"
                                     Style="{StaticResource SeasonCorrectionTextBoxStyle}"
                                     Text="{Binding SeasonCorrectionSeasonNumber, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Margin="0,0,4,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Command="{Binding ClearSeasonCorrectionSeasonNumberCommand}"
                                    Tag="{Binding SeasonCorrectionSeasonNumber}"
                                    Style="{StaticResource SeasonCorrectionClearButtonStyle}" />
                        </Grid>
                    </Grid>
                    <Button Grid.Column="4"
                            Command="{Binding OpenSeasonEpisodeMappingCommand}"
                            Content="目标集号映射"
                            Style="{StaticResource SeasonCorrectionToolbarButtonStyle}" />
                    <Button Grid.Column="6"
                            Command="{Binding SearchSeasonCorrectionCandidatesCommand}"
                            Style="{StaticResource SeasonCorrectionToolbarButtonStyle}">
                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       RenderTransformOrigin="0.5,0.5"
                                       Style="{StaticResource SeasonCorrectionToolbarIconStyle}"
                                       Text="&#xE721;">
                                <TextBlock.RenderTransform>
                                    <ScaleTransform ScaleX="-1" />
                                </TextBlock.RenderTransform>
                            </TextBlock>
                            <TextBlock Margin="7,0,0,0" VerticalAlignment="Center" Text="TMDB" />
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="8"
                            Command="{Binding AiSuggestSeasonCorrectionCommand}"
                            Style="{StaticResource SeasonCorrectionToolbarButtonStyle}">
                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe UI Symbol"
                                       FontSize="16"
                                       Style="{StaticResource SeasonCorrectionToolbarIconStyle}"
                                       Text="✦" />
                            <TextBlock Margin="7,0,0,0" VerticalAlignment="Center" Text="AI辅助识别" />
                        </StackPanel>
                    </Button>
                </Grid>

                <Grid Grid.Column="2">
                    <Grid.Style>
                        <Style TargetType="Grid" BasedOn="{StaticResource SeasonCorrectionModePanelStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSeasonCorrectionTargetUnknown}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="158" />
                    </Grid.ColumnDefinitions>
                    <Button Command="{Binding OpenSeasonEpisodeMappingCommand}"
                            Content="目标集号映射"
                            Style="{StaticResource SeasonCorrectionToolbarButtonStyle}" />
                    <Button Grid.Column="2"
                            Margin="0,0,26,0"
                            Command="{Binding ApplySeasonCorrectionCommand}"
                            Content="加入到该季"
                            Style="{StaticResource SeasonCorrectionToolbarButtonStyle}" />
                </Grid>
            </Grid>

            <TextBlock Grid.Row="1"
                       Margin="0,10,0,0"
                       Text="{Binding SeasonCorrectionStatusMessage}"
                       TextWrapping="Wrap">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SeasonCorrectionStatusMessage}" Value="">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <Grid Grid.Row="3"
                  IsHitTestVisible="{Binding IsSeasonCorrectionBaseInteractionEnabled}">
                <TextBlock HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Text="搜索后会在这里显示电视剧候选。">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsSeasonCorrectionTargetRecognized}" Value="True" />
                                        <Condition Binding="{Binding HasRecognizedSeasonTargets}" Value="False" />
                                        <Condition Binding="{Binding IsSeasonCorrectionBusy}" Value="False" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <ListBox ItemsSource="{Binding RecognizedSeasonSeriesGroups}">
                    <ListBox.Style>
                        <Style TargetType="ListBox" BasedOn="{StaticResource SeasonCorrectionResultListStyle}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSeasonCorrectionTargetRecognized}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.Style>
                    <ListBox.Resources>
                        <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource SeasonCorrectionModernScrollBarStyle}" />
                        <Style TargetType="{x:Type ScrollViewer}">
                            <Setter Property="helpers:ScrollBarAutoRevealBehavior.IsEnabled" Value="True" />
                        </Style>
                    </ListBox.Resources>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Expander Style="{StaticResource SeasonCorrectionRowExpanderStyle}">
                                <Expander.Header>
                                    <Grid Margin="0,12,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                                <TextBlock VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource BrushForegroundPrimary}" Text="{Binding SeriesTitle}" />
                                                <TextBlock Margin="9,0,0,0" VerticalAlignment="Center" Style="{StaticResource BodyMutedTextStyle}" Text="{Binding OriginalSeriesTitleDisplayText}" />
                                                <Border Width="1" Height="14" Margin="12,0" VerticalAlignment="Center" Background="{DynamicResource BrushBorder}" />
                                                <Grid Width="16" Height="16" VerticalAlignment="Center">
                                                    <TextBlock Style="{StaticResource SeasonCorrectionInlineIconStyle}" Text="&#xE787;" />
                                                </Grid>
                                                <TextBlock Margin="7,0,0,0" VerticalAlignment="Center" Style="{StaticResource BodyMutedTextStyle}" Text="{Binding FirstAirDateDisplayText}" />
                                                <Grid Width="16" Height="16" Margin="14,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Style="{StaticResource SeasonCorrectionInlineIconStyle}" Text="&#xE8B2;" />
                                                </Grid>
                                                <TextBlock Margin="7,0,0,0" VerticalAlignment="Center" Style="{StaticResource BodyMutedTextStyle}" Text="{Binding SeasonCountText}" />
                                            </StackPanel>
                                            <Grid Margin="0,7,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="300" />
                                                    <ColumnDefinition Width="1.74*" />
                                                    <ColumnDefinition Width="0.58*" />
                                                    <ColumnDefinition Width="0.58*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Margin="0,0,28,0" Style="{StaticResource SeasonCorrectionTrimmedTextStyle}" Text="{Binding DirectorText, StringFormat=导演  {0}}" />
                                                <TextBlock Grid.Column="1" Margin="0,0,24,0" Style="{StaticResource SeasonCorrectionTrimmedTextStyle}" Text="{Binding GenresDisplayText, StringFormat=类型  {0}}" />
                                                <TextBlock Grid.Column="2" Margin="0,0,2,0" Style="{StaticResource SeasonCorrectionTrimmedTextStyle}" Text="{Binding CountryDisplayText, StringFormat=国家/地区  {0}}" />
                                                <TextBlock Grid.Column="3" Style="{StaticResource SeasonCorrectionTrimmedTextStyle}" Text="{Binding LanguageDisplayText, StringFormat=语言  {0}}" />
                                            </Grid>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Width="96"
                                                Margin="0,0,26,0"
                                                VerticalAlignment="Center"
                                                Command="{Binding DataContext.SelectRecognizedSeasonTargetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Content="修正到剧"
                                                Style="{StaticResource SeasonCorrectionPrimaryButtonStyle}" />
                                    </Grid>
                                </Expander.Header>
                                <Border Margin="22,0,44,0">
                                    <ItemsControl ItemsSource="{Binding Seasons}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource SeasonCorrectionNestedRowBorderStyle}">
                                                    <Grid Margin="0,9">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="12" />
                                                            <ColumnDefinition Width="14" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="14" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <Ellipse Width="7" Height="7" VerticalAlignment="Center" Fill="{DynamicResource BrushForegroundPrimary}" />
                                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                            <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource BrushForegroundPrimary}" Text="{Binding SeriesAndSeasonTitle}" />
                                                            <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
                                                                <Grid Width="16" Height="16" VerticalAlignment="Center">
                                                                    <TextBlock Style="{StaticResource SeasonCorrectionInlineIconStyle}" Text="&#xE787;" />
                                                                </Grid>
                                                                <TextBlock Margin="7,0,0,0" VerticalAlignment="Center" Style="{StaticResource BodyMutedTextStyle}" Text="{Binding AirDateDisplayText}" />
                                                                <Grid Width="16" Height="16" Margin="14,0,0,0" VerticalAlignment="Center">
                                                                    <TextBlock Style="{StaticResource SeasonCorrectionInlineIconStyle}" Text="&#xE8B2;" />
                                                                </Grid>
                                                                <TextBlock Margin="7,0,0,0" VerticalAlignment="Center" Style="{StaticResource BodyMutedTextStyle}" Text="{Binding EpisodeCountText}" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <Button Grid.Column="4"
                                                                Width="96"
                                                                VerticalAlignment="Center"
                                                                Command="{Binding DataContext.SelectRecognizedSeasonTargetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Content="修正到季"
                                                                Style="{StaticResource SeasonCorrectionPrimaryButtonStyle}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                            </Expander>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Text="没有可选择的已有未识别季。">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsSeasonCorrectionTargetUnknown}" Value="True" />
                                        <Condition Binding="{Binding HasUnknownSeasonTargets}" Value="False" />
                                        <Condition Binding="{Binding IsSeasonCorrectionBusy}" Value="False" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <ListBox ItemsSource="{Binding UnknownSeasonSeriesGroups}">
                    <ListBox.Style>
                        <Style TargetType="ListBox" BasedOn="{StaticResource SeasonCorrectionResultListStyle}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSeasonCorrectionTargetUnknown}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.Style>
                    <ListBox.Resources>
                        <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource SeasonCorrectionModernScrollBarStyle}" />
                        <Style TargetType="{x:Type ScrollViewer}">
                            <Setter Property="helpers:ScrollBarAutoRevealBehavior.IsEnabled" Value="True" />
                        </Style>
                    </ListBox.Resources>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Expander Style="{StaticResource SeasonCorrectionRowExpanderStyle}">
                                <Expander.Header>
                                    <StackPanel Margin="0,12" VerticalAlignment="Center" Orientation="Horizontal">
                                        <TextBlock VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource BrushForegroundPrimary}" Text="{Binding SeriesTitle}" />
                                        <Grid Width="16" Height="16" Margin="14,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Style="{StaticResource SeasonCorrectionInlineIconStyle}" Text="&#xE8B2;" />
                                        </Grid>
                                        <TextBlock Margin="7,0,0,0" VerticalAlignment="Center" Style="{StaticResource BodyMutedTextStyle}" Text="{Binding SeasonCountText}" />
                                    </StackPanel>
                                </Expander.Header>
                                <Border Margin="22,0,26,0">
                                    <ItemsControl ItemsSource="{Binding Seasons}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource SeasonCorrectionNestedRowBorderStyle}">
                                                    <Grid Margin="0,9">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="12" />
                                                            <ColumnDefinition Width="14" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="14" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <Ellipse Width="7" Height="7" VerticalAlignment="Center" Fill="{DynamicResource BrushForegroundPrimary}" />
                                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                            <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource BrushForegroundPrimary}" Text="{Binding SeriesAndSeasonTitle}" />
                                                            <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
                                                                <Grid Width="16" Height="16" VerticalAlignment="Center">
                                                                    <TextBlock Style="{StaticResource SeasonCorrectionInlineIconStyle}" Text="&#xE8B2;" />
                                                                </Grid>
                                                                <TextBlock Margin="7,0,0,0" VerticalAlignment="Center" Style="{StaticResource BodyMutedTextStyle}" Text="{Binding SourceCountText}" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <Button Grid.Column="4"
                                                                Width="96"
                                                                VerticalAlignment="Center"
                                                                Command="{Binding DataContext.SelectUnknownSeasonTargetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Content="选择该季"
                                                                Style="{StaticResource SeasonCorrectionPrimaryButtonStyle}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                            </Expander>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Grid.Row="0"
                        Grid.RowSpan="5"
                        Panel.ZIndex="20"
                        Background="Transparent"
                        IsHitTestVisible="True">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSeasonCorrectionBusy}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <Grid Width="34"
                              Height="34"
                              HorizontalAlignment="Center">
                            <Ellipse Stroke="{DynamicResource BrushBorder}"
                                     StrokeThickness="3" />
                            <Path Data="M17,2 A15,15 0 0 1 32,17"
                                  Stroke="{DynamicResource BrushAccent}"
                                  StrokeThickness="3"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round">
                                <Path.RenderTransform>
                                    <RotateTransform CenterX="17"
                                                     CenterY="17" />
                                </Path.RenderTransform>
                                <Path.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetProperty="(Path.RenderTransform).(RotateTransform.Angle)"
                                                                 From="0"
                                                                 To="360"
                                                                 Duration="0:0:0.9" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Path.Triggers>
                            </Path>
                        </Grid>
                        <TextBlock Margin="0,10,0,0"
                                   HorizontalAlignment="Center"
                                   Style="{StaticResource BodyMutedTextStyle}"
                                   Text="正在处理，请稍候..." />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="4"
                  Margin="0,14,0,0"
                  IsHitTestVisible="{Binding IsSeasonCorrectionBaseInteractionEnabled}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Width="138"
                            Margin="0,0,12,0"
                            Command="{Binding ApplySeasonCorrectionCommand}"
                            Content="确认修正为季">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SeasonCorrectionPrimaryButtonStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSeasonCorrectionTargetRecognized}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Width="96"
                            Command="{Binding CancelSeasonCorrectionCommand}"
                            Content="取消"
                            Style="{StaticResource SeasonCorrectionToolbarButtonStyle}" />
                </StackPanel>
            </Grid>

            <Border Grid.RowSpan="5"
                    Panel.ZIndex="30"
                    Background="Transparent"
                    IsHitTestVisible="True">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSeasonEpisodeMappingDialogOpen}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border Width="850"
                        MaxHeight="470"
                        Padding="16"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Style="{StaticResource PageCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="28" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="36" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="28" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource BrushForegroundPrimary}"
                                       Text="目标集号映射" />
                            <Button Grid.Column="1"
                                    Width="28"
                                    Height="28"
                                    MinWidth="28"
                                    MinHeight="28"
                                    Command="{Binding CloseSeasonEpisodeMappingCommand}"
                                    Content="&#xE711;"
                                    FontFamily="Segoe MDL2 Assets"
                                    FontSize="15"
                                    Style="{StaticResource SmallIconButtonStyle}"
                                    ToolTip="{x:Null}" />
                        </Grid>

                        <ListBox Grid.Row="2"
                                 ItemsSource="{Binding SeasonCorrectionMappings}"
                                 Style="{StaticResource SeasonMappingListStyle}">
                            <ListBox.Resources>
                                <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource SeasonCorrectionModernScrollBarStyle}" />
                                <Style TargetType="{x:Type ScrollViewer}">
                                    <Setter Property="helpers:ScrollBarAutoRevealBehavior.IsEnabled" Value="True" />
                                </Style>
                            </ListBox.Resources>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid MinHeight="48">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="112" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="14" />
                                            <ColumnDefinition Width="148" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                            <TextBlock VerticalAlignment="Center" Style="{StaticResource BodyMutedTextStyle}" Text="当前集号" />
                                            <TextBlock Margin="7,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource BrushForegroundPrimary}" Text="{Binding OriginalEpisodeNumberText}" />
                                        </StackPanel>
                                        <ComboBox Grid.Column="2"
                                                  ItemsSource="{Binding SourceOptions}"
                                                  SelectedItem="{Binding SelectedSourceOption, Mode=TwoWay}"
                                                  Style="{StaticResource CorrectionDialogPlaybackSourceComboBoxStyle}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DisplayText}"
                                                               TextTrimming="CharacterEllipsis"
                                                               TextWrapping="NoWrap"
                                                               helpers:TrimmedTextToolTipBehavior.FullText="{Binding DisplayText}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <StackPanel Grid.Column="4" VerticalAlignment="Center" Orientation="Horizontal">
                                            <TextBlock VerticalAlignment="Center" Style="{StaticResource BodyMutedTextStyle}" Text="目标集号" />
                                            <TextBox Margin="8,0,0,0"
                                                     Style="{StaticResource SeasonMappingEpisodeTextBoxStyle}"
                                                     Text="{Binding TargetEpisodeNumberText, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <UniformGrid Grid.Row="4"
                                     Width="340"
                                     HorizontalAlignment="Center"
                                     Columns="2">
                            <Button Margin="0,0,20,0"
                                    Command="{Binding ConfirmSeasonEpisodeMappingCommand}"
                                    Content="确认"
                                    Style="{StaticResource SeasonCorrectionPrimaryButtonStyle}" />
                            <Button Margin="20,0,0,0"
                                    Command="{Binding CloseSeasonEpisodeMappingCommand}"
                                    Content="取消"
                                    Style="{StaticResource SeasonCorrectionToolbarButtonStyle}" />
                        </UniformGrid>
                    </Grid>
                </Border>
            </Border>
        </Grid>
    </Border>
</UserControl>
