<UserControl x:Class="MediaLibrary.App.Controls.SettingFieldRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:MediaLibrary.App.Helpers"
             x:Name="Root">
    <Grid Margin="0,0,0,14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180" />
            <ColumnDefinition Width="18" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock VerticalAlignment="Center"
                   helpers:TrimmedTextToolTipBehavior.FullText="{Binding Label, ElementName=Root}"
                   Style="{StaticResource LongFieldTextBlockStyle}"
                   Text="{Binding Label, ElementName=Root}" />

        <ContentPresenter Grid.Column="2"
                          Content="{Binding FieldContent, ElementName=Root}" />

        <TextBlock Grid.Row="1"
                   Grid.Column="2"
                   Margin="0,8,0,0"
                   Text="{Binding Description, ElementName=Root}"
                   TextWrapping="Wrap">
            <TextBlock.Style>
                <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Description, ElementName=Root}" Value="">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
    </Grid>
</UserControl>
