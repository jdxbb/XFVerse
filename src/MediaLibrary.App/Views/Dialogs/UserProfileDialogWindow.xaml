<Window x:Class="MediaLibrary.App.Views.Dialogs.UserProfileDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="个人资料"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ShowInTaskbar="False"
        ShowActivated="True"
        Background="{DynamicResource BrushDialogBackground}"
        Style="{StaticResource DialogWindowStyle}"
        Loaded="Window_Loaded">
    <Border Width="680"
            Style="{StaticResource DialogSurfaceStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource DialogLogoMarkStyle}">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="13"
                               FontWeight="Black"
                               Foreground="{DynamicResource BrushOnAccent}"
                               Text="XF" />
                </Border>

                <StackPanel Grid.Column="1"
                            Margin="14,0,18,0"
                            VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource DialogTitleStyle}"
                               Text="个人资料" />
                    <TextBlock Margin="0,5,0,0"
                               Style="{StaticResource DialogBodyStyle}"
                               Text="管理你的账号信息" />
                </StackPanel>

                <Button Grid.Column="2"
                        Content="×"
                        Click="CloseButton_Click"
                        Style="{StaticResource DialogCloseButtonStyle}"
                        ToolTip="关闭" />
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,22,0,0"
                    Style="{StaticResource ElevatedSurfaceStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource DialogAvatarStyle}">
                        <TextBlock x:Name="AvatarInitialBlock"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="26"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource BrushOnAccent}"
                                   Text="J" />
                    </Border>

                    <StackPanel Grid.Column="1"
                                Margin="18,0,0,0"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="SummaryNameBlock"
                                   Style="{StaticResource SectionTitleTextStyle}"
                                   Text="James" />
                        <TextBlock Margin="0,7,0,0"
                                   Style="{StaticResource BodyMutedTextStyle}"
                                   Text="本地个人资料" />
                    </StackPanel>

                    <Border Grid.Column="2"
                            VerticalAlignment="Center"
                            Style="{StaticResource InfoBadgeStyle}">
                        <TextBlock Style="{StaticResource BadgeTextStyle}"
                                   Text="本地资料" />
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Margin="0,16,0,0"
                    Style="{StaticResource PageCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                   Text="基础信息" />
                        <Button x:Name="EditSaveButton"
                                Grid.Column="1"
                                MinWidth="96"
                                Click="EditSaveButton_Click"
                                Content="编辑资料"
                                Style="{StaticResource SecondaryButtonStyle}" />
                    </Grid>

                    <Grid x:Name="ProfileDisplayGrid"
                          Grid.Row="1"
                          Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="1" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel>
                                <TextBlock Style="{StaticResource DialogFieldLabelTextStyle}" Text="用户名：" />
                                <TextBlock x:Name="DisplayUserNameBlock" Style="{StaticResource DialogFieldValueTextStyle}" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Margin="0,14,0,0">
                                <TextBlock Style="{StaticResource DialogFieldLabelTextStyle}" Text="账号：" />
                                <TextBlock x:Name="DisplayAccountBlock" Style="{StaticResource DialogFieldValueTextStyle}" />
                            </StackPanel>
                            <StackPanel Grid.Row="2" Margin="0,14,0,0">
                                <TextBlock Style="{StaticResource DialogFieldLabelTextStyle}" Text="手机号：" />
                                <TextBlock x:Name="DisplayPhoneBlock" Style="{StaticResource DialogFieldValueTextStyle}" />
                            </StackPanel>
                            <StackPanel Grid.Row="3" Margin="0,14,0,0">
                                <TextBlock Style="{StaticResource DialogFieldLabelTextStyle}" Text="邮箱：" />
                                <TextBlock x:Name="DisplayEmailBlock" Style="{StaticResource DialogFieldValueTextStyle}" />
                            </StackPanel>
                        </Grid>

                        <Border Grid.Column="1"
                                Margin="18,0"
                                Width="1"
                                Background="{DynamicResource BrushDivider}" />

                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel>
                                <TextBlock Style="{StaticResource DialogFieldLabelTextStyle}" Text="性别：" />
                                <TextBlock x:Name="DisplayGenderBlock" Style="{StaticResource DialogFieldValueTextStyle}" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Margin="0,14,0,0">
                                <TextBlock Style="{StaticResource DialogFieldLabelTextStyle}" Text="年龄：" />
                                <TextBlock x:Name="DisplayAgeBlock" Style="{StaticResource DialogFieldValueTextStyle}" />
                            </StackPanel>
                            <StackPanel Grid.Row="2" Margin="0,14,0,0">
                                <TextBlock Style="{StaticResource DialogFieldLabelTextStyle}" Text="个性签名：" />
                                <TextBlock x:Name="DisplaySignatureBlock" Style="{StaticResource DialogFieldValueTextStyle}" />
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <Grid x:Name="ProfileEditGrid"
                          Grid.Row="1"
                          Margin="0,18,0,0"
                          Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="1" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel>
                                <TextBlock Style="{StaticResource DialogFieldLabelTextStyle}" Text="用户名：" />
                                <TextBox x:Name="UserNameTextBox" Style="{StaticResource TextBoxStyle}" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Margin="0,12,0,0">
                                <TextBlock Style="{StaticResource DialogFieldLabelTextStyle}" Text="账号：" />
                                <TextBox x:Name="AccountTextBox" Style="{StaticResource TextBoxStyle}" />
                            </StackPanel>
                            <StackPanel Grid.Row="2" Margin="0,12,0,0">
                                <TextBlock Style="{StaticResource DialogFieldLabelTextStyle}" Text="手机号：" />
                                <TextBox x:Name="PhoneTextBox" Style="{StaticResource TextBoxStyle}" />
                            </StackPanel>
                            <StackPanel Grid.Row="3" Margin="0,12,0,0">
                                <TextBlock Style="{StaticResource DialogFieldLabelTextStyle}" Text="邮箱：" />
                                <TextBox x:Name="EmailTextBox" Style="{StaticResource TextBoxStyle}" />
                            </StackPanel>
                        </Grid>

                        <Border Grid.Column="1"
                                Margin="18,0"
                                Width="1"
                                Background="{DynamicResource BrushDivider}" />

                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel>
                                <TextBlock Style="{StaticResource DialogFieldLabelTextStyle}" Text="性别：" />
                                <TextBox x:Name="GenderTextBox" Style="{StaticResource TextBoxStyle}" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Margin="0,12,0,0">
                                <TextBlock Style="{StaticResource DialogFieldLabelTextStyle}" Text="年龄：" />
                                <TextBox x:Name="AgeTextBox" Style="{StaticResource TextBoxStyle}" />
                            </StackPanel>
                            <StackPanel Grid.Row="2" Margin="0,12,0,0">
                                <TextBlock Style="{StaticResource DialogFieldLabelTextStyle}" Text="个性签名：" />
                                <TextBox x:Name="SignatureTextBox" Style="{StaticResource TextBoxStyle}" />
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <Border Grid.Row="2"
                            Margin="0,18,0,0"
                            Style="{StaticResource InfoBannerStyle}">
                        <TextBlock x:Name="ProfileStatusBlock"
                                   Style="{StaticResource BodyMutedTextStyle}"
                                   Text="当前仅展示本地资料形态，不接入登录、注册或云同步。" />
                    </Border>
                </Grid>
            </Border>

            <StackPanel Grid.Row="3"
                        Style="{StaticResource DialogButtonRowStyle}">
                <Button MinWidth="92"
                        Click="CancelButton_Click"
                        Content="取消"
                        IsCancel="True"
                        Style="{StaticResource SecondaryButtonStyle}" />
                <Button MinWidth="92"
                        Margin="10,0,0,0"
                        Click="DoneButton_Click"
                        Content="完成"
                        Style="{StaticResource PrimaryButtonStyle}" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
