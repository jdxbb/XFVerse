<Window x:Class="MediaLibrary.App.Views.Dialogs.UserProfileDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="个人资料"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        ShowActivated="True"
        Background="Transparent"
        Foreground="{DynamicResource BrushForegroundPrimary}"
        FontFamily="{StaticResource FontFamilyBase}"
        Loaded="Window_Loaded"
        Closed="Window_Closed">
    <Window.Resources>
        <SolidColorBrush x:Key="ProfileToastWarningBackgroundBrush" Color="{DynamicResource ColorWarningBackground}" Opacity="0.88" />
        <SolidColorBrush x:Key="ProfileToastErrorBackgroundBrush" Color="{DynamicResource ColorErrorBackground}" Opacity="0.88" />
        <SolidColorBrush x:Key="ProfileToastSuccessBackgroundBrush" Color="{DynamicResource ColorSuccessBackground}" Opacity="0.88" />

        <Style x:Key="ProfileDialogSurfaceStyle" TargetType="Border" BasedOn="{StaticResource DialogSurfaceStyle}">
            <Setter Property="Padding" Value="28,24,28,24" />
        </Style>

        <Style x:Key="ProfileInnerCardStyle" TargetType="Border" BasedOn="{StaticResource GlassPageCardStyle}">
            <Setter Property="Padding" Value="18,16" />
            <Setter Property="Effect" Value="{StaticResource ShadowStaticInlineCard}" />
        </Style>

        <Style x:Key="ProfileHeaderIconButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="MinWidth" Value="40" />
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource BrushForegroundMuted}" />
        </Style>

        <Style x:Key="ProfileIconButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="34" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource BrushForegroundSecondary}" />
        </Style>

        <Style x:Key="ProfileAvatarOverlayButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="MinWidth" Value="26" />
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="{DynamicResource BrushAccent}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource BrushOnAccent}" />
            <Setter Property="Opacity" Value="0.82" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="13">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.95" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.74" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ProfileCompactTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource TextBoxStyle}">
            <Setter Property="Width" Value="218" />
            <Setter Property="Height" Value="30" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="9,4" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="ProfileSignatureTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource ProfileCompactTextBoxStyle}">
            <Setter Property="Height" Value="58" />
            <Setter Property="VerticalContentAlignment" Value="Top" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="AcceptsReturn" Value="False" />
            <Setter Property="MaxLines" Value="2" />
            <Setter Property="VerticalScrollBarVisibility" Value="Disabled" />
        </Style>

        <Style x:Key="ProfileFieldValueTextStyle" TargetType="TextBlock" BasedOn="{StaticResource DialogFieldValueTextStyle}">
            <Setter Property="MinHeight" Value="20" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
    </Window.Resources>

    <Grid Width="684"
          Margin="22"
          ClipToBounds="False">
        <Border Width="640"
                HorizontalAlignment="Center"
                ClipToBounds="False"
                Style="{StaticResource ProfileDialogSurfaceStyle}">
            <Grid ClipToBounds="False">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid MouseLeftButtonDown="Header_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Width="44"
                            Height="44"
                            CornerRadius="12"
                            Background="Transparent">
                        <Viewbox Stretch="Uniform">
                            <Canvas Width="1024" Height="1024">
                                <Rectangle Canvas.Left="88"
                                           Canvas.Top="88"
                                           Width="848"
                                           Height="848"
                                           RadiusX="196"
                                           RadiusY="196"
                                           Fill="#0B0B0D" />
                                <Line X1="258" Y1="350" X2="605" Y2="732"
                                      Stroke="#F7F7F5"
                                      StrokeThickness="84"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round" />
                                <Line X1="605" Y1="292" X2="258" Y2="682"
                                      Stroke="#F7F7F5"
                                      StrokeThickness="84"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round" />
                                <Line X1="612" Y1="292" X2="612" Y2="732"
                                      Stroke="#F7F7F5"
                                      StrokeThickness="84"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" />
                                <Line X1="612" Y1="292" X2="804" Y2="292"
                                      Stroke="#F7F7F5"
                                      StrokeThickness="84"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" />
                                <Line X1="612" Y1="512" X2="804" Y2="512"
                                      Stroke="#F7F7F5"
                                      StrokeThickness="84"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" />
                            </Canvas>
                        </Viewbox>
                    </Border>

                    <StackPanel Grid.Column="1"
                                Margin="14,0,18,0"
                                VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource DialogTitleStyle}"
                                   Text="个人资料" />
                        <TextBlock Margin="0,5,0,0"
                                   Style="{StaticResource DialogBodyStyle}"
                                   Text="管理你的账号信息" />
                    </StackPanel>

                    <Button Grid.Column="2"
                            Click="CloseButton_Click"
                            Style="{StaticResource ProfileHeaderIconButtonStyle}"
                            ToolTip="关闭">
                        <Viewbox Width="14"
                                 Height="14"
                                 Stretch="Uniform">
                            <Path Data="M2,2 L12,12 M12,2 L2,12"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round" />
                        </Viewbox>
                    </Button>
                </Grid>

                <Border Grid.Row="1"
                        Margin="0,18,0,0"
                        ClipToBounds="False"
                        Style="{StaticResource ProfileInnerCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid Width="76"
                              Height="76"
                              ClipToBounds="False">
                            <Ellipse x:Name="AvatarBackgroundEllipse"
                                     Fill="{DynamicResource BrushAccent}"
                                     Stroke="{DynamicResource BrushGlassBorder}"
                                     StrokeThickness="1" />
                            <Ellipse x:Name="AvatarImageEllipse"
                                     Visibility="Collapsed">
                                <Ellipse.Fill>
                                    <ImageBrush x:Name="AvatarImageBrush"
                                                Stretch="UniformToFill" />
                                </Ellipse.Fill>
                            </Ellipse>
                            <TextBlock x:Name="AvatarInitialBlock"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="26"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource BrushOnAccent}"
                                       Text="J" />
                            <Button x:Name="AvatarRemoveButton"
                                    Click="RemoveAvatarButton_Click"
                                    Style="{StaticResource ProfileAvatarOverlayButtonStyle}"
                                    Visibility="Collapsed">
                                <Viewbox Width="10" Height="10" Stretch="Uniform">
                                    <Path Data="M1,1 L9,9 M9,1 L1,9"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          StrokeThickness="2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round" />
                                </Viewbox>
                            </Button>
                            <Button x:Name="AvatarAddButton"
                                    Click="ChooseAvatarButton_Click"
                                    Style="{StaticResource ProfileAvatarOverlayButtonStyle}"
                                    Visibility="Collapsed">
                                <Viewbox Width="11" Height="11" Stretch="Uniform">
                                    <Path Data="M5.5,1 L5.5,10 M1,5.5 L10,5.5"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          StrokeThickness="2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round" />
                                </Viewbox>
                            </Button>
                        </Grid>

                        <TextBlock x:Name="SummaryNameBlock"
                                   Grid.Column="1"
                                   Margin="18,0,0,0"
                                   VerticalAlignment="Center"
                                   FontSize="{StaticResource FontSizeCardTitle}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource BrushForegroundPrimary}"
                                   Text="James"
                                   TextTrimming="CharacterEllipsis" />
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Margin="0,14,0,0"
                        ClipToBounds="False"
                        Style="{StaticResource ProfileInnerCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center"
                                       Style="{StaticResource SectionTitleTextStyle}"
                                       Text="基础信息" />
                            <Button x:Name="EditSaveButton"
                                    Grid.Column="1"
                                    Click="EditSaveButton_Click"
                                    Style="{StaticResource ProfileIconButtonStyle}"
                                    ToolTip="编辑">
                                <Grid Width="18"
                                      Height="18">
                                    <Path x:Name="EditIconPath"
                                          Data="M3,14.5 L3,17 L5.5,17 L14.8,7.7 L12.3,5.2 L3,14.5 Z M11.4,4.3 L13.1,2.6 C13.8,1.9 15,1.9 15.7,2.6 C16.4,3.3 16.4,4.5 15.7,5.2 L14,6.9"
                                          Fill="Transparent"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          StrokeThickness="1.7"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round" />
                                    <Path x:Name="DoneIconPath"
                                          Data="M2.5,9.4 L7.2,14 L15.8,4.2"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          StrokeThickness="2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          Visibility="Collapsed" />
                                </Grid>
                            </Button>
                        </Grid>

                        <Grid x:Name="ProfileDisplayGrid"
                              Grid.Row="1"
                              Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource DialogFieldLabelTextStyle}" Text="用户名：" />
                                    <TextBlock x:Name="DisplayUserNameBlock" Style="{StaticResource ProfileFieldValueTextStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Margin="0,10,0,0">
                                    <TextBlock Style="{StaticResource DialogFieldLabelTextStyle}" Text="账号：" />
                                    <TextBlock x:Name="DisplayAccountBlock" Style="{StaticResource ProfileFieldValueTextStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Row="2" Margin="0,10,0,0">
                                    <TextBlock Style="{StaticResource DialogFieldLabelTextStyle}" Text="手机号：" />
                                    <TextBlock x:Name="DisplayPhoneBlock" Style="{StaticResource ProfileFieldValueTextStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Row="3" Margin="0,10,0,0">
                                    <TextBlock Style="{StaticResource DialogFieldLabelTextStyle}" Text="个性签名：" />
                                    <TextBlock x:Name="DisplaySignatureBlock"
                                               MaxHeight="40"
                                               Style="{StaticResource ProfileFieldValueTextStyle}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>

                            <Border Grid.Column="1"
                                    Margin="18,2"
                                    Width="1"
                                    Background="{DynamicResource BrushDivider}" />

                            <Grid Grid.Column="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource DialogFieldLabelTextStyle}" Text="性别：" />
                                    <TextBlock x:Name="DisplayGenderBlock" Style="{StaticResource ProfileFieldValueTextStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Margin="0,10,0,0">
                                    <TextBlock Style="{StaticResource DialogFieldLabelTextStyle}" Text="年龄：" />
                                    <TextBlock x:Name="DisplayAgeBlock" Style="{StaticResource ProfileFieldValueTextStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Row="2" Margin="0,10,0,0">
                                    <TextBlock Style="{StaticResource DialogFieldLabelTextStyle}" Text="邮箱：" />
                                    <TextBlock x:Name="DisplayEmailBlock" Style="{StaticResource ProfileFieldValueTextStyle}" />
                                </StackPanel>
                            </Grid>
                        </Grid>

                        <Grid x:Name="ProfileEditGrid"
                              Grid.Row="1"
                              Margin="0,12,0,0"
                              Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource DialogFieldLabelTextStyle}" Text="用户名：" />
                                    <TextBox x:Name="UserNameTextBox"
                                             MaxLength="24"
                                             Style="{StaticResource ProfileCompactTextBoxStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Margin="0,8,0,0">
                                    <TextBlock Style="{StaticResource DialogFieldLabelTextStyle}" Text="账号：" />
                                    <TextBox x:Name="AccountTextBox"
                                             MaxLength="32"
                                             Style="{StaticResource ProfileCompactTextBoxStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Row="2" Margin="0,8,0,0">
                                    <TextBlock Style="{StaticResource DialogFieldLabelTextStyle}" Text="手机号：" />
                                    <TextBox x:Name="PhoneTextBox"
                                             MaxLength="24"
                                             Style="{StaticResource ProfileCompactTextBoxStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Row="3" Margin="0,8,0,0">
                                    <TextBlock Style="{StaticResource DialogFieldLabelTextStyle}" Text="个性签名：" />
                                    <TextBox x:Name="SignatureTextBox"
                                             MaxLength="48"
                                             PreviewTextInput="SignatureTextBox_PreviewTextInput"
                                             Style="{StaticResource ProfileSignatureTextBoxStyle}" />
                                </StackPanel>
                            </Grid>

                            <Border Grid.Column="1"
                                    Margin="18,2"
                                    Width="1"
                                    Background="{DynamicResource BrushDivider}" />

                            <Grid Grid.Column="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource DialogFieldLabelTextStyle}" Text="性别：" />
                                    <TextBox x:Name="GenderTextBox"
                                             MaxLength="16"
                                             Style="{StaticResource ProfileCompactTextBoxStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Margin="0,8,0,0">
                                    <TextBlock Style="{StaticResource DialogFieldLabelTextStyle}" Text="年龄：" />
                                    <TextBox x:Name="AgeTextBox"
                                             MaxLength="8"
                                             Style="{StaticResource ProfileCompactTextBoxStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Row="2" Margin="0,8,0,0">
                                    <TextBlock Style="{StaticResource DialogFieldLabelTextStyle}" Text="邮箱：" />
                                    <TextBox x:Name="EmailTextBox"
                                             MaxLength="64"
                                             Style="{StaticResource ProfileCompactTextBoxStyle}" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border x:Name="ProfileToastBorder"
                Margin="0,0,0,12"
                Padding="16,9"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                BorderThickness="1"
                CornerRadius="12"
                SnapsToDevicePixels="True"
                Visibility="Collapsed">
            <Border.Effect>
                <DropShadowEffect BlurRadius="22"
                                  Color="#000000"
                                  Direction="270"
                                  Opacity="0.20"
                                  ShadowDepth="8" />
            </Border.Effect>
            <TextBlock x:Name="ProfileToastTextBlock"
                       MaxWidth="380"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="13"
                       FontWeight="SemiBold"
                       TextAlignment="Center"
                       TextTrimming="CharacterEllipsis" />
        </Border>
    </Grid>
</Window>
