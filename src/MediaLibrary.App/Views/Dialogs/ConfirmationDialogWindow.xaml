<Window x:Class="MediaLibrary.App.Views.Dialogs.ConfirmationDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Border Width="420"
            Padding="24"
            Background="{DynamicResource BrushSurface}"
            BorderBrush="{DynamicResource BrushBorder}"
            BorderThickness="1"
            CornerRadius="18">
        <StackPanel>
            <TextBlock x:Name="TitleBlock"
                       Style="{StaticResource CardTitleTextStyle}"
                       TextWrapping="Wrap" />
            <TextBlock x:Name="MessageBlock"
                       Margin="0,14,0,0"
                       Style="{StaticResource BodyTextStyle}"
                       TextWrapping="Wrap" />
            <StackPanel Margin="0,24,0,0"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">
                <Button x:Name="CancelButton"
                        MinWidth="92"
                        Click="CancelButton_Click"
                        Style="{StaticResource SecondaryButtonStyle}" />
                <Button x:Name="ConfirmButton"
                        MinWidth="92"
                        Margin="10,0,0,0"
                        Click="ConfirmButton_Click"
                        Style="{StaticResource PrimaryButtonStyle}" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
