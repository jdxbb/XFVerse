<Window x:Class="MediaLibrary.App.Views.Dialogs.ConfirmationDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="确认操作"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ShowInTaskbar="False"
        Background="{DynamicResource BrushDialogBackground}"
        Style="{StaticResource DialogWindowStyle}"
        Loaded="Window_Loaded">
    <Border x:Name="DialogSurface"
            Width="480"
            Style="{StaticResource DialogSurfaceStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border x:Name="VariantIconShell"
                        Style="{StaticResource ConfirmationVariantIconStyle}">
                    <TextBlock x:Name="VariantIconText"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="22"
                               FontWeight="Bold"
                               Text="i" />
                </Border>

                <StackPanel Grid.Column="1"
                            Margin="14,0,16,0"
                            VerticalAlignment="Center">
                    <Border x:Name="VariantBadge"
                            HorizontalAlignment="Left"
                            Style="{StaticResource InfoBadgeStyle}">
                        <TextBlock x:Name="VariantLabelBlock"
                                   Style="{StaticResource BadgeTextStyle}"
                                   Text="普通确认" />
                    </Border>
                    <TextBlock x:Name="TitleBlock"
                               Margin="0,10,0,0"
                               Style="{StaticResource DialogTitleStyle}"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Button Grid.Column="2"
                        Content="×"
                        Click="CancelButton_Click"
                        Style="{StaticResource DialogCloseButtonStyle}"
                        ToolTip="关闭" />
            </Grid>

            <TextBlock x:Name="MessageBlock"
                       Grid.Row="1"
                       Margin="0,20,0,0"
                       MaxWidth="410"
                       Style="{StaticResource DialogBodyStyle}"
                       TextWrapping="Wrap" />

            <StackPanel Grid.Row="2"
                        Style="{StaticResource DialogButtonRowStyle}">
                <Button x:Name="CancelButton"
                        MinWidth="92"
                        Click="CancelButton_Click"
                        Content="取消"
                        IsCancel="True"
                        Style="{StaticResource SecondaryButtonStyle}" />
                <Button x:Name="ConfirmButton"
                        MinWidth="104"
                        Margin="10,0,0,0"
                        Click="ConfirmButton_Click"
                        Content="确认"
                        Style="{StaticResource PrimaryButtonStyle}" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
