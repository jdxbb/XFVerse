<UserControl x:Class="MediaLibrary.App.Views.Pages.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Style="{StaticResource HeroCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="420" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="你的智能影音库已经就绪" FontSize="34" FontWeight="Bold" Foreground="{DynamicResource BrushForegroundPrimary}" />
                        <TextBlock Margin="0,12,0,0"
                                   Text="{Binding StatusMessage}"
                                   TextWrapping="Wrap"
                                   Style="{StaticResource BodyTextStyle}" />
                        <StackPanel Margin="0,24,0,0" Orientation="Horizontal">
                            <Button Content="浏览资源库"
                                    Command="{Binding OpenLibraryCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                            <Button Margin="12,0,0,0"
                                    Content="查看扫描任务"
                                    Command="{Binding OpenScanTasksCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                        </StackPanel>
                    </StackPanel>

                    <UniformGrid Grid.Column="1" Columns="2" Rows="2" Margin="28,0,0,0">
                        <Border Margin="0,0,12,12" Style="{StaticResource CompactCardStyle}">
                            <StackPanel>
                                <TextBlock Text="{Binding MovieCount}" Style="{StaticResource MetricTextStyle}" />
                                <TextBlock Text="影片" Style="{StaticResource BodyMutedTextStyle}" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,0,12" Style="{StaticResource CompactCardStyle}">
                            <StackPanel>
                                <TextBlock Text="{Binding SourceCount}" Style="{StaticResource MetricTextStyle}" />
                                <TextBlock Text="播放源" Style="{StaticResource BodyMutedTextStyle}" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,12,0" Style="{StaticResource CompactCardStyle}">
                            <StackPanel>
                                <TextBlock Text="{Binding WatchedCount}" Style="{StaticResource MetricTextStyle}" />
                                <TextBlock Text="已看" Style="{StaticResource BodyMutedTextStyle}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CompactCardStyle}">
                            <StackPanel>
                                <TextBlock Text="{Binding FavoriteCount}" Style="{StaticResource MetricTextStyle}" />
                                <TextBlock Text="喜爱" Style="{StaticResource BodyMutedTextStyle}" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </Grid>
            </Border>

            <Grid Margin="0,22,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="22" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource PageCardStyle}">
                    <StackPanel>
                        <DockPanel>
                            <TextBlock Text="最近新增" Style="{StaticResource CardTitleTextStyle}" />
                            <Button DockPanel.Dock="Right"
                                    Content="查看全部"
                                    Command="{Binding OpenLibraryCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                        </DockPanel>
                        <ItemsControl Margin="0,18,0,0" ItemsSource="{Binding RecentlyAdded}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="170" Margin="0,0,14,14" Style="{StaticResource CompactCardStyle}">
                                        <StackPanel>
                                            <Border Height="210" CornerRadius="16" Background="{DynamicResource BrushSurfaceAlt}">
                                                <Image Source="{Binding PosterRemoteUrl}" Stretch="UniformToFill" />
                                            </Border>
                                            <TextBlock Margin="0,10,0,0" Text="{Binding Title}" TextWrapping="Wrap" Style="{StaticResource SectionTitleTextStyle}" />
                                            <TextBlock Text="{Binding ReleaseYear}" Style="{StaticResource BodyMutedTextStyle}" />
                                            <Button Margin="0,10,0,0"
                                                    Content="详情"
                                                    Command="{Binding DataContext.OpenMovieCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource SecondaryButtonStyle}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource PageCardStyle}">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock Text="扫描状态" Style="{StaticResource CardTitleTextStyle}" />
                                <Button DockPanel.Dock="Right"
                                        Content="进入"
                                        Command="{Binding OpenScanTasksCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                            </DockPanel>
                            <TextBlock Margin="0,14,0,0" Text="{Binding LastScanStatus}" TextWrapping="Wrap" Style="{StaticResource BodyTextStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Margin="0,22,0,0" Style="{StaticResource PageCardStyle}">
                        <StackPanel>
                            <TextBlock Text="类型分布" Style="{StaticResource CardTitleTextStyle}" />
                            <ItemsControl Margin="0,14,0,0" ItemsSource="{Binding GenreDistribution}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="48" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Label}" Style="{StaticResource BodyTextStyle}" />
                                            <ProgressBar Grid.Column="1" Height="8" Maximum="100" Value="{Binding Percent}" />
                                            <TextBlock Grid.Column="2" Text="{Binding Count}" HorizontalAlignment="Right" Style="{StaticResource BodyMutedTextStyle}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <Grid Margin="0,22,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="22" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="22" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource PageCardStyle}">
                    <StackPanel>
                        <TextBlock Text="最近播放" Style="{StaticResource CardTitleTextStyle}" />
                        <ItemsControl Margin="0,14,0,0" ItemsSource="{Binding RecentlyPlayed}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,10" Padding="10" CornerRadius="12" Background="{DynamicResource BrushSurfaceAlt}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="54" />
                                                <ColumnDefinition Width="10" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Height="76" CornerRadius="8" Background="{DynamicResource BrushSurface}">
                                                <Image Source="{Binding PosterRemoteUrl}" Stretch="UniformToFill" />
                                            </Border>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="{Binding Title}" TextWrapping="Wrap" Style="{StaticResource SectionTitleTextStyle}" />
                                                <TextBlock Margin="0,4,0,0" Text="{Binding LastPlayedAtText}" Style="{StaticResource BodyMutedTextStyle}" />
                                                <Grid Margin="0,4,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding ResumePositionText}" Style="{StaticResource BodyTextStyle}" />
                                                    <TextBlock Grid.Column="1"
                                                               Margin="8,0,0,0"
                                                               Text="{Binding ProgressPercentText}"
                                                               Style="{StaticResource BodyMutedTextStyle}" />
                                                </Grid>
                                                <ProgressBar Margin="0,8,0,0" Height="6" Maximum="100" Value="{Binding ProgressValue}">
                                                    <ProgressBar.Style>
                                                        <Style TargetType="ProgressBar">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasProgressPercent}" Value="False">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ProgressBar.Style>
                                                </ProgressBar>
                                                <Button Margin="0,10,0,0"
                                                        Content="{Binding ContinueButtonText}"
                                                        Command="{Binding DataContext.ContinuePlaybackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource SecondaryButtonStyle}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource PageCardStyle}">
                    <StackPanel>
                        <DockPanel>
                            <TextBlock Text="收藏夹" Style="{StaticResource CardTitleTextStyle}" />
                            <Button DockPanel.Dock="Right"
                                    Content="查看全部"
                                    Command="{Binding OpenFavoritesCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                        </DockPanel>

                        <TextBlock Margin="0,14,0,0" Text="喜爱" Style="{StaticResource BodyMutedTextStyle}" />
                        <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding FavoriteCollectionItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Margin="0,0,0,8"
                                            HorizontalContentAlignment="Stretch"
                                            Command="{Binding DataContext.OpenMovieCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource SecondaryButtonStyle}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" TextWrapping="Wrap" />
                                            <TextBlock Margin="0,3,0,0" Text="{Binding AvailabilityText}" Style="{StaticResource BodyMutedTextStyle}" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Margin="0,12,0,0" Text="想看" Style="{StaticResource BodyMutedTextStyle}" />
                        <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding WantToWatchItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Margin="0,0,0,8"
                                            HorizontalContentAlignment="Stretch"
                                            Command="{Binding DataContext.OpenMovieCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource SecondaryButtonStyle}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" TextWrapping="Wrap" />
                                            <TextBlock Margin="0,3,0,0" Text="{Binding AvailabilityText}" Style="{StaticResource BodyMutedTextStyle}" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource PageCardStyle}">
                    <StackPanel>
                        <DockPanel>
                            <TextBlock Text="AI 推荐" Style="{StaticResource CardTitleTextStyle}" />
                            <Button DockPanel.Dock="Right"
                                    Content="更多"
                                    Command="{Binding OpenRecommendationsCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                        </DockPanel>
                        <TextBlock Margin="0,14,0,0"
                                   Text="{Binding RecommendationsStatusMessage}"
                                   TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RecommendationsStatusMessage}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <ItemsControl Margin="0,14,0,0" ItemsSource="{Binding Recommendations}">
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Recommendations.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,10" Padding="12" CornerRadius="16" Background="{DynamicResource BrushSurfaceAlt}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" Style="{StaticResource SectionTitleTextStyle}" />
                                            <TextBlock Margin="0,6,0,0" Text="{Binding Reason}" TextWrapping="Wrap" Style="{StaticResource BodyTextStyle}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
