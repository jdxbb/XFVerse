<UserControl x:Class="MediaLibrary.App.Views.Pages.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:MediaLibrary.App.Helpers">
    <UserControl.Resources>
        <Style x:Key="HomeTwoLineTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource SectionTitleTextStyle}">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="LineHeight" Value="20" />
            <Setter Property="MaxHeight" Value="40" />
            <Setter Property="MinHeight" Value="40" />
        </Style>

        <Style x:Key="HomePosterButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="HomeTextButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>

        <Style x:Key="HomeAiTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource HomeTwoLineTitleStyle}">
            <Setter Property="LineHeight" Value="18" />
            <Setter Property="MaxHeight" Value="36" />
            <Setter Property="MinHeight" Value="36" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="660" />
            <ColumnDefinition Width="24" />
            <ColumnDefinition Width="360" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="1.1*" MinHeight="122" />
                <RowDefinition Height="2.6*" MinHeight="218" />
                <RowDefinition Height="1.8*" MinHeight="170" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Margin="0,0,0,18"
                    Style="{StaticResource PageCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel>
                        <StackPanel>
                            <TextBlock Text="片库预览" Style="{StaticResource CardTitleTextStyle}" />
                        </StackPanel>
                    </DockPanel>

                    <ItemsControl Grid.Row="2" ItemsSource="{Binding LibraryStatusOverview}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="4" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,12,0" Style="{StaticResource HomeMetricCardStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="34"
                                                Height="34"
                                                CornerRadius="17"
                                                Background="{DynamicResource BrushAccentSoft}">
                                            <TextBlock Text="{Binding IconGlyph}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource BrushAccent}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock Grid.Column="1"
                                                   Margin="10,0,0,0"
                                                   Text="{Binding Title}"
                                                   VerticalAlignment="Center"
                                                   Style="{StaticResource BodyMutedTextStyle}" />
                                        <StackPanel Grid.Row="1"
                                                    Grid.ColumnSpan="2"
                                                    Margin="0,8,0,2"
                                                    Orientation="Horizontal">
                                            <TextBlock Text="{Binding ValueText}" Style="{StaticResource MetricTextStyle}" />
                                            <TextBlock Margin="6,10,0,0"
                                                       Text="{Binding UnitText}"
                                                       Style="{StaticResource BodyMutedTextStyle}" />
                                        </StackPanel>
                                        <TextBlock Grid.Row="2"
                                                   Grid.ColumnSpan="2"
                                                   Text="{Binding TrendText}"
                                                   Style="{StaticResource CaptionTextStyle}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Margin="0,0,0,18"
                    Style="{StaticResource PageCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel>
                        <StackPanel>
                            <TextBlock Text="继续观看" Style="{StaticResource CardTitleTextStyle}" />
                        </StackPanel>
                        <Button DockPanel.Dock="Right"
                                Width="42"
                                Height="42"
                                Padding="0"
                                Content="›"
                                ToolTip="进入观影历史"
                                Command="{Binding NavigateToWatchHistoryCommand}"
                                Style="{StaticResource IconButtonStyle}" />
                    </DockPanel>

                    <Border Grid.Row="2">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource EmptyStateContainerStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RecentlyPlayed.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="还没有观看记录" Style="{StaticResource EmptyStateTitleStyle}" />
                            <TextBlock Margin="0,6,0,0"
                                       Text="播放或标记影片后，这里会显示你的继续观看列表。"
                                       Style="{StaticResource EmptyStateDescriptionStyle}" />
                        </StackPanel>
                    </Border>

                    <ItemsControl Grid.Row="2" ItemsSource="{Binding RecentlyPlayedPreview}">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RecentlyPlayed.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="3" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,12,0" Style="{StaticResource HomeMediaCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="78" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Command="{Binding DataContext.OpenMovieCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource HomePosterButtonStyle}">
                                            <Border Height="112" Style="{StaticResource HomeMediaPosterChromeStyle}">
                                                <Grid>
                                                    <TextBlock HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Text="无海报"
                                                               Style="{StaticResource CaptionTextStyle}" />
                                                    <Image helpers:PosterCacheImageBehavior.Source="{Binding PosterRemoteUrl}" Stretch="UniformToFill" />
                                                </Grid>
                                            </Border>
                                        </Button>

                                        <StackPanel Grid.Column="2">
                                            <Button Command="{Binding DataContext.OpenMovieCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource HomeTextButtonStyle}">
                                                <TextBlock Text="{Binding Title}"
                                                           ToolTip="{Binding Title}"
                                                           Style="{StaticResource HomeTwoLineTitleStyle}" />
                                            </Button>
                                            <TextBlock Margin="0,6,0,0"
                                                       Text="{Binding WatchPositionText}"
                                                       Style="{StaticResource MetadataTextStyle}" />
                                            <TextBlock Margin="0,2,0,0"
                                                       Text="{Binding ProgressPercentText}"
                                                       Style="{StaticResource CaptionTextStyle}" />
                                            <ProgressBar Margin="0,8,0,0"
                                                         Maximum="100"
                                                         Value="{Binding ProgressValue}"
                                                         Style="{StaticResource ThinProgressBarStyle}" />
                                            <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                                                <Border>
                                                    <Border.Style>
                                                        <Style TargetType="Border" BasedOn="{StaticResource SuccessBadgeStyle}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding CanContinuePlayback}" Value="False">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="播放源可用" Style="{StaticResource BadgeTextStyle}" />
                                                </Border>
                                                <Border>
                                                    <Border.Style>
                                                        <Style TargetType="Border" BasedOn="{StaticResource NoSourceBadgeStyle}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding CanContinuePlayback}" Value="False">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="暂无播放源" Style="{StaticResource BadgeTextStyle}" />
                                                </Border>
                                                <Button Margin="8,0,0,0"
                                                        MinWidth="78"
                                                        Content="{Binding ContinueButtonText}"
                                                        Command="{Binding DataContext.ContinuePlaybackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource SmallButtonStyle}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource PageCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel>
                        <StackPanel>
                            <TextBlock Text="最近新增" Style="{StaticResource CardTitleTextStyle}" />
                        </StackPanel>
                        <Button DockPanel.Dock="Right"
                                Width="42"
                                Height="42"
                                Padding="0"
                                Content="›"
                                ToolTip="进入媒体库"
                                Command="{Binding OpenLibraryCommand}"
                                Style="{StaticResource IconButtonStyle}" />
                    </DockPanel>

                    <Border Grid.Row="2">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource EmptyStateContainerStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RecentlyAdded.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="还没有新增影片" Style="{StaticResource EmptyStateTitleStyle}" />
                            <TextBlock Margin="0,6,0,0"
                                       Text="扫描完成后，最近加入的影片会出现在这里。"
                                       Style="{StaticResource EmptyStateDescriptionStyle}" />
                        </StackPanel>
                    </Border>

                    <ItemsControl Grid.Row="2" ItemsSource="{Binding RecentlyAddedPreview}">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RecentlyAdded.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="4" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,12,0" Style="{StaticResource HomeMediaCardStyle}">
                                    <StackPanel>
                                        <Button Command="{Binding DataContext.OpenMovieCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource HomePosterButtonStyle}">
                                            <Border Height="88" Style="{StaticResource HomeMediaPosterChromeStyle}">
                                                <Grid>
                                                    <TextBlock HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Text="无海报"
                                                               Style="{StaticResource CaptionTextStyle}" />
                                                    <Image helpers:PosterCacheImageBehavior.Source="{Binding PosterRemoteUrl}" Stretch="UniformToFill" />
                                                </Grid>
                                            </Border>
                                        </Button>
                                        <Button Margin="0,8,0,0"
                                                Command="{Binding DataContext.OpenMovieCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource HomeTextButtonStyle}">
                                            <TextBlock Text="{Binding Title}"
                                                       ToolTip="{Binding Title}"
                                                       Style="{StaticResource HomeTwoLineTitleStyle}" />
                                        </Button>
                                        <TextBlock Text="{Binding ReleaseYear}"
                                                   Style="{StaticResource CaptionTextStyle}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Column="2" Style="{StaticResource HomeAiPanelStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel>
                    <StackPanel>
                        <TextBlock Text="AI 推荐" Style="{StaticResource CardTitleTextStyle}" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="默认推荐库外 + 未看影片"
                                   Style="{StaticResource BodyMutedTextStyle}" />
                    </StackPanel>
                    <Button DockPanel.Dock="Right"
                            Content="{Binding AiRecommendationViewModel.RefreshBatchButtonText}"
                            Command="{Binding AiRecommendationViewModel.RefreshBatchCommand}"
                            Style="{StaticResource SmallButtonStyle}" />
                </DockPanel>

                <StackPanel Grid.Row="1" Margin="0,16,0,0">
                    <TextBlock Text="{Binding AiRecommendationViewModel.StatusMessage}"
                               TextWrapping="Wrap"
                               TextTrimming="CharacterEllipsis"
                               MaxHeight="40"
                               Style="{StaticResource MetadataTextStyle}" />

                    <Border Margin="0,14,0,0">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource EmptyStateContainerStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AiRecommendationViewModel.Recommendations.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock Text="暂无可展示的推荐" Style="{StaticResource EmptyStateTitleStyle}" />
                            <TextBlock Margin="0,6,0,0"
                                       Text="标记几部影片后，AI 推荐会更准确。"
                                       Style="{StaticResource EmptyStateDescriptionStyle}" />
                        </StackPanel>
                    </Border>

                    <ItemsControl Margin="0,14,0,0" ItemsSource="{Binding AiRecommendationViewModel.Recommendations}">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AiRecommendationViewModel.Recommendations.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8" Style="{StaticResource HomeAiCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="56" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Button Command="{Binding DataContext.AiRecommendationViewModel.OpenMovieCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource HomePosterButtonStyle}">
                                            <Border Height="74" Style="{StaticResource HomeMediaPosterChromeStyle}">
                                                <Grid>
                                                    <TextBlock HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Text="无海报"
                                                               Style="{StaticResource CaptionTextStyle}" />
                                                    <Image helpers:PosterCacheImageBehavior.Source="{Binding PosterRemoteUrl}" Stretch="UniformToFill" />
                                                </Grid>
                                            </Border>
                                        </Button>

                                        <Grid Grid.Column="2">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <Button Command="{Binding DataContext.AiRecommendationViewModel.OpenMovieCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource HomeTextButtonStyle}">
                                                <TextBlock Text="{Binding Title}"
                                                           ToolTip="{Binding Title}"
                                                           Style="{StaticResource HomeAiTitleStyle}" />
                                            </Button>

                                            <StackPanel Grid.Row="1" Margin="0,2,0,4">
                                                <StackPanel>
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding DataContext.IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    <TextBlock Text="{Binding ReleaseYear, StringFormat=年份 {0}, TargetNullValue=年份 -}"
                                                               Style="{StaticResource CaptionTextStyle}" />
                                                    <WrapPanel Margin="0,2,0,0">
                                                        <Border Margin="0,0,4,4">
                                                            <Border.Style>
                                                                <Style TargetType="Border" BasedOn="{StaticResource TagStyle}">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Tags}" Value="">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="{Binding Tags}" MaxWidth="86" Style="{StaticResource BadgeTextStyle}" />
                                                        </Border>
                                                        <Border Margin="0,0,4,4">
                                                            <Border.Style>
                                                                <Style TargetType="Border" BasedOn="{StaticResource InfoBadgeStyle}">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding EmotionTagsText}" Value="">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="{Binding EmotionTagsText}" MaxWidth="76" Style="{StaticResource BadgeTextStyle}" />
                                                        </Border>
                                                        <Border Margin="0,0,4,4">
                                                            <Border.Style>
                                                                <Style TargetType="Border" BasedOn="{StaticResource BadgeStyle}">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding SceneTagsText}" Value="">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="{Binding SceneTagsText}" MaxWidth="76" Style="{StaticResource BadgeTextStyle}" />
                                                        </Border>
                                                    </WrapPanel>
                                                    <TextBlock Text="{Binding TmdbRating, StringFormat=平均评分 {0:0.0}, TargetNullValue=平均评分 -}"
                                                               Style="{StaticResource MetadataTextStyle}" />
                                                </StackPanel>

                                                <StackPanel>
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding DataContext.IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    <DockPanel>
                                                        <TextBlock Text="{Binding ReleaseYear, StringFormat=年份 {0}, TargetNullValue=年份 -}"
                                                                   Style="{StaticResource CaptionTextStyle}" />
                                                        <TextBlock DockPanel.Dock="Right"
                                                                   Text="{Binding TmdbRating, StringFormat=评分 {0:0.0}, TargetNullValue=评分 -}"
                                                                   Style="{StaticResource CaptionTextStyle}" />
                                                    </DockPanel>
                                                    <Border Margin="0,6,0,0"
                                                            HorizontalAlignment="Left">
                                                        <Border.Style>
                                                            <Style TargetType="Border" BasedOn="{StaticResource TagStyle}">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Tags}" Value="">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="{Binding Tags}" MaxWidth="126" Style="{StaticResource BadgeTextStyle}" />
                                                    </Border>
                                                    <TextBlock Margin="0,8,0,0"
                                                               Text="{Binding Reason}"
                                                               TextWrapping="Wrap"
                                                               TextTrimming="CharacterEllipsis"
                                                               LineHeight="18"
                                                               MaxHeight="42"
                                                               Style="{StaticResource MetadataTextStyle}" />
                                                </StackPanel>
                                            </StackPanel>

                                            <Button Grid.Row="2"
                                                    HorizontalAlignment="Right"
                                                    MinHeight="26"
                                                    Padding="10,4"
                                                    Content="{Binding WantToWatchButtonText}"
                                                    Command="{Binding DataContext.AiRecommendationViewModel.AddWantToWatchCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource SmallButtonStyle}" />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <Button Grid.Row="2"
                        Margin="0,14,0,0"
                        Content="发现更多影片 »"
                        Command="{Binding NavigateToMovieDiscoveryCommand}"
                        Style="{StaticResource PrimaryButtonStyle}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
