<UserControl x:Class="MediaLibrary.App.Views.Pages.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:MediaLibrary.App.Helpers">
    <UserControl.Resources>
        <SolidColorBrush x:Key="HomePosterCardBackgroundBrush" Color="#121821" />
        <SolidColorBrush x:Key="HomePosterCardSurfaceBrush" Color="#202938" />

        <Style x:Key="HomeTwoLineTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource SectionTitleTextStyle}">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="LineHeight" Value="20" />
            <Setter Property="MaxHeight" Value="40" />
            <Setter Property="MinHeight" Value="40" />
        </Style>

        <Style x:Key="HomePosterButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.55" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HomeTextButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Top" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HomeAiTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource HomeTwoLineTitleStyle}">
            <Setter Property="LineHeight" Value="18" />
            <Setter Property="MaxHeight" Value="36" />
            <Setter Property="MinHeight" Value="36" />
        </Style>

        <Style x:Key="HomeCompactActionButtonStyle" TargetType="Button" BasedOn="{StaticResource GlassSecondaryButtonStyle}">
            <Setter Property="Width" Value="66" />
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="HomeWantButtonStyle" TargetType="Button" BasedOn="{StaticResource GlassSecondaryButtonStyle}">
            <Setter Property="Width" Value="52" />
            <Setter Property="Height" Value="26" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="Padding" Value="2,2" />
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="HomeAiStatusLineStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
            <Setter Property="LineHeight" Value="16" />
            <Setter Property="MinHeight" Value="16" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>

        <Style x:Key="HomeAiTagTextStyle" TargetType="TextBlock" BasedOn="{StaticResource CaptionTextStyle}">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="LineHeight" Value="14" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Style.Triggers>
                <Trigger Property="Text" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HomeAiRatingBadgeStyle" TargetType="Border">
            <Setter Property="MinWidth" Value="42" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="{DynamicResource BrushGlassSurfaceAlt}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>

        <Style x:Key="HomeAiRatingTextStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsHighWeightedAverageRating}" Value="True">
                    <Setter Property="Foreground" Value="#F5C84B" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HomeInlineEmptyStateStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="HomeInlineEmptyStateTextStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="HomeMetricValueTextStyle" TargetType="TextBlock" BasedOn="{StaticResource MetricTextStyle}">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="LineHeight" Value="28" />
            <Setter Property="VerticalAlignment" Value="Bottom" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>

        <Style x:Key="HomeSectionArrowButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="54" />
            <Setter Property="MinWidth" Value="32" />
            <Setter Property="MinHeight" Value="54" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource BrushForegroundSecondary}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HomeRecentTitleTextStyle" TargetType="TextBlock" BasedOn="{StaticResource CaptionTextStyle}">
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="LineHeight" Value="13" />
            <Setter Property="Width" Value="90" />
            <Setter Property="MaxHeight" Value="13" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
        </Style>

        <Style x:Key="HomeReasonScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="Width" Value="4" />
            <Setter Property="MinWidth" Value="4" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource BrushForegroundMuted}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}"
                                                  IsTabStop="False"
                                                  Opacity="0" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Width="4"
                                                        CornerRadius="2"
                                                        Background="{DynamicResource BrushForegroundMuted}"
                                                        Opacity="0.55" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}"
                                                  IsTabStop="False"
                                                  Opacity="0" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HomeAiExpandedTitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="LineHeight" Value="18" />
            <Setter Property="MaxHeight" Value="36" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
        </Style>

        <Style x:Key="HomeAiCollapsedTitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
        </Style>

        <Style x:Key="HomeRecentDateTextStyle" TargetType="TextBlock" BasedOn="{StaticResource CaptionTextStyle}">
            <Setter Property="Margin" Value="0,3,0,0" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="LineHeight" Value="12" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>

        <Style x:Key="HomePosterClipMaskStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>

        <Style x:Key="HomePosterPaletteShadowStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,3,0,0" />
            <Setter Property="Background" Value="{StaticResource HomePosterCardBackgroundBrush}" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="IsHitTestVisible" Value="False" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="28"
                                      Direction="270"
                                      Opacity="0.42"
                                      ShadowDepth="7"
                                      Color="#192230" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HomePosterBaseShadowStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource HomePosterCardBackgroundBrush}" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="IsHitTestVisible" Value="False" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="14"
                                      Direction="270"
                                      Opacity="0.28"
                                      ShadowDepth="3"
                                      Color="#000000" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HomePosterLiftGridStyle" TargetType="Grid">
            <Setter Property="ClipToBounds" Value="False" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="0" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <TranslateTransform Y="-2" />
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <ItemsPanelTemplate x:Key="HomeRecentFiveColumnsPanel">
            <UniformGrid Columns="5" />
        </ItemsPanelTemplate>

        <ItemsPanelTemplate x:Key="HomeRecentSixColumnsPanel">
            <UniformGrid Columns="6" />
        </ItemsPanelTemplate>

        <DataTemplate x:Key="HomeRecentItemTemplate">
            <StackPanel Width="98"
                        Margin="0,0,4,0"
                        HorizontalAlignment="Center">
                <Button Command="{Binding DataContext.OpenMovieCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding}"
                        Style="{StaticResource HomePosterButtonStyle}">
                    <Grid Width="82"
                          Height="123"
                          Margin="8,9,8,0"
                          HorizontalAlignment="Center"
                          Style="{StaticResource HomePosterLiftGridStyle}">
                        <Border x:Name="HomeRecentPosterClipMask"
                                Style="{StaticResource HomePosterClipMaskStyle}" />
                        <Border x:Name="HomeRecentPosterPaletteShadowHost"
                                Style="{StaticResource HomePosterPaletteShadowStyle}" />
                        <Border Style="{StaticResource HomePosterBaseShadowStyle}" />
                        <Grid>
                            <Grid.OpacityMask>
                                <VisualBrush Visual="{Binding ElementName=HomeRecentPosterClipMask}" />
                            </Grid.OpacityMask>
                            <Border Background="{StaticResource HomePosterCardSurfaceBrush}" />
                            <Control IsHitTestVisible="False"
                                     Template="{StaticResource PosterPlaceholderTemplate}" />
                            <Image helpers:PosterCacheImageBehavior.DecodePixelWidth="180"
                                   helpers:PosterCacheImageBehavior.Source="{Binding PosterRemoteUrl}"
                                   helpers:PosterPaletteShadowBehavior.TargetElement="{Binding ElementName=HomeRecentPosterPaletteShadowHost}"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   SnapsToDevicePixels="True"
                                   Stretch="UniformToFill" />
                            <Grid IsHitTestVisible="False">
                                <Grid.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#00000000" Offset="0" />
                                        <GradientStop Color="#0A111827" Offset="0.42" />
                                        <GradientStop Color="#78111824" Offset="0.78" />
                                        <GradientStop Color="#B8111824" Offset="1" />
                                    </LinearGradientBrush>
                                </Grid.Background>
                            </Grid>
                            <Border Height="48"
                                    VerticalAlignment="Top"
                                    IsHitTestVisible="False">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#38FFFFFF" Offset="0" />
                                        <GradientStop Color="#20FFFFFF" Offset="0.22" />
                                        <GradientStop Color="#08FFFFFF" Offset="0.62" />
                                        <GradientStop Color="#00FFFFFF" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>
                    </Grid>
                </Button>
                <Button Width="92"
                        Margin="0,6,0,0"
                        HorizontalAlignment="Center"
                        Command="{Binding DataContext.OpenMovieCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding}"
                        Style="{StaticResource HomeTextButtonStyle}">
                    <TextBlock Text="{Binding Title}"
                               helpers:TrimmedTextToolTipBehavior.FullText="{Binding Title}"
                               Style="{StaticResource HomeRecentTitleTextStyle}" />
                </Button>
                <TextBlock Text="{Binding ReleaseYear}"
                           Style="{StaticResource HomeRecentDateTextStyle}" />
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="MainContentColumn" Width="*" MinWidth="660" />
            <ColumnDefinition Width="24" />
            <ColumnDefinition x:Name="AiPanelColumn" Width="360" />
        </Grid.ColumnDefinitions>

        <Grid Grid.ColumnSpan="3">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsHomeInitialLoading}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="660" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="1.34*" MinHeight="156" />
                <RowDefinition Height="2.73*" MinHeight="261" />
                <RowDefinition Height="1.78*" MinHeight="185" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Margin="0,0,0,14"
                    Padding="22,22,22,11"
                    Style="{StaticResource GlassPageCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel>
                        <StackPanel>
                            <TextBlock Text="片库预览" Style="{StaticResource CardTitleTextStyle}" />
                        </StackPanel>
                    </DockPanel>

                    <ItemsControl Grid.Row="2"
                                  Margin="0,0,-12,0"
                                  ItemsSource="{Binding LibraryStatusOverview}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="4" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,12,0" Style="{StaticResource GlassHomeMetricCardStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="34"
                                                Height="34"
                                                CornerRadius="17"
                                                Background="{DynamicResource BrushGlassSelected}">
                                            <TextBlock Text="{Binding IconGlyph}"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource BrushAccent}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <Grid Grid.Column="1"
                                              Margin="10,0,0,0"
                                              VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Title}"
                                                       VerticalAlignment="Center"
                                                       Style="{StaticResource BodyMutedTextStyle}" />
                                            <TextBlock Grid.Column="1"
                                                       MinWidth="34"
                                                       Margin="8,0,4,0"
                                                       HorizontalAlignment="Center"
                                                       Text="{Binding ValueText}"
                                                       Style="{StaticResource HomeMetricValueTextStyle}" />
                                            <TextBlock Grid.Column="2"
                                                       Margin="0,8,8,0"
                                                       Text="{Binding UnitText}"
                                                       Style="{StaticResource BodyMutedTextStyle}" />
                                        </Grid>
                                        <StackPanel Grid.Row="1"
                                                    Grid.ColumnSpan="2"
                                                    Margin="0,8,0,0"
                                                    HorizontalAlignment="Center"
                                                    Orientation="Horizontal">
                                            <TextBlock VerticalAlignment="Center"
                                                       Text="{Binding TrendText}"
                                                       Style="{StaticResource CaptionTextStyle}" />
                                            <TextBlock Margin="9,-2,0,0"
                                                       VerticalAlignment="Center"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource BrushForegroundMuted}"
                                                       Text="{Binding TrendArrowText}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Margin="0,0,0,14"
                    Padding="22,22,22,6"
                    Style="{StaticResource GlassPageCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="3" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel>
                        <StackPanel>
                            <TextBlock Text="继续观看" Style="{StaticResource CardTitleTextStyle}" />
                        </StackPanel>
                    </DockPanel>

                    <Border Grid.Row="2">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource HomeInlineEmptyStateStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RecentlyPlayed.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="还没有观看记录" Style="{StaticResource HomeInlineEmptyStateTextStyle}" />
                    </Border>

                    <ItemsControl Grid.Row="2"
                                  Margin="0,0,48,0"
                                  ItemsSource="{Binding RecentlyPlayedPreview}">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RecentlyPlayed.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="3" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Margin="0,0,12,0"
                                        Command="{Binding DataContext.OpenMovieCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource HomePosterButtonStyle}">
                                    <Grid Width="158"
                                          Height="237"
                                          HorizontalAlignment="Center"
                                          Style="{StaticResource HomePosterLiftGridStyle}">
                                        <Border x:Name="HomeContinuePosterClipMask"
                                                Style="{StaticResource HomePosterClipMaskStyle}" />
                                        <Border x:Name="HomeContinuePosterPaletteShadowHost"
                                                Style="{StaticResource HomePosterPaletteShadowStyle}" />
                                        <Border Style="{StaticResource HomePosterBaseShadowStyle}" />
                                        <Grid>
                                            <Grid.OpacityMask>
                                                <VisualBrush Visual="{Binding ElementName=HomeContinuePosterClipMask}" />
                                            </Grid.OpacityMask>
                                            <Border Background="{StaticResource HomePosterCardSurfaceBrush}" />
                                            <Control IsHitTestVisible="False"
                                                     Template="{StaticResource PosterPlaceholderTemplate}" />
                                            <Image helpers:PosterCacheImageBehavior.DecodePixelWidth="320"
                                                   helpers:PosterCacheImageBehavior.Source="{Binding PosterRemoteUrl}"
                                                   helpers:PosterPaletteShadowBehavior.TargetElement="{Binding ElementName=HomeContinuePosterPaletteShadowHost}"
                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                   SnapsToDevicePixels="True"
                                                   Stretch="UniformToFill" />
                                            <Grid IsHitTestVisible="False">
                                                <Grid.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="#00000000" Offset="0" />
                                                        <GradientStop Color="#0A111827" Offset="0.42" />
                                                        <GradientStop Color="#78111824" Offset="0.78" />
                                                        <GradientStop Color="#B8111824" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Grid.Background>
                                            </Grid>
                                            <Border Height="86"
                                                    VerticalAlignment="Top"
                                                    IsHitTestVisible="False">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="#38FFFFFF" Offset="0" />
                                                        <GradientStop Color="#20FFFFFF" Offset="0.22" />
                                                        <GradientStop Color="#08FFFFFF" Offset="0.62" />
                                                        <GradientStop Color="#00FFFFFF" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                            <Border VerticalAlignment="Bottom"
                                                    Padding="12,52,12,12">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}"
                                                               helpers:TrimmedTextToolTipBehavior.FullText="{Binding Title}"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Foreground="White"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <Grid Margin="0,6,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding WatchPositionText}"
                                                                   Foreground="#DDFFFFFF"
                                                                   FontSize="10.5" />
                                                        <TextBlock Grid.Column="1"
                                                                   Margin="8,0,0,0"
                                                                   Text="{Binding ProgressValue, StringFormat={}{0:0}%}"
                                                                   Foreground="#DDFFFFFF"
                                                                   FontSize="10.5" />
                                                    </Grid>
                                                    <ProgressBar Margin="0,6,0,0"
                                                                 Maximum="100"
                                                                 Value="{Binding ProgressValue}"
                                                                 Style="{StaticResource ThinProgressBarStyle}" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Grid.Row="0"
                            Grid.RowSpan="3"
                            Width="32"
                            Height="54"
                            Padding="0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            ToolTip="进入观影历史"
                            Command="{Binding NavigateToWatchHistoryCommand}"
                            Style="{StaticResource HomeSectionArrowButtonStyle}">
                        <Viewbox Width="16"
                                 Height="16"
                                 Stretch="Uniform">
                            <Path Data="M6,3 L12,9 L6,15"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.8"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round" />
                        </Viewbox>
                    </Button>
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource GlassPageCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="0.75" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel>
                        <StackPanel>
                            <TextBlock Text="最近新增" Style="{StaticResource CardTitleTextStyle}" />
                        </StackPanel>
                    </DockPanel>

                    <Border Grid.Row="2">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource HomeInlineEmptyStateStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RecentlyAdded.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="还没有新增影片" Style="{StaticResource HomeInlineEmptyStateTextStyle}" />
                    </Border>

                    <ItemsControl Grid.Row="2"
                                  Margin="0,0,46,0"
                                  ItemsSource="{Binding RecentlyAddedPreview}"
                                  ItemsPanel="{StaticResource HomeRecentFiveColumnsPanel}"
                                  ItemTemplate="{StaticResource HomeRecentItemTemplate}">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RecentlyAdded.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding DataContext.IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                    </ItemsControl>
                    <ItemsControl Grid.Row="2"
                                  Margin="0,0,46,0"
                                  ItemsSource="{Binding RecentlyAddedCollapsedPreview}"
                                  ItemsPanel="{StaticResource HomeRecentSixColumnsPanel}"
                                  ItemTemplate="{StaticResource HomeRecentItemTemplate}">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding RecentlyAdded.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                    </ItemsControl>
                    <Button Grid.Row="0"
                            Grid.RowSpan="3"
                            Width="32"
                            Height="54"
                            Padding="0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            ToolTip="进入媒体库"
                            Command="{Binding OpenLibraryCommand}"
                            Style="{StaticResource HomeSectionArrowButtonStyle}">
                        <Viewbox Width="16"
                                 Height="16"
                                 Stretch="Uniform">
                            <Path Data="M6,3 L12,9 L6,15"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.8"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round" />
                        </Viewbox>
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Column="2" Style="{StaticResource GlassHomeAiPanelStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="66" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="AI 推荐" Style="{StaticResource CardTitleTextStyle}" />
                        <Grid Margin="0,6,0,0"
                              HorizontalAlignment="Left"
                              ToolTip="{Binding AiRecommendationStatusText}">
                            <StackPanel Width="250">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="{Binding AiRecommendationStatusExpandedLine1}"
                                           Style="{StaticResource HomeAiStatusLineStyle}" />
                                <TextBlock Text="{Binding AiRecommendationStatusExpandedLine2}"
                                           Style="{StaticResource HomeAiStatusLineStyle}" />
                            </StackPanel>
                            <StackPanel Width="292">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="{Binding AiRecommendationStatusCollapsedLine1}"
                                           Style="{StaticResource HomeAiStatusLineStyle}" />
                                <TextBlock Text="{Binding AiRecommendationStatusCollapsedLine2}"
                                           Style="{StaticResource HomeAiStatusLineStyle}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="{Binding AiRecommendationViewModel.RefreshBatchButtonText}"
                            Command="{Binding AiRecommendationViewModel.RefreshBatchCommand}"
                            Style="{StaticResource HomeCompactActionButtonStyle}" />
                </Grid>

                <Grid Grid.Row="1" Margin="0,10,0,0">
                    <Border>
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource HomeInlineEmptyStateStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AiRecommendationViewModel.Recommendations.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="暂无可展示的推荐" Style="{StaticResource HomeInlineEmptyStateTextStyle}" />
                    </Border>

                    <ItemsControl ItemsSource="{Binding AiRecommendationPreview}">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AiRecommendationViewModel.Recommendations.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding DataContext.IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="3" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="0,8"
                                        BorderBrush="{DynamicResource BrushDivider}"
                                        BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="112" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="60" />
                                        </Grid.ColumnDefinitions>

                                        <Button Command="{Binding DataContext.AiRecommendationViewModel.OpenMovieCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource HomePosterButtonStyle}">
                                            <Grid Width="112"
                                                  Height="168"
                                                  Style="{StaticResource HomePosterLiftGridStyle}">
                                                <Border x:Name="HomeAiPosterClipMask"
                                                        Style="{StaticResource HomePosterClipMaskStyle}" />
                                                <Border x:Name="HomeAiPosterPaletteShadowHost"
                                                        Style="{StaticResource HomePosterPaletteShadowStyle}" />
                                                <Border Style="{StaticResource HomePosterBaseShadowStyle}" />
                                                <Grid>
                                                    <Grid.OpacityMask>
                                                        <VisualBrush Visual="{Binding ElementName=HomeAiPosterClipMask}" />
                                                    </Grid.OpacityMask>
                                                    <Border Background="{StaticResource HomePosterCardSurfaceBrush}" />
                                                    <Control IsHitTestVisible="False"
                                                             Template="{StaticResource PosterPlaceholderTemplate}" />
                                                    <Image helpers:PosterCacheImageBehavior.DecodePixelWidth="240"
                                                           helpers:PosterCacheImageBehavior.Source="{Binding PosterRemoteUrl}"
                                                           helpers:PosterPaletteShadowBehavior.TargetElement="{Binding ElementName=HomeAiPosterPaletteShadowHost}"
                                                           RenderOptions.BitmapScalingMode="HighQuality"
                                                           SnapsToDevicePixels="True"
                                                           Stretch="UniformToFill" />
                                                    <Grid IsHitTestVisible="False">
                                                        <Grid.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                <GradientStop Color="#00000000" Offset="0" />
                                                                <GradientStop Color="#0A111827" Offset="0.42" />
                                                                <GradientStop Color="#78111824" Offset="0.78" />
                                                                <GradientStop Color="#B8111824" Offset="1" />
                                                            </LinearGradientBrush>
                                                        </Grid.Background>
                                                    </Grid>
                                                    <Border Height="64"
                                                            VerticalAlignment="Top"
                                                            IsHitTestVisible="False">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                <GradientStop Color="#38FFFFFF" Offset="0" />
                                                                <GradientStop Color="#20FFFFFF" Offset="0.22" />
                                                                <GradientStop Color="#08FFFFFF" Offset="0.62" />
                                                                <GradientStop Color="#00FFFFFF" Offset="1" />
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                    </Border>
                                                </Grid>
                                            </Grid>
                                        </Button>

                                        <Grid Grid.Column="2"
                                              Height="152"
                                              Margin="0,8,8,0"
                                              VerticalAlignment="Top">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <Button Command="{Binding DataContext.AiRecommendationViewModel.OpenMovieCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource HomeTextButtonStyle}">
                                                <TextBlock Text="{Binding Title}"
                                                           helpers:TrimmedTextToolTipBehavior.FullText="{Binding Title}"
                                                           Style="{StaticResource HomeAiExpandedTitleTextStyle}" />
                                            </Button>
                                            <TextBlock Grid.Row="1"
                                                       Margin="0,5,0,0"
                                                       Text="{Binding ReleaseDateText}"
                                                       helpers:TrimmedTextToolTipBehavior.FullText="{Binding ReleaseDateText}"
                                                       Style="{StaticResource CaptionTextStyle}" />
                                            <TextBlock Grid.Row="3"
                                                       Margin="0,0,0,0"
                                                       Text="{Binding Tags}"
                                                       helpers:TrimmedTextToolTipBehavior.FullText="{Binding Tags}"
                                                       Style="{StaticResource HomeAiTagTextStyle}" />
                                            <TextBlock Grid.Row="4"
                                                       Margin="0,3,0,0"
                                                       Text="{Binding EmotionTagsText}"
                                                       helpers:TrimmedTextToolTipBehavior.FullText="{Binding EmotionTagsText}"
                                                       Style="{StaticResource HomeAiTagTextStyle}" />
                                            <TextBlock Grid.Row="5"
                                                       Margin="0,3,0,0"
                                                       Text="{Binding SceneTagsText}"
                                                       helpers:TrimmedTextToolTipBehavior.FullText="{Binding SceneTagsText}"
                                                       Style="{StaticResource HomeAiTagTextStyle}" />
                                        </Grid>

                                        <Grid Grid.Column="3"
                                              Height="152"
                                              Margin="0,8,0,0"
                                              VerticalAlignment="Top">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="24" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="6" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <Border Style="{StaticResource HomeAiRatingBadgeStyle}">
                                                <TextBlock Text="{Binding WeightedAverageRatingText}"
                                                           Style="{StaticResource HomeAiRatingTextStyle}" />
                                            </Border>
                                            <Button Grid.Row="2"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Top"
                                                    Content="{Binding WantToWatchButtonText}"
                                                    Command="{Binding DataContext.AiRecommendationViewModel.AddWantToWatchCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource HomeWantButtonStyle}" />
                                            <Button Grid.Row="4"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Top"
                                                    Content="{Binding NotInterestedButtonText}"
                                                    Command="{Binding DataContext.AiRecommendationViewModel.ToggleNotInterestedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource HomeWantButtonStyle}" />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <ItemsControl ItemsSource="{Binding AiRecommendationPreview}">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding AiRecommendationViewModel.Recommendations.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="3" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="0,8"
                                        BorderBrush="{DynamicResource BrushDivider}"
                                        BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="112" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="60" />
                                        </Grid.ColumnDefinitions>

                                        <Button Command="{Binding DataContext.AiRecommendationViewModel.OpenMovieCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource HomePosterButtonStyle}">
                                            <Grid Width="112"
                                                  Height="168"
                                                  Style="{StaticResource HomePosterLiftGridStyle}">
                                                <Border x:Name="HomeAiCollapsedPosterClipMask"
                                                        Style="{StaticResource HomePosterClipMaskStyle}" />
                                                <Border x:Name="HomeAiCollapsedPosterPaletteShadowHost"
                                                        Style="{StaticResource HomePosterPaletteShadowStyle}" />
                                                <Border Style="{StaticResource HomePosterBaseShadowStyle}" />
                                                <Grid>
                                                    <Grid.OpacityMask>
                                                        <VisualBrush Visual="{Binding ElementName=HomeAiCollapsedPosterClipMask}" />
                                                    </Grid.OpacityMask>
                                                    <Border Background="{StaticResource HomePosterCardSurfaceBrush}" />
                                                    <Control IsHitTestVisible="False"
                                                             Template="{StaticResource PosterPlaceholderTemplate}" />
                                                    <Image helpers:PosterCacheImageBehavior.DecodePixelWidth="240"
                                                           helpers:PosterCacheImageBehavior.Source="{Binding PosterRemoteUrl}"
                                                           helpers:PosterPaletteShadowBehavior.TargetElement="{Binding ElementName=HomeAiCollapsedPosterPaletteShadowHost}"
                                                           RenderOptions.BitmapScalingMode="HighQuality"
                                                           SnapsToDevicePixels="True"
                                                           Stretch="UniformToFill" />
                                                    <Grid IsHitTestVisible="False">
                                                        <Grid.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                <GradientStop Color="#00000000" Offset="0" />
                                                                <GradientStop Color="#0A111827" Offset="0.42" />
                                                                <GradientStop Color="#78111824" Offset="0.78" />
                                                                <GradientStop Color="#B8111824" Offset="1" />
                                                            </LinearGradientBrush>
                                                        </Grid.Background>
                                                    </Grid>
                                                    <Border Height="64"
                                                            VerticalAlignment="Top"
                                                            IsHitTestVisible="False">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                <GradientStop Color="#38FFFFFF" Offset="0" />
                                                                <GradientStop Color="#20FFFFFF" Offset="0.22" />
                                                                <GradientStop Color="#08FFFFFF" Offset="0.62" />
                                                                <GradientStop Color="#00FFFFFF" Offset="1" />
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                    </Border>
                                                </Grid>
                                            </Grid>
                                        </Button>

                                        <Grid Grid.Column="2"
                                              Height="152"
                                              Margin="0,8,8,0"
                                              VerticalAlignment="Top">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>

                                            <Button Command="{Binding DataContext.AiRecommendationViewModel.OpenMovieCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource HomeTextButtonStyle}">
                                                <TextBlock Text="{Binding Title}"
                                                           helpers:TrimmedTextToolTipBehavior.FullText="{Binding Title}"
                                                           Style="{StaticResource HomeAiCollapsedTitleTextStyle}" />
                                            </Button>
                                            <TextBlock Grid.Row="1"
                                                       Margin="0,5,0,0"
                                                       Text="{Binding ReleaseDateText}"
                                                       helpers:TrimmedTextToolTipBehavior.FullText="{Binding ReleaseDateText}"
                                                       Style="{StaticResource HomeAiTagTextStyle}" />
                                            <TextBlock Grid.Row="2"
                                                       Margin="0,3,0,0"
                                                       Text="{Binding Tags}"
                                                       helpers:TrimmedTextToolTipBehavior.FullText="{Binding Tags}"
                                                       Style="{StaticResource HomeAiTagTextStyle}" />
                                            <TextBlock Grid.Row="3"
                                                       Margin="0,3,0,0"
                                                       Text="{Binding EmotionTagsText}"
                                                       helpers:TrimmedTextToolTipBehavior.FullText="{Binding EmotionTagsText}"
                                                       Style="{StaticResource HomeAiTagTextStyle}" />
                                            <TextBlock Grid.Row="4"
                                                       Margin="0,3,0,0"
                                                       Text="{Binding SceneTagsText}"
                                                       helpers:TrimmedTextToolTipBehavior.FullText="{Binding SceneTagsText}"
                                                       Style="{StaticResource HomeAiTagTextStyle}" />
                                            <Border Grid.Row="5"
                                                    Height="56"
                                                    Margin="0,4,0,0"
                                                    VerticalAlignment="Bottom"
                                                    ClipToBounds="True">
                                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                              HorizontalScrollBarVisibility="Disabled"
                                                              Loaded="ReasonScrollViewer_Loaded"
                                                              Unloaded="ReasonScrollViewer_Unloaded"
                                                              ScrollChanged="ReasonScrollViewer_ScrollChanged"
                                                              helpers:ScrollBarAutoRevealBehavior.IsEnabled="True"
                                                              helpers:TextScrollOverflowCueBehavior.IsEnabled="True">
                                                    <ScrollViewer.Resources>
                                                        <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource HomeReasonScrollBarStyle}" />
                                                    </ScrollViewer.Resources>
                                                    <TextBlock Text="{Binding Reason}"
                                                               TextWrapping="Wrap"
                                                               FontSize="11"
                                                               LineHeight="14"
                                                               Foreground="{DynamicResource BrushForegroundSecondary}" />
                                                </ScrollViewer>
                                            </Border>
                                        </Grid>

                                        <Grid Grid.Column="3"
                                              Height="152"
                                              Margin="0,8,0,0"
                                              VerticalAlignment="Top">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="24" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="6" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <Border Style="{StaticResource HomeAiRatingBadgeStyle}">
                                                <TextBlock Text="{Binding WeightedAverageRatingText}"
                                                           Style="{StaticResource HomeAiRatingTextStyle}" />
                                            </Border>
                                            <Button Grid.Row="2"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Top"
                                                    Content="{Binding WantToWatchButtonText}"
                                                    Command="{Binding DataContext.AiRecommendationViewModel.AddWantToWatchCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource HomeWantButtonStyle}" />
                                            <Button Grid.Row="4"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Top"
                                                    Content="{Binding NotInterestedButtonText}"
                                                    Command="{Binding DataContext.AiRecommendationViewModel.ToggleNotInterestedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource HomeWantButtonStyle}" />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>

                <Button Grid.Row="2"
                        Margin="0,11,0,0"
                        Width="220"
                        HorizontalAlignment="Center"
                        Content="发现更多影片 »"
                        Command="{Binding NavigateToMovieDiscoveryCommand}"
                        Style="{StaticResource GlassPrimaryButtonStyle}" />
            </Grid>
        </Border>
        </Grid>

        <Border Grid.ColumnSpan="3"
                Panel.ZIndex="220"
                Background="Transparent">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsHomeInitialLoading}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <Control Width="34"
                         Height="34"
                         HorizontalAlignment="Center"
                         Template="{StaticResource LoadingSpinnerTemplate}" />
                <TextBlock Margin="0,12,0,0"
                           HorizontalAlignment="Center"
                           Style="{StaticResource InlineLoadingStyle}"
                           Text="{Binding StatusMessage}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
