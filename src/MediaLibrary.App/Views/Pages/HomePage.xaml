<UserControl x:Class="MediaLibrary.App.Views.Pages.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="7*" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <Border Style="{StaticResource PageCardStyle}">
                    <StackPanel>
                        <DockPanel>
                            <StackPanel>
                                <TextBlock Text="片库预览" Style="{StaticResource CardTitleTextStyle}" />
                                <TextBlock Margin="0,8,0,0"
                                           Text="{Binding StatusMessage}"
                                           TextWrapping="Wrap"
                                           Style="{StaticResource BodyMutedTextStyle}" />
                            </StackPanel>
                            <Button DockPanel.Dock="Right"
                                    Content="进入媒体库"
                                    Command="{Binding OpenLibraryCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                        </DockPanel>

                        <ItemsControl Margin="0,18,0,0" ItemsSource="{Binding LibraryStatusOverview}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="4" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,12,0" Style="{StaticResource CompactCardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding ValueText}" Style="{StaticResource MetricTextStyle}" />
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Title}" Style="{StaticResource BodyMutedTextStyle}" />
                                                <TextBlock Margin="4,0,0,0"
                                                           Text="{Binding UnitText}"
                                                           Style="{StaticResource BodyMutedTextStyle}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Margin="0,22,0,0" Style="{StaticResource PageCardStyle}">
                    <StackPanel>
                        <DockPanel>
                            <StackPanel>
                                <TextBlock Text="继续观看" Style="{StaticResource CardTitleTextStyle}" />
                                <TextBlock Margin="0,8,0,0"
                                           Text="最近观看的影片会保留当前进度。"
                                           Style="{StaticResource BodyMutedTextStyle}" />
                            </StackPanel>
                            <Button DockPanel.Dock="Right"
                                    Content="查看更多"
                                    Command="{Binding NavigateToWatchHistoryCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                        </DockPanel>

                        <TextBlock Margin="0,18,0,0" Text="还没有观看记录。">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RecentlyPlayed.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ItemsControl Margin="0,18,0,0" ItemsSource="{Binding RecentlyPlayed}">
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RecentlyPlayed.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="158" Margin="0,0,14,14" Style="{StaticResource CompactCardStyle}">
                                        <StackPanel>
                                            <Border Height="210" CornerRadius="16" Background="{DynamicResource BrushSurfaceAlt}">
                                                <Grid>
                                                    <TextBlock HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Text="无海报"
                                                               Style="{StaticResource BodyMutedTextStyle}" />
                                                    <Image Source="{Binding PosterRemoteUrl}" Stretch="UniformToFill" />
                                                </Grid>
                                            </Border>
                                            <TextBlock Margin="0,10,0,0"
                                                       Text="{Binding Title}"
                                                       TextWrapping="Wrap"
                                                       Style="{StaticResource SectionTitleTextStyle}" />
                                            <TextBlock Margin="0,5,0,0"
                                                       Text="{Binding LastPlayedAtText}"
                                                       Style="{StaticResource BodyMutedTextStyle}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Text="{Binding ProgressText}"
                                                       TextWrapping="Wrap"
                                                       Style="{StaticResource BodyTextStyle}" />
                                            <ProgressBar Margin="0,8,0,0"
                                                         Height="6"
                                                         Maximum="100"
                                                         Value="{Binding ProgressValue}">
                                                <ProgressBar.Style>
                                                    <Style TargetType="ProgressBar">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasProgressPercent}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ProgressBar.Style>
                                            </ProgressBar>
                                            <UniformGrid Margin="0,12,0,0" Columns="2">
                                                <Button Margin="0,0,6,0"
                                                        Content="详情"
                                                        Command="{Binding DataContext.OpenMovieCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource SecondaryButtonStyle}" />
                                                <Button Margin="6,0,0,0"
                                                        Content="{Binding ContinueButtonText}"
                                                        Command="{Binding DataContext.ContinuePlaybackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource SecondaryButtonStyle}" />
                                            </UniformGrid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Margin="0,22,0,0" Style="{StaticResource PageCardStyle}">
                    <StackPanel>
                        <DockPanel>
                            <StackPanel>
                                <TextBlock Text="最近新增" Style="{StaticResource CardTitleTextStyle}" />
                                <TextBlock Margin="0,8,0,0"
                                           Text="按入库时间倒序展示最近加入媒体库的影片。"
                                           Style="{StaticResource BodyMutedTextStyle}" />
                            </StackPanel>
                            <Button DockPanel.Dock="Right"
                                    Content="查看全部"
                                    Command="{Binding OpenLibraryCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                        </DockPanel>

                        <TextBlock Margin="0,18,0,0" Text="还没有新增影片。">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RecentlyAdded.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ItemsControl Margin="0,18,0,0" ItemsSource="{Binding RecentlyAdded}">
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RecentlyAdded.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Width="138"
                                            Margin="0,0,14,14"
                                            Padding="0"
                                            Command="{Binding DataContext.OpenMovieCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource SecondaryButtonStyle}">
                                        <StackPanel>
                                            <Border Height="184" CornerRadius="16" Background="{DynamicResource BrushSurfaceAlt}">
                                                <Grid>
                                                    <TextBlock HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Text="无海报"
                                                               Style="{StaticResource BodyMutedTextStyle}" />
                                                    <Image Source="{Binding PosterRemoteUrl}" Stretch="UniformToFill" />
                                                </Grid>
                                            </Border>
                                            <TextBlock Margin="10,10,10,0"
                                                       Text="{Binding Title}"
                                                       TextWrapping="Wrap"
                                                       Style="{StaticResource SectionTitleTextStyle}" />
                                            <TextBlock Margin="10,4,10,10"
                                                       Text="{Binding ReleaseYear}"
                                                       Style="{StaticResource BodyMutedTextStyle}" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Grid.Column="2" Style="{StaticResource PageCardStyle}">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="AI 推荐预览" Style="{StaticResource CardTitleTextStyle}" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="{Binding AiRecommendationViewModel.StatusMessage}"
                                   TextWrapping="Wrap"
                                   Style="{StaticResource BodyMutedTextStyle}" />
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Bottom" Margin="0,18,0,0">
                        <Button Content="换一批"
                                Command="{Binding AiRecommendationViewModel.RefreshBatchCommand}"
                                Style="{StaticResource PrimaryButtonStyle}" />
                        <Button Margin="0,10,0,0"
                                Content="发现更多影片"
                                Command="{Binding NavigateToMovieDiscoveryCommand}"
                                Style="{StaticResource SecondaryButtonStyle}" />
                    </StackPanel>

                    <StackPanel Margin="0,18,0,0">
                        <TextBlock Text="暂无可展示的推荐。">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AiRecommendationViewModel.Recommendations.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ItemsControl ItemsSource="{Binding AiRecommendationViewModel.Recommendations}">
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AiRecommendationViewModel.Recommendations.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Margin="0,0,0,14"
                                            Padding="0"
                                            HorizontalContentAlignment="Stretch"
                                            Command="{Binding DataContext.AiRecommendationViewModel.OpenMovieCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource SecondaryButtonStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="82" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Height="118"
                                                    CornerRadius="14"
                                                    Background="{DynamicResource BrushSurfaceAlt}">
                                                <Grid>
                                                    <TextBlock HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Text="无海报"
                                                               Style="{StaticResource BodyMutedTextStyle}" />
                                                    <Image Source="{Binding PosterRemoteUrl}" Stretch="UniformToFill" />
                                                </Grid>
                                            </Border>
                                            <StackPanel Grid.Column="2" Margin="0,10,10,10">
                                                <TextBlock Text="{Binding Title}"
                                                           TextWrapping="Wrap"
                                                           Style="{StaticResource SectionTitleTextStyle}" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="{Binding Reason}"
                                                           TextWrapping="Wrap"
                                                           MaxHeight="58"
                                                           Style="{StaticResource BodyTextStyle}" />
                                            </StackPanel>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
