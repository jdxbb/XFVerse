<UserControl x:Class="MediaLibrary.App.Views.Pages.SeriesOverviewPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:MediaLibrary.App.Helpers">
    <UserControl.Resources>
        <Style x:Key="TvDetailPillStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,10,10" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Background" Value="{DynamicResource BrushSurface}" />
            <Setter Property="CornerRadius" Value="999" />
        </Style>

        <Style x:Key="TvDetailMetaLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Width="240"
                  Height="360"
                  HorizontalAlignment="Left">
                <Border x:Name="SeriesPosterClipMask"
                        Background="White"
                        CornerRadius="20"
                        IsHitTestVisible="False" />
                <Canvas ClipToBounds="False"
                        IsHitTestVisible="False">
                    <Image x:Name="SeriesPosterPaletteShadowHost"
                           Width="360"
                           Height="480"
                           Canvas.Left="-60"
                           Canvas.Top="-60"
                           helpers:PosterCachedShadowBehavior.BlurRadius="30"
                           helpers:PosterCachedShadowBehavior.CardHeight="360"
                           helpers:PosterCachedShadowBehavior.CardWidth="240"
                           helpers:PosterCachedShadowBehavior.CornerRadius="20"
                           helpers:PosterCachedShadowBehavior.Direction="270"
                           helpers:PosterCachedShadowBehavior.InnerMargin="0,4,0,0"
                           helpers:PosterCachedShadowBehavior.IsEnabled="True"
                           helpers:PosterCachedShadowBehavior.Opacity="0.40"
                           helpers:PosterCachedShadowBehavior.Padding="60"
                           helpers:PosterCachedShadowBehavior.QuantizeColor="True"
                           helpers:PosterCachedShadowBehavior.ShadowColor="#192230"
                           helpers:PosterCachedShadowBehavior.ShadowDepth="8"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Stretch="Fill" />
                    <Image Width="360"
                           Height="480"
                           Canvas.Left="-60"
                           Canvas.Top="-60"
                           helpers:PosterCachedShadowBehavior.BlurRadius="14"
                           helpers:PosterCachedShadowBehavior.CardHeight="360"
                           helpers:PosterCachedShadowBehavior.CardWidth="240"
                           helpers:PosterCachedShadowBehavior.CornerRadius="20"
                           helpers:PosterCachedShadowBehavior.Direction="270"
                           helpers:PosterCachedShadowBehavior.IsEnabled="True"
                           helpers:PosterCachedShadowBehavior.Opacity="0.24"
                           helpers:PosterCachedShadowBehavior.Padding="60"
                           helpers:PosterCachedShadowBehavior.ShadowColor="#000000"
                           helpers:PosterCachedShadowBehavior.ShadowDepth="4"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Stretch="Fill" />
                </Canvas>
                <Grid>
                    <Grid.OpacityMask>
                        <VisualBrush Visual="{Binding ElementName=SeriesPosterClipMask}" />
                    </Grid.OpacityMask>
                    <Border Background="{DynamicResource BrushSurfaceAlt}" />
                    <Control IsHitTestVisible="False"
                             Template="{StaticResource PosterPlaceholderTemplate}" />
                    <Image helpers:PosterCacheImageBehavior.DecodePixelWidth="420"
                           helpers:PosterCacheImageBehavior.Source="{Binding PosterDisplayUrl}"
                           helpers:PosterPaletteShadowBehavior.TargetElement="{Binding ElementName=SeriesPosterPaletteShadowHost}"
                           helpers:PosterPaletteShadowBehavior.TargetName="SeriesPosterPaletteShadowHost"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Stretch="UniformToFill" />
                </Grid>
            </Grid>

            <Border Grid.Column="2" Style="{StaticResource HeroCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="310" />
                    </Grid.ColumnDefinitions>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Button HorizontalAlignment="Left"
                                Command="{Binding NavigateBackCommand}"
                                Content="&#xE72B;"
                                Style="{StaticResource DetailBackButtonStyle}" />

                        <StackPanel Grid.Row="1" Margin="0,16,0,0">
                            <TextBlock FontSize="34"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource BrushForegroundPrimary}"
                                       Text="{Binding Name}"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource BodyMutedTextStyle}"
                                       Text="{Binding OriginalName}"
                                       TextTrimming="CharacterEllipsis" />

                            <WrapPanel Margin="0,18,0,0">
                                <Border Style="{StaticResource TvDetailPillStyle}"
                                        Background="{DynamicResource BrushAccent}">
                                    <TextBlock FontWeight="SemiBold"
                                               Foreground="{DynamicResource BrushOnAccent}"
                                               Text="电视剧" />
                                </Border>
                                <Border Style="{StaticResource TvDetailPillStyle}">
                                    <TextBlock Style="{StaticResource BodyTextStyle}"
                                               Text="{Binding FirstAirDateText, StringFormat=首播 {0}}" />
                                </Border>
                                <Border Style="{StaticResource TvDetailPillStyle}">
                                    <TextBlock Style="{StaticResource BodyTextStyle}"
                                               Text="{Binding SeasonCountText}" />
                                </Border>
                                <Border Style="{StaticResource TvDetailPillStyle}">
                                    <TextBlock Style="{StaticResource BodyTextStyle}"
                                               Text="{Binding SourceSummary}" />
                                </Border>
                            </WrapPanel>
                        </StackPanel>

                        <Grid Grid.Row="2" Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="220" />
                            </Grid.ColumnDefinitions>

                            <Border Padding="14"
                                    Background="{DynamicResource BrushSurfaceAlt}"
                                    BorderBrush="{DynamicResource BrushBorder}"
                                    BorderThickness="1"
                                    CornerRadius="14">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="简介" />
                                    <ScrollViewer Margin="0,8,0,0"
                                                  MaxHeight="116"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Auto">
                                        <TextBlock Style="{StaticResource BodyTextStyle}"
                                                   Text="{Binding Overview}"
                                                   TextWrapping="Wrap" />
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    Padding="14"
                                    Background="{DynamicResource BrushSurfaceAlt}"
                                    BorderBrush="{DynamicResource BrushBorder}"
                                    BorderThickness="1"
                                    CornerRadius="14">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="基础信息" />
                                    <TextBlock Margin="0,10,0,0" Style="{StaticResource TvDetailMetaLabelStyle}" Text="类型" />
                                    <TextBlock Style="{StaticResource BodyTextStyle}"
                                               Text="{Binding GenresText}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,10,0,0" Style="{StaticResource TvDetailMetaLabelStyle}" Text="Season" />
                                    <TextBlock Style="{StaticResource BodyTextStyle}"
                                               Text="{Binding SeasonCountText}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,10,0,0" Style="{StaticResource TvDetailMetaLabelStyle}" Text="播放源" />
                                    <TextBlock Style="{StaticResource BodyTextStyle}"
                                               Text="{Binding SourceSummary}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>

                    <StackPanel Grid.Column="2">
                        <Border Style="{StaticResource CompactCardStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="剧集状态" />
                                <TextBlock Margin="0,10,0,0"
                                           Style="{StaticResource BodyMutedTextStyle}"
                                           Text="{Binding StatusMessage}"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,12,0,0"
                                           Style="{StaticResource BodyMutedTextStyle}"
                                           Text="来源摘要" />
                                <TextBlock Margin="0,6,0,0"
                                           Style="{StaticResource BodyTextStyle}"
                                           Text="{Binding SourceSummary}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Button Margin="0,14,0,0"
                                Command="{Binding AddSeriesToLibraryCommand}"
                                Content="{Binding AddSeriesToLibraryButtonText}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ShowSeriesLibraryAction}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource PageCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardTitleTextStyle}" Text="Season 列表" />
                        <TextBlock Margin="0,6,0,0"
                                   Style="{StaticResource BodyMutedTextStyle}"
                                   Text="已识别季、未识别季和 metadata-only 季使用同一列表结构，进入季详情后再查看集列表。" />
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               VerticalAlignment="Center"
                               Style="{StaticResource BodyMutedTextStyle}"
                               Text="{Binding SeasonCountText}" />
                </Grid>

                <ListBox Grid.Row="2"
                         ItemsSource="{Binding Seasons}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.Style>
                        <Style TargetType="ListBox" BasedOn="{StaticResource SectionListBoxStyle}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasSeasons}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.Style>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12"
                                    Background="{DynamicResource BrushSurfaceAlt}"
                                    BorderBrush="{DynamicResource BrushBorder}"
                                    BorderThickness="1"
                                    CornerRadius="14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="86" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="154" />
                                    </Grid.ColumnDefinitions>

                                    <Border Width="86"
                                            Height="126"
                                            Background="{DynamicResource BrushSurface}"
                                            CornerRadius="12"
                                            ClipToBounds="True">
                                        <Grid>
                                            <Control IsHitTestVisible="False"
                                                     Template="{StaticResource PosterPlaceholderTemplate}" />
                                            <Image helpers:PosterCacheImageBehavior.Source="{Binding PosterDisplayUrl}"
                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                   Stretch="UniformToFill" />
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <WrapPanel>
                                            <TextBlock VerticalAlignment="Center"
                                                       Style="{StaticResource SectionTitleTextStyle}"
                                                       Text="{Binding Name}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <Border Margin="10,0,0,0"
                                                    Padding="8,4"
                                                    Background="{DynamicResource BrushAccentSoft}"
                                                    CornerRadius="999">
                                                <TextBlock Style="{StaticResource BodyMutedTextStyle}"
                                                           Text="{Binding SeasonNumberText}" />
                                            </Border>
                                            <Border Margin="8,0,0,0"
                                                    Padding="8,4"
                                                    Background="{DynamicResource BrushSurface}"
                                                    CornerRadius="999">
                                                <TextBlock Style="{StaticResource BodyMutedTextStyle}"
                                                           Text="{Binding IdentificationStatusText}" />
                                            </Border>
                                        </WrapPanel>

                                        <WrapPanel Margin="0,10,0,0">
                                            <TextBlock Margin="0,0,16,0"
                                                       Style="{StaticResource BodyTextStyle}"
                                                       Text="{Binding ProgressText}" />
                                            <TextBlock Margin="0,0,16,0"
                                                       Style="{StaticResource BodyTextStyle}"
                                                       Text="{Binding InLibraryText}" />
                                            <TextBlock Margin="0,0,16,0"
                                                       Style="{StaticResource BodyMutedTextStyle}"
                                                       Text="{Binding SourceSummary}" />
                                            <TextBlock Margin="0,0,16,0"
                                                       Style="{StaticResource BodyMutedTextStyle}"
                                                       Text="{Binding AirDateText, StringFormat=首播 {0}}" />
                                        </WrapPanel>
                                    </StackPanel>

                                    <Button Grid.Column="3"
                                            VerticalAlignment="Center"
                                            Command="{Binding DataContext.NavigateToSeasonCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Content="查看季详情"
                                            Style="{StaticResource PrimaryButtonStyle}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Grid.Row="2"
                        Padding="18"
                        Background="{DynamicResource BrushSurfaceAlt}"
                        BorderBrush="{DynamicResource BrushBorder}"
                        BorderThickness="1"
                        CornerRadius="16">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasNoSeries}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding HasNoSeasons}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock HorizontalAlignment="Center"
                                   Style="{StaticResource SectionTitleTextStyle}"
                                   Text="暂无可展示的 Season" />
                        <TextBlock Margin="0,8,0,0"
                                   HorizontalAlignment="Center"
                                   Style="{StaticResource BodyMutedTextStyle}"
                                   Text="{Binding StatusMessage}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
