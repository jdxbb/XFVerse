<UserControl x:Class="MediaLibrary.App.Views.Pages.SeriesOverviewPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:MediaLibrary.App.Helpers">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource PageCardStyle}">
                <Grid Height="320">
                    <Border Background="{DynamicResource BrushSurfaceAlt}" CornerRadius="18">
                        <Image helpers:PosterCacheImageBehavior.Source="{Binding PosterDisplayUrl}" Stretch="UniformToFill" />
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource HeroCardStyle}">
                <StackPanel>
                    <TextBlock FontSize="32"
                               FontWeight="Bold"
                               Foreground="{DynamicResource BrushForegroundPrimary}"
                               Text="{Binding Name}" />
                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource BodyMutedTextStyle}"
                               Text="{Binding OriginalName}" />

                    <WrapPanel Margin="0,18,0,0">
                        <Border Margin="0,0,10,10"
                                Padding="10,6"
                                Background="{DynamicResource BrushAccent}"
                                CornerRadius="999">
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="{DynamicResource BrushOnAccent}"
                                       Text="Series" />
                        </Border>
                        <Border Margin="0,0,10,10"
                                Padding="10,6"
                                Background="{DynamicResource BrushSurface}"
                                CornerRadius="999">
                            <TextBlock Style="{StaticResource BodyTextStyle}" Text="{Binding FirstAirDateText}" />
                        </Border>
                        <Border Margin="0,0,10,10"
                                Padding="10,6"
                                Background="{DynamicResource BrushSurface}"
                                CornerRadius="999">
                            <TextBlock Style="{StaticResource BodyTextStyle}" Text="{Binding SeasonCountText}" />
                        </Border>
                        <Border Margin="0,0,10,10"
                                Padding="10,6"
                                Background="{DynamicResource BrushSurface}"
                                CornerRadius="999">
                            <TextBlock Style="{StaticResource BodyTextStyle}" Text="{Binding SourceSummary}" />
                        </Border>
                    </WrapPanel>

                    <TextBlock Margin="0,6,0,0"
                               Style="{StaticResource BodyTextStyle}"
                               Text="{Binding GenresText}" />
                    <TextBlock Margin="0,14,0,0"
                               MaxHeight="110"
                               Style="{StaticResource BodyTextStyle}"
                               Text="{Binding Overview}"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,14,0,0"
                               Style="{StaticResource BodyMutedTextStyle}"
                               Text="{Binding StatusMessage}"
                               TextWrapping="Wrap" />
                    <Button Margin="0,14,0,0"
                            HorizontalAlignment="Left"
                            Content="{Binding AddSeriesToLibraryButtonText}"
                            Command="{Binding AddSeriesToLibraryCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowSeriesLibraryAction}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource PageCardStyle}">
            <Grid>
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasNoSeries}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Style="{StaticResource CardTitleTextStyle}" Text="全部 Season" />
                    <ScrollViewer Grid.Row="1"
                                  Margin="0,16,0,0"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                        <ListBox ItemsSource="{Binding Seasons}"
                                 ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                 Style="{StaticResource SectionListBoxStyle}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="88" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="140" />
                                        </Grid.ColumnDefinitions>

                                        <Border Background="{DynamicResource BrushSurfaceAlt}" CornerRadius="12">
                                            <Image helpers:PosterCacheImageBehavior.Source="{Binding PosterDisplayUrl}" Stretch="UniformToFill" />
                                        </Border>

                                        <StackPanel Grid.Column="2" Margin="0,0,18,0">
                                            <WrapPanel>
                                                <TextBlock VerticalAlignment="Center"
                                                           Style="{StaticResource SectionTitleTextStyle}"
                                                           Text="{Binding Name}" />
                                                <Border Margin="10,0,0,0"
                                                        Padding="8,4"
                                                        Background="{DynamicResource BrushSurface}"
                                                        CornerRadius="999">
                                                    <TextBlock Style="{StaticResource BodyMutedTextStyle}" Text="{Binding SeasonNumberText}" />
                                                </Border>
                                                <Border Margin="10,0,0,0"
                                                        Padding="8,4"
                                                        Background="{DynamicResource BrushSurface}"
                                                        CornerRadius="999">
                                                    <TextBlock Style="{StaticResource BodyMutedTextStyle}" Text="{Binding IdentificationStatusText}" />
                                                </Border>
                                            </WrapPanel>
                                            <WrapPanel Margin="0,8,0,0">
                                                <TextBlock Margin="0,0,16,0"
                                                           Style="{StaticResource BodyTextStyle}"
                                                           Text="{Binding ProgressText}" />
                                                <TextBlock Margin="0,0,16,0"
                                                           Style="{StaticResource BodyTextStyle}"
                                                           Text="{Binding InLibraryText}" />
                                                <TextBlock Margin="0,0,16,0"
                                                           Style="{StaticResource BodyMutedTextStyle}"
                                                           Text="{Binding SourceSummary}" />
                                                <TextBlock Margin="0,0,16,0"
                                                           Style="{StaticResource BodyMutedTextStyle}"
                                                           Text="{Binding AirDateText}" />
                                            </WrapPanel>
                                        </StackPanel>

                                        <Button Grid.Column="3"
                                                VerticalAlignment="Center"
                                                Command="{Binding DataContext.NavigateToSeasonCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Content="查看季详情"
                                                Style="{StaticResource PrimaryButtonStyle}" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                    <Border Grid.Row="2"
                            Margin="0,16,0,0"
                            Padding="16"
                            Background="{DynamicResource BrushSurfaceAlt}"
                            CornerRadius="16">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasNoSeasons}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Style="{StaticResource BodyTextStyle}"
                                   Text="暂无 Season metadata。"
                                   TextWrapping="Wrap" />
                    </Border>
                </Grid>

                <Border Padding="16"
                        Background="{DynamicResource BrushSurfaceAlt}"
                        CornerRadius="18">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasNoSeries}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Style="{StaticResource BodyTextStyle}"
                               Text="{Binding StatusMessage}"
                               TextWrapping="Wrap" />
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
