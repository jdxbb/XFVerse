<UserControl x:Class="MediaLibrary.App.Views.Pages.SeriesOverviewPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MediaLibrary.App.Controls"
             xmlns:helpers="clr-namespace:MediaLibrary.App.Helpers">
    <UserControl.Resources>
        <helpers:RatingStarsConverter x:Key="RatingStarsConverter" />

        <Style x:Key="SeriesDetailSmallCardTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource SectionTitleTextStyle}">
            <Setter Property="FontSize" Value="15" />
        </Style>

        <Style x:Key="SeriesDetailInfoLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
            <Setter Property="Margin" Value="0,0,14,4" />
            <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}" />
        </Style>

        <Style x:Key="SeriesDetailInfoValueStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyTextStyle}">
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="helpers:TrimmedTextToolTipBehavior.FullText" Value="{Binding RelativeSource={RelativeSource Self}, Path=Text}" />
        </Style>

        <DataTemplate x:Key="SeriesDetailActionButtonTemplate">
            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                <controls:PhosphorIcon Width="16"
                                       Height="16"
                                       VerticalAlignment="Center"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                       Icon="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" />
                <TextBlock Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           Text="{Binding}" />
            </StackPanel>
        </DataTemplate>

        <Style x:Key="SeriesDetailModernScrollBarThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border Width="6"
                                Background="{DynamicResource BrushForegroundMuted}"
                                CornerRadius="3"
                                Opacity="0.58" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SeriesDetailModernScrollRepeatButtonStyle" TargetType="{x:Type RepeatButton}">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SeriesDetailModernScrollBarStyle" TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="6" />
            <Setter Property="MinWidth" Value="6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Width="{TemplateBinding Width}" Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}"
                                                  Style="{StaticResource SeriesDetailModernScrollRepeatButtonStyle}" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SeriesDetailModernScrollBarThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}"
                                                  Style="{StaticResource SeriesDetailModernScrollRepeatButtonStyle}" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
                <Trigger Property="IsMouseCaptureWithin" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=(helpers:ScrollBarAutoRevealBehavior.IsRevealed)}"
                             Value="True">
                    <Setter Property="Opacity" Value="1" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.RowSpan="3">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDetailLoading}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="18" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="1" Width="240" Height="360" HorizontalAlignment="Left">
                    <Border x:Name="SeriesPosterClipMask" Background="White" CornerRadius="20" IsHitTestVisible="False" />
                    <Canvas ClipToBounds="False" IsHitTestVisible="False">
                        <Image x:Name="SeriesPosterPaletteShadowHost"
                               Width="360"
                               Height="480"
                               Canvas.Left="-60"
                               Canvas.Top="-60"
                               helpers:PosterCachedShadowBehavior.BlurRadius="30"
                               helpers:PosterCachedShadowBehavior.CardHeight="360"
                               helpers:PosterCachedShadowBehavior.CardWidth="240"
                               helpers:PosterCachedShadowBehavior.CornerRadius="20"
                               helpers:PosterCachedShadowBehavior.Direction="270"
                               helpers:PosterCachedShadowBehavior.InnerMargin="0,4,0,0"
                               helpers:PosterCachedShadowBehavior.IsEnabled="True"
                               helpers:PosterCachedShadowBehavior.Opacity="0.40"
                               helpers:PosterCachedShadowBehavior.Padding="60"
                               helpers:PosterCachedShadowBehavior.QuantizeColor="True"
                               helpers:PosterCachedShadowBehavior.ShadowColor="#192230"
                               helpers:PosterCachedShadowBehavior.ShadowDepth="8"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Stretch="Fill" />
                        <Image Width="360"
                               Height="480"
                               Canvas.Left="-60"
                               Canvas.Top="-60"
                               helpers:PosterCachedShadowBehavior.BlurRadius="14"
                               helpers:PosterCachedShadowBehavior.CardHeight="360"
                               helpers:PosterCachedShadowBehavior.CardWidth="240"
                               helpers:PosterCachedShadowBehavior.CornerRadius="20"
                               helpers:PosterCachedShadowBehavior.Direction="270"
                               helpers:PosterCachedShadowBehavior.IsEnabled="True"
                               helpers:PosterCachedShadowBehavior.Opacity="0.24"
                               helpers:PosterCachedShadowBehavior.Padding="60"
                           helpers:PosterCachedShadowBehavior.ShadowColor="#000000"
                               helpers:PosterCachedShadowBehavior.ShadowDepth="4"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Stretch="Fill" />
                    </Canvas>
                    <Grid>
                        <Grid.OpacityMask>
                            <VisualBrush Visual="{Binding ElementName=SeriesPosterClipMask}" />
                        </Grid.OpacityMask>
                        <Border Background="{DynamicResource BrushGlassSurfaceAlt}" />
                        <Control IsHitTestVisible="False" Template="{StaticResource PosterPlaceholderLargeTemplate}" />
                        <Image helpers:PosterCacheImageBehavior.DecodePixelWidth="780"
                               helpers:PosterCacheImageBehavior.PreferredTmdbImageSize="w780"
                               helpers:PosterCacheImageBehavior.Source="{Binding PosterDisplayUrl}"
                               helpers:PosterPaletteShadowBehavior.TargetElement="{Binding ElementName=SeriesPosterPaletteShadowHost}"
                               helpers:PosterPaletteShadowBehavior.TargetName="SeriesPosterPaletteShadowHost"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Stretch="UniformToFill" />
                    </Grid>
                </Grid>
            </Grid>

            <helpers:CachedShadowBorder Grid.Column="2"
                    Height="360"
                    Margin="0,14,0,0"
                    Style="{StaticResource HeroCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="390" />
                    </Grid.ColumnDefinitions>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="106" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel>
                            <TextBlock FontSize="30"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource BrushForegroundPrimary}"
                                       Text="{Binding Name}"
                                       TextTrimming="CharacterEllipsis"
                                       TextWrapping="NoWrap"
                                       helpers:TrimmedTextToolTipBehavior.FullText="{Binding Name}" />
                            <TextBlock Margin="0,2,0,0"
                                       FontSize="17"
                                       Foreground="{DynamicResource BrushForegroundMuted}"
                                       Text="{Binding OriginalName}"
                                       TextTrimming="CharacterEllipsis"
                                       TextWrapping="NoWrap"
                                       helpers:TrimmedTextToolTipBehavior.FullText="{Binding OriginalName}" />
                            <StackPanel Margin="0,6,0,0" Orientation="Horizontal">
                                <StackPanel Orientation="Horizontal">
                                    <controls:PhosphorIcon Width="16"
                                                           Height="16"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource BrushForegroundSecondary}"
                                                           Icon="calendar-blank" />
                                    <TextBlock Margin="6,0,0,0"
                                               FontSize="17"
                                               Foreground="{DynamicResource BrushForegroundSecondary}"
                                               Text="{Binding FirstAirDateText}" />
                                </StackPanel>
                                <StackPanel Margin="18,0,0,0" Orientation="Horizontal">
                                    <controls:PhosphorIcon Width="16"
                                                           Height="16"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource BrushForegroundSecondary}"
                                                           Icon="television" />
                                    <TextBlock Margin="6,0,0,0"
                                               FontSize="17"
                                               Foreground="{DynamicResource BrushForegroundSecondary}"
                                               Text="{Binding SeasonCountText}" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <ItemsControl Grid.Row="2" Margin="8,0" ItemsSource="{Binding Ratings}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1" Columns="2" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <helpers:CachedShadowBorder Margin="8,0"
                                            Padding="10"
                                            CornerRadius="12"
                                            Style="{StaticResource GlassInlinePanelStyle}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                                                <Border Width="24" Height="24" Margin="0,0,7,0" Background="{DynamicResource BrushGlassSelected}" CornerRadius="7">
                                                    <controls:PhosphorIcon Width="16"
                                                                           Height="16"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           Foreground="{DynamicResource BrushAccent}"
                                                                           Icon="star-fill" />
                                                </Border>
                                                <TextBlock VerticalAlignment="Center"
                                                           Style="{StaticResource SeriesDetailSmallCardTitleStyle}"
                                                           Text="{Binding SourceName}" />
                                            </StackPanel>
                                            <Grid Grid.Row="1" Margin="0,7,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="3*" />
                                                    <ColumnDefinition Width="2" />
                                                    <ColumnDefinition Width="2*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                                        <TextBlock FontSize="15" FontWeight="Bold" Foreground="{DynamicResource BrushForegroundPrimary}" Text="{Binding ScoreDisplayText}" />
                                                        <TextBlock Margin="2,0,0,0" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource BrushForegroundMuted}" Text="/" />
                                                        <TextBlock VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource BrushForegroundMuted}" Text="10" />
                                                    </StackPanel>
                                                    <controls:RatingStarsBar HorizontalAlignment="Center"
                                                                             Margin="0,3,0,0"
                                                                             Fill="{DynamicResource BrushRatingStarFill}"
                                                                             ScoreValue="{Binding ScoreValue}"
                                                                             StarSize="16"
                                                                             StarSpacing="1.5"
                                                                             Stroke="{DynamicResource BrushRatingStarStroke}"
                                                                             StrokeThickness="0.65" />
                                                </StackPanel>
                                                <Border Grid.Column="1" Style="{StaticResource RatingCardDividerStyle}" />
                                                <StackPanel Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock HorizontalAlignment="Center" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource BrushForegroundPrimary}" Text="票数" />
                                                    <TextBlock HorizontalAlignment="Center" Margin="0,2,0,0" Style="{StaticResource BodyMutedTextStyle}" Text="{Binding VoteCountDisplayText}" />
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </helpers:CachedShadowBorder>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Grid Grid.Row="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Style="{StaticResource SeriesDetailSmallCardTitleStyle}" Text="简介" />
                            <ScrollViewer Grid.Row="1"
                                          Margin="0,5,0,0"
                                          HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto"
                                          PreviewMouseWheel="OnOverviewPreviewMouseWheel"
                                          helpers:ScrollBarAutoRevealBehavior.IsEnabled="True"
                                          helpers:TextScrollOverflowCueBehavior.IsEnabled="True">
                                <ScrollViewer.Resources>
                                    <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource SeriesDetailModernScrollBarStyle}" />
                                </ScrollViewer.Resources>
                                <TextBlock Style="{StaticResource BodyTextStyle}" Text="{Binding Overview}" TextWrapping="Wrap" />
                            </ScrollViewer>
                        </Grid>
                    </Grid>

                    <helpers:CachedShadowBorder Grid.Column="2" Padding="10" Style="{StaticResource GlassPageCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="6" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Style="{StaticResource SeriesDetailSmallCardTitleStyle}" Text="电视剧信息" />
                            <ScrollViewer Grid.Row="2"
                                          HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto"
                                          helpers:ScrollBarAutoRevealBehavior.IsEnabled="True"
                                          helpers:TextScrollOverflowCueBehavior.IsEnabled="True">
                                <ScrollViewer.Resources>
                                    <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource SeriesDetailModernScrollBarStyle}" />
                                </ScrollViewer.Resources>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="86" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Style="{StaticResource SeriesDetailInfoLabelStyle}" Text="导演" />
                                <TextBlock Grid.Column="1" Style="{StaticResource SeriesDetailInfoValueStyle}" Text="{Binding DirectorText}" />
                                <TextBlock Grid.Row="1" Style="{StaticResource SeriesDetailInfoLabelStyle}" Text="编剧" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource SeriesDetailInfoValueStyle}" Text="{Binding WriterText}" />
                                <TextBlock Grid.Row="2" Style="{StaticResource SeriesDetailInfoLabelStyle}" Text="主演" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource SeriesDetailInfoValueStyle}" Text="{Binding ActorsText}" />
                                <TextBlock Grid.Row="3" Style="{StaticResource SeriesDetailInfoLabelStyle}" Text="国家/地区" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource SeriesDetailInfoValueStyle}" Text="{Binding CountryText}" />
                                <TextBlock Grid.Row="4" Style="{StaticResource SeriesDetailInfoLabelStyle}" Text="语言" />
                                <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource SeriesDetailInfoValueStyle}" Text="{Binding LanguageText}" />
                                <TextBlock Grid.Row="5" Style="{StaticResource SeriesDetailInfoLabelStyle}" Text="类型" />
                                <TextBlock Grid.Row="5" Grid.Column="1" Style="{StaticResource SeriesDetailInfoValueStyle}" Text="{Binding GenresText}" />
                                <TextBlock Grid.Row="6" Style="{StaticResource SeriesDetailInfoLabelStyle}" Text="制片公司" />
                                <TextBlock Grid.Row="6" Grid.Column="1" Style="{StaticResource SeriesDetailInfoValueStyle}" Text="{Binding ProductionCompaniesText}" />
                                <TextBlock Grid.Row="7" Style="{StaticResource SeriesDetailInfoLabelStyle}" Text="制作状态" />
                                <TextBlock Grid.Row="7" Grid.Column="1" Style="{StaticResource SeriesDetailInfoValueStyle}" Text="{Binding ProductionStatusText}" />
                                <TextBlock Grid.Row="8" Style="{StaticResource SeriesDetailInfoLabelStyle}" Text="播出平台" />
                                <TextBlock Grid.Row="8" Grid.Column="1" Style="{StaticResource SeriesDetailInfoValueStyle}" Text="{Binding NetworksText}" />
                                <TextBlock Grid.Row="9" Style="{StaticResource SeriesDetailInfoLabelStyle}" Text="总季数" />
                                <TextBlock Grid.Row="9" Grid.Column="1" Style="{StaticResource SeriesDetailInfoValueStyle}" Text="{Binding SeasonCountText}" />
                                <TextBlock Grid.Row="10" Style="{StaticResource SeriesDetailInfoLabelStyle}" Text="总集数" />
                                <TextBlock Grid.Row="10" Grid.Column="1" Style="{StaticResource SeriesDetailInfoValueStyle}" Text="{Binding EpisodeCountText}" />
                            </Grid>
                            </ScrollViewer>
                        </Grid>
                    </helpers:CachedShadowBorder>
                </Grid>
            </helpers:CachedShadowBorder>
        </Grid>

        <helpers:CachedShadowBorder Grid.Row="2" Style="{StaticResource GlassPageCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Margin="0,0,14,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource CardTitleTextStyle}" Text="Season" />
                    <Button Grid.Column="1"
                            Command="{Binding AddSeriesToLibraryCommand}"
                            Content="{Binding AddSeriesToLibraryButtonText}"
                            ContentTemplate="{StaticResource SeriesDetailActionButtonTemplate}"
                            Tag="{Binding AddSeriesToLibraryButtonIcon}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource GlassSecondaryButtonStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowSeriesLibraryAction}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>

                <ListBox x:Name="SeasonListBox"
                         Grid.Row="2"
                         ItemsSource="{Binding Seasons}"
                         Background="Transparent"
                         BorderBrush="{DynamicResource BrushBorder}"
                         BorderThickness="0,1,0,0"
                         ScrollViewer.ScrollChanged="OnSeasonListScrollChanged"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         helpers:ScrollBarAutoRevealBehavior.IsEnabled="True"
                         VirtualizingPanel.ScrollUnit="Pixel"
                         Margin="-12,0,-6,0">
                    <ListBox.Resources>
                        <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource SeriesDetailModernScrollBarStyle}" />
                    </ListBox.Resources>
                    <ListBox.Style>
                        <Style TargetType="ListBox">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Setter Property="ItemContainerStyle">
                                <Setter.Value>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Focusable" Value="False" />
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="0" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
                                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}">
                                                        <ContentPresenter />
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasSeasons}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.Style>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid MinHeight="138" Margin="0,8,14,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="88" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="110" />
                                </Grid.ColumnDefinitions>
                                <Grid Width="76"
                                      Height="114"
                                      Margin="12,12,0,0"
                                      HorizontalAlignment="Left"
                                      VerticalAlignment="Top">
                                    <Canvas ClipToBounds="False" IsHitTestVisible="False">
                                        <Image x:Name="SeasonRowPosterPaletteShadowHost"
                                               Width="116"
                                               Height="154"
                                               Canvas.Left="-20"
                                               Canvas.Top="-20"
                                               helpers:PosterCachedShadowBehavior.BlurRadius="18"
                                               helpers:PosterCachedShadowBehavior.CardHeight="114"
                                               helpers:PosterCachedShadowBehavior.CardWidth="76"
                                               helpers:PosterCachedShadowBehavior.CornerRadius="10"
                                               helpers:PosterCachedShadowBehavior.IsEnabled="True"
                                               helpers:PosterCachedShadowBehavior.Opacity="0.32"
                                               helpers:PosterCachedShadowBehavior.Padding="20"
                                               helpers:PosterCachedShadowBehavior.QuantizeColor="True"
                                               helpers:PosterCachedShadowBehavior.ShadowDepth="5"
                                               Stretch="Fill" />
                                    </Canvas>
                                    <helpers:CachedShadowBorder Background="{DynamicResource BrushGlassSurface}"
                                                                CornerRadius="10"
                                                                Effect="{x:Null}"
                                                                ShadowBlurRadius="16"
                                                                ShadowColor="{DynamicResource ColorCachedShadowCompact}"
                                                                ShadowDepth="4"
                                                                ShadowOpacity="0.12"
                                                                ShadowPadding="24" />
                                    <Border x:Name="SeasonRowPosterClipMask"
                                            Background="White"
                                            CornerRadius="10"
                                            IsHitTestVisible="False" />
                                    <Grid>
                                        <Grid.OpacityMask>
                                            <VisualBrush Visual="{Binding ElementName=SeasonRowPosterClipMask}" />
                                        </Grid.OpacityMask>
                                        <Border Background="{DynamicResource BrushGlassSurface}" />
                                            <Control IsHitTestVisible="False" Template="{StaticResource PosterPlaceholderTemplate}" />
                                            <Image helpers:PosterCacheImageBehavior.DecodePixelWidth="160"
                                                   helpers:PosterCacheImageBehavior.Source="{Binding PosterDisplayUrl}"
                                                   helpers:PosterPaletteShadowBehavior.TargetElement="{Binding ElementName=SeasonRowPosterPaletteShadowHost}"
                                                   helpers:PosterPaletteShadowBehavior.TargetName="SeasonRowPosterPaletteShadowHost"
                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                   Stretch="UniformToFill" />
                                            <Border BorderBrush="{DynamicResource BrushBorder}"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    IsHitTestVisible="False">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Offset="0" Color="#18FFFFFF" />
                                                        <GradientStop Offset="0.54" Color="#00FFFFFF" />
                                                        <GradientStop Offset="1" Color="#16000000" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                    </Grid>
                                </Grid>
                                <StackPanel Grid.Column="2"
                                            Margin="0,2,18,2"
                                            VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                                   Text="{Binding SeasonDisplayText}" />
                                        <TextBlock Margin="12,0,0,0"
                                                   Style="{StaticResource SectionTitleTextStyle}"
                                                   Text="{Binding SeasonNameDisplayText}"
                                                   TextTrimming="CharacterEllipsis"
                                                   TextWrapping="NoWrap"
                                                   helpers:TrimmedTextToolTipBehavior.FullText="{Binding SeasonNameDisplayText}" />
                                    </StackPanel>
                                    <TextBlock Margin="0,5,0,0"
                                               Style="{StaticResource BodyMutedTextStyle}"
                                               Text="{Binding AirDateText, StringFormat=首播 {0}}" />
                                    <TextBlock Margin="0,5,0,0"
                                               Style="{StaticResource BodyMutedTextStyle}"
                                               Text="{Binding SourceCountText}" />
                                    <TextBlock Margin="0,5,0,0"
                                               Style="{StaticResource BodyMutedTextStyle}"
                                               Text="{Binding WatchedSummaryText}" />
                                </StackPanel>
                                <Button Grid.Column="3"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Focusable="False"
                                        Command="{Binding DataContext.NavigateToSeasonCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Content="查看详情"
                                        Style="{StaticResource GlassSecondaryButtonStyle}" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Grid.Row="2" Background="Transparent">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasNoSeries}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding HasNoSeasons}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Style="{StaticResource BodyMutedTextStyle}"
                               Text="{Binding StatusMessage}"
                               TextWrapping="Wrap" />
                </Border>
            </Grid>
        </helpers:CachedShadowBorder>
        </Grid>

        <Border Grid.RowSpan="3"
                Panel.ZIndex="220"
                Background="Transparent">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDetailLoading}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel Style="{StaticResource PageLoadingHostStyle}">
                <Control Style="{StaticResource PageLoadingSpinnerStyle}" />
                <TextBlock Text="{Binding StatusMessage}"
                           Style="{StaticResource PageLoadingTextStyle}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
