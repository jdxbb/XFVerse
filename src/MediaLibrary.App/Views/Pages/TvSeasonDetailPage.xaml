<UserControl x:Class="MediaLibrary.App.Views.Pages.TvSeasonDetailPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:MediaLibrary.App.Helpers">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource PageCardStyle}">
                <Grid Height="320">
                    <Border Background="{DynamicResource BrushSurfaceAlt}" CornerRadius="18">
                        <Image helpers:PosterCacheImageBehavior.Source="{Binding PosterDisplayUrl}" Stretch="UniformToFill" />
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource HeroCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="180" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource BodyMutedTextStyle}" Text="{Binding SeriesName}" />
                        <TextBlock Margin="0,6,0,0"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource BrushForegroundPrimary}"
                                   Text="{Binding Name}" />

                        <WrapPanel Margin="0,18,0,0">
                            <Border Margin="0,0,10,10"
                                    Padding="10,6"
                                    Background="{DynamicResource BrushAccent}"
                                    CornerRadius="999">
                                <TextBlock FontWeight="SemiBold"
                                           Foreground="{DynamicResource BrushOnAccent}"
                                           Text="{Binding SeasonNumberText}" />
                            </Border>
                            <Border Margin="0,0,10,10"
                                    Padding="10,6"
                                    Background="{DynamicResource BrushSurface}"
                                    CornerRadius="999">
                                <TextBlock Style="{StaticResource BodyTextStyle}" Text="{Binding IdentificationStatusText}" />
                            </Border>
                            <Border Margin="0,0,10,10"
                                    Padding="10,6"
                                    Background="{DynamicResource BrushSurface}"
                                    CornerRadius="999">
                                <TextBlock Style="{StaticResource BodyTextStyle}" Text="{Binding AirDateText}" />
                            </Border>
                            <Border Margin="0,0,10,10"
                                    Padding="10,6"
                                    Background="{DynamicResource BrushSurface}"
                                    CornerRadius="999">
                                <TextBlock Style="{StaticResource BodyTextStyle}" Text="{Binding SourceSummary}" />
                            </Border>
                        </WrapPanel>

                        <TextBlock Margin="0,6,0,0"
                                   Style="{StaticResource BodyTextStyle}"
                                   Text="{Binding GenreDisplay}" />
                        <TextBlock Margin="0,14,0,0"
                                   MaxHeight="105"
                                   Style="{StaticResource BodyTextStyle}"
                                   Text="{Binding Overview}"
                                   TextWrapping="Wrap" />
                        <TextBlock Margin="0,14,0,0"
                                   Style="{StaticResource BodyMutedTextStyle}"
                                   Text="{Binding StatusMessage}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="20,0,0,0">
                        <Button Command="{Binding NavigateBackToSeriesCommand}"
                                Content="返回剧页"
                                Style="{StaticResource SecondaryButtonStyle}" />
                        <WrapPanel Margin="0,12,0,0">
                            <Button Margin="0,0,8,8"
                                    Command="{Binding ToggleFavoriteCommand}"
                                    Content="{Binding FavoriteButtonText}"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Margin="0,0,8,8"
                                    Command="{Binding ToggleWantToWatchCommand}"
                                    Content="{Binding WantToWatchButtonText}"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Margin="0,0,0,8"
                                    Command="{Binding ToggleNotInterestedCommand}"
                                    Content="{Binding NotInterestedButtonText}"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                        </WrapPanel>
                        <WrapPanel Margin="0,4,0,0">
                            <Button Margin="0,0,8,8"
                                    Command="{Binding MarkSeasonWatchedCommand}"
                                    Content="标记整季已看"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Margin="0,0,0,8"
                                    Command="{Binding MarkSeasonUnwatchedCommand}"
                                    Content="标记整季未看"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                        </WrapPanel>

                        <Button Margin="0,8,0,0"
                                Content="{Binding AddSeasonToLibraryButtonText}"
                                Command="{Binding AddSeasonToLibraryCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CanAddSeasonToLibrary}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Border Margin="0,14,0,0" Style="{StaticResource CompactCardStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding ProgressText}" />
                                <TextBlock Margin="0,8,0,0"
                                           Style="{StaticResource BodyMutedTextStyle}"
                                           Text="{Binding InLibraryText}" />
                                <TextBlock Margin="0,8,0,0"
                                           Style="{StaticResource BodyMutedTextStyle}"
                                           Text="{Binding RatingDisplay}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource PageCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Padding="14"
                        Background="{DynamicResource BrushSurfaceAlt}"
                        CornerRadius="16">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsUnidentified}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardTitleTextStyle}" Text="未识别电视剧季" />
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource BodyTextStyle}"
                                   Text="{Binding UnidentifiedSummary}"
                                   TextWrapping="Wrap" />
                        <Button Margin="0,12,0,0"
                                HorizontalAlignment="Left"
                                Command="{Binding OpenSeasonCorrectionCommand}"
                                Content="修正为已识别季">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CanCorrectSeasonToRecognized}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Border>

                <Border Padding="14"
                        Background="{DynamicResource BrushSurfaceAlt}"
                        CornerRadius="16">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CanShowRecognizedSeasonCorrectionEntry}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardTitleTextStyle}" Text="季级修正" />
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource BodyTextStyle}"
                                   Text="将当前季的播放源整体修正到另一个已识别季或已有未识别季。"
                                   TextWrapping="Wrap" />
                        <Button Margin="0,12,0,0"
                                HorizontalAlignment="Left"
                                Command="{Binding OpenSeasonCorrectionCommand}"
                                Content="修正季"
                                Style="{StaticResource PrimaryButtonStyle}" />
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="2"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <ListBox ItemsSource="{Binding Episodes}"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled"
                             Style="{StaticResource SectionListBoxStyle}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="170" />
                                    </Grid.ColumnDefinitions>

                                    <Border Width="52"
                                            Height="52"
                                            Background="{DynamicResource BrushSurfaceAlt}"
                                            CornerRadius="14">
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource BrushForegroundPrimary}"
                                                   Text="{Binding EpisodeNumberText}" />
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="0,0,18,0">
                                        <WrapPanel>
                                            <TextBlock VerticalAlignment="Center"
                                                       Style="{StaticResource SectionTitleTextStyle}"
                                                       Text="{Binding Name}" />
                                            <Border Margin="10,0,0,0"
                                                    Padding="8,4"
                                                    Background="{DynamicResource BrushSurface}"
                                                    CornerRadius="999">
                                                <TextBlock Style="{StaticResource BodyMutedTextStyle}" Text="{Binding WatchedText}" />
                                            </Border>
                                            <Border Margin="10,0,0,0"
                                                    Padding="8,4"
                                                    Background="{DynamicResource BrushSurface}"
                                                    CornerRadius="999">
                                                <TextBlock Style="{StaticResource BodyMutedTextStyle}" Text="{Binding SourceSummary}" />
                                            </Border>
                                        </WrapPanel>
                                        <TextBlock Margin="0,7,0,0"
                                                   MaxHeight="56"
                                                   Style="{StaticResource BodyTextStyle}"
                                                   Text="{Binding Overview}"
                                                   TextWrapping="Wrap" />
                                        <WrapPanel Margin="0,8,0,0">
                                            <TextBlock Margin="0,0,16,0"
                                                       Style="{StaticResource BodyMutedTextStyle}"
                                                       Text="{Binding AirDateText, StringFormat=首播：{0}}" />
                                            <TextBlock Margin="0,0,16,0"
                                                       Style="{StaticResource BodyMutedTextStyle}"
                                                       Text="{Binding RuntimeText, StringFormat=时长：{0}}" />
                                            <TextBlock Margin="0,0,16,0"
                                                       Style="{StaticResource BodyMutedTextStyle}"
                                                       Text="{Binding ProgressText}" />
                                            <TextBlock Margin="0,0,16,0"
                                                       Style="{StaticResource BodyMutedTextStyle}"
                                                       Text="{Binding LastPlayedText, StringFormat=最近播放：{0}}" />
                                            <TextBlock Margin="0,0,16,0"
                                                       Style="{StaticResource BodyMutedTextStyle}"
                                                       Text="{Binding ActiveSourceCount, StringFormat=播放源：{0}}" />
                                        </WrapPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <Button Margin="0,0,0,8"
                                                Command="{Binding DataContext.OpenEpisodeDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Content="详情"
                                                Style="{StaticResource SecondaryButtonStyle}" />
                                        <Button Command="{Binding DataContext.PlayEpisodeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Content="{Binding PlayButtonText}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                                    <Setter Property="IsEnabled" Value="False" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasPlayableSource}" Value="True">
                                                            <Setter Property="IsEnabled" Value="True" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding DataContext.CanOpenEpisodePlayer, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="False">
                                                            <Setter Property="IsEnabled" Value="False" />
                                                            <Setter Property="Content" Value="播放器打开中" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <WrapPanel Margin="0,8,0,0" HorizontalAlignment="Center">
                                            <Button Margin="0,0,8,0"
                                                    Command="{Binding DataContext.MarkEpisodeWatchedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Content="{Binding WatchedActionText}"
                                                    Style="{StaticResource SecondaryButtonStyle}" />
                                            <Button Command="{Binding DataContext.MarkEpisodeUnwatchedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Content="{Binding UnwatchedActionText}"
                                                    Style="{StaticResource SecondaryButtonStyle}" />
                                        </WrapPanel>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>

                <Border Grid.Row="2"
                        Padding="16"
                        Background="{DynamicResource BrushSurfaceAlt}"
                        CornerRadius="16">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasNoEpisodes}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Style="{StaticResource BodyTextStyle}"
                               Text="{Binding EpisodeEmptyText}"
                               TextWrapping="Wrap" />
                </Border>
            </Grid>
        </Border>

        <Border Grid.RowSpan="3"
                Background="#99000000">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSeasonCorrectionPanelOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border Width="720"
                    MaxHeight="520"
                    Padding="22"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Style="{StaticResource PageCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource CardTitleTextStyle}" Text="修正为已识别季" />
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource BodyMutedTextStyle}"
                                   Text="选择目标电视剧和季后确认修正。修正只移动播放源，不删除本地或 WebDAV 文件，不补空集。"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <ScrollViewer Grid.Row="2"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="目标季" />
                            <Button Margin="0,10,0,0"
                                    HorizontalAlignment="Left"
                                    Command="{Binding SelectSeasonCorrectionRecognizedTargetKindCommand}"
                                    Content="{Binding SeasonCorrectionRecognizedTargetButtonText}"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Margin="0,10,0,0"
                                    HorizontalAlignment="Left"
                                    Command="{Binding SelectSeasonCorrectionUnknownTargetKindCommand}"
                                    Content="{Binding SeasonCorrectionUnknownTargetButtonText}"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                                                        <StackPanel Margin="0,14,0,0">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSeasonCorrectionTargetRecognized}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Style="{StaticResource BodyTextStyle}" Text="目标电视剧名" />
                                <TextBox Margin="0,6,0,0"
                                         Text="{Binding SeasonCorrectionSearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource FormTextBoxStyle}" />
                                <TextBlock Margin="0,10,0,0" Style="{StaticResource BodyTextStyle}" Text="目标季号" />
                                <TextBox Margin="0,6,0,0"
                                         Text="{Binding SeasonCorrectionSeasonNumber, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource FormTextBoxStyle}" />
                                <Button Margin="0,10,0,0"
                                        HorizontalAlignment="Left"
                                        Command="{Binding AiSuggestSeasonCorrectionCommand}"
                                        Content="AI 辅助季搜索"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                            </StackPanel><Button Margin="0,10,0,0"
                                    HorizontalAlignment="Left"
                                    Command="{Binding SearchSeasonCorrectionCandidatesCommand}"
                                    Content="搜索 TMDB 电视剧..."
                                    Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Margin="0,10,0,0"
                                    HorizontalAlignment="Left"
                                    Command="{Binding OpenUnknownSeasonCorrectionPickerCommand}"
                                    Content="选择已有未识别季..."
                                    Style="{StaticResource SecondaryButtonStyle}" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource BodyMutedTextStyle}"
                                       Text="{Binding SeasonCorrectionStatusMessage}"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,10,0,0"
                                       Style="{StaticResource BodyMutedTextStyle}"
                                       Text="{Binding SelectedSeasonCorrectionTargetDisplay}"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource BodyTextStyle}"
                                       Text="{Binding SeasonCorrectionConfirmationText}"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,18,0,0"
                                       Style="{StaticResource SectionTitleTextStyle}"
                                       Text="目标集号映射" />
                            <TextBlock Margin="0,6,0,0"
                                       Style="{StaticResource BodyMutedTextStyle}"
                                       Text="默认按当前集号迁移；可逐行改为目标已识别季中的集号。重复目标集号会追加为同一集的多个播放源。"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="目标集号必须是正整数。">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasInvalidSeasonCorrectionMappings}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Setter Property="Foreground" Value="{DynamicResource BrushDanger}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <ItemsControl Margin="0,10,0,0" ItemsSource="{Binding SeasonCorrectionMappings}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,8"
                                                Padding="12"
                                                Background="{DynamicResource BrushSurfaceAlt}"
                                                BorderBrush="{DynamicResource BrushBorder}"
                                                BorderThickness="1"
                                                CornerRadius="10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="88" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="104" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Style="{StaticResource BodyMutedTextStyle}" Text="当前" />
                                                    <TextBlock Margin="0,4,0,0"
                                                               Style="{StaticResource SectionTitleTextStyle}"
                                                               Text="{Binding OriginalEpisodeNumberText}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Margin="10,0">
                                                    <TextBlock Style="{StaticResource BodyTextStyle}"
                                                               Text="{Binding FileName}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Margin="0,4,0,0"
                                                               Style="{StaticResource BodyMutedTextStyle}"
                                                               Text="{Binding SourceSummary}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Style="{StaticResource BodyMutedTextStyle}" Text="目标集号" />
                                                    <TextBox Margin="0,4,0,0"
                                                             Text="{Binding TargetEpisodeNumberText, UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource FormTextBoxStyle}" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>

                    <WrapPanel Grid.Row="4" HorizontalAlignment="Right">
                        <Button Margin="0,0,8,0"
                                Command="{Binding ApplySeasonCorrectionCommand}"
                                Content="确认修正"
                                Style="{StaticResource PrimaryButtonStyle}" />
                        <Button Command="{Binding CancelSeasonCorrectionCommand}"
                                Content="取消"
                                Style="{StaticResource SecondaryButtonStyle}" />
                    </WrapPanel>
                </Grid>
            </Border>
        </Border>

        <Border Grid.RowSpan="3"
                Background="#99000000">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsRecognizedSeasonPickerDialogOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border Width="780"
                    MaxHeight="640"
                    Padding="22"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Style="{StaticResource PageCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource CardTitleTextStyle}" Text="选择已识别季" />
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource BodyMutedTextStyle}"
                                   Text="按电视剧折叠展示，展开后按季号顺序选择目标季。"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Border Grid.Row="2"
                            Padding="14"
                            Background="{DynamicResource BrushSurfaceAlt}"
                            CornerRadius="14">
                        <TextBlock Text="没有可选择的已识别季。">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasRecognizedSeasonTargets}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding RecognizedSeasonSeriesGroups}"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.Style>
                            <Style TargetType="ListBox" BasedOn="{StaticResource SectionListBoxStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasRecognizedSeasonTargets}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.Style>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Expander IsExpanded="False">
                                    <Expander.Header>
                                        <Border Padding="14"
                                                Background="{DynamicResource BrushAccentSoft}"
                                                BorderBrush="{DynamicResource BrushBorder}"
                                                BorderThickness="1"
                                                CornerRadius="12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="132" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Margin="0,0,12,0">
                                                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding DisplayTitle}" />
                                                    <TextBlock Margin="0,5,0,0"
                                                               Style="{StaticResource BodyMutedTextStyle}"
                                                               Text="{Binding HeaderSubtitle}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                                <Button Grid.Column="1"
                                                        VerticalAlignment="Center"
                                                        Command="{Binding DataContext.SelectRecognizedSeasonTargetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="修正到剧"
                                                        Style="{StaticResource PrimaryButtonStyle}" />
                                            </Grid>
                                        </Border>
                                    </Expander.Header>
                                    <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding Seasons}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="20,0,0,8"
                                                        Padding="0"
                                                        Background="{DynamicResource BrushSurfaceAlt}"
                                                        BorderBrush="{DynamicResource BrushBorder}"
                                                        BorderThickness="1"
                                                        CornerRadius="12">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="4" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="120" />
                                                        </Grid.ColumnDefinitions>
                                                        <Border Background="{DynamicResource BrushAccent}" CornerRadius="12,0,0,12" />
                                                        <StackPanel Grid.Column="1" Margin="12">
                                                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding SeasonTitle}" />
                                                            <TextBlock Margin="0,5,0,0"
                                                                       Style="{StaticResource BodyMutedTextStyle}"
                                                                       Text="{Binding DisplaySubtitle}"
                                                                       TextWrapping="Wrap" />
                                                        </StackPanel>
                                                        <Button Grid.Column="2"
                                                                Margin="0,12,12,12"
                                                                VerticalAlignment="Center"
                                                                Command="{Binding DataContext.SelectRecognizedSeasonTargetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Content="修正到季"
                                                                Style="{StaticResource PrimaryButtonStyle}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Button Grid.Row="4"
                            HorizontalAlignment="Right"
                            Width="120"
                            Command="{Binding CloseRecognizedSeasonPickerCommand}"
                            Content="取消"
                            Style="{StaticResource SecondaryButtonStyle}" />
                </Grid>
            </Border>
        </Border>

        <Border Grid.RowSpan="3"
                Background="#99000000">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsUnknownSeasonPickerDialogOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border Width="780"
                    MaxHeight="640"
                    Padding="22"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Style="{StaticResource PageCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource CardTitleTextStyle}" Text="选择已有未识别季" />
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource BodyMutedTextStyle}"
                                   Text="按未识别剧折叠展示，展开后按季号选择目标季。"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Border Grid.Row="2"
                            Padding="14"
                            Background="{DynamicResource BrushSurfaceAlt}"
                            CornerRadius="14">
                        <TextBlock Text="没有可选择的未识别季。">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasUnknownSeasonTargets}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding UnknownSeasonSeriesGroups}"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.Style>
                            <Style TargetType="ListBox" BasedOn="{StaticResource SectionListBoxStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasUnknownSeasonTargets}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.Style>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Expander IsExpanded="False">
                                    <Expander.Header>
                                        <Border Padding="14"
                                                Background="{DynamicResource BrushAccentSoft}"
                                                BorderBrush="{DynamicResource BrushBorder}"
                                                BorderThickness="1"
                                                CornerRadius="12">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding SeriesTitle}" />
                                                <TextBlock Margin="0,5,0,0"
                                                           Style="{StaticResource BodyMutedTextStyle}"
                                                           Text="{Binding HeaderSubtitle}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </Expander.Header>
                                    <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding Seasons}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="20,0,0,8"
                                                        Padding="0"
                                                        Background="{DynamicResource BrushSurfaceAlt}"
                                                        BorderBrush="{DynamicResource BrushBorder}"
                                                        BorderThickness="1"
                                                        CornerRadius="12">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="4" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="120" />
                                                        </Grid.ColumnDefinitions>
                                                        <Border Background="{DynamicResource BrushAccent}" CornerRadius="12,0,0,12" />
                                                        <StackPanel Grid.Column="1" Margin="12">
                                                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding DisplayTitle}" />
                                                            <TextBlock Margin="0,5,0,0"
                                                                       Style="{StaticResource BodyMutedTextStyle}"
                                                                       Text="{Binding DisplaySubtitle}"
                                                                       TextWrapping="Wrap" />
                                                        </StackPanel>
                                                        <Button Grid.Column="2"
                                                                Margin="0,12,12,12"
                                                                VerticalAlignment="Center"
                                                                Command="{Binding DataContext.SelectUnknownSeasonTargetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Content="选择"
                                                                Style="{StaticResource PrimaryButtonStyle}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Button Grid.Row="4"
                            HorizontalAlignment="Right"
                            Width="120"
                            Command="{Binding CloseUnknownSeasonPickerCommand}"
                            Content="取消"
                            Style="{StaticResource SecondaryButtonStyle}" />
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
