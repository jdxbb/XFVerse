<UserControl x:Class="MediaLibrary.App.Views.Pages.TvSeasonDetailPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MediaLibrary.App.Controls"
             xmlns:helpers="clr-namespace:MediaLibrary.App.Helpers">
    <UserControl.Resources>
        <helpers:RatingStarsConverter x:Key="RatingStarsConverter" />

        <Style x:Key="TvDetailPillStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,10,10" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Background" Value="{DynamicResource BrushGlassSurface}" />
            <Setter Property="CornerRadius" Value="999" />
        </Style>

        <Style x:Key="TvDetailMetaLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}" />
        </Style>

        <Style x:Key="TvDetailSourceMetaTextStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
            <Setter Property="Margin" Value="0,0,14,6" />
        </Style>

        <Style x:Key="TvSeasonSmallCardTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource SectionTitleTextStyle}">
            <Setter Property="FontSize" Value="15" />
        </Style>

        <Style x:Key="TvSeasonInfoValueStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyTextStyle}">
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="helpers:TrimmedTextToolTipBehavior.FullText" Value="{Binding RelativeSource={RelativeSource Self}, Path=Text}" />
        </Style>

        <Style x:Key="TvSeasonModernScrollBarThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border Width="6"
                                Background="{DynamicResource BrushForegroundMuted}"
                                CornerRadius="3"
                                Opacity="0.58" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TvSeasonModernScrollRepeatButtonStyle" TargetType="{x:Type RepeatButton}">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TvSeasonModernScrollBarStyle" TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="6" />
            <Setter Property="MinWidth" Value="6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Width="{TemplateBinding Width}" Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}"
                                                  Style="{StaticResource TvSeasonModernScrollRepeatButtonStyle}" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource TvSeasonModernScrollBarThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}"
                                                  Style="{StaticResource TvSeasonModernScrollRepeatButtonStyle}" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
                <Trigger Property="IsMouseCaptureWithin" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=(helpers:ScrollBarAutoRevealBehavior.IsRevealed)}"
                             Value="True">
                    <Setter Property="Opacity" Value="1" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="TvSeasonDetailActionButtonTemplate">
            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                <TextBlock VerticalAlignment="Center"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="14"
                           Text="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" />
                <TextBlock Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           Text="{Binding}" />
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Width="240"
                  Height="360"
                  Margin="0,14,0,0"
                  HorizontalAlignment="Left">
                <Border x:Name="SeasonPosterClipMask"
                        Background="White"
                        CornerRadius="20"
                        IsHitTestVisible="False" />
                <Canvas ClipToBounds="False"
                        IsHitTestVisible="False">
                    <Image x:Name="SeasonPosterPaletteShadowHost"
                           Width="360"
                           Height="480"
                           Canvas.Left="-60"
                           Canvas.Top="-60"
                           helpers:PosterCachedShadowBehavior.BlurRadius="30"
                           helpers:PosterCachedShadowBehavior.CardHeight="360"
                           helpers:PosterCachedShadowBehavior.CardWidth="240"
                           helpers:PosterCachedShadowBehavior.CornerRadius="20"
                           helpers:PosterCachedShadowBehavior.Direction="270"
                           helpers:PosterCachedShadowBehavior.InnerMargin="0,4,0,0"
                           helpers:PosterCachedShadowBehavior.IsEnabled="True"
                           helpers:PosterCachedShadowBehavior.Opacity="0.40"
                           helpers:PosterCachedShadowBehavior.Padding="60"
                           helpers:PosterCachedShadowBehavior.QuantizeColor="True"
                           helpers:PosterCachedShadowBehavior.ShadowColor="#192230"
                           helpers:PosterCachedShadowBehavior.ShadowDepth="8"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Stretch="Fill" />
                    <Image Width="360"
                           Height="480"
                           Canvas.Left="-60"
                           Canvas.Top="-60"
                           helpers:PosterCachedShadowBehavior.BlurRadius="14"
                           helpers:PosterCachedShadowBehavior.CardHeight="360"
                           helpers:PosterCachedShadowBehavior.CardWidth="240"
                           helpers:PosterCachedShadowBehavior.CornerRadius="20"
                           helpers:PosterCachedShadowBehavior.Direction="270"
                           helpers:PosterCachedShadowBehavior.IsEnabled="True"
                           helpers:PosterCachedShadowBehavior.Opacity="0.24"
                           helpers:PosterCachedShadowBehavior.Padding="60"
                           helpers:PosterCachedShadowBehavior.ShadowColor="#000000"
                           helpers:PosterCachedShadowBehavior.ShadowDepth="4"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Stretch="Fill" />
                </Canvas>
                <Grid>
                    <Grid.OpacityMask>
                        <VisualBrush Visual="{Binding ElementName=SeasonPosterClipMask}" />
                    </Grid.OpacityMask>
                    <Border Background="{DynamicResource BrushGlassSurfaceAlt}" />
                    <Control IsHitTestVisible="False"
                             Template="{StaticResource PosterPlaceholderLargeTemplate}" />
                    <Image helpers:PosterCacheImageBehavior.DecodePixelWidth="420"
                           helpers:PosterCacheImageBehavior.Source="{Binding PosterDisplayUrl}"
                           helpers:PosterPaletteShadowBehavior.TargetElement="{Binding ElementName=SeasonPosterPaletteShadowHost}"
                           helpers:PosterPaletteShadowBehavior.TargetName="SeasonPosterPaletteShadowHost"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Stretch="UniformToFill" />
                </Grid>
            </Grid>

            <Grid Grid.Column="2" Margin="0,14,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="304" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="44" />
                </Grid.RowDefinitions>

                <Border Padding="28,14" Style="{StaticResource HeroCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="390" />
                        </Grid.ColumnDefinitions>

                        <Grid Margin="0,2" VerticalAlignment="Stretch">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="68" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <TextBlock FontSize="30"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource BrushForegroundPrimary}"
                                           Text="{Binding SeasonTitleText}"
                                           TextTrimming="CharacterEllipsis"
                                           TextWrapping="NoWrap"
                                           helpers:TrimmedTextToolTipBehavior.FullText="{Binding SeasonTitleText}" />
                                <TextBlock Margin="0,2,0,0"
                                           FontSize="17"
                                           Foreground="{DynamicResource BrushForegroundMuted}"
                                           Text="{Binding SeriesAndOriginalNameText}"
                                           TextTrimming="CharacterEllipsis"
                                           TextWrapping="NoWrap"
                                           helpers:TrimmedTextToolTipBehavior.FullText="{Binding SeriesAndOriginalNameText}" />
                                <StackPanel Margin="0,6,0,0" Orientation="Horizontal">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{DynamicResource BrushForegroundSecondary}" Text="&#xE787;" />
                                        <TextBlock Margin="6,0,0,0" FontSize="17" Foreground="{DynamicResource BrushForegroundSecondary}" Text="{Binding AirDateText}" />
                                    </StackPanel>
                                    <StackPanel Margin="18,0,0,0" Orientation="Horizontal">
                                        <TextBlock VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{DynamicResource BrushForegroundSecondary}" Text="&#xE8B2;" />
                                        <TextBlock Margin="6,0,0,0" FontSize="17" Foreground="{DynamicResource BrushForegroundSecondary}" Text="{Binding EpisodeCountText}" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <Border Grid.Row="2" Padding="10" HorizontalAlignment="Center" Style="{StaticResource GlassPageCardStyle}">
                                <Grid Width="330">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="92" />
                                        <ColumnDefinition Width="3" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="3" />
                                        <ColumnDefinition Width="92" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Horizontal">
                                        <Border Width="24" Height="24" Margin="0,0,7,0" Background="{DynamicResource BrushGlassSelected}" CornerRadius="7">
                                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="{DynamicResource BrushAccent}" LineHeight="16" LineStackingStrategy="BlockLineHeight" Text="&#x2605;" TextAlignment="Center" />
                                        </Border>
                                        <TextBlock VerticalAlignment="Center" Style="{StaticResource TvSeasonSmallCardTitleStyle}" Text="TMDB" />
                                    </StackPanel>
                                    <Border Grid.Column="1" Width="3" Margin="0,2" Background="{DynamicResource BrushDivider}" />
                                    <StackPanel Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                            <TextBlock FontSize="15" FontWeight="Bold" Foreground="{DynamicResource BrushForegroundPrimary}" Text="{Binding SeasonTmdbRating.ScoreDisplayText}" />
                                            <TextBlock Margin="2,0,0,0" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource BrushForegroundMuted}" Text="/" />
                                            <TextBlock VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource BrushForegroundMuted}" Text="10" />
                                        </StackPanel>
                                        <TextBlock HorizontalAlignment="Center" Margin="0,2,0,0" FontSize="18" Foreground="{DynamicResource BrushAccent}" Text="{Binding SeasonTmdbRating.ScoreValue, Converter={StaticResource RatingStarsConverter}}" />
                                    </StackPanel>
                                    <Border Grid.Column="3" Width="3" Margin="0,2" Background="{DynamicResource BrushDivider}" />
                                    <StackPanel Grid.Column="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock HorizontalAlignment="Center" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource BrushForegroundPrimary}" Text="票数" />
                                        <TextBlock HorizontalAlignment="Center" Margin="0,2,0,0" Style="{StaticResource BodyMutedTextStyle}" Text="{Binding SeasonTmdbRating.VoteCountDisplayText}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="4">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Style="{StaticResource TvSeasonSmallCardTitleStyle}" Text="简介" />
                                <ScrollViewer Grid.Row="1"
                                              Margin="0,5,0,0"
                                              HorizontalScrollBarVisibility="Disabled"
                                              VerticalScrollBarVisibility="Auto"
                                              helpers:ScrollBarAutoRevealBehavior.IsEnabled="True"
                                              helpers:TextScrollOverflowCueBehavior.IsEnabled="True">
                                    <ScrollViewer.Resources>
                                        <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource TvSeasonModernScrollBarStyle}" />
                                    </ScrollViewer.Resources>
                                    <TextBlock Style="{StaticResource BodyTextStyle}" Text="{Binding Overview}" TextWrapping="Wrap" />
                                </ScrollViewer>
                            </Grid>
                        </Grid>

                        <Border Grid.Column="2" Margin="0,2" Padding="10" VerticalAlignment="Stretch" Style="{StaticResource GlassPageCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="6" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Style="{StaticResource TvSeasonSmallCardTitleStyle}" Text="单季信息" />
                                    <ScrollViewer Grid.Row="2"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Auto"
                                                  helpers:ScrollBarAutoRevealBehavior.IsEnabled="True">
                                        <ScrollViewer.Resources>
                                            <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource TvSeasonModernScrollBarStyle}" />
                                        </ScrollViewer.Resources>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="86" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Style="{StaticResource TvDetailMetaLabelStyle}" Text="导演" />
                                        <TextBlock Grid.Column="1" Style="{StaticResource TvSeasonInfoValueStyle}" Text="{Binding DirectorText}" />
                                        <TextBlock Grid.Row="1" Style="{StaticResource TvDetailMetaLabelStyle}" Text="编剧" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource TvSeasonInfoValueStyle}" Text="{Binding WriterText}" />
                                        <TextBlock Grid.Row="2" Style="{StaticResource TvDetailMetaLabelStyle}" Text="主演" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource TvSeasonInfoValueStyle}" Text="{Binding ActorsText}" />
                                        <TextBlock Grid.Row="3" Style="{StaticResource TvDetailMetaLabelStyle}" Text="国家/地区" />
                                        <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource TvSeasonInfoValueStyle}" Text="{Binding CountryText}" />
                                        <TextBlock Grid.Row="4" Style="{StaticResource TvDetailMetaLabelStyle}" Text="语言" />
                                        <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource TvSeasonInfoValueStyle}" Text="{Binding LanguageText}" />
                                        <TextBlock Grid.Row="5" Style="{StaticResource TvDetailMetaLabelStyle}" Text="类型" />
                                        <TextBlock Grid.Row="5" Grid.Column="1" Style="{StaticResource TvSeasonInfoValueStyle}" Text="{Binding GenreDisplay}" />
                                        <TextBlock Grid.Row="6" Style="{StaticResource TvDetailMetaLabelStyle}" Text="制片公司" />
                                        <TextBlock Grid.Row="6" Grid.Column="1" Style="{StaticResource TvSeasonInfoValueStyle}" Text="{Binding ProductionCompaniesText}" />
                                        <TextBlock Grid.Row="7" Style="{StaticResource TvDetailMetaLabelStyle}" Text="播出平台" />
                                        <TextBlock Grid.Row="7" Grid.Column="1" Style="{StaticResource TvSeasonInfoValueStyle}" Text="{Binding NetworksText}" />
                                        <TextBlock Grid.Row="8" Style="{StaticResource TvDetailMetaLabelStyle}" Text="总集数" />
                                        <TextBlock Grid.Row="8" Grid.Column="1" Style="{StaticResource TvSeasonInfoValueStyle}" Text="{Binding TotalEpisodeCountText}" />
                                        <TextBlock Grid.Row="9" Style="{StaticResource TvDetailMetaLabelStyle}" Text="已看集数" />
                                        <TextBlock Grid.Row="9" Grid.Column="1" Style="{StaticResource TvSeasonInfoValueStyle}" Text="{Binding WatchedCountText}" />
                                    </Grid>
                                    </ScrollViewer>
                                </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Row="2" Margin="0,0,14,0" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Command="{Binding TogglePreferenceCommand}" Content="{Binding PreferenceButtonText}" ContentTemplate="{StaticResource TvSeasonDetailActionButtonTemplate}" Style="{StaticResource GlassSecondaryButtonStyle}" Tag="{Binding PreferenceButtonIcon}" />
                    <Button Grid.Column="2" ContentTemplate="{StaticResource TvSeasonDetailActionButtonTemplate}" Tag="{Binding WatchedButtonIcon}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource GlassSecondaryButtonStyle}">
                                <Setter Property="Command" Value="{Binding MarkSeasonWatchedCommand}" />
                                <Setter Property="Content" Value="标记已看" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSeasonWatched}" Value="True">
                                        <Setter Property="Command" Value="{Binding MarkSeasonUnwatchedCommand}" />
                                        <Setter Property="Content" Value="取消已看" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Grid.Column="4" Command="{Binding ToggleNotInterestedCommand}" Content="{Binding NotInterestedButtonText}" ContentTemplate="{StaticResource TvSeasonDetailActionButtonTemplate}" Style="{StaticResource GlassSecondaryButtonStyle}" Tag="{Binding NotInterestedButtonIcon}" />
                    <Button Grid.Column="6" Command="{Binding OpenSeasonCorrectionCommand}" Content="修正季归属" ContentTemplate="{StaticResource TvSeasonDetailActionButtonTemplate}" Style="{StaticResource GlassSecondaryButtonStyle}" Tag="&#xE70F;" />
                    <Button Grid.Column="8" Command="{Binding AddSeasonToLibraryCommand}" Content="{Binding AddSeasonToLibraryButtonText}" ContentTemplate="{StaticResource TvSeasonDetailActionButtonTemplate}" Style="{StaticResource GlassSecondaryButtonStyle}" Tag="{Binding AddSeasonToLibraryButtonIcon}" />
                </Grid>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource GlassPageCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource CardTitleTextStyle}" Text="Episode" />
                </Grid>

                <ListBox x:Name="EpisodeListBox"
                         Grid.Row="2"
                         ItemsSource="{Binding Episodes}"
                         Background="Transparent"
                         BorderBrush="{DynamicResource BrushBorder}"
                         BorderThickness="0,1,0,0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         helpers:ScrollBarAutoRevealBehavior.IsEnabled="True"
                         VirtualizingPanel.ScrollUnit="Pixel"
                         Margin="0,0,-6,0">
                    <ListBox.Resources>
                        <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource TvSeasonModernScrollBarStyle}" />
                    </ListBox.Resources>
                    <ListBox.Style>
                        <Style TargetType="ListBox">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Setter Property="ItemContainerStyle">
                                <Setter.Value>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Focusable" Value="False" />
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="0" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
                                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}">
                                                        <ContentPresenter />
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasEpisodes}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.Style>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="0,8,14,8"
                                    BorderThickness="0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTargetEpisode}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource BrushGlassSelected}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="320" />
                                    </Grid.ColumnDefinitions>

                                    <Border MinWidth="54"
                                            Height="54"
                                            Padding="10,0"
                                            HorizontalAlignment="Left"
                                            Background="{DynamicResource BrushGlassSurface}"
                                            BorderBrush="{DynamicResource BrushBorder}"
                                            BorderThickness="1"
                                            CornerRadius="16">
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource BrushForegroundPrimary}"
                                                   Text="{Binding EpisodeNumberText}" />
                                    </Border>

                                    <Grid Grid.Column="1" Margin="18,0,18,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                                   Text="{Binding Name}"
                                                   TextTrimming="CharacterEllipsis"
                                                   TextWrapping="NoWrap"
                                                   helpers:TrimmedTextToolTipBehavior.FullText="{Binding Name}" />
                                        <TextBlock Grid.Row="1"
                                                   Margin="0,6,0,0"
                                                   MaxHeight="38"
                                                   Style="{StaticResource BodyTextStyle}"
                                                   Text="{Binding OverviewDisplayText}"
                                                   TextTrimming="CharacterEllipsis"
                                                   TextWrapping="Wrap" />
                                        <StackPanel Grid.Row="2" Margin="0,8,0,0" Orientation="Horizontal">
                                            <TextBlock Margin="0,0,18,0" Style="{StaticResource BodyMutedTextStyle}" Text="{Binding AirDateText, StringFormat=首播 {0}}" />
                                            <TextBlock Margin="0,0,18,0" Style="{StaticResource BodyMutedTextStyle}" Text="{Binding SourceCountText}" />
                                            <TextBlock Margin="0,0,18,0" Style="{StaticResource BodyMutedTextStyle}" Text="{Binding RuntimeClockText, StringFormat=时长 {0}}" />
                                            <TextBlock Margin="0,0,18,0" Style="{StaticResource BodyMutedTextStyle}" Text="{Binding LastPlayedText, StringFormat=最近播放 {0}}" />
                                            <TextBlock Style="{StaticResource BodyMutedTextStyle}" Text="{Binding WatchedText}" />
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel Grid.Column="2"
                                                 HorizontalAlignment="Right"
                                                 Orientation="Horizontal"
                                                 VerticalAlignment="Center">
                                        <Button Margin="0,0,8,0"
                                                Focusable="False"
                                                Command="{Binding DataContext.OpenEpisodeDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Content="详情"
                                                Style="{StaticResource GlassSecondaryButtonStyle}" />
                                        <Button Margin="0,0,8,0"
                                                Focusable="False"
                                                CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource GlassSecondaryButtonStyle}">
                                                    <Setter Property="Command" Value="{Binding DataContext.MarkEpisodeWatchedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                                    <Setter Property="Content" Value="标记已看" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsWatched}" Value="True">
                                                            <Setter Property="Command" Value="{Binding DataContext.MarkEpisodeUnwatchedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                                            <Setter Property="Content" Value="标记未看" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Focusable="False"
                                                Command="{Binding DataContext.PlayEpisodeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Content="{Binding PlayButtonText}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource GlassPrimaryButtonStyle}">
                                                    <Setter Property="IsEnabled" Value="False" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasPlayableSource}" Value="True">
                                                            <Setter Property="IsEnabled" Value="True" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding DataContext.CanOpenEpisodePlayer, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="False">
                                                            <Setter Property="IsEnabled" Value="False" />
                                                            <Setter Property="Content" Value="播放器打开中" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Grid.Row="2"
                        Padding="18"
                        Background="Transparent">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasNoSeason}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding HasNoEpisodes}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock HorizontalAlignment="Center"
                                   Style="{StaticResource SectionTitleTextStyle}"
                                   Text="暂无可展示的 Episode" />
                        <TextBlock Margin="0,8,0,0"
                                   HorizontalAlignment="Center"
                                   Style="{StaticResource BodyMutedTextStyle}"
                                   Text="{Binding EpisodeEmptyText}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <controls:CorrectionDialogShell Grid.RowSpan="3"
                                        DialogWidth="1180"
                                        DialogMaxHeight="760"
                                        IsOpen="{Binding IsSeasonCorrectionPanelOpen}"
                                        Title="单季修正识别"
                                        Summary=""
                                        StatusText=""
                                        FooterSpacing="0"
                                        CloseCommand="{Binding CloseSeasonCorrectionCommand}"
                                        UseDefaultActions="False">
            <!-- Legacy footer retained temporarily as a source comparison during manual UI acceptance.
            <controls:CorrectionDialogShell.FooterContent>
                <WrapPanel HorizontalAlignment="Right">
                    <Button Margin="0,0,8,0"
                            Command="{Binding ApplySeasonCorrectionCommand}"
                            Content="确认修正"
                            Style="{StaticResource GlassPrimaryButtonStyle}" />
                    <Button Command="{Binding CancelSeasonCorrectionCommand}"
                            Content="取消"
                            Style="{StaticResource GlassSecondaryButtonStyle}" />
                </WrapPanel>
            </controls:CorrectionDialogShell.FooterContent>
            -->
            <controls:CorrectionDialogShell.DialogContent>
                <Grid>
                    <controls:SeasonCorrectionDialogContent />
                    <!-- Legacy correction content retained temporarily as a source comparison during manual UI acceptance.
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="330" />
                                <ColumnDefinition Width="22" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="修正目标" />
                                <Button Margin="0,10,0,0"
                                        Command="{Binding SelectSeasonCorrectionRecognizedTargetKindCommand}"
                                        Content="{Binding SeasonCorrectionRecognizedTargetButtonText}"
                                        Style="{StaticResource GlassSecondaryButtonStyle}" />
                                <Button Margin="0,10,0,0"
                                        Command="{Binding SelectSeasonCorrectionUnknownTargetKindCommand}"
                                        Content="{Binding SeasonCorrectionUnknownTargetButtonText}"
                                        Style="{StaticResource GlassSecondaryButtonStyle}" />

                                <StackPanel Margin="0,16,0,0">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSeasonCorrectionTargetRecognized}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Style="{StaticResource BodyTextStyle}" Text="目标电视剧名" />
                                    <TextBox Margin="0,6,0,0"
                                             Text="{Binding SeasonCorrectionSearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource FormTextBoxStyle}" />
                                    <TextBlock Margin="0,10,0,0"
                                               Style="{StaticResource BodyTextStyle}"
                                               Text="目标季号" />
                                    <TextBox Margin="0,6,0,0"
                                             Text="{Binding SeasonCorrectionSeasonNumber, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource FormTextBoxStyle}" />
                                    <Button Margin="0,10,0,0"
                                            Command="{Binding AiSuggestSeasonCorrectionCommand}"
                                            Content="AI 辅助季搜索"
                                            Style="{StaticResource GlassSecondaryButtonStyle}" />
                                    <Button Margin="0,10,0,0"
                                            Command="{Binding SearchSeasonCorrectionCandidatesCommand}"
                                            Content="搜索 TMDB 电视剧"
                                            Style="{StaticResource GlassPrimaryButtonStyle}" />
                                </StackPanel>

                                <Button Margin="0,16,0,0"
                                        Command="{Binding OpenUnknownSeasonCorrectionPickerCommand}"
                                        Content="选择已有未识别季">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource GlassPrimaryButtonStyle}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSeasonCorrectionTargetUnknown}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <TextBlock Margin="0,14,0,0"
                                           Style="{StaticResource BodyMutedTextStyle}"
                                           Text="{Binding SeasonCorrectionStatusMessage}"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,10,0,0"
                                           Style="{StaticResource BodyTextStyle}"
                                           Text="{Binding SelectedSeasonCorrectionTargetDisplay}"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,10,0,0"
                                           Style="{StaticResource BodyTextStyle}"
                                           Text="{Binding SeasonCorrectionConfirmationText}"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="目标集号映射" />
                                <TextBlock Margin="0,6,0,0"
                                           Style="{StaticResource BodyMutedTextStyle}"
                                           Text="默认按当前集号迁移；可以逐行改为目标季中的集号。重复目标集号会追加为同一集的多个播放源。"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,8,0,0"
                                           Text="目标集号必须是正整数。">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasInvalidSeasonCorrectionMappings}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Setter Property="Foreground" Value="{DynamicResource BrushDanger}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <ItemsControl Margin="0,10,0,0" ItemsSource="{Binding SeasonCorrectionMappings}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,8"
                                                    Padding="12"
                                                    Background="{DynamicResource BrushGlassSurfaceAlt}"
                                                    BorderBrush="{DynamicResource BrushBorder}"
                                                    BorderThickness="1"
                                                    CornerRadius="10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="86" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="104" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Style="{StaticResource BodyMutedTextStyle}" Text="当前" />
                                                        <TextBlock Margin="0,4,0,0"
                                                                   Style="{StaticResource SectionTitleTextStyle}"
                                                                   Text="{Binding OriginalEpisodeNumberText}" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Margin="10,0">
                                                        <TextBlock Style="{StaticResource BodyTextStyle}"
                                                                   Text="{Binding FileName}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Margin="0,4,0,0"
                                                                   Style="{StaticResource BodyMutedTextStyle}"
                                                                   Text="{Binding SourceSummary}"
                                                                   TextWrapping="Wrap" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Style="{StaticResource BodyMutedTextStyle}" Text="目标集号" />
                                                        <TextBox Margin="0,4,0,0"
                                                                 Text="{Binding TargetEpisodeNumberText, UpdateSourceTrigger=PropertyChanged}"
                                                                 Style="{StaticResource FormTextBoxStyle}" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                    -->
                </Grid>
            </controls:CorrectionDialogShell.DialogContent>
        </controls:CorrectionDialogShell>

        <Border Grid.RowSpan="3" Visibility="Collapsed" Background="Transparent">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsRecognizedSeasonPickerDialogOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border Width="780"
                    MaxHeight="640"
                    Padding="22"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Style="{StaticResource GlassPageCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource CardTitleTextStyle}" Text="选择已识别季" />
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource BodyMutedTextStyle}"
                                   Text="按电视剧折叠展示，展开后按季号顺序选择目标季。"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Border Grid.Row="2"
                            Padding="14"
                            Background="{DynamicResource BrushGlassSurfaceAlt}"
                            CornerRadius="14">
                        <TextBlock Text="没有可选择的已识别季。">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasRecognizedSeasonTargets}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding RecognizedSeasonSeriesGroups}"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.Style>
                            <Style TargetType="ListBox" BasedOn="{StaticResource SectionListBoxStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasRecognizedSeasonTargets}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.Style>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Expander IsExpanded="False">
                                    <Expander.Header>
                                        <Border Padding="14"
                                                Background="{DynamicResource BrushGlassSelected}"
                                                BorderBrush="{DynamicResource BrushBorder}"
                                                BorderThickness="1"
                                                CornerRadius="12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="132" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Margin="0,0,12,0">
                                                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding DisplayTitle}" />
                                                    <TextBlock Margin="0,5,0,0"
                                                               Style="{StaticResource BodyMutedTextStyle}"
                                                               Text="{Binding HeaderSubtitle}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                                <Button Grid.Column="1"
                                                        VerticalAlignment="Center"
                                                        Command="{Binding DataContext.SelectRecognizedSeasonTargetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="修正到剧"
                                                        Style="{StaticResource GlassPrimaryButtonStyle}" />
                                            </Grid>
                                        </Border>
                                    </Expander.Header>
                                    <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding Seasons}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="20,0,0,8"
                                                        Padding="0"
                                                        Background="{DynamicResource BrushGlassSurfaceAlt}"
                                                        BorderBrush="{DynamicResource BrushBorder}"
                                                        BorderThickness="1"
                                                        CornerRadius="12">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="4" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="120" />
                                                        </Grid.ColumnDefinitions>
                                                        <Border Background="{DynamicResource BrushAccent}" CornerRadius="12,0,0,12" />
                                                        <StackPanel Grid.Column="1" Margin="12">
                                                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding SeasonTitle}" />
                                                            <TextBlock Margin="0,5,0,0"
                                                                       Style="{StaticResource BodyMutedTextStyle}"
                                                                       Text="{Binding DisplaySubtitle}"
                                                                       TextWrapping="Wrap" />
                                                        </StackPanel>
                                                        <Button Grid.Column="2"
                                                                Margin="0,12,12,12"
                                                                VerticalAlignment="Center"
                                                                Command="{Binding DataContext.SelectRecognizedSeasonTargetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Content="修正到季"
                                                                Style="{StaticResource GlassPrimaryButtonStyle}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Button Grid.Row="4"
                            HorizontalAlignment="Right"
                            Width="120"
                            Command="{Binding CloseRecognizedSeasonPickerCommand}"
                            Content="取消"
                            Style="{StaticResource GlassSecondaryButtonStyle}" />
                </Grid>
            </Border>
        </Border>

        <Border Grid.RowSpan="3" Visibility="Collapsed" Background="Transparent">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsUnknownSeasonPickerDialogOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border Width="780"
                    MaxHeight="640"
                    Padding="22"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Style="{StaticResource GlassPageCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource CardTitleTextStyle}" Text="选择已有未识别季" />
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource BodyMutedTextStyle}"
                                   Text="按未识别剧折叠展示，展开后按季号选择目标季。"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Border Grid.Row="2"
                            Padding="14"
                            Background="{DynamicResource BrushGlassSurfaceAlt}"
                            CornerRadius="14">
                        <TextBlock Text="没有可选择的未识别季。">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasUnknownSeasonTargets}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding UnknownSeasonSeriesGroups}"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.Style>
                            <Style TargetType="ListBox" BasedOn="{StaticResource SectionListBoxStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasUnknownSeasonTargets}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.Style>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Expander IsExpanded="False">
                                    <Expander.Header>
                                        <Border Padding="14"
                                                Background="{DynamicResource BrushGlassSelected}"
                                                BorderBrush="{DynamicResource BrushBorder}"
                                                BorderThickness="1"
                                                CornerRadius="12">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding SeriesTitle}" />
                                                <TextBlock Margin="0,5,0,0"
                                                           Style="{StaticResource BodyMutedTextStyle}"
                                                           Text="{Binding HeaderSubtitle}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </Expander.Header>
                                    <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding Seasons}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="20,0,0,8"
                                                        Padding="0"
                                                        Background="{DynamicResource BrushGlassSurfaceAlt}"
                                                        BorderBrush="{DynamicResource BrushBorder}"
                                                        BorderThickness="1"
                                                        CornerRadius="12">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="4" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="120" />
                                                        </Grid.ColumnDefinitions>
                                                        <Border Background="{DynamicResource BrushAccent}" CornerRadius="12,0,0,12" />
                                                        <StackPanel Grid.Column="1" Margin="12">
                                                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding DisplayTitle}" />
                                                            <TextBlock Margin="0,5,0,0"
                                                                       Style="{StaticResource BodyMutedTextStyle}"
                                                                       Text="{Binding DisplaySubtitle}"
                                                                       TextWrapping="Wrap" />
                                                        </StackPanel>
                                                        <Button Grid.Column="2"
                                                                Margin="0,12,12,12"
                                                                VerticalAlignment="Center"
                                                                Command="{Binding DataContext.SelectUnknownSeasonTargetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Content="选择"
                                                                Style="{StaticResource GlassPrimaryButtonStyle}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Button Grid.Row="4"
                            HorizontalAlignment="Right"
                            Width="120"
                            Command="{Binding CloseUnknownSeasonPickerCommand}"
                            Content="取消"
                            Style="{StaticResource GlassSecondaryButtonStyle}" />
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
