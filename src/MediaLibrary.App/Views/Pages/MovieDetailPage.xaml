            <controls:CorrectionDialogShell.HeaderContent>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Viewbox Width="20"
                             Height="20"
                             VerticalAlignment="Center">
                        <Canvas Width="20" Height="20">
                            <Ellipse Canvas.Left="1.2"
                                     Canvas.Top="1.2"
                                     Width="15.6"
                                     Height="15.6"
                                     Fill="Transparent"
                                     Stroke="{DynamicResource BrushForegroundMuted}"
                                     StrokeThickness="1.4" />
                            <Ellipse Canvas.Left="7.1"
                                     Canvas.Top="7.1"
                                     Width="3.8"
                                     Height="3.8"
                                     Fill="{DynamicResource BrushForegroundMuted}" />
                            <Ellipse Canvas.Left="7.3"
                                     Canvas.Top="3.3"
                                     Width="3.4"
                                     Height="3.4"
                                     Fill="Transparent"
                                     Stroke="{DynamicResource BrushForegroundMuted}"
                                     StrokeThickness="1.1" />
                            <Ellipse Canvas.Left="11.2"
                                     Canvas.Top="7.2"
                                     Width="3.4"
                                     Height="3.4"
                                     Fill="Transparent"
                                     Stroke="{DynamicResource BrushForegroundMuted}"
                                     StrokeThickness="1.1" />
                            <Ellipse Canvas.Left="7.3"
                                     Canvas.Top="11.1"
                                     Width="3.4"
                                     Height="3.4"
                                     Fill="Transparent"
                                     Stroke="{DynamicResource BrushForegroundMuted}"
                                     StrokeThickness="1.1" />
                            <Ellipse Canvas.Left="3.4"
                                     Canvas.Top="7.2"
                                     Width="3.4"
                                     Height="3.4"
                                     Fill="Transparent"
                                     Stroke="{DynamicResource BrushForegroundMuted}"
                                     StrokeThickness="1.1" />
                            <Path Data="M13.5,15.1 C15.6,17 17.3,17.8 19,17.8"
                                  Fill="Transparent"
                                  Stroke="{DynamicResource BrushForegroundMuted}"
                                  StrokeEndLineCap="Round"
                                  StrokeThickness="1.4" />
                        </Canvas>
                    </Viewbox>
                    <ComboBox Grid.Column="2"
                              IsEnabled="{Binding IsCorrectionInteractionEnabled}"
                              ItemsSource="{Binding Sources}"
