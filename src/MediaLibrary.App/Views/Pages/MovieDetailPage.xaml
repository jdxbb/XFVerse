                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="72" />
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="142" />
                            <ColumnDefinition Width="104" />
                            <ColumnDefinition Width="264" />
