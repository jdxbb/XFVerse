                                    <Setter.Value>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="Margin" Value="0" />
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
                                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}">
                                                            <ContentPresenter />
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSources}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.Style>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid MinHeight="54">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="52" />
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="62" />
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="72" />
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="142" />
                                        <ColumnDefinition Width="104" />
                                        <ColumnDefinition Width="264" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Margin="4,4,8,4"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource BodyTextStyle}"
                                                   Text="{Binding FileName}"
                                                   TextAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   helpers:TrimmedTextToolTipBehavior.FullText="{Binding FileName}" />
                                        <TextBlock Margin="0,2,0,0"
                                                   Style="{StaticResource MonospacePathTextStyle}"
                                                   Text="{Binding FilePath}"
                                                   TextAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   helpers:TrimmedTextToolTipBehavior.FullText="{Binding FilePath}" />
                                    </StackPanel>

                                    <TextBlock Grid.Column="1" Style="{StaticResource MovieDetailSourceCellTextStyle}" Text="{Binding ExtensionDisplayText}" />
                                    <TextBlock Grid.Column="2" Style="{StaticResource MovieDetailResolutionSourceCellTextStyle}" Text="{Binding ResolutionShortText}" />
                                    <TextBlock Grid.Column="3" Style="{StaticResource MovieDetailSourceCellTextStyle}" Text="{Binding FrameRateText}" />
                                    <TextBlock Grid.Column="4" Style="{StaticResource MovieDetailSourceCellTextStyle}" Text="{Binding VideoCodecText}" />
                                    <TextBlock Grid.Column="5" Style="{StaticResource MovieDetailSourceCellTextStyle}" Text="{Binding AudioText}" />
                                    <TextBlock Grid.Column="6" Style="{StaticResource MovieDetailSourceCellTextStyle}" Text="{Binding FormattedFileSize}" />
                                    <TextBlock Grid.Column="7" Style="{StaticResource MovieDetailSourceCellTextStyle}" Text="{Binding ProbeStatusShortText}" />
                                    <TextBlock Grid.Column="8" Style="{StaticResource MovieDetailSourceCellTextStyle}" Text="{Binding LastPlayedText}" />
                                    <TextBlock Grid.Column="9" Style="{StaticResource MovieDetailSourceCellTextStyle}" Text="{Binding LastPlayPositionProgressText}" />

                                    <StackPanel Grid.Column="10"
