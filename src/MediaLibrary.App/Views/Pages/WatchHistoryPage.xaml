<UserControl x:Class="MediaLibrary.App.Views.Pages.WatchHistoryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MediaLibrary.App.Controls"
             xmlns:helpers="clr-namespace:MediaLibrary.App.Helpers"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <SolidColorBrush x:Key="LibraryMediaCardBackgroundBrush" Color="#121821" />
        <SolidColorBrush x:Key="LibraryMediaCardSurfaceBrush" Color="#202938" />
        <SolidColorBrush x:Key="LibraryMediaCardTextBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="LibraryMediaCardMutedTextBrush" Color="#D8DEE9" />
        <SolidColorBrush x:Key="LibraryMediaCardAccentBrush" Color="#E2E8F0" />
        <SolidColorBrush x:Key="LibraryMediaCardAccentTextBrush" Color="#111827" />
        <SolidColorBrush x:Key="LibraryMediaCardDividerBrush" Color="#E5E7EB" />
        <SolidColorBrush x:Key="LibraryMediaProgressFillBrush" Color="#67C7F2" />
        <SolidColorBrush x:Key="LibraryMediaProgressTrackBrush" Color="#E5E7EB" />
        <SolidColorBrush x:Key="LibraryTagDividerBrush" Color="#7DD3FC" />

        <Style x:Key="LibraryMediaProgressBarStyle" TargetType="{x:Type ProgressBar}">
            <Setter Property="Height" Value="4" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="Background" Value="{StaticResource LibraryMediaProgressTrackBrush}" />
            <Setter Property="Foreground" Value="{StaticResource LibraryMediaProgressFillBrush}" />
            <Setter Property="Visibility" Value="Visible" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ProgressBar}">
                        <Grid Height="{TemplateBinding Height}"
                              SnapsToDevicePixels="True">
                            <Border x:Name="PART_Track"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="2" />
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="2" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LibraryModernScrollBarThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border x:Name="ThumbRoot"
                                Margin="3"
                                Background="#66FFFFFF"
                                CornerRadius="4"
                                Opacity="0.75" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbRoot" Property="Opacity" Value="1" />
                                <Setter TargetName="ThumbRoot" Property="Background" Value="#99FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbRoot" Property="Opacity" Value="1" />
                                <Setter TargetName="ThumbRoot" Property="Background" Value="#CCFFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LibraryModernScrollRepeatButtonStyle" TargetType="{x:Type RepeatButton}">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LibraryModernScrollBarStyle" TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="10" />
            <Setter Property="MinWidth" Value="10" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Style="{StaticResource LibraryModernScrollRepeatButtonStyle}" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource LibraryModernScrollBarThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Style="{StaticResource LibraryModernScrollRepeatButtonStyle}" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=(helpers:ScrollBarAutoRevealBehavior.IsRevealed)}" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WatchHistoryFilterButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource GlassSmallButtonStyle}">
            <Setter Property="MinWidth" Value="64" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="14,0" />
        </Style>

        <Style x:Key="WatchHistoryActiveFilterButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource WatchHistoryFilterButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsAllDateFilterSelected}" Value="True">
                    <Setter Property="Background" Value="{StaticResource BrushAccent}" />
                    <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}" />
                    <Setter Property="Foreground" Value="White" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WatchHistoryTodayFilterButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource WatchHistoryFilterButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsTodayDateFilterSelected}" Value="True">
                    <Setter Property="Background" Value="{StaticResource BrushAccent}" />
                    <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}" />
                    <Setter Property="Foreground" Value="White" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WatchHistoryThisWeekFilterButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource WatchHistoryFilterButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsThisWeekDateFilterSelected}" Value="True">
                    <Setter Property="Background" Value="{StaticResource BrushAccent}" />
                    <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}" />
                    <Setter Property="Foreground" Value="White" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WatchHistoryThisMonthFilterButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource WatchHistoryFilterButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsThisMonthDateFilterSelected}" Value="True">
                    <Setter Property="Background" Value="{StaticResource BrushAccent}" />
                    <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}" />
                    <Setter Property="Foreground" Value="White" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WatchHistorySpecificDateFilterButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource WatchHistoryFilterButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSpecificDateFilterSelected}" Value="True">
                    <Setter Property="Background" Value="{StaticResource BrushAccent}" />
                    <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}" />
                    <Setter Property="Foreground" Value="White" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WatchHistoryEmptyStateStyle"
               TargetType="{x:Type StackPanel}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasDayGroups}" Value="False">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WatchHistoryDatePickerButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#22FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#33FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WatchHistoryModernCalendarStyle" TargetType="{x:Type Calendar}">
            <Setter Property="Background" Value="{DynamicResource BrushSurfaceRaised}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
        </Style>

        <Style x:Key="WatchHistoryModernDatePickerStyle"
               TargetType="{x:Type DatePicker}"
               BasedOn="{StaticResource DatePickerStyle}">
            <Setter Property="Width" Value="168" />
            <Setter Property="Height" Value="34" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Background" Value="{DynamicResource BrushInputBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushInputBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CalendarStyle" Value="{StaticResource WatchHistoryModernCalendarStyle}" />
        </Style>

        <Style x:Key="LibraryMediaChipStyle" TargetType="{x:Type Border}">
            <Setter Property="Padding" Value="7,4" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="{StaticResource LibraryMediaCardAccentBrush}" />
            <Setter Property="Opacity" Value="0.9" />
        </Style>

        <Style x:Key="LibraryMediaChipTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource LibraryMediaCardAccentTextBrush}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="LibraryMediaMutedTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource LibraryMediaCardMutedTextBrush}" />
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="LibraryTagLineContainerStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="450" />
            <Setter Property="ToolTipService.BetweenShowDelay" Value="0" />
            <Setter Property="ToolTipService.ShowDuration" Value="20000" />
        </Style>

        <Style x:Key="LibraryMediaTitleTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource LibraryMediaCardTextBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <DataTemplate x:Key="WatchHistoryItemCardTemplate">
            <Grid Width="180"
                  Height="270"
                  ClipToBounds="False"
                  SnapsToDevicePixels="True"
                  ToolTipService.ShowDuration="30000"
                  UseLayoutRounding="True">
                <Grid.InputBindings>
                    <MouseBinding Gesture="LeftClick"
                                  Command="{Binding DataContext.OpenMovieCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  CommandParameter="{Binding}" />
                </Grid.InputBindings>
                <Grid.Style>
                    <Style TargetType="{x:Type Grid}">
                        <Setter Property="Cursor" Value="Hand" />
                        <Setter Property="Margin" Value="0,3,14,15" />
                        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
                        <Setter Property="RenderTransform">
                            <Setter.Value>
                                <TranslateTransform />
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="-2" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Border x:Name="PosterCardClipMask"
                        Background="White"
                        CornerRadius="12"
                        IsHitTestVisible="False" />

                <Canvas Width="180"
                        Height="270"
                        ClipToBounds="False"
                        IsHitTestVisible="False">
                    <Image x:Name="PosterPaletteShadowHost"
                           Width="348"
                           Height="438"
                           Canvas.Left="-84"
                           Canvas.Top="-84"
                           helpers:PosterCachedShadowBehavior.BlurRadius="28"
                           helpers:PosterCachedShadowBehavior.CardHeight="270"
                           helpers:PosterCachedShadowBehavior.CardWidth="180"
                           helpers:PosterCachedShadowBehavior.CornerRadius="12"
                           helpers:PosterCachedShadowBehavior.Direction="270"
                           helpers:PosterCachedShadowBehavior.InnerMargin="0,3,0,0"
                           helpers:PosterCachedShadowBehavior.IsEnabled="True"
                           helpers:PosterCachedShadowBehavior.Opacity="0.42"
                           helpers:PosterCachedShadowBehavior.Padding="84"
                           helpers:PosterCachedShadowBehavior.QuantizeColor="True"
                           helpers:PosterCachedShadowBehavior.ShadowColor="#192230"
                           helpers:PosterCachedShadowBehavior.ShadowDepth="7"
                           IsHitTestVisible="False"
                           Opacity="0.95"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           SnapsToDevicePixels="True"
                           Stretch="Fill" />
                    <Image Width="348"
                           Height="438"
                           Canvas.Left="-84"
                           Canvas.Top="-84"
                           helpers:PosterCachedShadowBehavior.BlurRadius="14"
                           helpers:PosterCachedShadowBehavior.CardHeight="270"
                           helpers:PosterCachedShadowBehavior.CardWidth="180"
                           helpers:PosterCachedShadowBehavior.CornerRadius="12"
                           helpers:PosterCachedShadowBehavior.Direction="270"
                           helpers:PosterCachedShadowBehavior.IsEnabled="True"
                           helpers:PosterCachedShadowBehavior.Opacity="0.28"
                           helpers:PosterCachedShadowBehavior.Padding="84"
                           helpers:PosterCachedShadowBehavior.ShadowColor="#000000"
                           helpers:PosterCachedShadowBehavior.ShadowDepth="3"
                           IsHitTestVisible="False"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           SnapsToDevicePixels="True"
                           Stretch="Fill" />
                </Canvas>

                <Grid Width="180"
                      Height="270"
                      ClipToBounds="True">
                    <Grid.OpacityMask>
                        <VisualBrush Visual="{Binding ElementName=PosterCardClipMask}" />
                    </Grid.OpacityMask>
                    <Border Background="{StaticResource LibraryMediaCardSurfaceBrush}" />
                    <Control IsHitTestVisible="False"
                             Template="{StaticResource PosterPlaceholderTemplate}" />
                    <Image x:Name="PosterImage"
                           helpers:PosterCacheImageBehavior.DecodePixelWidth="320"
                           helpers:PosterCacheImageBehavior.Source="{Binding PosterRemoteUrl}"
                           helpers:PosterPaletteShadowBehavior.TargetElement="{Binding ElementName=PosterPaletteShadowHost}"
                           helpers:PosterPaletteShadowBehavior.TargetName="PosterPaletteShadowHost"
                           SnapsToDevicePixels="True"
                           Stretch="UniformToFill">
                        <Image.Style>
                            <Style TargetType="{x:Type Image}">
                                <Setter Property="RenderOptions.BitmapScalingMode" Value="HighQuality" />
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasPoster}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                    <Grid>
                        <Grid.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#00000000" Offset="0" />
                                <GradientStop Color="#0A111827" Offset="0.42" />
                                <GradientStop Color="#78111824" Offset="0.78" />
                                <GradientStop Color="#B8111824" Offset="1" />
                            </LinearGradientBrush>
                        </Grid.Background>
                    </Grid>
                    <Border Height="86"
                            VerticalAlignment="Top"
                            IsHitTestVisible="False">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#38FFFFFF" Offset="0" />
                                <GradientStop Color="#20FFFFFF" Offset="0.22" />
                                <GradientStop Color="#08FFFFFF" Offset="0.62" />
                                <GradientStop Color="#00FFFFFF" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <Border HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Margin="8"
                            MaxWidth="88"
                            Style="{StaticResource LibraryMediaChipStyle}">
                        <TextBlock Text="{Binding CategoryTagText}"
                                   Style="{StaticResource LibraryMediaChipTextStyle}" />
                    </Border>
                    <Border HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="8"
                            MaxWidth="88"
                            Style="{StaticResource LibraryMediaChipStyle}">
                        <TextBlock Text="{Binding SourceBadgeText}"
                                   Style="{StaticResource LibraryMediaChipTextStyle}" />
                    </Border>
                    <Border HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Margin="8,38,8,0"
                            MaxWidth="130">
                        <Border.Style>
                            <Style TargetType="{x:Type Border}" BasedOn="{StaticResource LibraryMediaChipStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasBatchModeHint}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding BatchModeHintText}"
                                   Style="{StaticResource LibraryMediaChipTextStyle}" />
                    </Border>

                    <StackPanel VerticalAlignment="Bottom"
                                Margin="10">
                        <TextBlock helpers:TrimmedTextToolTipBehavior.FullText="{Binding Title}"
                                   Style="{StaticResource LibraryMediaTitleTextStyle}"
                                   Text="{Binding Title}" />
                        <TextBlock helpers:TrimmedTextToolTipBehavior.FullText="{Binding ReleaseDateText}"
                                   Margin="0,3,0,0"
                                   MaxWidth="158"
                                   Style="{StaticResource LibraryMediaMutedTextStyle}"
                                   Text="{Binding ReleaseDateText}" />
                        <Border Margin="0,5,0,0"
                                helpers:TrimmedTextToolTipBehavior.FullText="{Binding PosterTagToolTipText}"
                                helpers:TrimmedTextToolTipBehavior.VisibleText="{Binding PosterTagLine}"
                                Style="{StaticResource LibraryTagLineContainerStyle}">
                            <TextBlock Style="{StaticResource LibraryMediaMutedTextStyle}">
                                <Run Text="{Binding PosterTagGroupOneText, Mode=OneWay}" />
                                <Run Foreground="{StaticResource LibraryTagDividerBrush}" Text="{Binding PosterTagSeparatorAfterOneText, Mode=OneWay}" />
                                <Run Text="{Binding PosterTagGroupTwoText, Mode=OneWay}" />
                                <Run Foreground="{StaticResource LibraryTagDividerBrush}" Text="{Binding PosterTagSeparatorAfterTwoText, Mode=OneWay}" />
                                <Run Text="{Binding PosterTagGroupThreeText, Mode=OneWay}" />
                            </TextBlock>
                        </Border>
                        <Grid Margin="0,7,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ProgressBar Grid.Column="0"
                                         VerticalAlignment="Center"
                                         Style="{StaticResource LibraryMediaProgressBarStyle}"
                                         Value="{Binding ProgressValue, Mode=OneWay}" />
                            <TextBlock Grid.Column="2"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource LibraryMediaCardTextBrush}"
                                       Text="{Binding ProgressLabel}" />
                        </Grid>
                    </StackPanel>
                    <Border BorderBrush="#14FFFFFF"
                            BorderThickness="1"
                            CornerRadius="12"
                            IsHitTestVisible="False" />
                    <Border Margin="1"
                            BorderBrush="#0A000000"
                            BorderThickness="1"
                            CornerRadius="11"
                            IsHitTestVisible="False" />
                </Grid>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="WatchHistoryDayGroupTemplate">
            <Border Margin="0,0,0,28"
                    Padding="0,0,0,2"
                    Background="Transparent">
                <StackPanel>
                    <Grid Margin="0,0,18,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushTextPrimary}"
                                   Text="{Binding Title}" />
                        <Border Grid.Column="1"
                                Height="1"
                                Margin="14,0"
                                VerticalAlignment="Center"
                                Background="{DynamicResource BrushBorder}" />
                        <TextBlock Grid.Column="2"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="{StaticResource BrushTextSecondary}"
                                   Text="{Binding SummaryText}" />
                    </Grid>
                    <ItemsControl ItemsSource="{Binding Items}"
                                  ItemTemplate="{StaticResource WatchHistoryItemCardTemplate}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <controls:EqualSpacingWrapPanel>
                                    <controls:EqualSpacingWrapPanel.Style>
                                        <Style TargetType="{x:Type controls:EqualSpacingWrapPanel}">
                                            <Setter Property="ItemWidth" Value="194" />
                                            <Setter Property="ItemContentWidth" Value="180" />
                                            <Setter Property="ItemHeight" Value="288" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                    <Setter Property="ItemWidth" Value="201" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </controls:EqualSpacingWrapPanel.Style>
                                </controls:EqualSpacingWrapPanel>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,18"
                Padding="12,10"
                Style="{StaticResource GlassCompactCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <WrapPanel Grid.Column="0"
                           VerticalAlignment="Center"
                           ItemHeight="34">
                    <Button Margin="0,0,8,0"
                            Command="{Binding SelectDateFilterCommand}"
                            CommandParameter="全部"
                            Content="全部"
                            Style="{StaticResource WatchHistoryActiveFilterButtonStyle}" />
                    <Button Margin="0,0,8,0"
                            Command="{Binding SelectDateFilterCommand}"
                            CommandParameter="今天"
                            Content="今天"
                            Style="{StaticResource WatchHistoryTodayFilterButtonStyle}" />
                    <Button Margin="0,0,8,0"
                            Command="{Binding SelectDateFilterCommand}"
                            CommandParameter="本周"
                            Content="本周"
                            Style="{StaticResource WatchHistoryThisWeekFilterButtonStyle}" />
                    <Button Margin="0,0,8,0"
                            Command="{Binding SelectDateFilterCommand}"
                            CommandParameter="本月"
                            Content="本月"
                            Style="{StaticResource WatchHistoryThisMonthFilterButtonStyle}" />
                    <Button Margin="0,0,8,0"
                            Command="{Binding SelectDateFilterCommand}"
                            CommandParameter="指定日期"
                            Content="指定日期"
                            Style="{StaticResource WatchHistorySpecificDateFilterButtonStyle}" />
                    <DatePicker Width="168"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                SelectedDate="{Binding SelectedCustomDate, Mode=TwoWay}"
                                Style="{StaticResource WatchHistoryModernDatePickerStyle}"
                                Visibility="{Binding IsCustomDateFilter, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </WrapPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Margin="16,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{StaticResource BrushTextSecondary}"
                               Text="{Binding StatusMessage}"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <StackPanel Width="320"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Style="{StaticResource WatchHistoryEmptyStateStyle}">
                <TextBlock FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource BrushTextPrimary}"
                           Text="暂无观影历史"
                           TextAlignment="Center" />
                <TextBlock Margin="0,10,0,0"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource BrushTextSecondary}"
                           Text="播放影片后，这里会按日期整理你的观看记录。"
                           TextAlignment="Center"
                           TextWrapping="Wrap" />
            </StackPanel>

            <ScrollViewer x:Name="HistoryScrollViewer"
                          Loaded="OnHistoryScrollViewerLoaded"
                          ScrollChanged="OnHistoryScrollChanged"
                          helpers:ScrollBarAutoRevealBehavior.IsEnabled="True"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding HasDayGroups, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ScrollViewer.Resources>
                    <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource LibraryModernScrollBarStyle}" />
                </ScrollViewer.Resources>
                <ItemsControl x:Name="HistoryGroupsItemsControl"
                              ItemTemplate="{StaticResource WatchHistoryDayGroupTemplate}"
                              ItemsSource="{Binding DayGroups}" />
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
