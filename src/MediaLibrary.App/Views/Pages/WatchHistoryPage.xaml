<UserControl x:Class="MediaLibrary.App.Views.Pages.WatchHistoryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource PageCardStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="观影历史" Style="{StaticResource CardTitleTextStyle}" />
                <TextBlock Margin="0,8,0,0"
                           Text="观影历史页面将在后续阶段接入真实观看记录。"
                           Style="{StaticResource BodyMutedTextStyle}" />
            </StackPanel>

            <Border Grid.Row="1"
                    Margin="0,22,0,0"
                    Style="{StaticResource CompactCardStyle}">
                <StackPanel>
                    <TextBlock Text="日期分组预留区" Style="{StaticResource SectionTitleTextStyle}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="后续会按观看日期分组，并展示影片海报、标题、观看时间、时长和播放进度。"
                               TextWrapping="Wrap"
                               Style="{StaticResource BodyTextStyle}" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
