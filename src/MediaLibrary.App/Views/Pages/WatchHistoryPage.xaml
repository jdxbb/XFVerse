<UserControl x:Class="MediaLibrary.App.Views.Pages.WatchHistoryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:MediaLibrary.App.Helpers">
    <Border Style="{StaticResource PageCardStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel>
                <StackPanel>
                    <TextBlock Text="观影历史" Style="{StaticResource CardTitleTextStyle}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="按日期回看你的观看记录。"
                               Style="{StaticResource BodyMutedTextStyle}" />
                </StackPanel>

                <Button DockPanel.Dock="Right"
                        Content="刷新"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" />
            </DockPanel>

            <WrapPanel Grid.Row="1" Margin="0,22,0,0" VerticalAlignment="Center">
                <StackPanel Width="150" Margin="0,0,12,12">
                    <TextBlock Text="日期筛选" Style="{StaticResource BodyMutedTextStyle}" />
                    <ComboBox SelectedItem="{Binding SelectedDateFilter}"
                              ItemsSource="{Binding DateFilterOptions}"
                              Style="{StaticResource FormComboBoxStyle}" />
                </StackPanel>

                <StackPanel Width="180" Margin="0,0,12,12">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCustomDateFilter}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="指定日期" Style="{StaticResource BodyMutedTextStyle}" />
                    <DatePicker SelectedDate="{Binding SelectedCustomDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <TextBlock Margin="0,22,0,0"
                           VerticalAlignment="Center"
                           Text="{Binding StatusMessage}"
                           Style="{StaticResource BodyMutedTextStyle}" />
            </WrapPanel>

            <Grid Grid.Row="2" Margin="0,16,0,0">
                <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource BodyTextStyle}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasDayGroups}" Value="False">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <ScrollViewer x:Name="HistoryScrollViewer" VerticalScrollBarVisibility="Auto">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasDayGroups}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <ItemsControl x:Name="HistoryGroupsItemsControl" ItemsSource="{Binding DayGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,24"
                                        Padding="12"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="BorderBrush" Value="Transparent" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTargetHighlightActive}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource BrushAccentSoft}" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <DockPanel>
                                            <TextBlock Text="{Binding Title}" Style="{StaticResource SectionTitleTextStyle}" />
                                            <TextBlock DockPanel.Dock="Right"
                                                       Text="{Binding SummaryText}"
                                                       Style="{StaticResource BodyMutedTextStyle}" />
                                        </DockPanel>

                                        <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding Items}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,12" Style="{StaticResource CompactCardStyle}">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="84" />
                                                                <ColumnDefinition Width="18" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>

                                                            <Border Height="116"
                                                                    CornerRadius="10"
                                                                    Background="{DynamicResource BrushSurfaceAlt}">
                                                                <Grid>
                                                                    <TextBlock HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center"
                                                                               Text="无海报"
                                                                               Style="{StaticResource BodyMutedTextStyle}" />
                                                                    <Image helpers:PosterCacheImageBehavior.Source="{Binding PosterRemoteUrl}" Stretch="UniformToFill" />
                                                                </Grid>
                                                            </Border>

                                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Title}"
                                                                           TextWrapping="Wrap"
                                                                           Style="{StaticResource SectionTitleTextStyle}" />
                                                                <TextBlock Margin="0,6,0,0"
                                                                           Text="{Binding ReleaseYearText}"
                                                                           Style="{StaticResource BodyMutedTextStyle}" />
                                                                <WrapPanel Margin="0,8,0,0">
                                                                    <TextBlock Margin="0,0,16,0"
                                                                               Text="{Binding WatchTimeText, StringFormat=观看时间：{0}}"
                                                                               Style="{StaticResource BodyTextStyle}" />
                                                                    <TextBlock Margin="0,0,16,0"
                                                                               Text="{Binding WatchDurationText, StringFormat=观看时长：{0}}"
                                                                               Style="{StaticResource BodyTextStyle}" />
                                                                    <TextBlock Text="{Binding ProgressText}"
                                                                               Style="{StaticResource BodyTextStyle}" />
                                                                </WrapPanel>
                                                                <ProgressBar Margin="0,10,0,0"
                                                                             Height="6"
                                                                             Maximum="100"
                                                                             Value="{Binding ProgressValue, Mode=OneWay}">
                                                                    <ProgressBar.Style>
                                                                        <Style TargetType="ProgressBar">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding HasProgressPercent}" Value="False">
                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </ProgressBar.Style>
                                                                </ProgressBar>
                                                                <TextBlock Margin="0,8,0,0"
                                                                           Text="{Binding SourceStatusText}">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding HasSourceStatus}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </StackPanel>

                                                            <Button Grid.Column="3"
                                                                    Margin="18,0,0,0"
                                                                    VerticalAlignment="Center"
                                                                    Content="查看详情"
                                                                    Command="{Binding DataContext.OpenMovieCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    IsEnabled="{Binding CanOpenDetail}"
                                                                    Style="{StaticResource SecondaryButtonStyle}" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</UserControl>
