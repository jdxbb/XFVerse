<UserControl x:Class="MediaLibrary.App.Views.Pages.RecommendationsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:MediaLibrary.App.Helpers">
    <Border Style="{StaticResource PageCardStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="AI 推荐 / 观影偏好" Style="{StaticResource CardTitleTextStyle}" />
                    <TextBlock Margin="0,8,0,0" Text="{Binding StatusMessage}" Style="{StaticResource BodyMutedTextStyle}" />
                    <TextBlock Margin="0,6,0,0"
                               Text="基于已看记录生成 3 部推荐，并标明已有播放源 / 外部候选。"
                               Style="{StaticResource BodyMutedTextStyle}" />
                </StackPanel>

                <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
                    <StackPanel Width="180">
                        <TextBlock Text="来源范围" Style="{StaticResource BodyMutedTextStyle}" />
                        <ComboBox AutomationProperties.Name="来源范围"
                                  ItemsSource="{Binding LibraryScopeOptions}"
                                  IsEnabled="{Binding CanChangeFilters}"
                                  SelectedItem="{Binding SelectedLibraryScope}"
                                  Style="{StaticResource FormComboBoxStyle}" />
                    </StackPanel>

                    <StackPanel Width="150" Margin="12,0,0,0">
                        <TextBlock Text="观影筛选" Style="{StaticResource BodyMutedTextStyle}" />
                        <ComboBox AutomationProperties.Name="观影筛选"
                                  ItemsSource="{Binding WatchFilterOptions}"
                                  IsEnabled="{Binding CanChangeFilters}"
                                  SelectedItem="{Binding SelectedWatchFilter}"
                                  Style="{StaticResource FormComboBoxStyle}" />
                    </StackPanel>

                    <StackPanel Width="160" Margin="12,0,0,0">
                        <TextBlock Text="自定义偏好" Style="{StaticResource BodyMutedTextStyle}" />
                        <CheckBox Content="{Binding CustomPreferenceToggleText}"
                                  IsEnabled="{Binding CanEditCustomPreference}"
                                  IsChecked="{Binding IsCustomPreferenceEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{StaticResource FormCheckBoxStyle}" />
                    </StackPanel>

                    <Button Width="100"
                            Margin="12,20,0,0"
                            VerticalAlignment="Top"
                            Content="编辑偏好"
                            IsEnabled="{Binding CanEditCustomPreference}"
                            Command="{Binding EditPreferenceCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" />

                    <Button Width="110"
                            Margin="12,20,0,0"
                            VerticalAlignment="Top"
                            Content="{Binding RefreshBatchButtonText}"
                            Command="{Binding RefreshBatchCommand}"
                            Style="{StaticResource PrimaryButtonStyle}" />
                </WrapPanel>
            </Grid>

            <ScrollViewer Grid.Row="1" Margin="0,20,0,0" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Recommendations}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="310" Margin="0,0,18,18" Style="{StaticResource CompactCardStyle}">
                                <StackPanel>
                                    <Border Height="220" CornerRadius="18" Background="{DynamicResource BrushSurfaceAlt}">
                                        <Grid>
                                            <Control IsHitTestVisible="False"
                                                     Template="{StaticResource PosterPlaceholderTemplate}" />
                                            <Image helpers:PosterCacheImageBehavior.Source="{Binding PosterRemoteUrl}" Stretch="UniformToFill" />
                                        </Grid>
                                    </Border>
                                    <TextBlock Margin="0,14,0,0" Text="{Binding Title}" TextWrapping="Wrap" Style="{StaticResource SectionTitleTextStyle}" />
                                    <WrapPanel Margin="0,8,0,0">
                                        <Border Margin="0,0,8,8" Padding="8,4" CornerRadius="999" Background="{DynamicResource BrushAccentSoft}">
                                            <TextBlock Text="{Binding ScopeText}" Style="{StaticResource BodyTextStyle}" />
                                        </Border>
                                        <Border Margin="0,0,8,8" Padding="8,4" CornerRadius="999" Background="{DynamicResource BrushSurfaceAlt}">
                                            <TextBlock Text="{Binding AvailabilityText}" Style="{StaticResource BodyTextStyle}" />
                                        </Border>
                                        <Border Margin="0,0,8,8" Padding="8,4" CornerRadius="999" Background="{DynamicResource BrushSurfaceAlt}">
                                            <TextBlock Text="{Binding WatchStateText}" Style="{StaticResource BodyTextStyle}" />
                                        </Border>
                                    </WrapPanel>
                                    <TextBlock Margin="0,8,0,0" Text="{Binding Reason}" TextWrapping="Wrap" Style="{StaticResource BodyTextStyle}" />
                                    <TextBlock Margin="0,10,0,0" Text="{Binding Tags}" TextWrapping="Wrap" Style="{StaticResource BodyMutedTextStyle}" />
                                    <UniformGrid Margin="0,16,0,0" Columns="3">
                                        <Button Margin="0,0,8,0"
                                                Content="{Binding DetailButtonText}"
                                                Command="{Binding DataContext.OpenMovieCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource PrimaryButtonStyle}" />
                                        <Button Margin="8,0,0,0"
                                                Content="{Binding WantToWatchButtonText}"
                                                Command="{Binding DataContext.AddWantToWatchCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CanToggleWantToWatch}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Margin="8,0,0,0"
                                                Content="{Binding NotInterestedButtonText}"
                                                Command="{Binding DataContext.ToggleNotInterestedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource SecondaryButtonStyle}" />
                                    </UniformGrid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Border Grid.RowSpan="2"
                    Background="#99000000">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPreferenceDialogOpen}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border Width="520"
                        Padding="22"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Style="{StaticResource PageCardStyle}">
                    <StackPanel>
                        <TextBlock Text="自定义推荐偏好" Style="{StaticResource CardTitleTextStyle}" />
                        <TextBlock Margin="0,10,0,0"
                                   Text="这些偏好会影响 AI 推荐，但不会覆盖不想看、已看过滤、推荐范围过滤等规则。保存后将在下次刷新或换一批时生效。"
                                   TextWrapping="Wrap"
                                   Style="{StaticResource BodyMutedTextStyle}" />
                        <TextBox Margin="0,16,0,0"
                                 MinHeight="140"
                                 MaxLength="{Binding CustomPreferenceMaxLength}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding DraftCustomPreferenceText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FormTextBoxStyle}" />
                        <TextBlock Margin="0,8,0,0"
                                   HorizontalAlignment="Right"
                                   Text="{Binding DraftCustomPreferenceCountText}"
                                   Style="{StaticResource BodyMutedTextStyle}" />
                        <UniformGrid Margin="0,18,0,0" Columns="3">
                            <Button Margin="0,0,8,0"
                                    Content="清空"
                                    Command="{Binding ClearPreferenceCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Margin="8,0,8,0"
                                    Content="取消"
                                    Command="{Binding CancelPreferenceCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Margin="8,0,0,0"
                                    Content="确认"
                                    Command="{Binding ConfirmPreferenceCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                        </UniformGrid>
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
    </Border>
</UserControl>
