<UserControl x:Class="MediaLibrary.App.Views.Pages.FavoritesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <DataTemplate x:Key="FavoriteMovieCardTemplate">
            <Border Width="230" Margin="0,0,18,18" Style="{StaticResource CompactCardStyle}">
                <StackPanel>
                    <Border Height="300" CornerRadius="18" Background="{DynamicResource BrushSurfaceAlt}">
                        <Image Source="{Binding PosterRemoteUrl}" Stretch="UniformToFill" />
                    </Border>
                    <TextBlock Margin="0,14,0,0"
                               Text="{Binding Title}"
                               TextWrapping="Wrap"
                               Style="{StaticResource SectionTitleTextStyle}" />
                    <TextBlock Margin="0,4,0,0"
                               Text="{Binding ReleaseYear}"
                               Style="{StaticResource BodyMutedTextStyle}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding GenresText}"
                               TextWrapping="Wrap"
                               Style="{StaticResource BodyTextStyle}" />
                    <WrapPanel Margin="0,10,0,0">
                        <Border Margin="0,0,8,8" Padding="8,4" CornerRadius="999" Background="{DynamicResource BrushAccentSoft}">
                            <TextBlock Text="{Binding CollectionTypeText}" Style="{StaticResource BodyTextStyle}" />
                        </Border>
                        <Border Margin="0,0,8,8" Padding="8,4" CornerRadius="999" Background="{DynamicResource BrushSurfaceAlt}">
                            <TextBlock Text="{Binding AvailabilityText}" Style="{StaticResource BodyTextStyle}" />
                        </Border>
                        <Border Margin="0,0,8,8" Padding="8,4" CornerRadius="999" Background="{DynamicResource BrushSurfaceAlt}">
                            <TextBlock Text="{Binding WatchStateText}" Style="{StaticResource BodyTextStyle}" />
                        </Border>
                    </WrapPanel>
                    <Button Margin="0,14,0,0"
                            Content="{Binding DetailButtonText}"
                            Command="{Binding DataContext.OpenMovieCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            Style="{StaticResource PrimaryButtonStyle}" />
                    <Button Margin="0,10,0,0"
                            Content="{Binding ActionText}"
                            Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            IsEnabled="{Binding CanRemove}"
                            Style="{StaticResource SecondaryButtonStyle}" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Border Style="{StaticResource PageCardStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="90" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="收藏夹" Style="{StaticResource CardTitleTextStyle}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="管理你喜爱和想看的影片。"
                               Style="{StaticResource BodyMutedTextStyle}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding StatusMessage}"
                               Style="{StaticResource BodyMutedTextStyle}" />
                </StackPanel>
                <Button Grid.Column="1"
                        Content="刷新"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" />
            </Grid>

            <TabControl Grid.Row="1"
                        Margin="0,20,0,0"
                        Style="{StaticResource ModernTabControlStyle}"
                        ItemContainerStyle="{StaticResource ModernTabItemStyle}">
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="喜爱" />
                            <TextBlock Margin="8,0,0,0" Text="{Binding FavoriteCountText}" />
                        </StackPanel>
                    </TabItem.Header>
                    <Grid Margin="0,18,0,0">
                        <Border Padding="20">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource CompactCardStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasFavoriteMovies}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="还没有喜爱的影片。"
                                       Style="{StaticResource BodyMutedTextStyle}" />
                        </Border>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ScrollViewer.Style>
                                <Style TargetType="ScrollViewer">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasFavoriteMovies}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ScrollViewer.Style>
                            <ItemsControl ItemsSource="{Binding FavoriteMovies}"
                                          ItemTemplate="{StaticResource FavoriteMovieCardTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </TabItem>

                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="想看" />
                            <TextBlock Margin="8,0,0,0" Text="{Binding WantToWatchCountText}" />
                        </StackPanel>
                    </TabItem.Header>
                    <Grid Margin="0,18,0,0">
                        <Border Padding="20">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource CompactCardStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasWantToWatchMovies}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="还没有想看的影片。"
                                       Style="{StaticResource BodyMutedTextStyle}" />
                        </Border>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ScrollViewer.Style>
                                <Style TargetType="ScrollViewer">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasWantToWatchMovies}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ScrollViewer.Style>
                            <ItemsControl ItemsSource="{Binding WantToWatchMovies}"
                                          ItemTemplate="{StaticResource FavoriteMovieCardTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</UserControl>
