<UserControl x:Class="MediaLibrary.App.Views.Pages.FavoritesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:MediaLibrary.App.Helpers"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <SolidColorBrush x:Key="FavoriteMediaCardBackgroundBrush" Color="#121821" />
        <SolidColorBrush x:Key="FavoriteMediaCardSurfaceBrush" Color="#202938" />
        <SolidColorBrush x:Key="FavoriteMediaCardTextBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="FavoriteMediaCardMutedTextBrush" Color="#D8DEE9" />
        <SolidColorBrush x:Key="FavoriteMediaCardAccentBrush" Color="#E2E8F0" />
        <SolidColorBrush x:Key="FavoriteMediaCardAccentTextBrush" Color="#111827" />
        <SolidColorBrush x:Key="FavoriteTagDividerBrush" Color="#7DD3FC" />

        <Style x:Key="FavoriteModernScrollBarThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border x:Name="ThumbRoot"
                                Margin="3"
                                Background="#66FFFFFF"
                                CornerRadius="4"
                                Opacity="0.75" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbRoot" Property="Opacity" Value="1" />
                                <Setter TargetName="ThumbRoot" Property="Background" Value="#99FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbRoot" Property="Opacity" Value="1" />
                                <Setter TargetName="ThumbRoot" Property="Background" Value="#CCFFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FavoriteModernScrollRepeatButtonStyle" TargetType="{x:Type RepeatButton}">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FavoriteModernScrollBarStyle" TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="10" />
            <Setter Property="MinWidth" Value="10" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Style="{StaticResource FavoriteModernScrollRepeatButtonStyle}" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource FavoriteModernScrollBarThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Style="{StaticResource FavoriteModernScrollRepeatButtonStyle}" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=(helpers:ScrollBarAutoRevealBehavior.IsRevealed)}" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FavoriteManualFavoriteTabButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource PageTopManualTabButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsFavoriteTabSelected, RelativeSource={RelativeSource AncestorType=TabControl}}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FavoriteManualWantTabButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource PageTopManualLastTabButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsWantToWatchTabSelected, RelativeSource={RelativeSource AncestorType=TabControl}}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FavoritesHiddenHeaderTabControlStyle" TargetType="{x:Type TabControl}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabControl}">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Border Style="{StaticResource PageTopTabDividerStyle}" />
                                <StackPanel HorizontalAlignment="Left"
                                            VerticalAlignment="Bottom"
                                            Orientation="Horizontal">
                                    <Button Content="{Binding DataContext.FavoriteTabHeaderText, RelativeSource={RelativeSource TemplatedParent}}"
                                            Command="{Binding DataContext.SelectTabCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                            CommandParameter="0"
                                            Style="{StaticResource FavoriteManualFavoriteTabButtonStyle}" />
                                    <Button Content="{Binding DataContext.WantToWatchTabHeaderText, RelativeSource={RelativeSource TemplatedParent}}"
                                            Command="{Binding DataContext.SelectTabCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                            CommandParameter="1"
                                            Style="{StaticResource FavoriteManualWantTabButtonStyle}" />
                                </StackPanel>
                                <TabPanel x:Name="HeaderPanel"
                                          Height="0"
                                          HorizontalAlignment="Left"
                                          IsHitTestVisible="False"
                                          IsItemsHost="True"
                                          KeyboardNavigation.TabIndex="1"
                                          Opacity="0" />
                            </Grid>

                            <ContentPresenter x:Name="PART_SelectedContentHost"
                                              Grid.Row="1"
                                              Margin="0,22,0,0"
                                              ContentSource="SelectedContent" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FavoritePosterOpenButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="180" />
            <Setter Property="Height" Value="270" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.96" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FavoriteMediaChipStyle" TargetType="{x:Type Border}">
            <Setter Property="Height" Value="20" />
            <Setter Property="Padding" Value="7,0" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="{StaticResource FavoriteMediaCardAccentBrush}" />
            <Setter Property="Opacity" Value="0.92" />
        </Style>

        <Style x:Key="FavoriteMediaChipTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource FavoriteMediaCardAccentTextBrush}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="LineHeight" Value="12" />
            <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="FavoriteRatingBadgeStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource FavoriteMediaChipStyle}">
            <Setter Property="MinWidth" Value="42" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="8,0" />
        </Style>

        <Style x:Key="FavoriteRatingTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource FavoriteMediaCardAccentTextBrush}" />
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="LineHeight" Value="16" />
            <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
        </Style>

        <Style x:Key="FavoriteMediaTitleTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource FavoriteMediaCardTextBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="LineHeight" Value="18" />
            <Setter Property="MaxHeight" Value="36" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="FavoriteMediaMutedTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource FavoriteMediaCardMutedTextBrush}" />
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="FavoriteTagLineContainerStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="450" />
            <Setter Property="ToolTipService.BetweenShowDelay" Value="0" />
            <Setter Property="ToolTipService.ShowDuration" Value="20000" />
        </Style>

        <Style x:Key="FavoriteCardActionButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource GlassSmallButtonStyle}">
            <Setter Property="Width" Value="180" />
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Margin" Value="0,10,0,0" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
        </Style>

        <Style x:Key="FavoriteActionStatusTextStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource CaptionTextStyle}">
            <Setter Property="Width" Value="180" />
            <Setter Property="Margin" Value="0,6,0,0" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Foreground" Value="{DynamicResource BrushForegroundMuted}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasActionError}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource BrushDanger}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="FavoriteMediaCardTemplate">
            <StackPanel Width="180"
                        Margin="0,0,22,28">
                <Button Command="{Binding DataContext.OpenMovieCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding}"
                        Style="{StaticResource FavoritePosterOpenButtonStyle}">
                    <Grid Width="180"
                          Height="270"
                          ClipToBounds="False">
                        <Grid.Resources>
                            <RectangleGeometry x:Key="FavoritePosterClipGeometry"
                                               Rect="0,0,180,270"
                                               RadiusX="12"
                                               RadiusY="12" />
                        </Grid.Resources>

                        <Border Margin="0,8,0,0"
                                Background="#26000000"
                                CornerRadius="12"
                                Opacity="0.45" />

                        <Grid Clip="{StaticResource FavoritePosterClipGeometry}">
                            <Border Background="{StaticResource FavoriteMediaCardSurfaceBrush}" />
                            <Control IsHitTestVisible="False"
                                     Template="{StaticResource PosterPlaceholderTemplate}" />
                            <Image helpers:PosterCacheImageBehavior.DecodePixelWidth="320"
                                   helpers:PosterCacheImageBehavior.Source="{Binding PosterRemoteUrl}"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   SnapsToDevicePixels="True"
                                   Stretch="UniformToFill">
                                <Image.Style>
                                    <Style TargetType="{x:Type Image}">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasPoster}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>

                            <Grid>
                                <Grid.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#00000000" Offset="0" />
                                        <GradientStop Color="#0A111827" Offset="0.42" />
                                        <GradientStop Color="#78111824" Offset="0.78" />
                                        <GradientStop Color="#B8111824" Offset="1" />
                                    </LinearGradientBrush>
                                </Grid.Background>
                            </Grid>
                            <Border Height="86"
                                    VerticalAlignment="Top"
                                    IsHitTestVisible="False">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#38FFFFFF" Offset="0" />
                                        <GradientStop Color="#20FFFFFF" Offset="0.22" />
                                        <GradientStop Color="#08FFFFFF" Offset="0.62" />
                                        <GradientStop Color="#00FFFFFF" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>

                            <Border HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Margin="8"
                                    MaxWidth="82"
                                    Style="{StaticResource FavoriteMediaChipStyle}">
                                <TextBlock Text="{Binding CategoryTagText}"
                                           Style="{StaticResource FavoriteMediaChipTextStyle}" />
                            </Border>
                            <Border HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="8"
                                    Style="{StaticResource FavoriteRatingBadgeStyle}">
                                <TextBlock Text="{Binding RatingBadgeText}"
                                           Style="{StaticResource FavoriteRatingTextStyle}" />
                            </Border>
                            <Border HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Margin="8,38,8,0"
                                    MaxWidth="110"
                                    Style="{StaticResource FavoriteMediaChipStyle}">
                                <TextBlock Text="{Binding CollectionTypeText}"
                                           Style="{StaticResource FavoriteMediaChipTextStyle}" />
                            </Border>

                            <StackPanel VerticalAlignment="Bottom"
                                        Margin="10">
                                <TextBlock Text="{Binding Title}"
                                           Style="{StaticResource FavoriteMediaTitleTextStyle}"
                                           helpers:TrimmedTextToolTipBehavior.FullText="{Binding Title}" />
                                <TextBlock Margin="0,3,0,0"
                                           Text="{Binding ReleaseDateText}"
                                           Style="{StaticResource FavoriteMediaMutedTextStyle}"
                                           helpers:TrimmedTextToolTipBehavior.FullText="{Binding ReleaseDateText}" />
                                <Border Margin="0,5,0,0"
                                        Style="{StaticResource FavoriteTagLineContainerStyle}"
                                        helpers:TrimmedTextToolTipBehavior.FullText="{Binding PosterTagToolTipText}"
                                        helpers:TrimmedTextToolTipBehavior.VisibleText="{Binding PosterTagLine}">
                                    <TextBlock Text="{Binding PosterTagLine}"
                                               Style="{StaticResource FavoriteMediaMutedTextStyle}" />
                                </Border>
                            </StackPanel>

                            <Border BorderBrush="#14FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    IsHitTestVisible="False" />
                            <Border Margin="1"
                                    BorderBrush="#0A000000"
                                    BorderThickness="1"
                                    CornerRadius="11"
                                    IsHitTestVisible="False" />
                        </Grid>
                    </Grid>
                </Button>

                <Button Content="{Binding ActionButtonText}"
                        Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding}"
                        IsEnabled="{Binding CanStartRemove}"
                        Style="{StaticResource FavoriteCardActionButtonStyle}"
                        ToolTip="{Binding ActionStatusText}" />
                <TextBlock Text="{Binding ActionStatusText}"
                           Style="{StaticResource FavoriteActionStatusTextStyle}"
                           Visibility="{Binding HasActionStatus, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="FavoriteLoadingStateTemplate">
            <Border MinHeight="320"
                    Style="{StaticResource LoadingStateStyle}">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Control Width="34"
                             Height="34"
                             Template="{StaticResource LoadingSpinnerTemplate}" />
                    <TextBlock Margin="0,14,0,0"
                               Text="正在加载收藏夹"
                               Style="{StaticResource InlineLoadingStyle}" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="FavoriteErrorStateTemplate">
            <Border MinHeight="320"
                    Style="{StaticResource EmptyStateContainerStyle}">
                <StackPanel MaxWidth="420"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="收藏夹加载失败"
                               TextAlignment="Center"
                               Style="{StaticResource EmptyStateTitleStyle}" />
                    <TextBlock Margin="0,10,0,0"
                               Text="{Binding LoadErrorMessage}"
                               TextAlignment="Center"
                               Style="{StaticResource EmptyStateDescriptionStyle}" />
                    <Button Margin="0,18,0,0"
                            HorizontalAlignment="Center"
                            Content="重试"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource GlassSecondaryButtonStyle}" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="FavoriteEmptyStateTemplate">
            <Border MinHeight="320"
                    Style="{StaticResource EmptyStateContainerStyle}">
                <StackPanel MaxWidth="420"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="暂无喜爱影片"
                               TextAlignment="Center"
                               Style="{StaticResource EmptyStateTitleStyle}" />
                    <TextBlock Margin="0,10,0,0"
                               Text="在影片详情页标记喜爱后，这里会展示你的心头好。"
                               TextAlignment="Center"
                               Style="{StaticResource EmptyStateDescriptionStyle}" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="WantToWatchEmptyStateTemplate">
            <Border MinHeight="320"
                    Style="{StaticResource EmptyStateContainerStyle}">
                <StackPanel MaxWidth="420"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="暂无想看影片"
                               TextAlignment="Center"
                               Style="{StaticResource EmptyStateTitleStyle}" />
                    <TextBlock Margin="0,10,0,0"
                               Text="在影片详情页标记想看后，这里会展示你准备观看的影片。"
                               TextAlignment="Center"
                               Style="{StaticResource EmptyStateDescriptionStyle}" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <TabControl SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}"
                    ItemContainerStyle="{StaticResource PageTopTabItemStyle}"
                    Style="{StaticResource FavoritesHiddenHeaderTabControlStyle}">
            <TabItem Header="喜爱">
                <Grid>
                    <ContentControl Content="{Binding}"
                                    ContentTemplate="{StaticResource FavoriteLoadingStateTemplate}"
                                    Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <ContentControl Content="{Binding}"
                                    ContentTemplate="{StaticResource FavoriteErrorStateTemplate}"
                                    Visibility="{Binding HasLoadError, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <ContentControl Content="{Binding}"
                                    ContentTemplate="{StaticResource FavoriteEmptyStateTemplate}"
                                    Visibility="{Binding ShowFavoriteEmptyState, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <ScrollViewer Padding="0,0,8,0"
                                  helpers:ScrollBarAutoRevealBehavior.IsEnabled="True"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding ShowFavoriteMovies, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ScrollViewer.Resources>
                            <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource FavoriteModernScrollBarStyle}" />
                        </ScrollViewer.Resources>
                        <ItemsControl ItemsSource="{Binding FavoriteMovies}"
                                      ItemTemplate="{StaticResource FavoriteMediaCardTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <TabItem Header="想看">
                <Grid>
                    <ContentControl Content="{Binding}"
                                    ContentTemplate="{StaticResource FavoriteLoadingStateTemplate}"
                                    Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <ContentControl Content="{Binding}"
                                    ContentTemplate="{StaticResource FavoriteErrorStateTemplate}"
                                    Visibility="{Binding HasLoadError, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <ContentControl Content="{Binding}"
                                    ContentTemplate="{StaticResource WantToWatchEmptyStateTemplate}"
                                    Visibility="{Binding ShowWantToWatchEmptyState, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <ScrollViewer Padding="0,0,8,0"
                                  helpers:ScrollBarAutoRevealBehavior.IsEnabled="True"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding ShowWantToWatchMovies, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ScrollViewer.Resources>
                            <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource FavoriteModernScrollBarStyle}" />
                        </ScrollViewer.Resources>
                        <ItemsControl ItemsSource="{Binding WantToWatchMovies}"
                                      ItemTemplate="{StaticResource FavoriteMediaCardTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
