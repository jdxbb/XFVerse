<UserControl x:Class="MediaLibrary.App.Views.Pages.FavoritesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource PageCardStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="90" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="收藏夹" Style="{StaticResource CardTitleTextStyle}" />
                    <TextBlock Margin="0,8,0,0" Text="{Binding StatusMessage}" Style="{StaticResource BodyMutedTextStyle}" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="暂无收藏影片" Style="{StaticResource BodyMutedTextStyle}" />
                    <ComboBox ItemsSource="{Binding CategoryOptions}"
                              SelectedItem="{Binding SelectedCategory}"
                              Style="{StaticResource FormComboBoxStyle}" />
                </StackPanel>
                <Button Grid.Column="3"
                        Content="刷新"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" />
            </Grid>

            <ScrollViewer Grid.Row="1" Margin="0,20,0,0" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Movies}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="230" Margin="0,0,18,18" Style="{StaticResource CompactCardStyle}">
                                <StackPanel>
                                    <Border Height="300" CornerRadius="18" Background="{DynamicResource BrushSurfaceAlt}">
                                        <Image Source="{Binding PosterRemoteUrl}" Stretch="UniformToFill" />
                                    </Border>
                                    <TextBlock Margin="0,14,0,0" Text="{Binding Title}" TextWrapping="Wrap" Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Margin="0,4,0,0" Text="{Binding ReleaseYear}" Style="{StaticResource BodyMutedTextStyle}" />
                                    <TextBlock Margin="0,8,0,0" Text="{Binding GenresText}" TextWrapping="Wrap" Style="{StaticResource BodyTextStyle}" />
                                    <WrapPanel Margin="0,10,0,0">
                                        <Border Margin="0,0,8,8" Padding="8,4" CornerRadius="999" Background="{DynamicResource BrushAccentSoft}">
                                            <TextBlock Text="{Binding CollectionTypeText}" Style="{StaticResource BodyTextStyle}" />
                                        </Border>
                                        <Border Margin="0,0,8,8" Padding="8,4" CornerRadius="999" Background="{DynamicResource BrushSurfaceAlt}">
                                            <TextBlock Text="{Binding AvailabilityText}" Style="{StaticResource BodyTextStyle}" />
                                        </Border>
                                        <Border Margin="0,0,8,8" Padding="8,4" CornerRadius="999" Background="{DynamicResource BrushSurfaceAlt}">
                                            <TextBlock Text="{Binding WatchStateText}" Style="{StaticResource BodyTextStyle}" />
                                        </Border>
                                    </WrapPanel>
                                    <Button Margin="0,14,0,0"
                                            Content="{Binding DetailButtonText}"
                                            Command="{Binding DataContext.OpenMovieCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource PrimaryButtonStyle}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
