<UserControl x:Class="MediaLibrary.App.Views.Pages.FavoritesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MediaLibrary.App.Controls"
             xmlns:helpers="clr-namespace:MediaLibrary.App.Helpers"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <SolidColorBrush x:Key="FavoriteMediaCardBackgroundBrush" Color="{DynamicResource ColorCard}" />
        <SolidColorBrush x:Key="FavoriteMediaCardSurfaceBrush" Color="{DynamicResource ColorSurfaceAlt}" />
        <SolidColorBrush x:Key="FavoriteMediaCardTextBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="FavoriteMediaCardMutedTextBrush" Color="#D8DEE9" />
        <SolidColorBrush x:Key="FavoriteMediaCardAccentBrush" Color="#E2E8F0" />
        <SolidColorBrush x:Key="FavoriteMediaCardAccentTextBrush" Color="#111827" />
        <SolidColorBrush x:Key="FavoriteTagDividerBrush" Color="#7DD3FC" />
        <SolidColorBrush x:Key="FavoriteRatingGoldBrush" Color="{DynamicResource ColorWarning}" />
        <SolidColorBrush x:Key="FavoriteIconOutlineBrush" Color="#F8FAFC" />

        <Style x:Key="FavoriteModernScrollBarThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border x:Name="ThumbRoot"
                                Margin="3"
                                Background="#66FFFFFF"
                                CornerRadius="4"
                                Opacity="0.75" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbRoot" Property="Opacity" Value="1" />
                                <Setter TargetName="ThumbRoot" Property="Background" Value="#99FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbRoot" Property="Opacity" Value="1" />
                                <Setter TargetName="ThumbRoot" Property="Background" Value="#CCFFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FavoriteModernScrollRepeatButtonStyle" TargetType="{x:Type RepeatButton}">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FavoriteModernScrollBarStyle" TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="10" />
            <Setter Property="MinWidth" Value="10" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Style="{StaticResource FavoriteModernScrollRepeatButtonStyle}" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource FavoriteModernScrollBarThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Style="{StaticResource FavoriteModernScrollRepeatButtonStyle}" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=(helpers:ScrollBarAutoRevealBehavior.IsRevealed)}" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FavoritePosterResultListBoxStyle" TargetType="{x:Type ListBox}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Arrow" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
            <Setter Property="helpers:ScrollBarAutoRevealBehavior.IsEnabled" Value="True" />
        </Style>

        <Style x:Key="FavoritePosterResultListBoxItemStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ClipToBounds" Value="False" />
            <Setter Property="Cursor" Value="Arrow" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Top" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          ClipToBounds="False"
                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FavoriteManualFavoriteTabButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource PageTopManualTabButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsFavoriteTabSelected, RelativeSource={RelativeSource AncestorType=TabControl}}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FavoriteManualWantTabButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource PageTopManualLastTabButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsWantToWatchTabSelected, RelativeSource={RelativeSource AncestorType=TabControl}}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FavoritesHiddenHeaderTabControlStyle" TargetType="{x:Type TabControl}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0,16,0,0" />
            <Setter Property="Margin" Value="0,-8,0,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabControl}">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0"
                                  ClipToBounds="False"
                                  SnapsToDevicePixels="True">
                                <Border Height="2"
                                        VerticalAlignment="Bottom"
                                        Background="{DynamicResource BrushDivider}" />
                                <StackPanel Panel.ZIndex="2"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Bottom"
                                            ClipToBounds="False"
                                            Orientation="Horizontal">
                                    <Button Content="{Binding DataContext.FavoriteTabHeaderText, RelativeSource={RelativeSource TemplatedParent}}"
                                            Command="{Binding DataContext.SelectTabCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                            CommandParameter="0"
                                            Style="{StaticResource FavoriteManualFavoriteTabButtonStyle}" />
                                    <Button Content="{Binding DataContext.WantToWatchTabHeaderText, RelativeSource={RelativeSource TemplatedParent}}"
                                            Command="{Binding DataContext.SelectTabCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                            CommandParameter="1"
                                            Style="{StaticResource FavoriteManualWantTabButtonStyle}" />
                                </StackPanel>
                                <TabPanel x:Name="HeaderPanel"
                                          Panel.ZIndex="0"
                                          Height="0"
                                          HorizontalAlignment="Left"
                                          IsHitTestVisible="False"
                                          IsItemsHost="True"
                                          KeyboardNavigation.TabIndex="1"
                                          Opacity="0" />
                            </Grid>

                            <ContentPresenter x:Name="PART_SelectedContentHost"
                                              Grid.Row="1"
                                              Margin="{TemplateBinding Padding}"
                                              ContentSource="SelectedContent" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FavoritePosterOpenButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="180" />
            <Setter Property="Height" Value="270" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.96" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FavoriteMediaChipStyle" TargetType="{x:Type Border}">
            <Setter Property="Height" Value="20" />
            <Setter Property="Padding" Value="7,0" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="{StaticResource FavoriteMediaCardAccentBrush}" />
            <Setter Property="Opacity" Value="0.92" />
        </Style>

        <Style x:Key="FavoriteMediaChipTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource FavoriteMediaCardAccentTextBrush}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="LineHeight" Value="12" />
            <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="FavoriteRatingBadgeStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource FavoriteMediaChipStyle}">
            <Setter Property="MinWidth" Value="42" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="HorizontalAlignment" Value="Right" />
        </Style>

        <Style x:Key="FavoriteRatingTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource FavoriteMediaCardAccentTextBrush}" />
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="LineHeight" Value="16" />
            <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsHighRating}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource FavoriteRatingGoldBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FavoriteMediaTitleTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource FavoriteMediaCardTextBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="FavoriteMediaMutedTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource FavoriteMediaCardMutedTextBrush}" />
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="FavoriteTagLineContainerStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="450" />
            <Setter Property="ToolTipService.BetweenShowDelay" Value="0" />
            <Setter Property="ToolTipService.ShowDuration" Value="20000" />
        </Style>

        <Style x:Key="FavoriteCardActionButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource GlassSmallButtonStyle}">
            <Setter Property="Width" Value="180" />
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Margin" Value="0,10,0,0" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
        </Style>

        <Style x:Key="FavoriteActionStatusTextStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource CaptionTextStyle}">
            <Setter Property="Width" Value="180" />
            <Setter Property="Margin" Value="0,6,0,0" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Foreground" Value="{DynamicResource BrushForegroundMuted}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasActionError}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource BrushDanger}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FavoritePosterStateIconButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="30" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Opacity" Value="0.96" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="Transparent">
                            <Grid>
                                <TextBlock x:Name="StateIconStroke"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="20"
                                           Foreground="{StaticResource FavoriteIconOutlineBrush}"
                                           IsHitTestVisible="False"
                                           Opacity="0"
                                           Text="{Binding Text, ElementName=StateIcon}">
                                    <TextBlock.Effect>
                                        <DropShadowEffect BlurRadius="3"
                                                          Color="#FFFFFFFF"
                                                          Direction="0"
                                                          Opacity="1"
                                                          ShadowDepth="0" />
                                    </TextBlock.Effect>
                                </TextBlock>
                                <TextBlock x:Name="StateIcon"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="20"
                                           Foreground="{StaticResource FavoriteIconOutlineBrush}"
                                           Text="&#xEB51;" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsFavoriteTab}" Value="True">
                                <Setter TargetName="StateIcon" Property="Text" Value="&#xEB52;" />
                                <Setter TargetName="StateIcon" Property="Foreground" Value="{DynamicResource BrushRatingStarFill}" />
                                <Setter TargetName="StateIconStroke" Property="Text" Value="&#xEB52;" />
                                <Setter TargetName="StateIconStroke" Property="Opacity" Value="1" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsWantToWatchTab}" Value="True">
                                <Setter TargetName="StateIcon" Property="Text" Value="&#xE735;" />
                                <Setter TargetName="StateIcon" Property="Foreground" Value="{DynamicResource BrushRatingStarFill}" />
                                <Setter TargetName="StateIconStroke" Property="Text" Value="&#xE735;" />
                                <Setter TargetName="StateIconStroke" Property="Opacity" Value="1" />
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.72" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.46" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="FavoriteMediaCardTemplate">
            <Grid Width="180"
                  Height="270"
                  ClipToBounds="False"
                  Cursor="Arrow"
                  Margin="0,3,14,15"
                  RenderTransformOrigin="0.5,0.5"
                  SnapsToDevicePixels="True"
                  UseLayoutRounding="True">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="RenderTransform">
                            <Setter.Value>
                                <TranslateTransform />
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="-2" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Border x:Name="FavoriteMoviePosterCardClipMask"
                        Background="White"
                        CornerRadius="12"
                        IsHitTestVisible="False" />
                <Canvas ClipToBounds="False"
                        IsHitTestVisible="False">
                    <Image x:Name="FavoriteMoviePosterPaletteShadowHost"
                           Width="348"
                           Height="438"
                           Canvas.Left="-84"
                           Canvas.Top="-84"
                           helpers:PosterCachedShadowBehavior.BlurRadius="28"
                           helpers:PosterCachedShadowBehavior.CardHeight="270"
                           helpers:PosterCachedShadowBehavior.CardWidth="180"
                           helpers:PosterCachedShadowBehavior.CornerRadius="12"
                           helpers:PosterCachedShadowBehavior.Direction="270"
                           helpers:PosterCachedShadowBehavior.InnerMargin="0,3,0,0"
                           helpers:PosterCachedShadowBehavior.IsEnabled="True"
                           helpers:PosterCachedShadowBehavior.Opacity="0.56"
                           helpers:PosterCachedShadowBehavior.Padding="84"
                           helpers:PosterCachedShadowBehavior.QuantizeColor="True"
                           helpers:PosterCachedShadowBehavior.ShadowColor="#192230"
                           helpers:PosterCachedShadowBehavior.ShadowDepth="7"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           SnapsToDevicePixels="True"
                           Stretch="Fill" />
                    <Image Width="348"
                           Height="438"
                           Canvas.Left="-84"
                           Canvas.Top="-84"
                           helpers:PosterCachedShadowBehavior.BlurRadius="14"
                           helpers:PosterCachedShadowBehavior.CardHeight="270"
                           helpers:PosterCachedShadowBehavior.CardWidth="180"
                           helpers:PosterCachedShadowBehavior.CornerRadius="12"
                           helpers:PosterCachedShadowBehavior.Direction="270"
                           helpers:PosterCachedShadowBehavior.IsEnabled="True"
                           helpers:PosterCachedShadowBehavior.Opacity="0.37"
                           helpers:PosterCachedShadowBehavior.Padding="84"
                           helpers:PosterCachedShadowBehavior.ShadowColor="#000000"
                           helpers:PosterCachedShadowBehavior.ShadowDepth="3"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           SnapsToDevicePixels="True"
                           Stretch="Fill" />
                </Canvas>
                <Grid>
                    <Grid.OpacityMask>
                        <VisualBrush Visual="{Binding ElementName=FavoriteMoviePosterCardClipMask}" />
                    </Grid.OpacityMask>
                    <Border Background="{StaticResource FavoriteMediaCardSurfaceBrush}" />
                    <Control IsHitTestVisible="False"
                             Template="{StaticResource PosterPlaceholderTemplate}" />
                    <Image helpers:PosterCacheImageBehavior.DecodePixelWidth="320"
                           helpers:PosterCacheImageBehavior.Source="{Binding PosterRemoteUrl}"
                           helpers:PosterPaletteShadowBehavior.TargetElement="{Binding ElementName=FavoriteMoviePosterPaletteShadowHost}"
                           helpers:PosterPaletteShadowBehavior.TargetName="FavoriteMoviePosterPaletteShadowHost"
                           SnapsToDevicePixels="True"
                           Stretch="UniformToFill">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="RenderOptions.BitmapScalingMode" Value="HighQuality" />
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasPoster}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                    <Grid IsHitTestVisible="False">
                        <Grid.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#00000000" Offset="0" />
                                <GradientStop Color="#0A111827" Offset="0.42" />
                                <GradientStop Color="#78111824" Offset="0.78" />
                                <GradientStop Color="#B8111824" Offset="1" />
                            </LinearGradientBrush>
                        </Grid.Background>
                    </Grid>
                    <Border Height="86"
                            VerticalAlignment="Top"
                            IsHitTestVisible="False">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#38FFFFFF" Offset="0" />
                                <GradientStop Color="#20FFFFFF" Offset="0.22" />
                                <GradientStop Color="#08FFFFFF" Offset="0.62" />
                                <GradientStop Color="#00FFFFFF" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <Border Height="180"
                            VerticalAlignment="Top"
                            Background="Transparent"
                            Cursor="Hand">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding DataContext.OpenMovieCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          CommandParameter="{Binding}" />
                        </Border.InputBindings>
                    </Border>
                    <Border HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Margin="8"
                            MaxWidth="88"
                            Style="{StaticResource FavoriteMediaChipStyle}">
                        <TextBlock Text="{Binding CategoryTagText}"
                                   Style="{StaticResource FavoriteMediaChipTextStyle}" />
                    </Border>
                    <Button HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,3,8,0"
                            Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            IsEnabled="{Binding CanStartRemove}"
                            Style="{StaticResource FavoritePosterStateIconButtonStyle}" />
                    <Grid HorizontalAlignment="Stretch"
                          VerticalAlignment="Bottom"
                          Background="Transparent"
                          Cursor="Arrow"
                          Margin="8,0,8,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Column="0"
                                   HorizontalAlignment="Left"
                                   MaxWidth="102"
                                   Text="{Binding Title}"
                                   helpers:TrimmedTextToolTipBehavior.FullText="{Binding Title}"
                                   Style="{StaticResource FavoriteMediaTitleTextStyle}" />
                        <TextBlock Grid.Row="1"
                                   Grid.Column="0"
                                   HorizontalAlignment="Left"
                                   Margin="0,3,0,0"
                                   MaxWidth="102"
                                   Text="{Binding ReleaseDateText}"
                                   Style="{StaticResource FavoriteMediaMutedTextStyle}" />
                        <Border Grid.RowSpan="2"
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                Style="{StaticResource FavoriteRatingBadgeStyle}">
                            <TextBlock Text="{Binding RatingBadgeText}"
                                       Style="{StaticResource FavoriteRatingTextStyle}" />
                        </Border>
                        <Border Grid.Row="2"
          Grid.ColumnSpan="3"
          Margin="0,5,0,0"
          helpers:TrimmedTextToolTipBehavior.FullText="{Binding PosterTagToolTipText}"
          helpers:TrimmedTextToolTipBehavior.OnlyWhenVisibleTextTruncated="True"
          helpers:TrimmedTextToolTipBehavior.VisibleText="{Binding PosterTagLine}"
          Style="{StaticResource FavoriteTagLineContainerStyle}">
                            <TextBlock Style="{StaticResource FavoriteMediaMutedTextStyle}">
                                <Run Text="{Binding PosterTagGroupOneText, Mode=OneWay}" />
                                <Run Text="{Binding PosterTagSeparatorAfterOneText, Mode=OneWay}"
                                     Foreground="{StaticResource FavoriteTagDividerBrush}" />
                                <Run Text="{Binding PosterTagGroupTwoText, Mode=OneWay}" />
                                <Run Text="{Binding PosterTagSeparatorAfterTwoText, Mode=OneWay}"
                                     Foreground="{StaticResource FavoriteTagDividerBrush}" />
                                <Run Text="{Binding PosterTagGroupThreeText, Mode=OneWay}" />
                            </TextBlock>
                        </Border>
                    </Grid>
                </Grid>
                <Border BorderBrush="#14FFFFFF"
                        BorderThickness="1"
                        CornerRadius="12"
                        IsHitTestVisible="False" />
                <Border Margin="1"
                        BorderBrush="#0A000000"
                        BorderThickness="1"
                        CornerRadius="11"
                        IsHitTestVisible="False" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="FavoriteLoadingStateTemplate">
            <Border MinHeight="320"
                    Style="{StaticResource LoadingStateStyle}">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Control Width="34"
                             Height="34"
                             Template="{StaticResource LoadingSpinnerTemplate}" />
                    <TextBlock Margin="0,14,0,0"
                               Text="正在加载收藏夹"
                               Style="{StaticResource InlineLoadingStyle}" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="FavoriteErrorStateTemplate">
            <Border MinHeight="320"
                    Style="{StaticResource EmptyStateContainerStyle}">
                <StackPanel MaxWidth="420"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="收藏夹加载失败"
                               TextAlignment="Center"
                               Style="{StaticResource EmptyStateTitleStyle}" />
                    <TextBlock Margin="0,10,0,0"
                               Text="{Binding LoadErrorMessage}"
                               TextAlignment="Center"
                               Style="{StaticResource EmptyStateDescriptionStyle}" />
                    <Button Margin="0,18,0,0"
                            HorizontalAlignment="Center"
                            Content="重试"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource GlassSecondaryButtonStyle}" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="FavoriteEmptyStateTemplate">
            <Border MinHeight="320"
                    Style="{StaticResource EmptyStateContainerStyle}">
                <StackPanel MaxWidth="420"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="暂无喜爱影片"
                               TextAlignment="Center"
                               Style="{StaticResource EmptyStateTitleStyle}" />
                    <TextBlock Margin="0,10,0,0"
                               Text="在影片详情页标记喜爱后，这里会展示你的心头好。"
                               TextAlignment="Center"
                               Style="{StaticResource EmptyStateDescriptionStyle}" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="WantToWatchEmptyStateTemplate">
            <Border MinHeight="320"
                    Style="{StaticResource EmptyStateContainerStyle}">
                <StackPanel MaxWidth="420"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="暂无想看影片"
                               TextAlignment="Center"
                               Style="{StaticResource EmptyStateTitleStyle}" />
                    <TextBlock Margin="0,10,0,0"
                               Text="在影片详情页标记想看后，这里会展示你准备观看的影片。"
                               TextAlignment="Center"
                               Style="{StaticResource EmptyStateDescriptionStyle}" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="0,0,0,-32" Cursor="Arrow">
        <TabControl SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}"
                    ItemContainerStyle="{StaticResource PageTopTabItemStyle}"
                    Style="{StaticResource FavoritesHiddenHeaderTabControlStyle}">
            <TabItem Header="喜爱">
                <Grid Background="Transparent" Cursor="Arrow">
                    <ContentControl Content="{Binding}"
                                    ContentTemplate="{StaticResource FavoriteLoadingStateTemplate}"
                                    Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <ContentControl Content="{Binding}"
                                    ContentTemplate="{StaticResource FavoriteErrorStateTemplate}"
                                    Visibility="{Binding HasLoadError, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <ContentControl Content="{Binding}"
                                    ContentTemplate="{StaticResource FavoriteEmptyStateTemplate}"
                                    Visibility="{Binding ShowFavoriteEmptyState, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <ListBox x:Name="FavoritePosterListBox"
                             ItemsSource="{Binding FavoriteMovies}"
                             ItemTemplate="{StaticResource FavoriteMediaCardTemplate}"
                             Loaded="FavoritesListBox_Loaded"
                             ScrollViewer.ScrollChanged="FavoritesListBox_ScrollChanged"
                             Style="{StaticResource FavoritePosterResultListBoxStyle}"
                             ItemContainerStyle="{StaticResource FavoritePosterResultListBoxItemStyle}"
                             Visibility="{Binding ShowFavoriteMovies, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ListBox.Resources>
                            <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource FavoriteModernScrollBarStyle}" />
                        </ListBox.Resources>
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <controls:VirtualizingWrapPanel>
                                    <controls:VirtualizingWrapPanel.Style>
                                        <Style TargetType="{x:Type controls:VirtualizingWrapPanel}">
                                            <Setter Property="ItemWidth" Value="194" />
                                            <Setter Property="ItemContentWidth" Value="180" />
                                            <Setter Property="ItemHeight" Value="288" />
                                            <Setter Property="OverscanRows" Value="1" />
                                            <Setter Property="ViewportPadding" Value="0,10,0,30" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                    <Setter Property="ItemWidth" Value="201" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </controls:VirtualizingWrapPanel.Style>
                                </controls:VirtualizingWrapPanel>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                    </ListBox>
                </Grid>
            </TabItem>

            <TabItem Header="想看">
                <Grid Background="Transparent" Cursor="Arrow">
                    <ContentControl Content="{Binding}"
                                    ContentTemplate="{StaticResource FavoriteLoadingStateTemplate}"
                                    Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <ContentControl Content="{Binding}"
                                    ContentTemplate="{StaticResource FavoriteErrorStateTemplate}"
                                    Visibility="{Binding HasLoadError, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <ContentControl Content="{Binding}"
                                    ContentTemplate="{StaticResource WantToWatchEmptyStateTemplate}"
                                    Visibility="{Binding ShowWantToWatchEmptyState, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <ListBox x:Name="WantToWatchPosterListBox"
                             ItemsSource="{Binding WantToWatchMovies}"
                             ItemTemplate="{StaticResource FavoriteMediaCardTemplate}"
                             Loaded="FavoritesListBox_Loaded"
                             ScrollViewer.ScrollChanged="FavoritesListBox_ScrollChanged"
                             Style="{StaticResource FavoritePosterResultListBoxStyle}"
                             ItemContainerStyle="{StaticResource FavoritePosterResultListBoxItemStyle}"
                             Visibility="{Binding ShowWantToWatchMovies, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ListBox.Resources>
                            <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource FavoriteModernScrollBarStyle}" />
                        </ListBox.Resources>
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <controls:VirtualizingWrapPanel>
                                    <controls:VirtualizingWrapPanel.Style>
                                        <Style TargetType="{x:Type controls:VirtualizingWrapPanel}">
                                            <Setter Property="ItemWidth" Value="194" />
                                            <Setter Property="ItemContentWidth" Value="180" />
                                            <Setter Property="ItemHeight" Value="288" />
                                            <Setter Property="OverscanRows" Value="1" />
                                            <Setter Property="ViewportPadding" Value="0,10,0,30" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                    <Setter Property="ItemWidth" Value="201" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </controls:VirtualizingWrapPanel.Style>
                                </controls:VirtualizingWrapPanel>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                    </ListBox>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
