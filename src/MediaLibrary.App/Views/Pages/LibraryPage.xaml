                            Style="{StaticResource LibraryFilterButtonStyle}">
                        <Button.ContextMenu>
                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                         Style="{StaticResource LibraryFilterContextMenuStyle}">
                                <MenuItem Header="全部" IsCheckable="True" IsChecked="{Binding IsContentTypeAllSelected, Mode=OneWay}" Command="{Binding SelectContentTypeCommand}" CommandParameter="全部" Style="{StaticResource LibraryFilterMenuItemStyle}" />
