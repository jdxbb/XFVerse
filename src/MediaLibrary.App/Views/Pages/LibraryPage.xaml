<UserControl x:Class="MediaLibrary.App.Views.Pages.LibraryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="SelectionDotButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding SelectionDotVisible}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                </DataTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="BatchSelectableCardStyle" TargetType="Border" BasedOn="{StaticResource CompactCardStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsBatchSelectionMode}" Value="True">
                    <Setter Property="Cursor" Value="Hand" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="BatchSelectableListItemContentStyle" TargetType="Grid">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsBatchSelectionMode}" Value="True">
                    <Setter Property="Cursor" Value="Hand" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource PageCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.1*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="1.2*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="140" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="关键词搜索" Style="{StaticResource BodyMutedTextStyle}" />
                        <TextBox Style="{StaticResource FormTextBoxStyle}"
                                 ToolTip="按片名或原名搜索"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="类型筛选" Style="{StaticResource BodyMutedTextStyle}" />
                        <TextBox Style="{StaticResource FormTextBoxStyle}"
                                 ToolTip="例如：剧情、动作、科幻"
                                 Text="{Binding GenreFilterText, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="年份" Style="{StaticResource BodyMutedTextStyle}" />
                        <TextBox Style="{StaticResource FormTextBoxStyle}"
                                 ToolTip="例如：2011"
                                 Text="{Binding YearFilterText, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Grid.Column="6">
                        <TextBlock Text="识别状态" Style="{StaticResource BodyMutedTextStyle}" />
                        <ComboBox SelectedItem="{Binding SelectedStatusFilter}"
                                  ItemsSource="{Binding StatusOptions}"
                                  Style="{StaticResource FormComboBoxStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Column="8">
                        <TextBlock Text="排序字段" Style="{StaticResource BodyMutedTextStyle}" />
                        <ComboBox SelectedItem="{Binding SelectedSortOption}"
                                  ItemsSource="{Binding SortOptions}"
                                  Style="{StaticResource FormComboBoxStyle}" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="排序方向" Style="{StaticResource BodyMutedTextStyle}" />
                        <ComboBox SelectedItem="{Binding SelectedSortDirection}"
                                  ItemsSource="{Binding SortDirectionOptions}"
                                  Style="{StaticResource FormComboBoxStyle}" />
                    </StackPanel>

                    <Button Grid.Column="2"
                            VerticalAlignment="Bottom"
                            Content="应用搜索"
                            Command="{Binding ApplySearchCommand}"
                            Style="{StaticResource PrimaryButtonStyle}" />
                    <Button Grid.Column="3"
                            Margin="12,0,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Bottom"
                            Content="清空筛选"
                            Command="{Binding ClearFiltersCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" />

                    <StackPanel Grid.Column="3"
                                Margin="150,0,0,0"
                                Orientation="Horizontal"
                                VerticalAlignment="Bottom">
                        <StackPanel>
                            <TextBlock Text="范围筛选" Style="{StaticResource BodyMutedTextStyle}" />
                            <ComboBox Width="230"
                                      SelectedItem="{Binding SelectedLibraryScope}"
                                      ItemsSource="{Binding LibraryScopeOptions}"
                                      Style="{StaticResource FormComboBoxStyle}" />
                        </StackPanel>
                        <StackPanel Margin="18,0,0,0">
                            <TextBlock Text="观看状态" Style="{StaticResource BodyMutedTextStyle}" />
                            <ComboBox Width="120"
                                      SelectedItem="{Binding SelectedWatchedFilter}"
                                      ItemsSource="{Binding WatchedFilterOptions}"
                                      Style="{StaticResource FormComboBoxStyle}" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Bottom">
                        <Button Content="{Binding BatchSelectionButtonText}"
                                Command="{Binding ToggleBatchSelectionModeCommand}"
                                Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Margin="10,0,0,0"
                                Content="海报墙"
                                Command="{Binding SwitchToPosterViewCommand}"
                                Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Margin="10,0,0,0"
                                Content="列表"
                                Command="{Binding SwitchToListViewCommand}"
                                Style="{StaticResource SecondaryButtonStyle}" />
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="4"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBatchSelectionMode}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock VerticalAlignment="Center"
                               Text="{Binding SelectedCount, StringFormat=已选 {0} 部}"
                               Style="{StaticResource BodyTextStyle}" />
                    <Button Margin="18,0,0,0"
                            Content="标记为已看"
                            Command="{Binding BatchMarkWatchedCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    <Button Margin="10,0,0,0"
                            Content="标记为未看"
                            Command="{Binding BatchMarkUnwatchedCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    <Button Margin="10,0,0,0"
                            Content="AI 辅助识别"
                            Command="{Binding BatchAutoIdentifyCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    <Button Margin="10,0,0,0"
                            Content="取消"
                            Command="{Binding CancelBatchOperationCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CanCancelBatchOperation}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Margin="10,0,0,0"
                            Content="移出资源库"
                            Command="{Binding BatchRemoveFromLibraryCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    <Button Margin="10,0,0,0"
                            Content="删除影片记录"
                            Command="{Binding BatchDeleteMovieRecordsCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Border Style="{StaticResource PageCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource BodyMutedTextStyle}" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="{Binding BatchResultSummary}"
                                   TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource BodyTextStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasBatchResultSummary}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" Margin="0,18,0,0" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Movies}">
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPosterView}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="218"
                                            Margin="0,0,18,18"
                                            Style="{StaticResource BatchSelectableCardStyle}">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding DataContext.OpenOrToggleSelectionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}" />
                                        </Border.InputBindings>
                                        <StackPanel>
                                            <Grid Height="286">
                                                <Border CornerRadius="18" Background="{DynamicResource BrushSurfaceAlt}">
                                                    <Image Source="{Binding PosterRemoteUrl}" Stretch="UniformToFill" />
                                                </Border>
                                                <Border HorizontalAlignment="Left"
                                                        VerticalAlignment="Top"
                                                        Margin="10"
                                                        Padding="9,5"
                                                        CornerRadius="999"
                                                        Background="{DynamicResource BrushAccent}">
                                                    <TextBlock Foreground="{DynamicResource BrushOnAccent}"
                                                               FontWeight="SemiBold"
                                                               Text="{Binding IdentificationStatus}" />
                                                </Border>
                                                <Border HorizontalAlignment="Right"
                                                        VerticalAlignment="Top"
                                                        Margin="10,48,10,0"
                                                        Padding="9,5"
                                                        CornerRadius="999"
                                                        Background="{DynamicResource BrushSurfaceAlt}">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsInLibrary}" Value="False">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Foreground="{DynamicResource BrushForegroundPrimary}"
                                                               FontWeight="SemiBold"
                                                               Text="未入库" />
                                                </Border>
                                                <Button HorizontalAlignment="Right"
                                                        VerticalAlignment="Top"
                                                        Margin="10"
                                                        Command="{Binding DataContext.ToggleItemSelectionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource SelectionDotButtonStyle}" />
                                            </Grid>

                                            <TextBlock Margin="0,14,0,0"
                                                       Text="{Binding Title}"
                                                       TextWrapping="Wrap"
                                                       Style="{StaticResource SectionTitleTextStyle}" />
                                            <TextBlock Margin="0,4,0,0" Text="{Binding ReleaseYear}" Style="{StaticResource BodyMutedTextStyle}" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Text="{Binding GenresText}"
                                                       TextWrapping="Wrap"
                                                       Style="{StaticResource BodyTextStyle}" />
                                            <DockPanel Margin="0,12,0,0">
                                                <TextBlock Text="{Binding PrimaryRatingValue, StringFormat={}{0:0.0}}" FontWeight="SemiBold" />
                                                <TextBlock DockPanel.Dock="Right"
                                                           Text="{Binding SourceCount, StringFormat={}{0} 个播放源}"
                                                           Style="{StaticResource BodyMutedTextStyle}" />
                                            </DockPanel>
                                            <Button Margin="0,14,0,0"
                                                    Content="查看详情"
                                                    Command="{Binding DataContext.OpenMovieCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsBatchSelectionMode}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <ListBox Grid.Row="1"
                             Margin="0,18,0,0"
                             ItemsSource="{Binding Movies}">
                        <ListBox.Style>
                            <Style TargetType="ListBox" BasedOn="{StaticResource SectionListBoxStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsListView}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.Style>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Style="{StaticResource BatchSelectableListItemContentStyle}">
                                    <Grid.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding DataContext.OpenOrToggleSelectionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding}" />
                                    </Grid.InputBindings>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="130" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                            Margin="0,0,14,0"
                                            VerticalAlignment="Center"
                                            Command="{Binding DataContext.ToggleItemSelectionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource SelectionDotButtonStyle}" />

                                    <StackPanel Grid.Column="1" Margin="0,0,16,0">
                                        <TextBlock Text="{Binding Title}" Style="{StaticResource SectionTitleTextStyle}" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Text="未入库">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsInLibrary}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Margin="0,4,0,0" Text="{Binding OriginalTitle}" Style="{StaticResource BodyMutedTextStyle}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Text="{Binding GenresText}"
                                                   TextWrapping="Wrap"
                                                   Style="{StaticResource BodyTextStyle}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="{Binding IdentificationStatus}" Style="{StaticResource SectionTitleTextStyle}" />
                                        <TextBlock Margin="0,6,0,0" Text="{Binding ReleaseYear}" Style="{StaticResource BodyTextStyle}" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Text="{Binding SourceCount, StringFormat={}{0} 个播放源}"
                                                   Style="{StaticResource BodyMutedTextStyle}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="3">
                                        <TextBlock Text="{Binding PrimaryRatingValue, StringFormat={}{0:0.0}}" Style="{StaticResource SectionTitleTextStyle}" />
                                        <TextBlock Margin="0,6,0,0" Text="{Binding PrimaryRatingSourceName}" Style="{StaticResource BodyMutedTextStyle}" />
                                    </StackPanel>

                                    <Button Grid.Column="4"
                                            VerticalAlignment="Center"
                                            Content="查看详情"
                                            Command="{Binding DataContext.OpenMovieCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsBatchSelectionMode}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
