<UserControl x:Class="MediaLibrary.App.Views.Pages.LibraryPage"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:MediaLibrary.App.Helpers">
    <UserControl.Resources>
        <Style x:Key="SelectionDotButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding SelectionDotVisible}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                </DataTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="BatchSelectableCardStyle" TargetType="Border" BasedOn="{StaticResource CompactCardStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsBatchSelectionMode}" Value="True">
                    <Setter Property="Cursor" Value="Hand" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="BatchSelectableListItemContentStyle" TargetType="Grid">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsBatchSelectionMode}" Value="True">
                    <Setter Property="Cursor" Value="Hand" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource PageCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="搜索" Style="{StaticResource BodyMutedTextStyle}" />
                        <TextBox MinWidth="320"
                                 Style="{StaticResource FormTextBoxStyle}"
                                 ToolTip="按片名或原名搜索"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <Button Grid.Column="2"
                            VerticalAlignment="Bottom"
                            Content="清除筛选"
                            Command="{Binding ClearFiltersCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" />
                </Grid>

                <WrapPanel Grid.Row="2">
                    <StackPanel Width="132" Margin="0,0,12,12">
                        <TextBlock Text="排序" Style="{StaticResource BodyMutedTextStyle}" />
                        <ComboBox SelectedItem="{Binding SelectedSortOption}"
                                  ItemsSource="{Binding SortOptions}"
                                  Style="{StaticResource FormComboBoxStyle}" />
                    </StackPanel>

                    <StackPanel Width="112" Margin="0,0,12,12">
                        <TextBlock Text="顺序" Style="{StaticResource BodyMutedTextStyle}" />
                        <ComboBox SelectedItem="{Binding SelectedSortDirection}"
                                  ItemsSource="{Binding SortDirectionOptions}"
                                  Style="{StaticResource FormComboBoxStyle}" />
                    </StackPanel>

                    <StackPanel Width="132" Margin="0,0,12,12">
                        <TextBlock Text="内容" Style="{StaticResource BodyMutedTextStyle}" />
                        <ComboBox SelectedItem="{Binding SelectedContentTypeFilter}"
                                  ItemsSource="{Binding ContentTypeOptions}"
                                  Style="{StaticResource FormComboBoxStyle}" />
                    </StackPanel>

                    <StackPanel Width="190" Margin="0,0,12,12">
                        <TextBlock Text="范围" Style="{StaticResource BodyMutedTextStyle}" />
                        <Menu>
                            <MenuItem Header="{Binding LibraryScopeMenuHeader}">
                                <MenuItem Header="播放源状态">
                                    <MenuItem Header="全部"
                                              Command="{Binding DataContext.SelectLibraryScopeCommand, ElementName=Root}"
                                              CommandParameter="全部" />
                                    <MenuItem Header="有播放源"
                                              Command="{Binding DataContext.SelectLibraryScopeCommand, ElementName=Root}"
                                              CommandParameter="有播放源" />
                                    <MenuItem Header="无播放源"
                                              Command="{Binding DataContext.SelectLibraryScopeCommand, ElementName=Root}"
                                              CommandParameter="无播放源" />
                                </MenuItem>
                                <Separator />
                                <MenuItem Header="影片来源">
                                    <MenuItem Header="全部来源"
                                              Command="{Binding DataContext.SelectSourceFilterCommand, ElementName=Root}"
                                              CommandParameter="全部来源" />
                                    <MenuItem Header="本地"
                                              Command="{Binding DataContext.SelectSourceFilterCommand, ElementName=Root}"
                                              CommandParameter="本地" />
                                    <MenuItem Header="网盘"
                                              Command="{Binding DataContext.SelectSourceFilterCommand, ElementName=Root}"
                                              CommandParameter="网盘" />
                                </MenuItem>
                            </MenuItem>
                        </Menu>
                    </StackPanel>

                    <StackPanel Width="210" Margin="0,0,12,12">
                        <TextBlock Text="标签" Style="{StaticResource BodyMutedTextStyle}" />
                        <Menu>
                            <MenuItem Header="{Binding TagFilterMenuHeader}">
                                <MenuItem Header="清除标签"
                                          Command="{Binding DataContext.ClearTagFilterCommand, ElementName=Root}" />
                                <Separator />
                                <MenuItem StaysOpenOnClick="True">
                                    <MenuItem.Header>
                                        <ScrollViewer Width="660" MaxHeight="420" VerticalScrollBarVisibility="Auto">
                                            <Grid Margin="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="220" />
                                                    <ColumnDefinition Width="220" />
                                                    <ColumnDefinition Width="220" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                                    <TextBlock Text="类型标签" Style="{StaticResource BodyMutedTextStyle}" />
                                                    <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding TypeTagOptions}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <WrapPanel />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <CheckBox MinWidth="82"
                                                                          Margin="0,0,8,8"
                                                                          Content="{Binding Label}"
                                                                          IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1" Margin="0,0,16,0">
                                                    <TextBlock Text="情绪标签" Style="{StaticResource BodyMutedTextStyle}" />
                                                    <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding EmotionTagOptions}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <WrapPanel />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <CheckBox MinWidth="82"
                                                                          Margin="0,0,8,8"
                                                                          Content="{Binding Label}"
                                                                          IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="场景标签" Style="{StaticResource BodyMutedTextStyle}" />
                                                    <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding SceneTagOptions}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <WrapPanel />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <CheckBox MinWidth="82"
                                                                          Margin="0,0,8,8"
                                                                          Content="{Binding Label}"
                                                                          IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Grid>
                                        </ScrollViewer>
                                    </MenuItem.Header>
                                </MenuItem>
                            </MenuItem>
                        </Menu>
                    </StackPanel>

                    <StackPanel Width="116" Margin="0,0,12,12">
                        <TextBlock Text="年代" Style="{StaticResource BodyMutedTextStyle}" />
                        <ComboBox SelectedItem="{Binding SelectedDecadeFilter}"
                                  ItemsSource="{Binding DecadeFilterOptions}"
                                  Style="{StaticResource FormComboBoxStyle}" />
                    </StackPanel>

                    <StackPanel Width="150" Margin="0,0,12,12">
                        <TextBlock Text="收藏状态" Style="{StaticResource BodyMutedTextStyle}" />
                        <Menu>
                            <MenuItem Header="{Binding CollectionStatusMenuHeader}">
                                <MenuItem Header="全部"
                                          Command="{Binding DataContext.SelectCollectionStatusCommand, ElementName=Root}"
                                          CommandParameter="全部" />
                                <MenuItem Header="喜爱"
                                          Command="{Binding DataContext.SelectCollectionStatusCommand, ElementName=Root}"
                                          CommandParameter="喜爱" />
                                <MenuItem Header="想看"
                                          Command="{Binding DataContext.SelectCollectionStatusCommand, ElementName=Root}"
                                          CommandParameter="想看" />
                                <MenuItem Header="不想看"
                                          Command="{Binding DataContext.SelectCollectionStatusCommand, ElementName=Root}"
                                          CommandParameter="不想看" />
                            </MenuItem>
                        </Menu>
                    </StackPanel>

                    <StackPanel Width="132" Margin="0,0,12,12">
                        <TextBlock Text="观看状态" Style="{StaticResource BodyMutedTextStyle}" />
                        <ComboBox SelectedItem="{Binding SelectedWatchedFilter}"
                                  ItemsSource="{Binding WatchedFilterOptions}"
                                  Style="{StaticResource FormComboBoxStyle}" />
                    </StackPanel>
                </WrapPanel>

                <WrapPanel Grid.Row="4" VerticalAlignment="Center">
                    <WrapPanel.Style>
                        <Style TargetType="WrapPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBatchSelectionMode}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </WrapPanel.Style>
                    <TextBlock Margin="0,0,18,0"
                               VerticalAlignment="Center"
                               Text="{Binding SelectedCount, StringFormat=已选 {0} 项}"
                               Style="{StaticResource BodyTextStyle}" />
                    <Button Margin="0,0,10,10"
                            Content="&#x5168;&#x9009;&#x5F53;&#x524D;&#x5217;&#x8868;"
                            Command="{Binding SelectVisibleItemsCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    <Button Margin="0,0,10,10"
                            Content="&#x6E05;&#x7A7A;&#x9009;&#x62E9;"
                            Command="{Binding ClearBatchSelectionCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    <Button Margin="0,0,10,10"
                            Content="标记为已看"
                            Command="{Binding BatchMarkWatchedCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    <Button Margin="0,0,10,10"
                            Content="标记为未看"
                            Command="{Binding BatchMarkUnwatchedCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    <Button Margin="0,0,10,10"
                            Content="AI &#x8F85;&#x52A9;&#x8BC6;&#x522B;"
                            Command="{Binding BatchAutoIdentifyCommand}"
                            Style="{StaticResource PrimaryButtonStyle}" />
                    <Button Margin="0,0,10,10"
                            Content="取消"
                            Command="{Binding CancelBatchOperationCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CanCancelBatchOperation}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Margin="0,0,10,10"
                            Content="移出媒体库"
                            Command="{Binding BatchRemoveFromLibraryCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    <Button Margin="0,0,10,10"
                            Content="删除记录"
                            Command="{Binding BatchDeleteMovieRecordsCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    <Button Margin="0,0,10,10"
                            Content="人工聚合为季"
                            Command="{Binding OpenManualAggregationCommand}"
                            Style="{StaticResource PrimaryButtonStyle}" />
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Border Style="{StaticResource PageCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel>
                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Top">
                            <Button Content="切换布局"
                                    Command="{Binding ShowLayoutSwitchPlaceholderCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Margin="10,0,0,0"
                                    Content="{Binding BatchSelectionButtonText}"
                                    Command="{Binding ToggleBatchSelectionModeCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Margin="10,0,0,0"
                                    Content="已移出媒体库"
                                    Command="{Binding OpenRemovedLibraryCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource BodyMutedTextStyle}" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="{Binding BatchResultSummary}"
                                       TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource BodyTextStyle}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasBatchResultSummary}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </DockPanel>

                    <ScrollViewer Grid.Row="1" Margin="0,18,0,0" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Movies}">
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPosterView}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="218"
                                            Margin="0,0,18,18"
                                            Style="{StaticResource BatchSelectableCardStyle}">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding DataContext.OpenOrToggleSelectionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}" />
                                        </Border.InputBindings>
                                        <StackPanel>
                                            <Grid Height="286">
                                                <Border CornerRadius="18" Background="{DynamicResource BrushSurfaceAlt}">
                                                    <Image helpers:PosterCacheImageBehavior.Source="{Binding PosterRemoteUrl}" Stretch="UniformToFill" />
                                                </Border>
                                                <Border HorizontalAlignment="Left"
                                                        VerticalAlignment="Top"
                                                        Margin="10"
                                                        Padding="9,5"
                                                        CornerRadius="999"
                                                        Background="{DynamicResource BrushAccent}">
                                                    <TextBlock Foreground="{DynamicResource BrushOnAccent}"
                                                               FontWeight="SemiBold"
                                                               Text="{Binding IdentificationStatus}" />
                                                </Border>
                                                <Border HorizontalAlignment="Right"
                                                        VerticalAlignment="Top"
                                                        Margin="10,48,10,0"
                                                        Padding="9,5"
                                                        CornerRadius="999"
                                                        Background="{DynamicResource BrushSurfaceAlt}">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasActiveSource}" Value="False">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Foreground="{DynamicResource BrushForegroundPrimary}"
                                                               FontWeight="SemiBold"
                                                               Text="暂无播放源" />
                                                </Border>
                                                <Button HorizontalAlignment="Right"
                                                        VerticalAlignment="Top"
                                                        Margin="10"
                                                        Command="{Binding DataContext.ToggleItemSelectionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource SelectionDotButtonStyle}" />
                                            </Grid>

                                            <TextBlock Margin="0,14,0,0"
                                                       Text="{Binding Title}"
                                                       TextWrapping="Wrap"
                                                       Style="{StaticResource SectionTitleTextStyle}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Text="{Binding MediaKindText}"
                                                       Style="{StaticResource BodyMutedTextStyle}" />
                                            <TextBlock Margin="0,4,0,0" Text="{Binding ReleaseYear}" Style="{StaticResource BodyMutedTextStyle}" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Text="{Binding GenresText}"
                                                       TextWrapping="Wrap"
                                                       Style="{StaticResource BodyTextStyle}" />
                                            <DockPanel Margin="0,12,0,0">
                                                <TextBlock Text="{Binding PrimaryRatingValue, StringFormat={}{0:0.0}}" FontWeight="SemiBold" />
                                                <TextBlock DockPanel.Dock="Right"
                                                           Text="{Binding SourceCount, StringFormat={}{0} 个播放源}"
                                                           Style="{StaticResource BodyMutedTextStyle}" />
                                            </DockPanel>
                                            <TextBlock Margin="0,5,0,0"
                                                       Text="{Binding ProgressSummary}"
                                                       Style="{StaticResource BodyMutedTextStyle}" />
                                            <Button Margin="0,14,0,0"
                                                    Content="查看详情"
                                                    Command="{Binding DataContext.OpenMovieCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsBatchSelectionMode}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <ListBox Grid.Row="1"
                             Margin="0,18,0,0"
                             ItemsSource="{Binding Movies}">
                        <ListBox.Style>
                            <Style TargetType="ListBox" BasedOn="{StaticResource SectionListBoxStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsListView}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.Style>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Style="{StaticResource BatchSelectableListItemContentStyle}">
                                    <Grid.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding DataContext.OpenOrToggleSelectionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding}" />
                                    </Grid.InputBindings>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="130" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                            Margin="0,0,14,0"
                                            VerticalAlignment="Center"
                                            Command="{Binding DataContext.ToggleItemSelectionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource SelectionDotButtonStyle}" />

                                    <StackPanel Grid.Column="1" Margin="0,0,16,0">
                                        <TextBlock Text="{Binding Title}" Style="{StaticResource SectionTitleTextStyle}" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Text="暂无播放源">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasActiveSource}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Margin="0,4,0,0" Text="{Binding OriginalTitle}" Style="{StaticResource BodyMutedTextStyle}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Text="{Binding GenresText}"
                                                   TextWrapping="Wrap"
                                                   Style="{StaticResource BodyTextStyle}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="{Binding IdentificationStatus}" Style="{StaticResource SectionTitleTextStyle}" />
                                        <TextBlock Margin="0,6,0,0" Text="{Binding ReleaseYear}" Style="{StaticResource BodyTextStyle}" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Text="{Binding SourceCount, StringFormat={}{0} 个播放源}"
                                                   Style="{StaticResource BodyMutedTextStyle}" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Text="{Binding SourceSummary}"
                                                   Style="{StaticResource BodyMutedTextStyle}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="3">
                                        <TextBlock Text="{Binding PrimaryRatingValue, StringFormat={}{0:0.0}}" Style="{StaticResource SectionTitleTextStyle}" />
                                        <TextBlock Margin="0,6,0,0" Text="{Binding PrimaryRatingSourceName}" Style="{StaticResource BodyMutedTextStyle}" />
                                    </StackPanel>

                                    <Button Grid.Column="4"
                                            VerticalAlignment="Center"
                                            Content="查看详情"
                                            Command="{Binding DataContext.OpenMovieCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsBatchSelectionMode}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.RowSpan="3"
                Background="#99000000">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsManualAggregationDialogOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border Width="980"
                    MaxHeight="700"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Style="{StaticResource PageCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="人工聚合为未识别季" Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="只为当前选中的未识别播放源创建集；重复集号会作为同一集的多播放源，不会补空集。"
                                   TextWrapping="Wrap"
                                   Style="{StaticResource BodyMutedTextStyle}" />
                    </StackPanel>

                    <Grid Grid.Row="1" Margin="0,18,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="剧名" Style="{StaticResource BodyMutedTextStyle}" />
                            <TextBox Margin="0,6,0,0"
                                     Text="{Binding ManualAggregationSeriesTitle, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource FormTextBoxStyle}">
                                        <Setter Property="IsEnabled" Value="True" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsManualAggregationBusy}" Value="True">
                                                <Setter Property="IsEnabled" Value="False" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="季号" Style="{StaticResource BodyMutedTextStyle}" />
                            <TextBox Margin="0,6,0,0"
                                     Text="{Binding ManualAggregationSeasonNumberText, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource FormTextBoxStyle}">
                                        <Setter Property="IsEnabled" Value="True" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsManualAggregationBusy}" Value="True">
                                                <Setter Property="IsEnabled" Value="False" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="季名称" Style="{StaticResource BodyMutedTextStyle}" />
                            <TextBox Margin="0,6,0,0"
                                     Text="{Binding ManualAggregationSeasonTitle, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource FormTextBoxStyle}">
                                        <Setter Property="IsEnabled" Value="True" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsManualAggregationBusy}" Value="True">
                                                <Setter Property="IsEnabled" Value="False" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                            <TextBlock Margin="0,6,0,0"
                                       Text="{Binding ManualAggregationSeasonDisplayText}"
                                       Style="{StaticResource BodyMutedTextStyle}" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="2">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="没有可聚合的播放源">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasManualAggregationSources}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ListBox ItemsSource="{Binding ManualAggregationSources}">
                            <ListBox.Style>
                                <Style TargetType="ListBox" BasedOn="{StaticResource SectionListBoxStyle}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasManualAggregationSources}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.Style>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8"
                                            Padding="12"
                                            Background="{DynamicResource BrushSurfaceAlt}"
                                            BorderBrush="{DynamicResource BrushBorder}"
                                            BorderThickness="1"
                                            CornerRadius="10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="160" />
                                                <ColumnDefinition Width="180" />
                                                <ColumnDefinition Width="120" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Margin="0,0,16,0">
                                                <TextBlock Text="{Binding FileName}"
                                                           TextTrimming="CharacterEllipsis"
                                                           Style="{StaticResource BodyTextStyle}" />
                                                <TextBlock Margin="0,5,0,0"
                                                           Text="{Binding SourceSummary}"
                                                           TextWrapping="Wrap"
                                                           Style="{StaticResource BodyMutedTextStyle}" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       Margin="0,0,14,0"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding CurrentBindingText}"
                                                       TextWrapping="Wrap"
                                                       Style="{StaticResource BodyMutedTextStyle}" />
                                            <TextBlock Grid.Column="2"
                                                       Margin="0,0,14,0"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding EpisodeNumberSourceText}"
                                                       Style="{StaticResource BodyMutedTextStyle}" />
                                            <TextBox Grid.Column="3"
                                                     VerticalAlignment="Center"
                                                     Text="{Binding EpisodeNumberText, UpdateSourceTrigger=PropertyChanged}">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox" BasedOn="{StaticResource FormTextBoxStyle}">
                                                        <Setter Property="IsEnabled" Value="True" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding DataContext.IsManualAggregationBusy, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                                <Setter Property="IsEnabled" Value="False" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>

                    <DockPanel Grid.Row="3" Margin="0,16,0,0" LastChildFill="True">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Margin="0,0,10,0"
                                    Content="取消"
                                    Command="{Binding CancelManualAggregationCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Margin="0,0,10,0"
                                    Content="聚合后识别"
                                    Command="{Binding ApplyManualAggregationAndIdentifyCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Content="聚合"
                                    Command="{Binding ApplyManualAggregationCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                        </StackPanel>
                        <TextBlock Margin="0,0,18,0"
                                   VerticalAlignment="Center"
                                   Text="{Binding ManualAggregationStatusMessage}"
                                   TextWrapping="Wrap"
                                   Style="{StaticResource BodyMutedTextStyle}" />
                    </DockPanel>
                </Grid>
            </Border>
        </Border>

        <Border Grid.RowSpan="3"
                Background="#99000000">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsRemovedLibraryPanelOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border Width="860"
                    MaxHeight="640"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Style="{StaticResource PageCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel>
                        <Button DockPanel.Dock="Right"
                                Content="关闭"
                                Command="{Binding CloseRemovedLibraryCommand}"
                                Style="{StaticResource SecondaryButtonStyle}" />
                        <StackPanel>
                            <TextBlock Text="已移出媒体库" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Margin="0,6,18,0"
                                       Text="{Binding RemovedLibraryStatusMessage}"
                                       TextWrapping="Wrap"
                                       Style="{StaticResource BodyMutedTextStyle}" />
                        </StackPanel>
                    </DockPanel>

                    <Grid Grid.Row="2">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="暂无已移出媒体库项目"
	                                   >
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasRemovedLibraryItems}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <ListBox ItemsSource="{Binding RemovedLibraryGroups}">
                            <ListBox.Style>
                                <Style TargetType="ListBox" BasedOn="{StaticResource SectionListBoxStyle}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasRemovedLibraryItems}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.Style>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                    <Expander IsExpanded="{Binding IsExpanded, Mode=TwoWay}">
                                        <Expander.Style>
                                            <Style TargetType="Expander">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsTvGroup}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Expander.Style>
                                        <Expander.Header>
                                            <Border Padding="14"
                                                    BorderBrush="{DynamicResource BrushBorder}"
                                                    BorderThickness="1"
                                                    CornerRadius="12">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{DynamicResource BrushSurfaceAlt}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsTvGroup}" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource BrushAccentSoft}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="112" />
                                                        <ColumnDefinition Width="124" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Margin="0,0,16,0">
                                                        <TextBlock Text="{Binding Title}" Style="{StaticResource SectionTitleTextStyle}" />
                                                        <TextBlock Margin="0,5,0,0"
                                                                   Text="{Binding HeaderSubtitle}"
                                                                   TextWrapping="Wrap"
                                                                   Style="{StaticResource BodyMutedTextStyle}" />
                                                    </StackPanel>
                                                    <Button Grid.Column="1"
                                                            Margin="0,0,8,0"
                                                            Content="恢复全部"
                                                            Command="{Binding DataContext.RestoreRemovedLibraryGroupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsTvGroup}" Value="False">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                    <Button Grid.Column="2"
                                                            Content="删除全部记录"
                                                            Command="{Binding DataContext.DeleteRemovedLibraryGroupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsTvGroup}" Value="False">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </Expander.Header>

                                        <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding Items}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="20,0,0,8"
                                                            Background="{DynamicResource BrushSurfaceAlt}"
                                                            BorderBrush="{DynamicResource BrushBorder}"
                                                            BorderThickness="1"
                                                            CornerRadius="12">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="4" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="100" />
                                                                <ColumnDefinition Width="100" />
                                                                <ColumnDefinition Width="110" />
                                                            </Grid.ColumnDefinitions>
                                                            <Border Background="{DynamicResource BrushAccent}" CornerRadius="12,0,0,12" />
                                                            <StackPanel Grid.Column="1" Margin="12,10,18,10">
                                                                <TextBlock Text="{Binding Title}" Style="{StaticResource SectionTitleTextStyle}" />
                                                                <WrapPanel Margin="0,6,0,0">
                                                                    <TextBlock Margin="0,0,12,0" Text="{Binding MediaKindText}" Style="{StaticResource BodyMutedTextStyle}" />
                                                                    <TextBlock Margin="0,0,12,0" Text="{Binding SourceStatusText}" Style="{StaticResource BodyMutedTextStyle}" />
                                                                    <TextBlock Text="{Binding StateSummary}" Style="{StaticResource BodyMutedTextStyle}" />
                                                                </WrapPanel>
                                                            </StackPanel>
                                                            <Button Grid.Column="2"
                                                                    Margin="0,10,8,10"
                                                                    Content="恢复"
                                                                    Command="{Binding DataContext.RestoreRemovedLibraryItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Style="{StaticResource PrimaryButtonStyle}" />
                                                            <Button Grid.Column="3"
                                                                    Margin="0,10,8,10"
                                                                    Content="详情"
                                                                    Command="{Binding DataContext.OpenRemovedLibraryDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Style="{StaticResource SecondaryButtonStyle}" />
                                                            <Button Grid.Column="4"
                                                                    Margin="0,10,12,10"
                                                                    Content="删除记录"
                                                                    Command="{Binding DataContext.DeleteRemovedLibraryItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Style="{StaticResource SecondaryButtonStyle}" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Expander>
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.Style>
                                            <Style TargetType="ItemsControl">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMovieGroup}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ItemsControl.Style>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,8"
                                                        Background="{DynamicResource BrushSurfaceAlt}"
                                                        BorderBrush="{DynamicResource BrushBorder}"
                                                        BorderThickness="1"
                                                        CornerRadius="12">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="4" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="100" />
                                                            <ColumnDefinition Width="100" />
                                                            <ColumnDefinition Width="110" />
                                                        </Grid.ColumnDefinitions>
                                                        <Border Background="{DynamicResource BrushAccent}" CornerRadius="12,0,0,12" />
                                                        <StackPanel Grid.Column="1" Margin="12,10,18,10">
                                                            <TextBlock Text="{Binding Title}" Style="{StaticResource SectionTitleTextStyle}" />
                                                            <WrapPanel Margin="0,6,0,0">
                                                                <TextBlock Margin="0,0,12,0" Text="{Binding MediaKindText}" Style="{StaticResource BodyMutedTextStyle}" />
                                                                <TextBlock Margin="0,0,12,0" Text="{Binding SourceStatusText}" Style="{StaticResource BodyMutedTextStyle}" />
                                                                <TextBlock Text="{Binding StateSummary}" Style="{StaticResource BodyMutedTextStyle}" />
                                                            </WrapPanel>
                                                        </StackPanel>
                                                        <Button Grid.Column="2"
                                                                Margin="0,10,8,10"
                                                                Content="恢复"
                                                                Command="{Binding DataContext.RestoreRemovedLibraryItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource PrimaryButtonStyle}" />
                                                        <Button Grid.Column="3"
                                                                Margin="0,10,8,10"
                                                                Content="详情"
                                                                Command="{Binding DataContext.OpenRemovedLibraryDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource SecondaryButtonStyle}" />
                                                        <Button Grid.Column="4"
                                                                Margin="0,10,12,10"
                                                                Content="删除记录"
                                                                Command="{Binding DataContext.DeleteRemovedLibraryItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource SecondaryButtonStyle}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
