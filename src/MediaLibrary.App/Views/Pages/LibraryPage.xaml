                                        <Border BorderBrush="#14FFFFFF"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                IsHitTestVisible="False" />
                                        <Border Margin="1"
                                                BorderBrush="#0A000000"
                                                BorderThickness="1"
                                                CornerRadius="11"
                                                IsHitTestVisible="False" />
