                                                    <Style TargetType="Border" BasedOn="{StaticResource LibraryMediaChipStyle}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasBatchModeHint}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding BatchModeHintText}"
                                                           Style="{StaticResource LibraryMediaChipTextStyle}" />
                                            </Border>
                                            <Button HorizontalAlignment="Center"
                                                    VerticalAlignment="Top"
                                                    Margin="0,8,0,0"
