                                <MenuItem Header="全部" Command="{Binding SelectSourceFilterCommand}" CommandParameter="全部来源" Style="{StaticResource LibraryFilterMenuItemStyle}" />
                                <MenuItem Header="本地" Command="{Binding SelectSourceFilterCommand}" CommandParameter="本地" Style="{StaticResource LibraryFilterMenuItemStyle}" />
                                <MenuItem Header="网盘" Command="{Binding SelectSourceFilterCommand}" CommandParameter="网盘" Style="{StaticResource LibraryFilterMenuItemStyle}" />
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button x:Name="ContentTypeFilterButton"
                            Grid.Column="4"
                            Content="{Binding ContentTypeButtonText}"
