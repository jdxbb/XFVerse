                                                        <GradientStop Color="#00FFFFFF" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                            <Border HorizontalAlignment="Left"
                                                    VerticalAlignment="Top"
                                                    Margin="8"
                                                    MaxWidth="88"
