                                                    <Run Text="{Binding ListTagGroupTwoText, Mode=OneWay}" />
                                                    <Run Text="{Binding ListTagSeparatorAfterTwoText, Mode=OneWay}"
                                                         Foreground="{StaticResource LibraryTagDividerBrush}" />
                                                    <Run Text="{Binding ListTagGroupThreeText, Mode=OneWay}" />
                                                </TextBlock>
                                            </Border>
                                            <Grid Margin="0,7,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <ProgressBar VerticalAlignment="Center"
                                                             Value="{Binding ProgressValue, Mode=OneWay}"
                                                             Style="{StaticResource LibraryMediaProgressBarStyle}" />
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding ProgressLabel}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource LibraryMediaCardTextBrush}" />
                                            </Grid>
                                        </StackPanel>

                                        <StackPanel Grid.Column="3"
                                                    Width="82"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center">
                                            <Border Margin="0,0,0,7"
                                                    HorizontalAlignment="Right"
                                                    MaxWidth="80"
                                                    Style="{StaticResource LibraryMediaChipStyle}">
                                                <TextBlock Text="{Binding SourceBadgeText}"
                                                           Style="{StaticResource LibraryMediaChipTextStyle}" />
                                            </Border>
                                            <Border HorizontalAlignment="Right"
                                                    MaxWidth="80"
                                                    Style="{StaticResource LibraryMediaChipStyle}">
                                                <TextBlock Text="{Binding DetailHintText}"
                                                           Style="{StaticResource LibraryMediaChipTextStyle}" />
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Border Grid.Row="1"
                            Panel.ZIndex="40"
                            Margin="0,18,0,0"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Background="Transparent">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowLibraryInitialLoading}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <Control Width="34"
                                     Height="34"
                                     HorizontalAlignment="Center"
                                     Template="{StaticResource LoadingSpinnerTemplate}" />
                            <TextBlock Margin="0,12,0,0"
                                       HorizontalAlignment="Center"
                                       Text="加载中"
                                       Style="{StaticResource InlineLoadingStyle}" />
                            <TextBlock Text="正在加载媒体库..."
                                       Margin="0,12,0,0"
                                       Visibility="Collapsed"
                                       Style="{StaticResource EmptyStateTitleStyle}" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="正在读取媒体库内容和筛选状态。"
                                       Visibility="Collapsed"
                                       Style="{StaticResource InlineLoadingStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Margin="0,18,0,0"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Background="Transparent">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowLibraryEmptyState}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="{Binding EmptyStateTitle}"
                                   TextAlignment="Center"
                                   Style="{StaticResource EmptyStateTitleStyle}" />
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.RowSpan="3"
                Background="#99000000">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsManualAggregationDialogOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border Width="980"
                    MaxHeight="700"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Style="{StaticResource GlassPageCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="人工聚合为未识别季" Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="只为当前选中的未识别播放源创建集；重复集号会作为同一集的多播放源，不会补空集。"
                                   TextWrapping="Wrap"
                                   Style="{StaticResource BodyMutedTextStyle}" />
                    </StackPanel>

                    <Grid Grid.Row="1" Margin="0,18,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="剧名" Style="{StaticResource BodyMutedTextStyle}" />
                            <TextBox Margin="0,6,0,0"
                                     Text="{Binding ManualAggregationSeriesTitle, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource FormTextBoxStyle}">
                                        <Setter Property="IsEnabled" Value="True" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsManualAggregationBusy}" Value="True">
                                                <Setter Property="IsEnabled" Value="False" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="季号" Style="{StaticResource BodyMutedTextStyle}" />
                            <TextBox Margin="0,6,0,0"
                                     Text="{Binding ManualAggregationSeasonNumberText, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource FormTextBoxStyle}">
                                        <Setter Property="IsEnabled" Value="True" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsManualAggregationBusy}" Value="True">
                                                <Setter Property="IsEnabled" Value="False" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="季名称" Style="{StaticResource BodyMutedTextStyle}" />
                            <TextBox Margin="0,6,0,0"
                                     Text="{Binding ManualAggregationSeasonTitle, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource FormTextBoxStyle}">
                                        <Setter Property="IsEnabled" Value="True" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsManualAggregationBusy}" Value="True">
                                                <Setter Property="IsEnabled" Value="False" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                            <TextBlock Margin="0,6,0,0"
                                       Text="{Binding ManualAggregationSeasonDisplayText}"
                                       Style="{StaticResource BodyMutedTextStyle}" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="2">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="没有可聚合的播放源">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasManualAggregationSources}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ListBox ItemsSource="{Binding ManualAggregationSources}">
                            <ListBox.Style>
                                <Style TargetType="ListBox" BasedOn="{StaticResource SectionListBoxStyle}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasManualAggregationSources}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.Style>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8"
                                            Padding="12"
                                            Background="{DynamicResource BrushGlassSurfaceAlt}"
                                            BorderBrush="{DynamicResource BrushBorder}"
                                            BorderThickness="1"
                                            CornerRadius="10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="160" />
                                                <ColumnDefinition Width="180" />
                                                <ColumnDefinition Width="120" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Margin="0,0,16,0">
                                                <TextBlock Text="{Binding FileName}"
                                                           TextTrimming="CharacterEllipsis"
                                                           Style="{StaticResource BodyTextStyle}" />
                                                <TextBlock Margin="0,5,0,0"
                                                           Text="{Binding SourceSummary}"
                                                           TextWrapping="Wrap"
                                                           Style="{StaticResource BodyMutedTextStyle}" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       Margin="0,0,14,0"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding CurrentBindingText}"
                                                       TextWrapping="Wrap"
                                                       Style="{StaticResource BodyMutedTextStyle}" />
                                            <TextBlock Grid.Column="2"
                                                       Margin="0,0,14,0"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding EpisodeNumberSourceText}"
                                                       Style="{StaticResource BodyMutedTextStyle}" />
                                            <TextBox Grid.Column="3"
                                                     VerticalAlignment="Center"
                                                     Text="{Binding EpisodeNumberText, UpdateSourceTrigger=PropertyChanged}">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox" BasedOn="{StaticResource FormTextBoxStyle}">
                                                        <Setter Property="IsEnabled" Value="True" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding DataContext.IsManualAggregationBusy, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                                <Setter Property="IsEnabled" Value="False" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>

                    <DockPanel Grid.Row="3" Margin="0,16,0,0" LastChildFill="True">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Margin="0,0,10,0"
                                    Content="取消"
                                    Command="{Binding CancelManualAggregationCommand}"
                                    Style="{StaticResource LibrarySecondaryButtonStyle}" />
                            <Button Margin="0,0,10,0"
                                    Content="聚合后识别"
                                    Command="{Binding ApplyManualAggregationAndIdentifyCommand}"
                                    Style="{StaticResource LibrarySecondaryButtonStyle}" />
                            <Button Content="聚合"
                                    Command="{Binding ApplyManualAggregationCommand}"
                                    Style="{StaticResource LibraryPrimaryButtonStyle}" />
                        </StackPanel>
                        <TextBlock Margin="0,0,18,0"
                                   VerticalAlignment="Center"
                                   LineHeight="{StaticResource LineHeightMetadata}"
                                   LineStackingStrategy="BlockLineHeight"
                                   MaxHeight="40"
                                   Text="{Binding ManualAggregationStatusMessage}"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="Wrap"
                                   helpers:TrimmedTextToolTipBehavior.FullText="{Binding ManualAggregationStatusMessage}"
                                   Style="{StaticResource BodyMutedTextStyle}" />
                    </DockPanel>
                </Grid>
            </Border>
        </Border>

        <Border Grid.RowSpan="3"
                Background="Transparent">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsRemovedLibraryPanelOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border Width="760"
                    MaxHeight="720"
                    Padding="18"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Style="{StaticResource GlassPageCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="已移出媒体库"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Margin="12,0,0,0"
                                       VerticalAlignment="Bottom"
                                       Text="{Binding RemovedLibraryItems.Count, StringFormat=共 {0} 项}"
                                       FontSize="12"
                                       Style="{StaticResource BodyMutedTextStyle}" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="×"
                                ToolTip="关闭"
                                Command="{Binding CloseRemovedLibraryCommand}"
                                Style="{StaticResource LibraryRemovedPanelCloseButtonStyle}" />
                    </Grid>

                    <Grid Grid.Row="2">
                        <Border HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource LoadingStateStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRemovedLibraryLoading}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <Control Width="34"
                                         Height="34"
                                         HorizontalAlignment="Center"
                                         Template="{StaticResource LoadingSpinnerTemplate}" />
                                <TextBlock Margin="0,12,0,0"
                                           HorizontalAlignment="Center"
                                           Text="正在加载已移出媒体库项目..."
                                           Style="{StaticResource InlineLoadingStyle}" />
                            </StackPanel>
                        </Border>
                        <Border HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource EmptyStateContainerStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding HasRemovedLibraryItems}" Value="False" />
                                                <Condition Binding="{Binding IsRemovedLibraryLoading}" Value="False" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        MaxWidth="360">
                                <TextBlock Text="暂无已移出项目"
                                           TextAlignment="Center"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource BrushForegroundPrimary}" />
                            </StackPanel>
                        </Border>
                        <ListBox ItemsSource="{Binding RemovedLibraryGroups}"
                                 ScrollViewer.CanContentScroll="True"
                                 ScrollViewer.ScrollChanged="OnLibraryListScrollChanged"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 VirtualizingPanel.ScrollUnit="Pixel"
                                 helpers:ScrollBarAutoRevealBehavior.IsEnabled="True"
                                 PreviewMouseWheel="RemovedLibraryListBox_PreviewMouseWheel"
                                 MaxHeight="560">
                            <ListBox.Resources>
                                <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource LibraryModernScrollBarStyle}" />
                            </ListBox.Resources>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem" BasedOn="{StaticResource LibraryRemovedPanelListItemStyle}" />
                            </ListBox.ItemContainerStyle>
                            <ListBox.Style>
                                <Style TargetType="ListBox" BasedOn="{StaticResource SectionListBoxStyle}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasRemovedLibraryItems}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsRemovedLibraryLoading}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.Style>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Expander IsExpanded="{Binding IsExpanded, Mode=TwoWay}">
                                            <Expander.Style>
                                                <Style TargetType="Expander" BasedOn="{StaticResource LibraryRemovedPanelExpanderStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsTvGroup}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Expander.Style>
                                            <Expander.Header>
                                                <Border Padding="16,8,12,8"
                                                        BorderBrush="{DynamicResource BrushDivider}"
                                                        BorderThickness="0,0,0,1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="8" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="8" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="18" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Margin="0,0,18,0"
                                                                    MaxWidth="470"
                                                                    Orientation="Horizontal"
                                                                    VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Title}"
                                                                       VerticalAlignment="Center"
                                                                       MaxWidth="210"
                                                                       FontSize="12"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource BrushForegroundPrimary}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       helpers:TrimmedTextToolTipBehavior.FullText="{Binding Title}"
                                                                       helpers:TrimmedTextToolTipBehavior.VisibleText="{Binding Title}" />
                                                            <StackPanel Margin="12,0,0,0"
                                                                        Orientation="Horizontal"
                                                                        VerticalAlignment="Center">
                                                                <Border Style="{StaticResource LibraryRemovedPanelChipStyle}">
                                                                    <TextBlock Text="{Binding Items[0].SourceStatusText}" Style="{StaticResource LibraryRemovedPanelChipTextStyle}" />
                                                                </Border>
                                                                <Border Style="{StaticResource LibraryRemovedPanelChipStyle}">
                                                                    <TextBlock Text="电视剧" Style="{StaticResource LibraryRemovedPanelChipTextStyle}" />
                                                                </Border>
                                                                <Border Style="{StaticResource LibraryRemovedPanelChipStyle}">
                                                                    <TextBlock Text="{Binding Items.Count, StringFormat=共 {0} 季}" Style="{StaticResource LibraryRemovedPanelChipTextStyle}" />
                                                                </Border>
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <Button Grid.Column="1"
                                                                Content="恢复全部"
                                                                Command="{Binding DataContext.RestoreRemovedLibraryGroupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource LibraryRemovedPanelActionButtonStyle}" />
                                                        <Button Grid.Column="3"
                                                                Content="详情"
                                                                Command="{Binding DataContext.OpenRemovedLibraryDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource LibraryRemovedPanelActionButtonStyle}" />
                                                        <Button Grid.Column="5"
                                                                Content="删除全部记录"
                                                                Command="{Binding DataContext.DeleteRemovedLibraryGroupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource LibraryRemovedPanelDangerButtonStyle}" />
                                                        <TextBlock Grid.Column="6"
                                                                   VerticalAlignment="Center"
                                                                   HorizontalAlignment="Right"
                                                                   FontFamily="Segoe MDL2 Assets"
                                                                   FontSize="10"
                                                                   Foreground="{DynamicResource BrushForegroundMuted}"
                                                                   >
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="&#xE70D;" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                            <Setter Property="Text" Value="&#xE70E;" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Grid>
                                                </Border>
                                            </Expander.Header>

                                            <ItemsControl Margin="16,0,0,0" ItemsSource="{Binding Items}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Style="{StaticResource LibraryRemovedPanelSeasonItemStyle}">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="14" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <Ellipse Width="5"
                                                                         Height="5"
                                                                         HorizontalAlignment="Left"
                                                                         VerticalAlignment="Center"
                                                                         Fill="{DynamicResource BrushForegroundMuted}" />
                                                                <StackPanel Grid.Column="1"
                                                                            Margin="0,8,14,8"
                                                                            MaxWidth="420"
                                                                            Orientation="Horizontal"
                                                                            VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding Title}"
                                                                               VerticalAlignment="Center"
                                                                               MaxWidth="180"
                                                                               FontSize="11"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{DynamicResource BrushForegroundPrimary}"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               helpers:TrimmedTextToolTipBehavior.FullText="{Binding Title}"
                                                                               helpers:TrimmedTextToolTipBehavior.VisibleText="{Binding Title}" />
                                                                    <StackPanel Margin="12,0,0,0"
                                                                                Orientation="Horizontal"
                                                                                VerticalAlignment="Center">
                                                                        <Border Style="{StaticResource LibraryRemovedPanelChipStyle}">
                                                                            <TextBlock Text="{Binding SourceStatusText}" Style="{StaticResource LibraryRemovedPanelChipTextStyle}" />
                                                                        </Border>
                                                                        <Border Style="{StaticResource LibraryRemovedPanelChipStyle}">
                                                                            <TextBlock Text="{Binding MediaKindText}" Style="{StaticResource LibraryRemovedPanelChipTextStyle}" />
                                                                        </Border>
                                                                        <Border Style="{StaticResource LibraryRemovedPanelChipStyle}">
                                                                            <TextBlock Text="{Binding Movie.TotalEpisodeCount, StringFormat=共 {0} 集}" Style="{StaticResource LibraryRemovedPanelChipTextStyle}" />
                                                                        </Border>
                                                                    </StackPanel>
                                                                </StackPanel>
                                                                <StackPanel Grid.Column="2"
                                                                            Margin="0,8,12,8"
                                                                            Orientation="Horizontal"
                                                                            VerticalAlignment="Center">
                                                                    <Button Margin="0,0,8,0"
                                                                            Content="恢复"
                                                                            Command="{Binding DataContext.RestoreRemovedLibraryItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                            CommandParameter="{Binding}"
                                                                            Style="{StaticResource LibraryRemovedPanelActionButtonStyle}" />
                                                                    <Button Margin="0,0,8,0"
                                                                            Content="详情"
                                                                            Command="{Binding DataContext.OpenRemovedLibraryDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                            CommandParameter="{Binding}"
                                                                            Style="{StaticResource LibraryRemovedPanelActionButtonStyle}" />
                                                                    <Button Content="删除记录"
                                                                            Command="{Binding DataContext.DeleteRemovedLibraryItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                            CommandParameter="{Binding}"
                                                                            Style="{StaticResource LibraryRemovedPanelDangerButtonStyle}" />
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Expander>
                                        <StackPanel>
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMovieGroup}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <ItemsControl ItemsSource="{Binding Items}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Style="{StaticResource LibraryRemovedPanelFlatItemStyle}">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <StackPanel Grid.Column="0"
                                                                            Margin="16,8,14,8"
                                                                            MaxWidth="470"
                                                                            Orientation="Horizontal"
                                                                            VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding Title}"
                                                                               VerticalAlignment="Center"
                                                                               MaxWidth="210"
                                                                               FontSize="12"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{DynamicResource BrushForegroundPrimary}"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               helpers:TrimmedTextToolTipBehavior.FullText="{Binding Title}"
                                                                               helpers:TrimmedTextToolTipBehavior.VisibleText="{Binding Title}" />
                                                                    <StackPanel Margin="12,0,0,0"
                                                                                Orientation="Horizontal"
                                                                                VerticalAlignment="Center">
                                                                        <Border Style="{StaticResource LibraryRemovedPanelChipStyle}">
                                                                            <TextBlock Text="{Binding SourceStatusText}" Style="{StaticResource LibraryRemovedPanelChipTextStyle}" />
                                                                        </Border>
                                                                        <Border Style="{StaticResource LibraryRemovedPanelChipStyle}">
                                                                            <TextBlock Text="{Binding MediaKindText}" Style="{StaticResource LibraryRemovedPanelChipTextStyle}" />
                                                                        </Border>
                                                                    </StackPanel>
                                                                </StackPanel>
                                                                <StackPanel Grid.Column="1"
                                                                            Margin="0,8,12,8"
                                                                            Orientation="Horizontal"
                                                                            VerticalAlignment="Center">
                                                                    <Button Margin="0,0,8,0"
                                                                            Content="恢复"
                                                                            Command="{Binding DataContext.RestoreRemovedLibraryItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                            CommandParameter="{Binding}"
                                                                            Style="{StaticResource LibraryRemovedPanelActionButtonStyle}" />
                                                                    <Button Margin="0,0,8,0"
                                                                            Content="详情"
                                                                            Command="{Binding DataContext.OpenRemovedLibraryDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                            CommandParameter="{Binding}"
                                                                            Style="{StaticResource LibraryRemovedPanelActionButtonStyle}" />
                                                                    <Button Content="删除记录"
                                                                            Command="{Binding DataContext.DeleteRemovedLibraryItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                            CommandParameter="{Binding}"
                                                                            Style="{StaticResource LibraryRemovedPanelDangerButtonStyle}" />
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
