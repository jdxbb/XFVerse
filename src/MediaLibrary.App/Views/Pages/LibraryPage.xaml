<UserControl x:Class="MediaLibrary.App.Views.Pages.LibraryPage"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MediaLibrary.App.Controls"
             xmlns:helpers="clr-namespace:MediaLibrary.App.Helpers">
    <UserControl.Resources>
        <SolidColorBrush x:Key="LibraryMediaCardBackgroundBrush" Color="#121821" />
        <SolidColorBrush x:Key="LibraryMediaCardSurfaceBrush" Color="#202938" />
        <SolidColorBrush x:Key="LibraryMediaCardTextBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="LibraryMediaCardMutedTextBrush" Color="#D8DEE9" />
        <SolidColorBrush x:Key="LibraryMediaCardAccentBrush" Color="#E2E8F0" />
        <SolidColorBrush x:Key="LibraryMediaCardAccentTextBrush" Color="#111827" />
        <SolidColorBrush x:Key="LibraryMediaCardDividerBrush" Color="#E5E7EB" />
        <SolidColorBrush x:Key="LibraryMediaProgressFillBrush" Color="#67C7F2" />
        <SolidColorBrush x:Key="LibraryMediaProgressTrackBrush" Color="#E5E7EB" />
        <SolidColorBrush x:Key="LibraryTagDividerBrush" Color="#7DD3FC" />
        <SolidColorBrush x:Key="LibraryRatingGoldBrush" Color="#F5C84B" />

        <Style x:Key="LibraryMediaProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="4" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="Background" Value="{StaticResource LibraryMediaProgressTrackBrush}" />
            <Setter Property="Foreground" Value="{StaticResource LibraryMediaProgressFillBrush}" />
            <Setter Property="Visibility" Value="Visible" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid Height="{TemplateBinding Height}"
                              SnapsToDevicePixels="True">
                            <Border x:Name="PART_Track"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="2" />
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="2" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LibraryMediaChipStyle" TargetType="Border">
            <Setter Property="Padding" Value="7,4" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="{StaticResource LibraryMediaCardAccentBrush}" />
            <Setter Property="Opacity" Value="0.9" />
        </Style>

        <Style x:Key="LibraryMediaChipTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource LibraryMediaCardAccentTextBrush}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="LibraryMediaMutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource LibraryMediaCardMutedTextBrush}" />
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="LibraryTagLineContainerStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="450" />
            <Setter Property="ToolTipService.BetweenShowDelay" Value="0" />
            <Setter Property="ToolTipService.ShowDuration" Value="20000" />
        </Style>

        <Style x:Key="LibraryMediaTitleTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource LibraryMediaCardTextBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="LibrarySearchBoxStyle" TargetType="TextBox" BasedOn="{StaticResource SearchBoxStyle}">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="10,3" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="LibraryCompactComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource FormComboBoxStyle}">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="LibraryFilterMenuItemStyle" TargetType="MenuItem" BasedOn="{StaticResource MenuItemStyle}">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Padding" Value="9,4" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="LibraryToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource SmallButtonStyle}">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="LibraryToolbarIconButtonStyle" TargetType="Button" BasedOn="{StaticResource SmallIconButtonStyle}">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="30" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="SelectionDotButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="11" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding SelectionDotVisible}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                </DataTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="BatchSelectableCardStyle" TargetType="Border" BasedOn="{StaticResource CompactCardStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsBatchSelectionMode}" Value="True">
                    <Setter Property="Cursor" Value="Hand" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="BatchSelectableListItemContentStyle" TargetType="Grid">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsBatchSelectionMode}" Value="True">
                    <Setter Property="Cursor" Value="Hand" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Padding="8" Style="{StaticResource PageCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="5" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="5" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="搜索媒体" Visibility="Collapsed" Style="{StaticResource BodyMutedTextStyle}" />
                        <TextBox MinWidth="320"
                                 Style="{StaticResource LibrarySearchBoxStyle}"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding ApplySearchCommand}" />
                            </TextBox.InputBindings>
                        </TextBox>
                    </StackPanel>

                    <Button Grid.Column="2"
                            VerticalAlignment="Bottom"
                            Command="{Binding ApplySearchCommand}"
                            Style="{StaticResource LibraryToolbarIconButtonStyle}">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   FontSize="16"
                                   Text="&#xE721;" />
                    </Button>
                    <Button Grid.Column="4"
                            VerticalAlignment="Bottom"
                            Content="清空搜索"
                            Command="{Binding ClearSearchCommand}"
                            Style="{StaticResource LibraryToolbarButtonStyle}" />
                    <Button Grid.Column="6"
                            VerticalAlignment="Bottom"
                            Content="清除筛选"
                            Command="{Binding ClearFiltersCommand}"
                            Style="{StaticResource LibraryToolbarButtonStyle}" />
                </Grid>

                <WrapPanel Grid.Row="2">
                    <StackPanel Width="118" Margin="0,0,6,4">
                        <TextBlock Text="排序" Visibility="Collapsed" Style="{StaticResource BodyMutedTextStyle}" />
                        <ComboBox SelectedItem="{Binding SelectedSortOption}"
                                  ItemsSource="{Binding SortOptions}"
                                  Style="{StaticResource LibraryCompactComboBoxStyle}" />
                    </StackPanel>

                    <StackPanel Width="96" Margin="0,0,6,4">
                        <TextBlock Text="顺序" Visibility="Collapsed" Style="{StaticResource BodyMutedTextStyle}" />
                        <ComboBox SelectedItem="{Binding SelectedSortDirection}"
                                  ItemsSource="{Binding SortDirectionOptions}"
                                  Style="{StaticResource LibraryCompactComboBoxStyle}" />
                    </StackPanel>

                    <StackPanel Width="108" Margin="0,0,6,4">
                        <TextBlock Text="内容" Visibility="Collapsed" Style="{StaticResource BodyMutedTextStyle}" />
                        <ComboBox SelectedItem="{Binding SelectedContentTypeFilter}"
                                  ItemsSource="{Binding ContentTypeOptions}"
                                  Style="{StaticResource LibraryCompactComboBoxStyle}" />
                    </StackPanel>

                    <StackPanel Width="176" Margin="0,0,6,4">
                        <TextBlock Text="范围" Visibility="Collapsed" Style="{StaticResource BodyMutedTextStyle}" />
                        <Menu>
                            <MenuItem Header="{Binding LibraryScopeMenuHeader}" Style="{StaticResource LibraryFilterMenuItemStyle}">
                                <MenuItem Header="播放源状态">
                                    <MenuItem Header="全部"
                                              Command="{Binding DataContext.SelectLibraryScopeCommand, ElementName=Root}"
                                              CommandParameter="全部" />
                                    <MenuItem Header="有播放源"
                                              Command="{Binding DataContext.SelectLibraryScopeCommand, ElementName=Root}"
                                              CommandParameter="有播放源" />
                                    <MenuItem Header="无播放源"
                                              Command="{Binding DataContext.SelectLibraryScopeCommand, ElementName=Root}"
                                              CommandParameter="无播放源" />
                                </MenuItem>
                                <Separator />
                                <MenuItem Header="影片来源">
                                    <MenuItem Header="全部来源"
                                              Command="{Binding DataContext.SelectSourceFilterCommand, ElementName=Root}"
                                              CommandParameter="全部来源" />
                                    <MenuItem Header="本地"
                                              Command="{Binding DataContext.SelectSourceFilterCommand, ElementName=Root}"
                                              CommandParameter="本地" />
                                    <MenuItem Header="网盘"
                                              Command="{Binding DataContext.SelectSourceFilterCommand, ElementName=Root}"
                                              CommandParameter="网盘" />
                                </MenuItem>
                            </MenuItem>
                        </Menu>
                    </StackPanel>

                    <StackPanel Width="194" Margin="0,0,6,4">
                        <TextBlock Text="标签" Visibility="Collapsed" Style="{StaticResource BodyMutedTextStyle}" />
                        <Menu>
                            <MenuItem Header="{Binding TagFilterMenuHeader}" Style="{StaticResource LibraryFilterMenuItemStyle}">
                                <MenuItem Header="清除标签"
                                          Command="{Binding DataContext.ClearTagFilterCommand, ElementName=Root}" />
                                <Separator />
                                <MenuItem StaysOpenOnClick="True">
                                    <MenuItem.Header>
                                        <ScrollViewer Width="660" MaxHeight="420" VerticalScrollBarVisibility="Auto">
                                            <Grid Margin="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="220" />
                                                    <ColumnDefinition Width="220" />
                                                    <ColumnDefinition Width="220" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                                    <TextBlock Text="类型标签" Style="{StaticResource BodyMutedTextStyle}" />
                                                    <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding TypeTagOptions}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <WrapPanel />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <CheckBox MinWidth="82"
                                                                          Margin="0,0,8,8"
                                                                          Content="{Binding Label}"
                                                                          IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1" Margin="0,0,16,0">
                                                    <TextBlock Text="情绪标签" Style="{StaticResource BodyMutedTextStyle}" />
                                                    <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding EmotionTagOptions}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <WrapPanel />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <CheckBox MinWidth="82"
                                                                          Margin="0,0,8,8"
                                                                          Content="{Binding Label}"
                                                                          IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="场景标签" Style="{StaticResource BodyMutedTextStyle}" />
                                                    <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding SceneTagOptions}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <WrapPanel />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <CheckBox MinWidth="82"
                                                                          Margin="0,0,8,8"
                                                                          Content="{Binding Label}"
                                                                          IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Grid>
                                        </ScrollViewer>
                                    </MenuItem.Header>
                                </MenuItem>
                            </MenuItem>
                        </Menu>
                    </StackPanel>

                    <StackPanel Width="100" Margin="0,0,6,4">
                        <TextBlock Text="年代" Visibility="Collapsed" Style="{StaticResource BodyMutedTextStyle}" />
                        <ComboBox SelectedItem="{Binding SelectedDecadeFilter}"
                                  ItemsSource="{Binding DecadeFilterOptions}"
                                  Style="{StaticResource LibraryCompactComboBoxStyle}" />
                    </StackPanel>

                    <StackPanel Width="138" Margin="0,0,6,4">
                        <TextBlock Text="收藏状态" Visibility="Collapsed" Style="{StaticResource BodyMutedTextStyle}" />
                        <Menu>
                            <MenuItem Header="{Binding CollectionStatusMenuHeader}" Style="{StaticResource LibraryFilterMenuItemStyle}">
                                <MenuItem Header="全部"
                                          Command="{Binding DataContext.SelectCollectionStatusCommand, ElementName=Root}"
                                          CommandParameter="全部" />
                                <MenuItem Header="喜爱"
                                          Command="{Binding DataContext.SelectCollectionStatusCommand, ElementName=Root}"
                                          CommandParameter="喜爱" />
                                <MenuItem Header="想看"
                                          Command="{Binding DataContext.SelectCollectionStatusCommand, ElementName=Root}"
                                          CommandParameter="想看" />
                                <MenuItem Header="不想看"
                                          Command="{Binding DataContext.SelectCollectionStatusCommand, ElementName=Root}"
                                          CommandParameter="不想看" />
                            </MenuItem>
                        </Menu>
                    </StackPanel>

                    <StackPanel Width="118" Margin="0,0,6,4">
                        <TextBlock Text="观看状态" Visibility="Collapsed" Style="{StaticResource BodyMutedTextStyle}" />
                        <ComboBox SelectedItem="{Binding SelectedWatchedFilter}"
                                  ItemsSource="{Binding WatchedFilterOptions}"
                                  Style="{StaticResource LibraryCompactComboBoxStyle}" />
                    </StackPanel>
                </WrapPanel>

                <WrapPanel Grid.Row="4" VerticalAlignment="Center">
                    <WrapPanel.Style>
                        <Style TargetType="WrapPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBatchSelectionMode}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </WrapPanel.Style>
                    <TextBlock Margin="0,0,18,0"
                               VerticalAlignment="Center"
                               Text="{Binding SelectedCount, StringFormat=已选 {0} 项}"
                               Style="{StaticResource BodyTextStyle}" />
                    <Button Margin="0,0,10,10"
                            Content="&#x5168;&#x9009;&#x5F53;&#x524D;&#x5217;&#x8868;"
                            Command="{Binding SelectVisibleItemsCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    <Button Margin="0,0,10,10"
                            Content="&#x6E05;&#x7A7A;&#x9009;&#x62E9;"
                            Command="{Binding ClearBatchSelectionCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    <Button Margin="0,0,10,10"
                            Content="标记为已看"
                            Command="{Binding BatchMarkWatchedCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    <Button Margin="0,0,10,10"
                            Content="标记为未看"
                            Command="{Binding BatchMarkUnwatchedCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    <Button Margin="0,0,10,10"
                            Content="AI &#x8F85;&#x52A9;&#x8BC6;&#x522B;"
                            Command="{Binding BatchAutoIdentifyCommand}"
                            Style="{StaticResource PrimaryButtonStyle}" />
                    <Button Margin="0,0,10,10"
                            Content="取消"
                            Command="{Binding CancelBatchOperationCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CanCancelBatchOperation}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Margin="0,0,10,10"
                            Content="移出媒体库"
                            Command="{Binding BatchRemoveFromLibraryCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    <Button Margin="0,0,10,10"
                            Content="删除记录"
                            Command="{Binding BatchDeleteMovieRecordsCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    <Button Margin="0,0,10,10"
                            Content="人工聚合为季"
                            Command="{Binding OpenManualAggregationCommand}"
                            Style="{StaticResource PrimaryButtonStyle}" />
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Border Style="{StaticResource PageCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel>
                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button Content="已移出媒体库"
                                    Command="{Binding OpenRemovedLibraryCommand}"
                                    Style="{StaticResource LibraryToolbarButtonStyle}" />
                            <Border Margin="8,0,0,0"
                                    Padding="2"
                                    Background="{DynamicResource BrushSurfaceAlt}"
                                    BorderBrush="{DynamicResource BrushBorder}"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="海报"
                                            Command="{Binding SwitchToPosterViewCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource LibraryToolbarButtonStyle}">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="BorderBrush" Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPosterView}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource BrushAccent}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                                                        <Setter Property="Foreground" Value="{DynamicResource BrushOnAccent}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Margin="2,0,0,0"
                                            Content="列表"
                                            Command="{Binding SwitchToListViewCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource LibraryToolbarButtonStyle}">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="BorderBrush" Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsListView}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource BrushAccent}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                                                        <Setter Property="Foreground" Value="{DynamicResource BrushOnAccent}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Border>
                            <Button Margin="10,0,0,0"
                                    Content="{Binding BatchSelectionButtonText}"
                                    Command="{Binding ToggleBatchSelectionModeCommand}"
                                    Style="{StaticResource LibraryToolbarButtonStyle}" />
                        </StackPanel>

                        <StackPanel Margin="20,0,0,0"
                                    VerticalAlignment="Center">
                            <TextBlock FontSize="12" Text="{Binding StatusMessage}" Style="{StaticResource BodyMutedTextStyle}" />
                            <TextBlock Margin="0,4,0,0"
                                       Text="{Binding BatchResultSummary}"
                                       TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource BodyTextStyle}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasBatchResultSummary}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </DockPanel>

                    <ListBox Grid.Row="1"
                             Margin="0,18,0,0"
                             Background="Transparent"
                             BorderThickness="0"
                             ItemsSource="{Binding Movies}"
                             ScrollViewer.CanContentScroll="True"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListBox.Style>
                            <Style TargetType="ListBox">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPosterView}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.Style>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Focusable" Value="False" />
                                <Setter Property="HorizontalContentAlignment" Value="Left" />
                                <Setter Property="VerticalContentAlignment" Value="Top" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <controls:VirtualizingWrapPanel>
                                    <controls:VirtualizingWrapPanel.Style>
                                        <Style TargetType="{x:Type controls:VirtualizingWrapPanel}">
                                            <Setter Property="ItemWidth" Value="192" />
                                            <Setter Property="ItemHeight" Value="282" />
                                            <Setter Property="OverscanRows" Value="1" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                    <Setter Property="ItemWidth" Value="199" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </controls:VirtualizingWrapPanel.Style>
                                </controls:VirtualizingWrapPanel>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="180"
                                            Height="270"
                                            Margin="0,0,12,12"
                                            Background="{StaticResource LibraryMediaCardBackgroundBrush}"
                                            BorderBrush="{DynamicResource BrushBorder}"
                                            BorderThickness="1"
                                            CornerRadius="18"
                                            ClipToBounds="True">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Cursor" Value="Arrow" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsBatchSelectionMode}" Value="True">
                                                        <Setter Property="Cursor" Value="Hand" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding DataContext.OpenOrToggleSelectionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}" />
                                        </Border.InputBindings>
                                        <Grid>
                                            <Border Background="{StaticResource LibraryMediaCardSurfaceBrush}" />
                                            <Image helpers:PosterCacheImageBehavior.DecodePixelWidth="240"
                                                   helpers:PosterCacheImageBehavior.Source="{Binding PosterRemoteUrl}"
                                                   Stretch="UniformToFill">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasPoster}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                            <Grid>
                                                <Grid.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="#00000000" Offset="0" />
                                                        <GradientStop Color="#16000000" Offset="0.45" />
                                                        <GradientStop Color="#A6000000" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Grid.Background>
                                            </Grid>
                                            <TextBlock HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Text="无海报">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource LibraryMediaMutedTextStyle}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasPoster}" Value="False">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <Border HorizontalAlignment="Left"
                                                    VerticalAlignment="Top"
                                                    Margin="8"
                                                    MaxWidth="88"
                                                    Style="{StaticResource LibraryMediaChipStyle}">
                                                <TextBlock Text="{Binding CategoryTagText}"
                                                           Style="{StaticResource LibraryMediaChipTextStyle}" />
                                            </Border>
                                            <Border HorizontalAlignment="Right"
                                                    VerticalAlignment="Top"
                                                    Margin="8"
                                                    MaxWidth="88"
                                                    Style="{StaticResource LibraryMediaChipStyle}">
                                                <TextBlock Text="{Binding SourceBadgeText}"
                                                           Style="{StaticResource LibraryMediaChipTextStyle}" />
                                            </Border>
                                            <Button HorizontalAlignment="Center"
                                                    VerticalAlignment="Top"
                                                    Margin="0,8,0,0"
                                                    Command="{Binding DataContext.ToggleItemSelectionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource SelectionDotButtonStyle}" />
                                            <StackPanel VerticalAlignment="Bottom" Margin="10">
                                                <TextBlock Text="{Binding Title}"
                                                           MaxHeight="36"
                                                           Style="{StaticResource LibraryMediaTitleTextStyle}" />
                                                <TextBlock Margin="0,3,0,0"
                                                           Text="{Binding ReleaseDateText}"
                                                           Style="{StaticResource LibraryMediaMutedTextStyle}" />
                                                <Border Margin="0,5,0,0"
                                                        helpers:TrimmedTextToolTipBehavior.FullText="{Binding PosterTagToolTipText}"
                                                        helpers:TrimmedTextToolTipBehavior.VisibleText="{Binding PosterTagLine}"
                                                        Style="{StaticResource LibraryTagLineContainerStyle}">
                                                    <TextBlock Style="{StaticResource LibraryMediaMutedTextStyle}">
                                                        <Run Text="{Binding PosterTagGroupOneText, Mode=OneWay}" />
                                                        <Run Text="{Binding PosterTagSeparatorAfterOneText, Mode=OneWay}"
                                                             Foreground="{StaticResource LibraryTagDividerBrush}" />
                                                        <Run Text="{Binding PosterTagGroupTwoText, Mode=OneWay}" />
                                                        <Run Text="{Binding PosterTagSeparatorAfterTwoText, Mode=OneWay}"
                                                             Foreground="{StaticResource LibraryTagDividerBrush}" />
                                                        <Run Text="{Binding PosterTagGroupThreeText, Mode=OneWay}" />
                                                    </TextBlock>
                                                </Border>
                                                <Grid Margin="0,7,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="8" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <ProgressBar VerticalAlignment="Center"
                                                                 Value="{Binding ProgressValue, Mode=OneWay}"
                                                                 Style="{StaticResource LibraryMediaProgressBarStyle}" />
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding ProgressLabel}"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource LibraryMediaCardTextBrush}" />
                                                </Grid>
                                            </StackPanel>
                                            <Button HorizontalAlignment="Stretch"
                                                    VerticalAlignment="Bottom"
                                                    Height="30"
                                                    Margin="10,0,10,10"
                                                    Opacity="0"
                                                    IsHitTestVisible="False"
                                                    Command="{Binding DataContext.OpenMovieCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsBatchSelectionMode}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <ListBox Grid.Row="1"
                             Margin="0,18,0,0"
                             ItemsSource="{Binding Movies}"
                             ScrollViewer.CanContentScroll="True"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListBox.Style>
                            <Style TargetType="ListBox">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsListView}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.Style>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,9" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Focusable" Value="False" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border MinHeight="74"
                                        Margin="0,0,18,0"
                                        Padding="7"
                                        Background="{StaticResource LibraryMediaCardBackgroundBrush}"
                                        BorderBrush="{DynamicResource BrushBorder}"
                                        BorderThickness="1"
                                        CornerRadius="14">
                                    <Grid Style="{StaticResource BatchSelectableListItemContentStyle}">
                                        <Grid.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding DataContext.OpenOrToggleSelectionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}" />
                                        </Grid.InputBindings>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="54" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Button Grid.Column="0"
                                                Margin="0,0,8,0"
                                                VerticalAlignment="Center"
                                                Command="{Binding DataContext.ToggleItemSelectionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource SelectionDotButtonStyle}" />

                                        <Border Grid.Column="1"
                                                Width="42"
                                                Height="46"
                                                VerticalAlignment="Center"
                                                Background="{StaticResource LibraryMediaCardAccentBrush}"
                                                CornerRadius="9">
                                            <StackPanel HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding RatingDisplayText}"
                                                           HorizontalAlignment="Center"
                                                           FontSize="15"
                                                           FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{StaticResource LibraryMediaCardAccentTextBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsHighRating}" Value="True">
                                                                    <Setter Property="Foreground" Value="{StaticResource LibraryRatingGoldBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>

                                        <StackPanel Grid.Column="2" Margin="8,0,6,0" VerticalAlignment="Center">
                                            <TextBlock ToolTip="{Binding ListTitleLineText}"
                                                       TextWrapping="NoWrap"
                                                       Style="{StaticResource LibraryMediaTitleTextStyle}">
                                                <Run Text="{Binding Title, Mode=OneWay}" />
                                                <Run Text="{Binding OriginalTitleSeparatorText, Mode=OneWay}" />
                                                <Run Text="{Binding OriginalTitle, Mode=OneWay}" />
                                                <Run Text="{Binding ListTitleMetaSpacingText, Mode=OneWay}" />
                                                <Run Text="{Binding ListTitleMetaText, Mode=OneWay}"
                                                     FontSize="10.5"
                                                     FontWeight="Normal"
                                                     Foreground="{StaticResource LibraryMediaCardMutedTextBrush}" />
                                            </TextBlock>
                                            <Border Margin="0,5,0,0"
                                                    helpers:TrimmedTextToolTipBehavior.FullText="{Binding ListTagToolTipText}"
                                                    helpers:TrimmedTextToolTipBehavior.VisibleText="{Binding ListTagLine}"
                                                    Style="{StaticResource LibraryTagLineContainerStyle}">
                                                <TextBlock Style="{StaticResource LibraryMediaMutedTextStyle}">
                                                    <Run Text="{Binding ListDateRuntimeText, Mode=OneWay}" />
                                                    <Run Text="{Binding ListDateAndTagSpacingText, Mode=OneWay}" />
                                                    <Run Text="{Binding ListTagGroupOneText, Mode=OneWay}" />
                                                    <Run Text="{Binding ListTagSeparatorAfterOneText, Mode=OneWay}"
                                                         Foreground="{StaticResource LibraryTagDividerBrush}" />
                                                    <Run Text="{Binding ListTagGroupTwoText, Mode=OneWay}" />
                                                    <Run Text="{Binding ListTagSeparatorAfterTwoText, Mode=OneWay}"
                                                         Foreground="{StaticResource LibraryTagDividerBrush}" />
                                                    <Run Text="{Binding ListTagGroupThreeText, Mode=OneWay}" />
                                                </TextBlock>
                                            </Border>
                                            <Grid Margin="0,7,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <ProgressBar VerticalAlignment="Center"
                                                             Value="{Binding ProgressValue, Mode=OneWay}"
                                                             Style="{StaticResource LibraryMediaProgressBarStyle}" />
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding ProgressLabel}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource LibraryMediaCardTextBrush}" />
                                            </Grid>
                                        </StackPanel>

                                        <StackPanel Grid.Column="3"
                                                    Width="82"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center">
                                            <Border Margin="0,0,0,7"
                                                    HorizontalAlignment="Right"
                                                    MaxWidth="80"
                                                    Style="{StaticResource LibraryMediaChipStyle}">
                                                <TextBlock Text="{Binding SourceBadgeText}"
                                                           Style="{StaticResource LibraryMediaChipTextStyle}" />
                                            </Border>
                                            <Border HorizontalAlignment="Right"
                                                    MaxWidth="80"
                                                    Style="{StaticResource LibraryMediaChipStyle}">
                                                <TextBlock Text="{Binding DetailHintText}"
                                                           Style="{StaticResource LibraryMediaChipTextStyle}" />
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Border Grid.Row="1"
                            Margin="0,18,0,0"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Top">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource EmptyStateContainerStyle}">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasMovies}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock Text="{Binding EmptyStateTitle}"
                                       Style="{StaticResource EmptyStateTitleStyle}" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="{Binding EmptyStateMessage}"
                                       Style="{StaticResource EmptyStateDescriptionStyle}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.RowSpan="3"
                Background="#99000000">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsManualAggregationDialogOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border Width="980"
                    MaxHeight="700"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Style="{StaticResource PageCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="人工聚合为未识别季" Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="只为当前选中的未识别播放源创建集；重复集号会作为同一集的多播放源，不会补空集。"
                                   TextWrapping="Wrap"
                                   Style="{StaticResource BodyMutedTextStyle}" />
                    </StackPanel>

                    <Grid Grid.Row="1" Margin="0,18,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="剧名" Style="{StaticResource BodyMutedTextStyle}" />
                            <TextBox Margin="0,6,0,0"
                                     Text="{Binding ManualAggregationSeriesTitle, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource FormTextBoxStyle}">
                                        <Setter Property="IsEnabled" Value="True" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsManualAggregationBusy}" Value="True">
                                                <Setter Property="IsEnabled" Value="False" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="季号" Style="{StaticResource BodyMutedTextStyle}" />
                            <TextBox Margin="0,6,0,0"
                                     Text="{Binding ManualAggregationSeasonNumberText, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource FormTextBoxStyle}">
                                        <Setter Property="IsEnabled" Value="True" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsManualAggregationBusy}" Value="True">
                                                <Setter Property="IsEnabled" Value="False" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="季名称" Style="{StaticResource BodyMutedTextStyle}" />
                            <TextBox Margin="0,6,0,0"
                                     Text="{Binding ManualAggregationSeasonTitle, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource FormTextBoxStyle}">
                                        <Setter Property="IsEnabled" Value="True" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsManualAggregationBusy}" Value="True">
                                                <Setter Property="IsEnabled" Value="False" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                            <TextBlock Margin="0,6,0,0"
                                       Text="{Binding ManualAggregationSeasonDisplayText}"
                                       Style="{StaticResource BodyMutedTextStyle}" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="2">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="没有可聚合的播放源">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasManualAggregationSources}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ListBox ItemsSource="{Binding ManualAggregationSources}">
                            <ListBox.Style>
                                <Style TargetType="ListBox" BasedOn="{StaticResource SectionListBoxStyle}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasManualAggregationSources}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.Style>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8"
                                            Padding="12"
                                            Background="{DynamicResource BrushSurfaceAlt}"
                                            BorderBrush="{DynamicResource BrushBorder}"
                                            BorderThickness="1"
                                            CornerRadius="10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="160" />
                                                <ColumnDefinition Width="180" />
                                                <ColumnDefinition Width="120" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Margin="0,0,16,0">
                                                <TextBlock Text="{Binding FileName}"
                                                           TextTrimming="CharacterEllipsis"
                                                           Style="{StaticResource BodyTextStyle}" />
                                                <TextBlock Margin="0,5,0,0"
                                                           Text="{Binding SourceSummary}"
                                                           TextWrapping="Wrap"
                                                           Style="{StaticResource BodyMutedTextStyle}" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       Margin="0,0,14,0"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding CurrentBindingText}"
                                                       TextWrapping="Wrap"
                                                       Style="{StaticResource BodyMutedTextStyle}" />
                                            <TextBlock Grid.Column="2"
                                                       Margin="0,0,14,0"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding EpisodeNumberSourceText}"
                                                       Style="{StaticResource BodyMutedTextStyle}" />
                                            <TextBox Grid.Column="3"
                                                     VerticalAlignment="Center"
                                                     Text="{Binding EpisodeNumberText, UpdateSourceTrigger=PropertyChanged}">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox" BasedOn="{StaticResource FormTextBoxStyle}">
                                                        <Setter Property="IsEnabled" Value="True" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding DataContext.IsManualAggregationBusy, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                                <Setter Property="IsEnabled" Value="False" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>

                    <DockPanel Grid.Row="3" Margin="0,16,0,0" LastChildFill="True">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Margin="0,0,10,0"
                                    Content="取消"
                                    Command="{Binding CancelManualAggregationCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Margin="0,0,10,0"
                                    Content="聚合后识别"
                                    Command="{Binding ApplyManualAggregationAndIdentifyCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Content="聚合"
                                    Command="{Binding ApplyManualAggregationCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                        </StackPanel>
                        <TextBlock Margin="0,0,18,0"
                                   VerticalAlignment="Center"
                                   Text="{Binding ManualAggregationStatusMessage}"
                                   TextWrapping="Wrap"
                                   Style="{StaticResource BodyMutedTextStyle}" />
                    </DockPanel>
                </Grid>
            </Border>
        </Border>

        <Border Grid.RowSpan="3"
                Background="#99000000">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsRemovedLibraryPanelOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border Width="860"
                    MaxHeight="640"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Style="{StaticResource PageCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel>
                        <Button DockPanel.Dock="Right"
                                Content="关闭"
                                Command="{Binding CloseRemovedLibraryCommand}"
                                Style="{StaticResource SecondaryButtonStyle}" />
                        <StackPanel>
                            <TextBlock Text="已移出媒体库" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Margin="0,6,18,0"
                                       Text="{Binding RemovedLibraryStatusMessage}"
                                       TextWrapping="Wrap"
                                       Style="{StaticResource BodyMutedTextStyle}" />
                        </StackPanel>
                    </DockPanel>

                    <Grid Grid.Row="2">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="暂无已移出媒体库项目"
	                                   >
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasRemovedLibraryItems}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <ListBox ItemsSource="{Binding RemovedLibraryGroups}">
                            <ListBox.Style>
                                <Style TargetType="ListBox" BasedOn="{StaticResource SectionListBoxStyle}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasRemovedLibraryItems}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.Style>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                    <Expander IsExpanded="{Binding IsExpanded, Mode=TwoWay}">
                                        <Expander.Style>
                                            <Style TargetType="Expander">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsTvGroup}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Expander.Style>
                                        <Expander.Header>
                                            <Border Padding="14"
                                                    BorderBrush="{DynamicResource BrushBorder}"
                                                    BorderThickness="1"
                                                    CornerRadius="12">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{DynamicResource BrushSurfaceAlt}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsTvGroup}" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource BrushAccentSoft}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="112" />
                                                        <ColumnDefinition Width="124" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Margin="0,0,16,0">
                                                        <TextBlock Text="{Binding Title}" Style="{StaticResource SectionTitleTextStyle}" />
                                                        <TextBlock Margin="0,5,0,0"
                                                                   Text="{Binding HeaderSubtitle}"
                                                                   TextWrapping="Wrap"
                                                                   Style="{StaticResource BodyMutedTextStyle}" />
                                                    </StackPanel>
                                                    <Button Grid.Column="1"
                                                            Margin="0,0,8,0"
                                                            Content="恢复全部"
                                                            Command="{Binding DataContext.RestoreRemovedLibraryGroupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsTvGroup}" Value="False">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                    <Button Grid.Column="2"
                                                            Content="删除全部记录"
                                                            Command="{Binding DataContext.DeleteRemovedLibraryGroupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsTvGroup}" Value="False">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </Expander.Header>

                                        <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding Items}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="20,0,0,8"
                                                            Background="{DynamicResource BrushSurfaceAlt}"
                                                            BorderBrush="{DynamicResource BrushBorder}"
                                                            BorderThickness="1"
                                                            CornerRadius="12">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="4" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="100" />
                                                                <ColumnDefinition Width="100" />
                                                                <ColumnDefinition Width="110" />
                                                            </Grid.ColumnDefinitions>
                                                            <Border Background="{DynamicResource BrushAccent}" CornerRadius="12,0,0,12" />
                                                            <StackPanel Grid.Column="1" Margin="12,10,18,10">
                                                                <TextBlock Text="{Binding Title}" Style="{StaticResource SectionTitleTextStyle}" />
                                                                <WrapPanel Margin="0,6,0,0">
                                                                    <TextBlock Margin="0,0,12,0" Text="{Binding MediaKindText}" Style="{StaticResource BodyMutedTextStyle}" />
                                                                    <TextBlock Margin="0,0,12,0" Text="{Binding SourceStatusText}" Style="{StaticResource BodyMutedTextStyle}" />
                                                                    <TextBlock Text="{Binding StateSummary}" Style="{StaticResource BodyMutedTextStyle}" />
                                                                </WrapPanel>
                                                            </StackPanel>
                                                            <Button Grid.Column="2"
                                                                    Margin="0,10,8,10"
                                                                    Content="恢复"
                                                                    Command="{Binding DataContext.RestoreRemovedLibraryItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Style="{StaticResource PrimaryButtonStyle}" />
                                                            <Button Grid.Column="3"
                                                                    Margin="0,10,8,10"
                                                                    Content="详情"
                                                                    Command="{Binding DataContext.OpenRemovedLibraryDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Style="{StaticResource SecondaryButtonStyle}" />
                                                            <Button Grid.Column="4"
                                                                    Margin="0,10,12,10"
                                                                    Content="删除记录"
                                                                    Command="{Binding DataContext.DeleteRemovedLibraryItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Style="{StaticResource SecondaryButtonStyle}" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Expander>
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.Style>
                                            <Style TargetType="ItemsControl">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMovieGroup}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ItemsControl.Style>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,8"
                                                        Background="{DynamicResource BrushSurfaceAlt}"
                                                        BorderBrush="{DynamicResource BrushBorder}"
                                                        BorderThickness="1"
                                                        CornerRadius="12">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="4" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="100" />
                                                            <ColumnDefinition Width="100" />
                                                            <ColumnDefinition Width="110" />
                                                        </Grid.ColumnDefinitions>
                                                        <Border Background="{DynamicResource BrushAccent}" CornerRadius="12,0,0,12" />
                                                        <StackPanel Grid.Column="1" Margin="12,10,18,10">
                                                            <TextBlock Text="{Binding Title}" Style="{StaticResource SectionTitleTextStyle}" />
                                                            <WrapPanel Margin="0,6,0,0">
                                                                <TextBlock Margin="0,0,12,0" Text="{Binding MediaKindText}" Style="{StaticResource BodyMutedTextStyle}" />
                                                                <TextBlock Margin="0,0,12,0" Text="{Binding SourceStatusText}" Style="{StaticResource BodyMutedTextStyle}" />
                                                                <TextBlock Text="{Binding StateSummary}" Style="{StaticResource BodyMutedTextStyle}" />
                                                            </WrapPanel>
                                                        </StackPanel>
                                                        <Button Grid.Column="2"
                                                                Margin="0,10,8,10"
                                                                Content="恢复"
                                                                Command="{Binding DataContext.RestoreRemovedLibraryItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource PrimaryButtonStyle}" />
                                                        <Button Grid.Column="3"
                                                                Margin="0,10,8,10"
                                                                Content="详情"
                                                                Command="{Binding DataContext.OpenRemovedLibraryDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource SecondaryButtonStyle}" />
                                                        <Button Grid.Column="4"
                                                                Margin="0,10,12,10"
                                                                Content="删除记录"
                                                                Command="{Binding DataContext.DeleteRemovedLibraryItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource SecondaryButtonStyle}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
