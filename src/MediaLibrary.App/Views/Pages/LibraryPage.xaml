                                <MenuItem Header="电视剧" IsCheckable="True" IsChecked="{Binding IsContentTypeTvSelected, Mode=OneWay}" StaysOpenOnClick="True" Command="{Binding SelectContentTypeCommand}" CommandParameter="电视剧" Style="{StaticResource LibraryFilterMenuItemStyle}" />
                                <MenuItem Header="其他" IsCheckable="True" IsChecked="{Binding IsContentTypeOtherSelected, Mode=OneWay}" StaysOpenOnClick="True" Command="{Binding SelectContentTypeCommand}" CommandParameter="其他" Style="{StaticResource LibraryFilterMenuItemStyle}" />
                            </ContextMenu>
                        </Button.ContextMenu>
