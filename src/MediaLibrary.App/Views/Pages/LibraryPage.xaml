                                                </ScrollViewer>
                                            </MenuItem.Header>
                                        </MenuItem>
                                    </MenuItem>
                                    <MenuItem Header="场景标签" Style="{StaticResource LibraryFilterSubmenuItemStyle}">
                                        <MenuItem StaysOpenOnClick="True" Style="{StaticResource LibraryFilterTagPanelMenuItemStyle}">
                                            <MenuItem.Header>
                                                <ScrollViewer Width="420" MaxHeight="360" VerticalScrollBarVisibility="Auto">
                                                    <ItemsControl ItemsSource="{Binding SceneTagOptionRows}"
                                                                  ItemTemplate="{StaticResource LibraryFilterTagRowItemTemplate}" />
                                                </ScrollViewer>
                                            </MenuItem.Header>
                                        </MenuItem>
                                    </MenuItem>
                                </MenuItem>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button x:Name="DecadeFilterButton"
                            Grid.Column="8"
                            Content="{Binding DecadeButtonText}"
                            Click="OpenDecadeFilterMenu"
                            Style="{StaticResource LibraryFilterButtonStyle}" />
                    <Button x:Name="CollectionStatusFilterButton"
                            Grid.Column="10"
                            Content="{Binding CollectionStatusButtonText}"
                            Click="OpenButtonContextMenu"
                            Style="{StaticResource LibraryFilterButtonStyle}">
                        <Button.ContextMenu>
                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                         Style="{StaticResource LibraryFilterContextMenuStyle}">
                                <MenuItem Header="全部" IsCheckable="True" IsChecked="{Binding IsCollectionStatusAllSelected, Mode=OneWay}" Command="{Binding SelectCollectionStatusCommand}" CommandParameter="全部" Style="{StaticResource LibraryFilterMenuItemStyle}" />
                                <MenuItem Header="喜爱" IsCheckable="True" IsChecked="{Binding IsCollectionStatusFavoriteSelected, Mode=OneWay}" StaysOpenOnClick="True" Command="{Binding SelectCollectionStatusCommand}" CommandParameter="喜爱" Style="{StaticResource LibraryFilterMenuItemStyle}" />
                                <MenuItem Header="想看" IsCheckable="True" IsChecked="{Binding IsCollectionStatusWantToWatchSelected, Mode=OneWay}" StaysOpenOnClick="True" Command="{Binding SelectCollectionStatusCommand}" CommandParameter="想看" Style="{StaticResource LibraryFilterMenuItemStyle}" />
                                <MenuItem Header="不想看" IsCheckable="True" IsChecked="{Binding IsCollectionStatusNotInterestedSelected, Mode=OneWay}" StaysOpenOnClick="True" Command="{Binding SelectCollectionStatusCommand}" CommandParameter="不想看" Style="{StaticResource LibraryFilterMenuItemStyle}" />
                                <MenuItem Header="其他" IsCheckable="True" IsChecked="{Binding IsCollectionStatusOtherSelected, Mode=OneWay}" StaysOpenOnClick="True" Command="{Binding SelectCollectionStatusCommand}" CommandParameter="其他" Style="{StaticResource LibraryFilterMenuItemStyle}" />
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button x:Name="WatchedStatusFilterButton"
                            Grid.Column="12"
                            Content="{Binding WatchedFilterButtonText}"
                            Click="OpenButtonContextMenu"
                            Tag="{Binding SelectedWatchedFilter}"
                            Style="{StaticResource LibraryFilterButtonStyle}">
                        <Button.ContextMenu>
                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                         Style="{StaticResource LibraryFilterContextMenuStyle}">
                                <MenuItem Header="全部" Command="{Binding SelectWatchedFilterCommand}" CommandParameter="全部" Style="{StaticResource LibraryFilterMenuItemStyle}" />
                                <MenuItem Header="已看" Command="{Binding SelectWatchedFilterCommand}" CommandParameter="已看" Style="{StaticResource LibraryFilterMenuItemStyle}" />
                                <MenuItem Header="未看" Command="{Binding SelectWatchedFilterCommand}" CommandParameter="未看" Style="{StaticResource LibraryFilterMenuItemStyle}" />
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button x:Name="BatchSelectionToggleButton"
                            Grid.Column="14"
