<UserControl x:Class="MediaLibrary.App.Views.Pages.LibraryPage"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MediaLibrary.App.Controls"
             xmlns:helpers="clr-namespace:MediaLibrary.App.Helpers">
    <UserControl.Resources>
        <SolidColorBrush x:Key="LibraryMediaCardBackgroundBrush" Color="#121821" />
        <SolidColorBrush x:Key="LibraryMediaCardSurfaceBrush" Color="#202938" />
        <SolidColorBrush x:Key="LibraryMediaCardTextBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="LibraryMediaCardMutedTextBrush" Color="#D8DEE9" />
        <SolidColorBrush x:Key="LibraryMediaCardAccentBrush" Color="#E2E8F0" />
        <SolidColorBrush x:Key="LibraryMediaCardAccentTextBrush" Color="#111827" />
        <SolidColorBrush x:Key="LibraryMediaCardDividerBrush" Color="#E5E7EB" />
        <SolidColorBrush x:Key="LibraryMediaProgressFillBrush" Color="#67C7F2" />
        <SolidColorBrush x:Key="LibraryMediaProgressTrackBrush" Color="#E5E7EB" />
        <SolidColorBrush x:Key="LibraryTagDividerBrush" Color="#7DD3FC" />
        <SolidColorBrush x:Key="LibraryRatingGoldBrush" Color="#F5C84B" />

        <Style x:Key="LibraryMediaProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="4" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="Background" Value="{StaticResource LibraryMediaProgressTrackBrush}" />
            <Setter Property="Foreground" Value="{StaticResource LibraryMediaProgressFillBrush}" />
            <Setter Property="Visibility" Value="Visible" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid Height="{TemplateBinding Height}"
                              SnapsToDevicePixels="True">
                            <Border x:Name="PART_Track"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="2" />
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="2" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LibraryModernScrollBarThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border Width="6"
                                Margin="0"
                                Background="{DynamicResource BrushForegroundMuted}"
                                CornerRadius="3"
                                Opacity="0.58" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LibraryModernScrollRepeatButtonStyle" TargetType="{x:Type RepeatButton}">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LibraryModernScrollBarStyle" TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="6" />
            <Setter Property="MinWidth" Value="6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Width="{TemplateBinding Width}"
                              Background="Transparent">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}"
                                                  Style="{StaticResource LibraryModernScrollRepeatButtonStyle}" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource LibraryModernScrollBarThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}"
                                                  Style="{StaticResource LibraryModernScrollRepeatButtonStyle}" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LibraryMediaChipStyle" TargetType="Border">
            <Setter Property="Padding" Value="7,4" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="{StaticResource LibraryMediaCardAccentBrush}" />
            <Setter Property="Opacity" Value="0.9" />
        </Style>

        <Style x:Key="LibraryMediaChipTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource LibraryMediaCardAccentTextBrush}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="LibraryMediaMutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource LibraryMediaCardMutedTextBrush}" />
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="LibraryTagLineContainerStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="450" />
            <Setter Property="ToolTipService.BetweenShowDelay" Value="0" />
            <Setter Property="ToolTipService.ShowDuration" Value="20000" />
        </Style>

        <Style x:Key="LibraryMediaTitleTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource LibraryMediaCardTextBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="LibrarySearchBoxStyle" TargetType="TextBox" BasedOn="{StaticResource SearchBoxStyle}">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="10,3" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="LibraryCompactComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource FormComboBoxStyle}">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="LibraryFilterMenuItemStyle" TargetType="MenuItem" BasedOn="{StaticResource MenuItemStyle}">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Padding" Value="9,4" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="LibraryToolbarMenuStyle" TargetType="Menu">
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="LibraryToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource SmallButtonStyle}">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>

        <Style x:Key="LibraryFilterButtonStyle" TargetType="Button" BasedOn="{StaticResource LibraryToolbarButtonStyle}">
            <Setter Property="Height" Value="28" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Padding" Value="10,4" />
        </Style>

        <Style x:Key="LibraryPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>

        <Style x:Key="LibrarySecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>

        <Style x:Key="LibrarySearchClearButtonStyle" TargetType="Button" BasedOn="{StaticResource SmallIconButtonStyle}">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="MinWidth" Value="22" />
            <Setter Property="MinHeight" Value="22" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource BrushForegroundMuted}" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding SearchText}" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
                <DataTrigger Binding="{Binding SearchText}" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LibraryBatchToggleButtonStyle" TargetType="Button" BasedOn="{StaticResource LibraryToolbarButtonStyle}">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsBatchSelectionMode}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LibraryToolbarIconButtonStyle" TargetType="Button" BasedOn="{StaticResource SmallIconButtonStyle}">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="30" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>

        <Style x:Key="SelectionDotButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="11" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding SelectionDotVisible}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                </DataTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="BatchSelectableCardStyle" TargetType="Border" BasedOn="{StaticResource CompactCardStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsBatchSelectionMode}" Value="True">
                    <Setter Property="Cursor" Value="Hand" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="BatchSelectableListItemContentStyle" TargetType="Grid">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsBatchSelectionMode}" Value="True">
                    <Setter Property="Cursor" Value="Hand" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LibraryBatchToolbarStyle" TargetType="Border">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Background" Value="{DynamicResource BrushSurfaceAlt}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{StaticResource RadiusCompactCard}" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsBatchSelectionMode}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LibraryBatchStatusPillStyle" TargetType="Border">
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Background" Value="{DynamicResource BrushAccentSoft}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style x:Key="LibraryBatchInfoButtonStyle" TargetType="Button" BasedOn="{StaticResource LibraryToolbarButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource BrushInfo}" />
            <Setter Property="Foreground" Value="{DynamicResource BrushOnAccent}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushInfo}" />
        </Style>

        <Style x:Key="LibraryBatchWarningButtonStyle" TargetType="Button" BasedOn="{StaticResource LibraryToolbarButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource BrushWarning}" />
            <Setter Property="Foreground" Value="{DynamicResource BrushOnAccent}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushWarning}" />
        </Style>

        <Style x:Key="LibraryBatchDangerButtonStyle" TargetType="Button" BasedOn="{StaticResource LibraryToolbarButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource BrushDanger}" />
            <Setter Property="Foreground" Value="{DynamicResource BrushOnAccent}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushDanger}" />
        </Style>
    </UserControl.Resources>

    <Grid Background="Transparent" PreviewMouseDown="OnRootPreviewMouseDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Padding="8" Style="{StaticResource PageCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="5" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="5" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="ToolbarSearchColumn" Width="816" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="16,0,0,0">
                        <TextBlock Text="搜索媒体" Visibility="Collapsed" Style="{StaticResource BodyMutedTextStyle}" />
                        <Grid>
                            <TextBox x:Name="SearchTextBox"
                                     KeyDown="SearchTextBox_KeyDown"
                                     Style="{StaticResource LibrarySearchBoxStyle}"
                                     Padding="10,3,30,3"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                            <Button HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Margin="0,0,4,0"
                                    Command="{Binding ClearSearchCommand}"
                                    Style="{StaticResource LibrarySearchClearButtonStyle}">
                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                           FontSize="10"
                                           Text="&#xE711;" />
                            </Button>
                        </Grid>
                    </StackPanel>

                    <Button Grid.Column="2"
                            VerticalAlignment="Bottom"
                            Command="{Binding ApplySearchCommand}"
                            Click="SearchButton_Click"
                            Style="{StaticResource LibraryToolbarIconButtonStyle}">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   FontSize="16"
                                   RenderTransformOrigin="0.5,0.5"
                                   Text="&#xE721;">
                            <TextBlock.RenderTransform>
                                <ScaleTransform ScaleX="-1" />
                            </TextBlock.RenderTransform>
                        </TextBlock>
                    </Button>
                    <UniformGrid Grid.Column="4"
                                 Rows="1"
                                 Columns="3">
                        <Button Content="{Binding SortButtonText}"
                                Click="OpenButtonContextMenu"
                                Style="{StaticResource LibraryFilterButtonStyle}">
                            <Button.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="最近更新" Command="{Binding SelectSortOptionCommand}" CommandParameter="最近更新" Style="{StaticResource LibraryFilterMenuItemStyle}" />
                                    <MenuItem Header="标题" Command="{Binding SelectSortOptionCommand}" CommandParameter="标题" Style="{StaticResource LibraryFilterMenuItemStyle}" />
                                    <MenuItem Header="年份" Command="{Binding SelectSortOptionCommand}" CommandParameter="年份" Style="{StaticResource LibraryFilterMenuItemStyle}" />
                                    <MenuItem Header="评分" Command="{Binding SelectSortOptionCommand}" CommandParameter="评分" Style="{StaticResource LibraryFilterMenuItemStyle}" />
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                        <Button Command="{Binding ToggleSortDirectionCommand}"
                                Style="{StaticResource LibraryFilterButtonStyle}"
                                ToolTip="{Binding SortDirectionButtonToolTip}">
                            <Viewbox Width="18" Height="18">
                                <Canvas Width="26" Height="24">
                                    <Path Data="{Binding SortDirectionIconData}"
                                          Stroke="{DynamicResource BrushForegroundSecondary}"
                                          StrokeThickness="2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round" />
                                </Canvas>
                            </Viewbox>
                        </Button>
                        <Button Content="清除筛选"
                                Command="{Binding ClearFiltersCommand}"
                                Style="{StaticResource LibraryFilterButtonStyle}" />
                    </UniformGrid>
                </Grid>

                <DockPanel Grid.Row="2" LastChildFill="True">
                    <Button DockPanel.Dock="Right"
                            Margin="8,0,0,0"
                            Content="{Binding BatchSelectionButtonText}"
                            Command="{Binding ToggleBatchSelectionModeCommand}"
                            Style="{StaticResource LibraryBatchToggleButtonStyle}" />
                    <UniformGrid Rows="1" Columns="7">
                        <Button Content="{Binding PlaybackSourceButtonText}"
                                Click="OpenButtonContextMenu"
                                Style="{StaticResource LibraryFilterButtonStyle}">
                            <Button.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="全部" Command="{Binding SelectLibraryScopeCommand}" CommandParameter="全部" Style="{StaticResource LibraryFilterMenuItemStyle}" />
                                    <MenuItem Header="有播放源" Command="{Binding SelectLibraryScopeCommand}" CommandParameter="有播放源" Style="{StaticResource LibraryFilterMenuItemStyle}" />
                                    <MenuItem Header="无播放源" Command="{Binding SelectLibraryScopeCommand}" CommandParameter="无播放源" Style="{StaticResource LibraryFilterMenuItemStyle}" />
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                        <Button Content="{Binding MediaSourceButtonText}"
                                Click="OpenButtonContextMenu"
                                Style="{StaticResource LibraryFilterButtonStyle}">
                            <Button.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="全部" Command="{Binding SelectSourceFilterCommand}" CommandParameter="全部来源" Style="{StaticResource LibraryFilterMenuItemStyle}" />
                                    <MenuItem Header="本地" Command="{Binding SelectSourceFilterCommand}" CommandParameter="本地" Style="{StaticResource LibraryFilterMenuItemStyle}" />
                                    <MenuItem Header="网盘" Command="{Binding SelectSourceFilterCommand}" CommandParameter="网盘" Style="{StaticResource LibraryFilterMenuItemStyle}" />
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                        <Button Content="{Binding ContentTypeButtonText}"
                                Click="OpenButtonContextMenu"
                                Style="{StaticResource LibraryFilterButtonStyle}">
                            <Button.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="全部" Command="{Binding SelectContentTypeCommand}" CommandParameter="全部" Style="{StaticResource LibraryFilterMenuItemStyle}" />
                                    <MenuItem Header="电影" Command="{Binding SelectContentTypeCommand}" CommandParameter="电影" Style="{StaticResource LibraryFilterMenuItemStyle}" />
                                    <MenuItem Header="电视剧" Command="{Binding SelectContentTypeCommand}" CommandParameter="电视剧" Style="{StaticResource LibraryFilterMenuItemStyle}" />
                                    <MenuItem Header="其他" Command="{Binding SelectContentTypeCommand}" CommandParameter="其他" Style="{StaticResource LibraryFilterMenuItemStyle}" />
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                        <Button Content="{Binding TagFilterButtonText}"
                                Click="OpenButtonContextMenu"
                                Style="{StaticResource LibraryFilterButtonStyle}">
                            <Button.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="清除标签" Command="{Binding ClearTagFilterCommand}" />
                                    <Separator />
                                    <MenuItem StaysOpenOnClick="True">
                                        <MenuItem.Header>
                                            <ScrollViewer Width="660" MaxHeight="420" VerticalScrollBarVisibility="Auto">
                                                <Grid Margin="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="220" />
                                                        <ColumnDefinition Width="220" />
                                                        <ColumnDefinition Width="220" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                                        <TextBlock Text="类型标签" Style="{StaticResource BodyMutedTextStyle}" />
                                                        <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding TypeTagOptions}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <WrapPanel />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <CheckBox MinWidth="82"
                                                                              Margin="0,0,8,8"
                                                                              Content="{Binding Label}"
                                                                              IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Margin="0,0,16,0">
                                                        <TextBlock Text="情绪标签" Style="{StaticResource BodyMutedTextStyle}" />
                                                        <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding EmotionTagOptions}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <WrapPanel />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <CheckBox MinWidth="82"
                                                                              Margin="0,0,8,8"
                                                                              Content="{Binding Label}"
                                                                              IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="场景标签" Style="{StaticResource BodyMutedTextStyle}" />
                                                        <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding SceneTagOptions}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <WrapPanel />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <CheckBox MinWidth="82"
                                                                              Margin="0,0,8,8"
                                                                              Content="{Binding Label}"
                                                                              IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Grid>
                                            </ScrollViewer>
                                        </MenuItem.Header>
                                    </MenuItem>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                        <Button x:Name="DecadeFilterButton"
                                Content="{Binding DecadeButtonText}"
                                Click="OpenDecadeFilterMenu"
                                Style="{StaticResource LibraryFilterButtonStyle}" />
                        <Button Content="{Binding CollectionStatusButtonText}"
                                Click="OpenButtonContextMenu"
                                Style="{StaticResource LibraryFilterButtonStyle}">
                            <Button.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="全部" Command="{Binding SelectCollectionStatusCommand}" CommandParameter="全部" Style="{StaticResource LibraryFilterMenuItemStyle}" />
                                    <MenuItem Header="喜爱" Command="{Binding SelectCollectionStatusCommand}" CommandParameter="喜爱" Style="{StaticResource LibraryFilterMenuItemStyle}" />
                                    <MenuItem Header="想看" Command="{Binding SelectCollectionStatusCommand}" CommandParameter="想看" Style="{StaticResource LibraryFilterMenuItemStyle}" />
                                    <MenuItem Header="不想看" Command="{Binding SelectCollectionStatusCommand}" CommandParameter="不想看" Style="{StaticResource LibraryFilterMenuItemStyle}" />
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                        <Button Content="{Binding WatchedFilterButtonText}"
                                Click="OpenButtonContextMenu"
                                Style="{StaticResource LibraryFilterButtonStyle}">
                            <Button.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="全部" Command="{Binding SelectWatchedFilterCommand}" CommandParameter="全部" Style="{StaticResource LibraryFilterMenuItemStyle}" />
                                    <MenuItem Header="已看" Command="{Binding SelectWatchedFilterCommand}" CommandParameter="已看" Style="{StaticResource LibraryFilterMenuItemStyle}" />
                                    <MenuItem Header="未看" Command="{Binding SelectWatchedFilterCommand}" CommandParameter="未看" Style="{StaticResource LibraryFilterMenuItemStyle}" />
                                    <MenuItem Header="不想看" Command="{Binding SelectWatchedFilterCommand}" CommandParameter="不想看" Style="{StaticResource LibraryFilterMenuItemStyle}" />
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                    </UniformGrid>
                </DockPanel>

                <Border Grid.Row="4" Style="{StaticResource LibraryBatchToolbarStyle}">
                    <DockPanel LastChildFill="True">
                        <WrapPanel DockPanel.Dock="Right"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center">
                            <Button Margin="0,0,6,0"
                                    Content="全选当前列表"
                                    Command="{Binding SelectVisibleItemsCommand}"
                                    Style="{StaticResource LibraryToolbarButtonStyle}" />
                            <Button Margin="0,0,6,0"
                                    Content="清空选择"
                                    Command="{Binding ClearBatchSelectionCommand}"
                                    Style="{StaticResource LibraryToolbarButtonStyle}" />
                            <Button Margin="0,0,6,0"
                                    Content="标记已看"
                                    Command="{Binding BatchMarkWatchedCommand}"
                                    Style="{StaticResource LibraryToolbarButtonStyle}" />
                            <Button Margin="0,0,6,0"
                                    Content="标记未看"
                                    Command="{Binding BatchMarkUnwatchedCommand}"
                                    Style="{StaticResource LibraryToolbarButtonStyle}" />
                            <Button Margin="0,0,6,0"
                                    Content="AI 辅助识别"
                                    Command="{Binding BatchAutoIdentifyCommand}"
                                    Style="{StaticResource LibraryBatchInfoButtonStyle}" />
                            <Button Margin="0,0,6,0"
                                    Content="取消"
                                    Command="{Binding CancelBatchOperationCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource LibraryToolbarButtonStyle}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CanCancelBatchOperation}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Margin="0,0,6,0"
                                    Content="移出媒体库"
                                    Command="{Binding BatchRemoveFromLibraryCommand}"
                                    Style="{StaticResource LibraryBatchWarningButtonStyle}" />
                            <Button Margin="0,0,6,0"
                                    Content="删除记录"
                                    Command="{Binding BatchDeleteMovieRecordsCommand}"
                                    Style="{StaticResource LibraryBatchDangerButtonStyle}" />
                            <Button Content="人工聚合为季"
                                    Command="{Binding OpenManualAggregationCommand}"
                                    Style="{StaticResource LibraryToolbarButtonStyle}" />
                        </WrapPanel>

                        <StackPanel Margin="0,0,16,0"
                                    VerticalAlignment="Center">
                            <Border Style="{StaticResource LibraryBatchStatusPillStyle}">
                                <TextBlock Text="{Binding SelectedCount, StringFormat=已选 {0} 项}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource BrushTextPrimary}" />
                            </Border>
                        </StackPanel>
                    </DockPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Border Style="{StaticResource PageCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel>
                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button Content="已移出媒体库"
                                    Command="{Binding OpenRemovedLibraryCommand}"
                                    Style="{StaticResource LibraryToolbarButtonStyle}" />
                            <Border Margin="8,0,0,0"
                                    Padding="2"
                                    Background="{DynamicResource BrushSurfaceAlt}"
                                    BorderBrush="{DynamicResource BrushBorder}"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="海报"
                                            Command="{Binding SwitchToPosterViewCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource LibraryToolbarButtonStyle}">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="BorderBrush" Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPosterView}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource BrushAccent}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                                                        <Setter Property="Foreground" Value="{DynamicResource BrushOnAccent}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Margin="2,0,0,0"
                                            Content="列表"
                                            Command="{Binding SwitchToListViewCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource LibraryToolbarButtonStyle}">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="BorderBrush" Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsListView}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource BrushAccent}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                                                        <Setter Property="Foreground" Value="{DynamicResource BrushOnAccent}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Margin="20,0,0,0"
                                    VerticalAlignment="Center">
                            <TextBlock FontSize="12" Text="{Binding StatusMessage}" Style="{StaticResource BodyMutedTextStyle}" />
                            <TextBlock Margin="0,4,0,0"
                                       Text="{Binding BatchResultSummary}"
                                       TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource BodyTextStyle}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasBatchResultSummary}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </DockPanel>

                    <ListBox Grid.Row="1"
                             Margin="0,18,0,0"
                             Background="Transparent"
                             BorderThickness="0"
                             ItemsSource="{Binding Movies}"
                             ScrollViewer.CanContentScroll="True"
                             ScrollViewer.ScrollChanged="OnLibraryListScrollChanged"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListBox.Resources>
                            <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource LibraryModernScrollBarStyle}" />
                        </ListBox.Resources>
                        <ListBox.Style>
                            <Style TargetType="ListBox">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPosterView}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.Style>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Focusable" Value="False" />
                                <Setter Property="HorizontalContentAlignment" Value="Left" />
                                <Setter Property="VerticalContentAlignment" Value="Top" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <controls:VirtualizingWrapPanel>
                                    <controls:VirtualizingWrapPanel.Style>
                                        <Style TargetType="{x:Type controls:VirtualizingWrapPanel}">
                                            <Setter Property="ItemWidth" Value="194" />
                                            <Setter Property="ItemHeight" Value="288" />
                                            <Setter Property="OverscanRows" Value="1" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                    <Setter Property="ItemWidth" Value="201" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </controls:VirtualizingWrapPanel.Style>
                                </controls:VirtualizingWrapPanel>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Width="180"
                                          Height="270"
                                          Margin="0,3,14,15"
                                          SnapsToDevicePixels="True"
                                          UseLayoutRounding="True">
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Cursor" Value="Arrow" />
                                                <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
                                                <Setter Property="RenderTransform">
                                                    <Setter.Value>
                                                        <TranslateTransform />
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsBatchSelectionMode}" Value="True">
                                                        <Setter Property="Cursor" Value="Hand" />
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="RenderTransform">
                                                            <Setter.Value>
                                                                <TranslateTransform Y="-2" />
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding DataContext.OpenOrToggleSelectionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}" />
                                        </Grid.InputBindings>
                                        <Border x:Name="PosterCardClipMask"
                                                Background="White"
                                                CornerRadius="12"
                                                IsHitTestVisible="False" />
                                        <Border x:Name="PosterPaletteShadowHost"
                                                Margin="0,3,0,0"
                                                Background="{StaticResource LibraryMediaCardBackgroundBrush}"
                                                CornerRadius="12"
                                                IsHitTestVisible="False">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="28"
                                                                  Direction="270"
                                                                  Opacity="0.42"
                                                                  ShadowDepth="7"
                                                                  Color="#192230" />
                                            </Border.Effect>
                                        </Border>
                                        <Border Background="{StaticResource LibraryMediaCardBackgroundBrush}"
                                                CornerRadius="12"
                                                IsHitTestVisible="False">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="14"
                                                                  Direction="270"
                                                                  Opacity="0.28"
                                                                  ShadowDepth="3"
                                                                  Color="#000000" />
                                            </Border.Effect>
                                        </Border>
                                        <Grid>
                                            <Grid.OpacityMask>
                                                <VisualBrush Visual="{Binding ElementName=PosterCardClipMask}" />
                                            </Grid.OpacityMask>
                                            <Border Background="{StaticResource LibraryMediaCardSurfaceBrush}" />
                                            <Image x:Name="PosterImage"
                                                   helpers:PosterCacheImageBehavior.DecodePixelWidth="320"
                                                   helpers:PosterCacheImageBehavior.Source="{Binding PosterRemoteUrl}"
                                                   helpers:PosterPaletteShadowBehavior.TargetElement="{Binding ElementName=PosterPaletteShadowHost}"
                                                   helpers:PosterPaletteShadowBehavior.TargetName="PosterPaletteShadowHost"
                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                   SnapsToDevicePixels="True"
                                                   Stretch="UniformToFill">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasPoster}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                            <Grid>
                                                <Grid.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="#00000000" Offset="0" />
                                                        <GradientStop Color="#0A111827" Offset="0.42" />
                                                        <GradientStop Color="#78111824" Offset="0.78" />
                                                        <GradientStop Color="#B8111824" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Grid.Background>
                                            </Grid>
                                            <Border Height="86"
                                                    VerticalAlignment="Top"
                                                    IsHitTestVisible="False">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="#38FFFFFF" Offset="0" />
                                                        <GradientStop Color="#20FFFFFF" Offset="0.22" />
                                                        <GradientStop Color="#08FFFFFF" Offset="0.62" />
                                                        <GradientStop Color="#00FFFFFF" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                            <TextBlock HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Text="无海报">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource LibraryMediaMutedTextStyle}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasPoster}" Value="False">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <Border HorizontalAlignment="Left"
                                                    VerticalAlignment="Top"
                                                    Margin="8"
                                                    MaxWidth="88"
                                                    Style="{StaticResource LibraryMediaChipStyle}">
                                                <TextBlock Text="{Binding CategoryTagText}"
                                                           Style="{StaticResource LibraryMediaChipTextStyle}" />
                                            </Border>
                                            <Border HorizontalAlignment="Right"
                                                    VerticalAlignment="Top"
                                                    Margin="8"
                                                    MaxWidth="88"
                                                    Style="{StaticResource LibraryMediaChipStyle}">
                                                <TextBlock Text="{Binding SourceBadgeText}"
                                                           Style="{StaticResource LibraryMediaChipTextStyle}" />
                                            </Border>
                                            <Border HorizontalAlignment="Left"
                                                    VerticalAlignment="Top"
                                                    Margin="8,38,8,0"
                                                    MaxWidth="130">
                                                <Border.Style>
                                                    <Style TargetType="Border" BasedOn="{StaticResource LibraryMediaChipStyle}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasBatchModeHint}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding BatchModeHintText}"
                                                           Style="{StaticResource LibraryMediaChipTextStyle}" />
                                            </Border>
                                            <Button HorizontalAlignment="Center"
                                                    VerticalAlignment="Top"
                                                    Margin="0,8,0,0"
                                                    Command="{Binding DataContext.ToggleItemSelectionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource SelectionDotButtonStyle}" />
                                            <StackPanel VerticalAlignment="Bottom" Margin="10">
                                                <TextBlock Text="{Binding Title}"
                                                           MaxHeight="36"
                                                           Style="{StaticResource LibraryMediaTitleTextStyle}" />
                                                <TextBlock Margin="0,3,0,0"
                                                           Text="{Binding ReleaseDateText}"
                                                           Style="{StaticResource LibraryMediaMutedTextStyle}" />
                                                <Border Margin="0,5,0,0"
                                                        helpers:TrimmedTextToolTipBehavior.FullText="{Binding PosterTagToolTipText}"
                                                        helpers:TrimmedTextToolTipBehavior.VisibleText="{Binding PosterTagLine}"
                                                        Style="{StaticResource LibraryTagLineContainerStyle}">
                                                    <TextBlock Style="{StaticResource LibraryMediaMutedTextStyle}">
                                                        <Run Text="{Binding PosterTagGroupOneText, Mode=OneWay}" />
                                                        <Run Text="{Binding PosterTagSeparatorAfterOneText, Mode=OneWay}"
                                                             Foreground="{StaticResource LibraryTagDividerBrush}" />
                                                        <Run Text="{Binding PosterTagGroupTwoText, Mode=OneWay}" />
                                                        <Run Text="{Binding PosterTagSeparatorAfterTwoText, Mode=OneWay}"
                                                             Foreground="{StaticResource LibraryTagDividerBrush}" />
                                                        <Run Text="{Binding PosterTagGroupThreeText, Mode=OneWay}" />
                                                    </TextBlock>
                                                </Border>
                                                <Grid Margin="0,7,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="8" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <ProgressBar VerticalAlignment="Center"
                                                                 Value="{Binding ProgressValue, Mode=OneWay}"
                                                                 Style="{StaticResource LibraryMediaProgressBarStyle}" />
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding ProgressLabel}"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource LibraryMediaCardTextBrush}" />
                                                </Grid>
                                            </StackPanel>
                                            <Button HorizontalAlignment="Stretch"
                                                    VerticalAlignment="Bottom"
                                                    Height="30"
                                                    Margin="10,0,10,10"
                                                    Opacity="0"
                                                    IsHitTestVisible="False"
                                                    Command="{Binding DataContext.OpenMovieCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsBatchSelectionMode}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>
                                        <Border BorderBrush="#14FFFFFF"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                IsHitTestVisible="False" />
                                        <Border Margin="1"
                                                BorderBrush="#0A000000"
                                                BorderThickness="1"
                                                CornerRadius="11"
                                                IsHitTestVisible="False" />
                                    </Grid>
                                </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <ListBox Grid.Row="1"
                             Margin="0,18,0,0"
                             ItemsSource="{Binding Movies}"
                             ScrollViewer.CanContentScroll="True"
                             ScrollViewer.ScrollChanged="OnLibraryListScrollChanged"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListBox.Resources>
                            <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource LibraryModernScrollBarStyle}" />
                        </ListBox.Resources>
                        <ListBox.Style>
                            <Style TargetType="ListBox">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsListView}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.Style>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,14" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Focusable" Value="False" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border MinHeight="74"
                                        Margin="0,0,18,0"
                                        Padding="7"
                                        Background="{StaticResource LibraryMediaCardBackgroundBrush}"
                                        BorderBrush="{DynamicResource BrushBorder}"
                                        BorderThickness="1"
                                        CornerRadius="14">
                                    <Grid Style="{StaticResource BatchSelectableListItemContentStyle}">
                                        <Grid.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding DataContext.OpenOrToggleSelectionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}" />
                                        </Grid.InputBindings>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="54" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Button Grid.Column="0"
                                                Margin="0,0,8,0"
                                                VerticalAlignment="Center"
                                                Command="{Binding DataContext.ToggleItemSelectionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource SelectionDotButtonStyle}" />

                                        <Border Grid.Column="1"
                                                Width="42"
                                                Height="46"
                                                VerticalAlignment="Center"
                                                Background="{StaticResource LibraryMediaCardAccentBrush}"
                                                CornerRadius="9">
                                            <StackPanel HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding RatingDisplayText}"
                                                           HorizontalAlignment="Center"
                                                           FontSize="15"
                                                           FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{StaticResource LibraryMediaCardAccentTextBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsHighRating}" Value="True">
                                                                    <Setter Property="Foreground" Value="{StaticResource LibraryRatingGoldBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>

                                        <StackPanel Grid.Column="2" Margin="8,0,6,0" VerticalAlignment="Center">
                                            <TextBlock ToolTip="{Binding ListTitleLineText}"
                                                       TextWrapping="NoWrap"
                                                       Style="{StaticResource LibraryMediaTitleTextStyle}">
                                                <Run Text="{Binding Title, Mode=OneWay}" />
                                                <Run Text="{Binding OriginalTitleSeparatorText, Mode=OneWay}" />
                                                <Run Text="{Binding OriginalTitle, Mode=OneWay}" />
                                                <Run Text="{Binding ListTitleMetaSpacingText, Mode=OneWay}" />
                                                <Run Text="{Binding ListTitleMetaText, Mode=OneWay}"
                                                     FontSize="10.5"
                                                     FontWeight="Normal"
                                                     Foreground="{StaticResource LibraryMediaCardMutedTextBrush}" />
                                            </TextBlock>
                                            <Border Margin="0,5,0,0"
                                                    helpers:TrimmedTextToolTipBehavior.FullText="{Binding ListTagToolTipText}"
                                                    helpers:TrimmedTextToolTipBehavior.VisibleText="{Binding ListTagLine}"
                                                    Style="{StaticResource LibraryTagLineContainerStyle}">
                                                <TextBlock Style="{StaticResource LibraryMediaMutedTextStyle}">
                                                    <Run Text="{Binding ListDateRuntimeText, Mode=OneWay}" />
                                                    <Run Text="{Binding ListDateAndTagSpacingText, Mode=OneWay}" />
                                                    <Run Text="{Binding ListTagGroupOneText, Mode=OneWay}" />
                                                    <Run Text="{Binding ListTagSeparatorAfterOneText, Mode=OneWay}"
                                                         Foreground="{StaticResource LibraryTagDividerBrush}" />
                                                    <Run Text="{Binding ListTagGroupTwoText, Mode=OneWay}" />
                                                    <Run Text="{Binding ListTagSeparatorAfterTwoText, Mode=OneWay}"
                                                         Foreground="{StaticResource LibraryTagDividerBrush}" />
                                                    <Run Text="{Binding ListTagGroupThreeText, Mode=OneWay}" />
                                                </TextBlock>
                                            </Border>
                                            <Grid Margin="0,7,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <ProgressBar VerticalAlignment="Center"
                                                             Value="{Binding ProgressValue, Mode=OneWay}"
                                                             Style="{StaticResource LibraryMediaProgressBarStyle}" />
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding ProgressLabel}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource LibraryMediaCardTextBrush}" />
                                            </Grid>
                                        </StackPanel>

                                        <StackPanel Grid.Column="3"
                                                    Width="82"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center">
                                            <Border Margin="0,0,0,7"
                                                    HorizontalAlignment="Right"
                                                    MaxWidth="80"
                                                    Style="{StaticResource LibraryMediaChipStyle}">
                                                <TextBlock Text="{Binding SourceBadgeText}"
                                                           Style="{StaticResource LibraryMediaChipTextStyle}" />
                                            </Border>
                                            <Border HorizontalAlignment="Right"
                                                    MaxWidth="80"
                                                    Style="{StaticResource LibraryMediaChipStyle}">
                                                <TextBlock Text="{Binding DetailHintText}"
                                                           Style="{StaticResource LibraryMediaChipTextStyle}" />
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Border Grid.Row="1"
                            Margin="0,18,0,0"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Top">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource EmptyStateContainerStyle}">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasMovies}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock Text="{Binding EmptyStateTitle}"
                                       Style="{StaticResource EmptyStateTitleStyle}" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="{Binding EmptyStateMessage}"
                                       Style="{StaticResource EmptyStateDescriptionStyle}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.RowSpan="3"
                Background="#99000000">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsManualAggregationDialogOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border Width="980"
                    MaxHeight="700"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Style="{StaticResource PageCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="人工聚合为未识别季" Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="只为当前选中的未识别播放源创建集；重复集号会作为同一集的多播放源，不会补空集。"
                                   TextWrapping="Wrap"
                                   Style="{StaticResource BodyMutedTextStyle}" />
                    </StackPanel>

                    <Grid Grid.Row="1" Margin="0,18,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="剧名" Style="{StaticResource BodyMutedTextStyle}" />
                            <TextBox Margin="0,6,0,0"
                                     Text="{Binding ManualAggregationSeriesTitle, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource FormTextBoxStyle}">
                                        <Setter Property="IsEnabled" Value="True" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsManualAggregationBusy}" Value="True">
                                                <Setter Property="IsEnabled" Value="False" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="季号" Style="{StaticResource BodyMutedTextStyle}" />
                            <TextBox Margin="0,6,0,0"
                                     Text="{Binding ManualAggregationSeasonNumberText, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource FormTextBoxStyle}">
                                        <Setter Property="IsEnabled" Value="True" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsManualAggregationBusy}" Value="True">
                                                <Setter Property="IsEnabled" Value="False" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="季名称" Style="{StaticResource BodyMutedTextStyle}" />
                            <TextBox Margin="0,6,0,0"
                                     Text="{Binding ManualAggregationSeasonTitle, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource FormTextBoxStyle}">
                                        <Setter Property="IsEnabled" Value="True" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsManualAggregationBusy}" Value="True">
                                                <Setter Property="IsEnabled" Value="False" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                            <TextBlock Margin="0,6,0,0"
                                       Text="{Binding ManualAggregationSeasonDisplayText}"
                                       Style="{StaticResource BodyMutedTextStyle}" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="2">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="没有可聚合的播放源">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasManualAggregationSources}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ListBox ItemsSource="{Binding ManualAggregationSources}">
                            <ListBox.Style>
                                <Style TargetType="ListBox" BasedOn="{StaticResource SectionListBoxStyle}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasManualAggregationSources}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.Style>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8"
                                            Padding="12"
                                            Background="{DynamicResource BrushSurfaceAlt}"
                                            BorderBrush="{DynamicResource BrushBorder}"
                                            BorderThickness="1"
                                            CornerRadius="10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="160" />
                                                <ColumnDefinition Width="180" />
                                                <ColumnDefinition Width="120" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Margin="0,0,16,0">
                                                <TextBlock Text="{Binding FileName}"
                                                           TextTrimming="CharacterEllipsis"
                                                           Style="{StaticResource BodyTextStyle}" />
                                                <TextBlock Margin="0,5,0,0"
                                                           Text="{Binding SourceSummary}"
                                                           TextWrapping="Wrap"
                                                           Style="{StaticResource BodyMutedTextStyle}" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       Margin="0,0,14,0"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding CurrentBindingText}"
                                                       TextWrapping="Wrap"
                                                       Style="{StaticResource BodyMutedTextStyle}" />
                                            <TextBlock Grid.Column="2"
                                                       Margin="0,0,14,0"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding EpisodeNumberSourceText}"
                                                       Style="{StaticResource BodyMutedTextStyle}" />
                                            <TextBox Grid.Column="3"
                                                     VerticalAlignment="Center"
                                                     Text="{Binding EpisodeNumberText, UpdateSourceTrigger=PropertyChanged}">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox" BasedOn="{StaticResource FormTextBoxStyle}">
                                                        <Setter Property="IsEnabled" Value="True" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding DataContext.IsManualAggregationBusy, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                                <Setter Property="IsEnabled" Value="False" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>

                    <DockPanel Grid.Row="3" Margin="0,16,0,0" LastChildFill="True">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Margin="0,0,10,0"
                                    Content="取消"
                                    Command="{Binding CancelManualAggregationCommand}"
                                    Style="{StaticResource LibrarySecondaryButtonStyle}" />
                            <Button Margin="0,0,10,0"
                                    Content="聚合后识别"
                                    Command="{Binding ApplyManualAggregationAndIdentifyCommand}"
                                    Style="{StaticResource LibrarySecondaryButtonStyle}" />
                            <Button Content="聚合"
                                    Command="{Binding ApplyManualAggregationCommand}"
                                    Style="{StaticResource LibraryPrimaryButtonStyle}" />
                        </StackPanel>
                        <TextBlock Margin="0,0,18,0"
                                   VerticalAlignment="Center"
                                   Text="{Binding ManualAggregationStatusMessage}"
                                   TextWrapping="Wrap"
                                   Style="{StaticResource BodyMutedTextStyle}" />
                    </DockPanel>
                </Grid>
            </Border>
        </Border>

        <Border Grid.RowSpan="3"
                Background="#99000000">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsRemovedLibraryPanelOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border Width="860"
                    MaxHeight="640"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Style="{StaticResource PageCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel>
                        <Button DockPanel.Dock="Right"
                                Content="关闭"
                                Command="{Binding CloseRemovedLibraryCommand}"
                                Style="{StaticResource LibrarySecondaryButtonStyle}" />
                        <StackPanel>
                            <TextBlock Text="已移出媒体库" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Margin="0,6,18,0"
                                       Text="{Binding RemovedLibraryStatusMessage}"
                                       TextWrapping="Wrap"
                                       Style="{StaticResource BodyMutedTextStyle}" />
                        </StackPanel>
                    </DockPanel>

                    <Grid Grid.Row="2">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="暂无已移出媒体库项目"
	                                   >
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasRemovedLibraryItems}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <ListBox ItemsSource="{Binding RemovedLibraryGroups}">
                            <ListBox.Style>
                                <Style TargetType="ListBox" BasedOn="{StaticResource SectionListBoxStyle}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasRemovedLibraryItems}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.Style>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                    <Expander IsExpanded="{Binding IsExpanded, Mode=TwoWay}">
                                        <Expander.Style>
                                            <Style TargetType="Expander">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsTvGroup}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Expander.Style>
                                        <Expander.Header>
                                            <Border Padding="14"
                                                    BorderBrush="{DynamicResource BrushBorder}"
                                                    BorderThickness="1"
                                                    CornerRadius="12">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{DynamicResource BrushSurfaceAlt}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsTvGroup}" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource BrushAccentSoft}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="112" />
                                                        <ColumnDefinition Width="124" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Margin="0,0,16,0">
                                                        <TextBlock Text="{Binding Title}" Style="{StaticResource SectionTitleTextStyle}" />
                                                        <TextBlock Margin="0,5,0,0"
                                                                   Text="{Binding HeaderSubtitle}"
                                                                   TextWrapping="Wrap"
                                                                   Style="{StaticResource BodyMutedTextStyle}" />
                                                    </StackPanel>
                                                    <Button Grid.Column="1"
                                                            Margin="0,0,8,0"
                                                            Content="恢复全部"
                                                            Command="{Binding DataContext.RestoreRemovedLibraryGroupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource LibraryPrimaryButtonStyle}">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsTvGroup}" Value="False">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                    <Button Grid.Column="2"
                                                            Content="删除全部记录"
                                                            Command="{Binding DataContext.DeleteRemovedLibraryGroupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource LibrarySecondaryButtonStyle}">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsTvGroup}" Value="False">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </Expander.Header>

                                        <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding Items}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="20,0,0,8"
                                                            Background="{DynamicResource BrushSurfaceAlt}"
                                                            BorderBrush="{DynamicResource BrushBorder}"
                                                            BorderThickness="1"
                                                            CornerRadius="12">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="4" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="100" />
                                                                <ColumnDefinition Width="100" />
                                                                <ColumnDefinition Width="110" />
                                                            </Grid.ColumnDefinitions>
                                                            <Border Background="{DynamicResource BrushAccent}" CornerRadius="12,0,0,12" />
                                                            <StackPanel Grid.Column="1" Margin="12,10,18,10">
                                                                <TextBlock Text="{Binding Title}" Style="{StaticResource SectionTitleTextStyle}" />
                                                                <WrapPanel Margin="0,6,0,0">
                                                                    <TextBlock Margin="0,0,12,0" Text="{Binding MediaKindText}" Style="{StaticResource BodyMutedTextStyle}" />
                                                                    <TextBlock Margin="0,0,12,0" Text="{Binding SourceStatusText}" Style="{StaticResource BodyMutedTextStyle}" />
                                                                    <TextBlock Text="{Binding StateSummary}" Style="{StaticResource BodyMutedTextStyle}" />
                                                                </WrapPanel>
                                                            </StackPanel>
                                                            <Button Grid.Column="2"
                                                                    Margin="0,10,8,10"
                                                                    Content="恢复"
                                                                    Command="{Binding DataContext.RestoreRemovedLibraryItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Style="{StaticResource LibraryPrimaryButtonStyle}" />
                                                            <Button Grid.Column="3"
                                                                    Margin="0,10,8,10"
                                                                    Content="详情"
                                                                    Command="{Binding DataContext.OpenRemovedLibraryDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Style="{StaticResource LibrarySecondaryButtonStyle}" />
                                                            <Button Grid.Column="4"
                                                                    Margin="0,10,12,10"
                                                                    Content="删除记录"
                                                                    Command="{Binding DataContext.DeleteRemovedLibraryItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Style="{StaticResource LibrarySecondaryButtonStyle}" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Expander>
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.Style>
                                            <Style TargetType="ItemsControl">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMovieGroup}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ItemsControl.Style>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,8"
                                                        Background="{DynamicResource BrushSurfaceAlt}"
                                                        BorderBrush="{DynamicResource BrushBorder}"
                                                        BorderThickness="1"
                                                        CornerRadius="12">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="4" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="100" />
                                                            <ColumnDefinition Width="100" />
                                                            <ColumnDefinition Width="110" />
                                                        </Grid.ColumnDefinitions>
                                                        <Border Background="{DynamicResource BrushAccent}" CornerRadius="12,0,0,12" />
                                                        <StackPanel Grid.Column="1" Margin="12,10,18,10">
                                                            <TextBlock Text="{Binding Title}" Style="{StaticResource SectionTitleTextStyle}" />
                                                            <WrapPanel Margin="0,6,0,0">
                                                                <TextBlock Margin="0,0,12,0" Text="{Binding MediaKindText}" Style="{StaticResource BodyMutedTextStyle}" />
                                                                <TextBlock Margin="0,0,12,0" Text="{Binding SourceStatusText}" Style="{StaticResource BodyMutedTextStyle}" />
                                                                <TextBlock Text="{Binding StateSummary}" Style="{StaticResource BodyMutedTextStyle}" />
                                                            </WrapPanel>
                                                        </StackPanel>
                                                        <Button Grid.Column="2"
                                                                Margin="0,10,8,10"
                                                                Content="恢复"
                                                                Command="{Binding DataContext.RestoreRemovedLibraryItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource LibraryPrimaryButtonStyle}" />
                                                        <Button Grid.Column="3"
                                                                Margin="0,10,8,10"
                                                                Content="详情"
                                                                Command="{Binding DataContext.OpenRemovedLibraryDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource LibrarySecondaryButtonStyle}" />
                                                        <Button Grid.Column="4"
                                                                Margin="0,10,12,10"
                                                                Content="删除记录"
                                                                Command="{Binding DataContext.DeleteRemovedLibraryItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource LibrarySecondaryButtonStyle}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
