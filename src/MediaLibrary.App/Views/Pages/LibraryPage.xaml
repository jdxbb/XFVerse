<UserControl x:Class="MediaLibrary.App.Views.Pages.LibraryPage"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MediaLibrary.App.Controls"
             xmlns:helpers="clr-namespace:MediaLibrary.App.Helpers">
    <UserControl.Resources>
        <SolidColorBrush x:Key="LibraryMediaCardBackgroundBrush" Color="{DynamicResource ColorCard}" />
        <SolidColorBrush x:Key="LibraryListMediaCardBackgroundBrush" Color="{DynamicResource ColorSidebar}" />
        <SolidColorBrush x:Key="LibraryMediaCardSurfaceBrush" Color="{DynamicResource ColorSurfaceAlt}" />
        <SolidColorBrush x:Key="LibraryMediaCardTextBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="LibraryMediaCardMutedTextBrush" Color="#D8DEE9" />
        <SolidColorBrush x:Key="LibraryMediaCardAccentBrush" Color="#E2E8F0" />
        <SolidColorBrush x:Key="LibraryMediaCardAccentTextBrush" Color="#111827" />
        <SolidColorBrush x:Key="LibraryMediaCardDividerBrush" Color="{DynamicResource ColorDivider}" />
        <SolidColorBrush x:Key="LibraryMediaProgressFillBrush" Color="{DynamicResource ColorWatchProgressFill}" />
        <SolidColorBrush x:Key="LibraryMediaProgressTrackBrush" Color="#E5E7EB" />
        <SolidColorBrush x:Key="LibraryTagDividerBrush" Color="#7DD3FC" />
        <SolidColorBrush x:Key="LibraryRatingGoldBrush" Color="{DynamicResource ColorWarning}" />

        <Style x:Key="LibraryMediaProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="4" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="Background" Value="{StaticResource LibraryMediaProgressTrackBrush}" />
            <Setter Property="Foreground" Value="{StaticResource LibraryMediaProgressFillBrush}" />
            <Setter Property="Visibility" Value="Visible" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid Height="{TemplateBinding Height}"
                              SnapsToDevicePixels="True">
                            <Border x:Name="PART_Track"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="2" />
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="2" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LibraryModernScrollBarThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border Width="6"
                                Margin="0"
                                Background="{DynamicResource BrushForegroundMuted}"
                                CornerRadius="3"
                                Opacity="0.58" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LibraryModernScrollRepeatButtonStyle" TargetType="{x:Type RepeatButton}">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LibraryModernScrollBarStyle" TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="6" />
            <Setter Property="MinWidth" Value="6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Width="{TemplateBinding Width}"
                              Background="Transparent">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}"
                                                  Style="{StaticResource LibraryModernScrollRepeatButtonStyle}" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource LibraryModernScrollBarThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}"
                                                  Style="{StaticResource LibraryModernScrollRepeatButtonStyle}" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LibraryMediaChipStyle" TargetType="Border">
            <Setter Property="Padding" Value="7,4" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="{StaticResource LibraryMediaCardAccentBrush}" />
            <Setter Property="Opacity" Value="0.9" />
        </Style>

        <Style x:Key="LibraryMediaChipTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource LibraryMediaCardAccentTextBrush}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="LibraryMediaMutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource LibraryMediaCardMutedTextBrush}" />
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="LibraryTagLineContainerStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="450" />
            <Setter Property="ToolTipService.BetweenShowDelay" Value="0" />
            <Setter Property="ToolTipService.ShowDuration" Value="20000" />
        </Style>

        <Style x:Key="LibraryMediaTitleTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource LibraryMediaCardTextBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="LibrarySearchBoxStyle" TargetType="TextBox" BasedOn="{StaticResource SearchBoxStyle}">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="FontFamily" Value="{StaticResource FontFamilyBase}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="LibraryCompactComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource FormComboBoxStyle}">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="LibraryFilterMenuItemStyle" TargetType="MenuItem" BasedOn="{StaticResource MenuItemStyle}">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
            <Setter Property="Cursor" Value="Hand" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                <Setter Property="HorizontalContentAlignment" Value="Center" />
                                <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="ItemChrome"
                                MinWidth="{TemplateBinding MinWidth}"
                                MinHeight="{TemplateBinding MinHeight}"
                                Margin="{TemplateBinding Margin}"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource BrushGlassSelected}" />
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                                <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource BrushGlassSelected}" />
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                                <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource BrushDisabledForeground}" />
                                <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource BrushDisabledBackground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LibraryFilterContextMenuStyle" TargetType="ContextMenu" BasedOn="{StaticResource ContextMenuStyle}">
            <Setter Property="Padding" Value="7" />
            <Setter Property="Background" Value="{DynamicResource BrushPopupBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
            <Setter Property="HasDropShadow" Value="False" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LibraryFilterSeparatorStyle" TargetType="Separator" BasedOn="{StaticResource MenuSeparatorStyle}">
            <Setter Property="Margin" Value="8,5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Height="1"
                                Background="{DynamicResource BrushDivider}"
                                Opacity="0.8" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LibraryFilterTagPanelMenuItemStyle" TargetType="MenuItem" BasedOn="{StaticResource LibraryFilterMenuItemStyle}">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <ContentPresenter ContentSource="Header"
                                          RecognizesAccessKey="True"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LibraryFilterSubmenuItemStyle" TargetType="MenuItem">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="18,5,8,5" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Grid>
                            <Border x:Name="ItemChrome"
                                    MinWidth="{TemplateBinding MinWidth}"
                                    MinHeight="{TemplateBinding MinHeight}"
                                    Margin="{TemplateBinding Margin}"
                                    Padding="{TemplateBinding Padding}"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="Transparent"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    SnapsToDevicePixels="True">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter ContentSource="Header"
                                                      RecognizesAccessKey="True"
                                                      VerticalAlignment="Center" />
                                    <TextBlock x:Name="SubmenuArrow"
                                               Grid.Column="1"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center"
                                               Text="›"
                                               Foreground="{DynamicResource BrushForegroundMuted}" />
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Custom"
                                   PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                   PopupAnimation="Fade"
                                   VerticalOffset="-7">
                                <Border Background="{DynamicResource BrushPopupBackground}"
                                        BorderBrush="{DynamicResource BrushBorder}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="10">
                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" />
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource BrushGlassSelected}" />
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                                <Setter TargetName="SubmenuArrow" Property="Foreground" Value="{DynamicResource BrushAccent}" />
                            </Trigger>
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource BrushGlassSelected}" />
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                                <Setter TargetName="SubmenuArrow" Property="Foreground" Value="{DynamicResource BrushAccent}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource BrushDisabledForeground}" />
                                <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource BrushDisabledBackground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LibraryFilterMenuHeaderTextStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="LibraryFilterTagCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="MinWidth" Value="74" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="6,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource BrushForegroundSecondary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="TextHitArea"
                                MinWidth="{TemplateBinding MinWidth}"
                                MinHeight="{TemplateBinding MinHeight}"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ContentPresenter ContentSource="Content"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
                                <Setter TargetName="TextHitArea" Property="Background" Value="{DynamicResource BrushGlassButtonHover}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource BrushAccent}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter TargetName="TextHitArea" Property="Background" Value="{DynamicResource BrushGlassSelected}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource BrushDisabledForeground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ItemsPanelTemplate x:Key="LibraryFilterTagGridPanelTemplate">
            <UniformGrid Columns="{Binding Tag, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}" />
        </ItemsPanelTemplate>

        <DataTemplate x:Key="LibraryFilterTagCheckBoxItemTemplate">
            <CheckBox Content="{Binding Label}"
                      Style="{StaticResource LibraryFilterTagCheckBoxStyle}"
                      IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        </DataTemplate>

        <DataTemplate x:Key="LibraryFilterTagRowItemTemplate">
            <Border MinWidth="420"
                    MinHeight="38"
                    Padding="0,5"
                    BorderBrush="{DynamicResource BrushDivider}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasDivider}" Value="False">
                                <Setter Property="BorderThickness" Value="0" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <ItemsControl ItemsSource="{Binding Options}"
                              Tag="{Binding ColumnCount}"
                              ItemsPanel="{StaticResource LibraryFilterTagGridPanelTemplate}"
                              ItemTemplate="{StaticResource LibraryFilterTagCheckBoxItemTemplate}">
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                </ItemsControl>
            </Border>
        </DataTemplate>

        <Style x:Key="LibraryToolbarMenuStyle" TargetType="Menu">
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="LibraryToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource GlassSmallButtonStyle}">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="MenuButton_PreviewMouseLeftButtonDown" />
        </Style>

        <Style x:Key="LibraryFilterButtonStyle" TargetType="Button" BasedOn="{StaticResource LibraryToolbarButtonStyle}">
            <Setter Property="Height" Value="28" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="MinWidth" Value="86" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Padding" Value="12,4" />
        </Style>

        <Style x:Key="LibraryPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource GlassPrimaryButtonStyle}">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>

        <Style x:Key="LibrarySecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource GlassSecondaryButtonStyle}">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>

        <Style x:Key="LibrarySearchClearButtonStyle" TargetType="Button" BasedOn="{StaticResource SmallIconButtonStyle}">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="MinWidth" Value="22" />
            <Setter Property="MinHeight" Value="22" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource BrushForegroundMuted}" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding SearchText}" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
                <DataTrigger Binding="{Binding SearchText}" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LibraryBatchToggleButtonStyle" TargetType="Button" BasedOn="{StaticResource LibraryToolbarButtonStyle}">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsBatchSelectionMode}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LibraryToolbarIconButtonStyle" TargetType="Button" BasedOn="{StaticResource SmallIconButtonStyle}">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="30" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>

        <Style x:Key="LibrarySortDirectionIconButtonStyle" TargetType="Button" BasedOn="{StaticResource LibraryToolbarIconButtonStyle}">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="28" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="LibraryLayoutSegmentButtonStyle" TargetType="Button" BasedOn="{StaticResource LibraryToolbarButtonStyle}">
            <Setter Property="Height" Value="28" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource BrushForegroundSecondary}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource BrushDisabledBackground}" />
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="{DynamicResource BrushDisabledBorder}" />
                                <Setter Property="Foreground" Value="{DynamicResource BrushDisabledForeground}" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BrushGlassButtonHover}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushGlassBorder}" />
                    <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LibraryPosterLayoutSegmentButtonStyle" TargetType="Button" BasedOn="{StaticResource LibraryLayoutSegmentButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPosterView}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="Foreground" Value="{DynamicResource BrushOnAccent}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LibraryListLayoutSegmentButtonStyle" TargetType="Button" BasedOn="{StaticResource LibraryLayoutSegmentButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsListView}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="Foreground" Value="{DynamicResource BrushOnAccent}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LibraryLayoutSegmentHostStyle" TargetType="Border">
            <Setter Property="Padding" Value="2" />
            <Setter Property="Background" Value="{DynamicResource BrushGlassButton}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushGlassBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="5" />
        </Style>

        <Style x:Key="SelectionDotButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#24FFFFFF" />
            <Setter Property="BorderBrush" Value="#8AFFFFFF" />
            <Setter Property="BorderThickness" Value="1.2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse Margin="-2"
                                     Fill="#22000000">
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="10"
                                                      ShadowDepth="0"
                                                      Opacity="0.34"
                                                      Color="#000000" />
                                </Ellipse.Effect>
                            </Ellipse>
                            <Border x:Name="ButtonChrome"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="11">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="9"
                                                      ShadowDepth="0"
                                                      Opacity="0.22"
                                                      Color="#000000" />
                                </Border.Effect>
                            </Border>
                            <Ellipse x:Name="InnerRing"
                                     Margin="1.5"
                                     Stroke="#66FFFFFF"
                                     StrokeThickness="1"
                                     Opacity="0.82" />
                            <Border x:Name="GlassHighlight"
                                    Height="9"
                                    Margin="3,2,3,0"
                                    VerticalAlignment="Top"
                                    CornerRadius="6"
                                    Opacity="0.58">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0.5,0"
                                                         EndPoint="0.5,1">
                                        <GradientStop Color="#D8FFFFFF"
                                                      Offset="0" />
                                        <GradientStop Color="#2EFFFFFF"
                                                      Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <Border x:Name="BottomHighlight"
                                    Height="7"
                                    Margin="4,0,4,3"
                                    VerticalAlignment="Bottom"
                                    CornerRadius="6"
                                    Opacity="0.26">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0.5,0"
                                                         EndPoint="0.5,1">
                                        <GradientStop Color="#00FFFFFF"
                                                      Offset="0" />
                                        <GradientStop Color="#8FFFFFFF"
                                                      Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <Ellipse x:Name="LiquidCore"
                                     Width="12"
                                     Height="12"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Fill="{DynamicResource BrushAccent}"
                                     Opacity="0" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="LiquidCore" Property="Opacity" Value="0" />
                                <Setter TargetName="GlassHighlight" Property="Opacity" Value="0" />
                                <Setter TargetName="BottomHighlight" Property="Opacity" Value="0" />
                                <Setter TargetName="InnerRing" Property="Opacity" Value="0" />
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                                <Setter TargetName="GlassHighlight" Property="Opacity" Value="0.72" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="GlassHighlight" Property="Opacity" Value="0.24" />
                            </Trigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsSelected}" Value="True" />
                                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="GlassHighlight" Property="Opacity" Value="0" />
                                <Setter TargetName="BottomHighlight" Property="Opacity" Value="0" />
                                <Setter TargetName="InnerRing" Property="Opacity" Value="0" />
                            </MultiDataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding SelectionDotVisible}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BrushSelectionDotSelectedBackground}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushSelectionDotSelectedBorder}" />
                </DataTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SelectionDotListButtonStyle" TargetType="Button" BasedOn="{StaticResource SelectionDotButtonStyle}">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="BatchSelectableCardStyle" TargetType="Border" BasedOn="{StaticResource GlassCompactCardStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsBatchSelectionMode}" Value="True">
                    <Setter Property="Cursor" Value="Hand" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="BatchSelectableListItemContentStyle" TargetType="Grid">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsBatchSelectionMode}" Value="True">
                    <Setter Property="Cursor" Value="Hand" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LibraryBatchToolbarStyle" TargetType="Border">
            <Setter Property="Padding" Value="0,10,0,0" />
            <Setter Property="Margin" Value="0,8,0,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="0,1,0,0" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsBatchSelectionMode}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LibraryBatchActionButtonStyle" TargetType="Button" BasedOn="{StaticResource LibraryToolbarButtonStyle}">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Margin" Value="4,0" />
            <Setter Property="Padding" Value="8,4" />
        </Style>

        <Style x:Key="LibraryBatchInfoButtonStyle" TargetType="Button" BasedOn="{StaticResource LibraryBatchActionButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource BrushInfo}" />
            <Setter Property="Foreground" Value="{DynamicResource BrushOnAccent}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushInfo}" />
        </Style>

        <Style x:Key="LibraryBatchWarningButtonStyle" TargetType="Button" BasedOn="{StaticResource LibraryBatchActionButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource BrushWarning}" />
            <Setter Property="Foreground" Value="{DynamicResource BrushOnAccent}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushWarning}" />
        </Style>

        <Style x:Key="LibraryBatchDangerButtonStyle" TargetType="Button" BasedOn="{StaticResource LibraryBatchActionButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource BrushDanger}" />
            <Setter Property="Foreground" Value="{DynamicResource BrushOnAccent}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushDanger}" />
        </Style>

        <Style x:Key="LibraryRemovedPanelActionButtonStyle" TargetType="Button" BasedOn="{StaticResource LibraryToolbarButtonStyle}">
            <Setter Property="MinWidth" Value="58" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>

        <Style x:Key="LibraryRemovedPanelDangerButtonStyle" TargetType="Button" BasedOn="{StaticResource LibraryToolbarButtonStyle}">
            <Setter Property="MinWidth" Value="72" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Background" Value="{DynamicResource BrushErrorBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource BrushDanger}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushErrorBorder}" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>

        <Style x:Key="LibraryRemovedPanelItemStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Background" Value="{DynamicResource BrushGlassSurfaceAlt}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="LibraryRemovedPanelFlatItemStyle" TargetType="Border" BasedOn="{StaticResource LibraryRemovedPanelItemStyle}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushDivider}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Margin" Value="0" />
        </Style>

        <Style x:Key="LibraryRemovedPanelSeasonItemStyle" TargetType="Border" BasedOn="{StaticResource LibraryRemovedPanelFlatItemStyle}">
            <Setter Property="BorderBrush" Value="{DynamicResource BrushDivider}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>

        <Style x:Key="LibraryRemovedPanelChipStyle" TargetType="Border">
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Background" Value="{DynamicResource BrushGlassSurface}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="5" />
        </Style>

        <Style x:Key="LibraryRemovedPanelChipTextStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>

        <Style x:Key="LibraryRemovedPanelCloseButtonStyle" TargetType="Button" BasedOn="{StaticResource LibraryToolbarIconButtonStyle}">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="28" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="LibraryRemovedPanelListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LibraryRemovedPanelExpanderStyle" TargetType="Expander">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Expander}">
                        <DockPanel>
                            <ToggleButton x:Name="HeaderSite"
                                          DockPanel.Dock="Top"
                                          Padding="0"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False"
                                          HorizontalContentAlignment="Stretch"
                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent">
                                            <ContentPresenter HorizontalAlignment="Stretch"
                                                              VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <ContentPresenter ContentSource="Header"
                                                  RecognizesAccessKey="True" />
                            </ToggleButton>
                            <ContentPresenter x:Name="ExpandSite"
                                              DockPanel.Dock="Bottom"
                                              Visibility="Collapsed"
                                              ContentSource="Content" />
                        </DockPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="-32,-24,-32,-32"
          Background="Transparent"
          PreviewMouseDown="OnRootPreviewMouseDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Margin="32,24,32,0"
                Padding="14"
                Style="{StaticResource GlassPageCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="0" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="ToolbarSearchColumn" Width="816" />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="2" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="搜索媒体" Visibility="Collapsed" Style="{StaticResource BodyMutedTextStyle}" />
                        <Grid>
                            <TextBox x:Name="SearchTextBox"
                                     helpers:TextBoxPlaceholderBehavior.IsEnabled="True"
                                     helpers:TextBoxPlaceholderBehavior.PlaceholderText="请输入需要搜索的影视作品名/导演/演员"
                                     KeyDown="SearchTextBox_KeyDown"
                                     Style="{StaticResource LibrarySearchBoxStyle}"
                                     Padding="10,0,30,0"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                            <Button HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Margin="0,0,4,0"
                                    Command="{Binding ClearSearchCommand}"
                                    Style="{StaticResource LibrarySearchClearButtonStyle}">
                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                           FontSize="10"
                                           Text="&#xE711;" />
                            </Button>
                        </Grid>
                    </StackPanel>

                    <Button Grid.Column="2"
                            VerticalAlignment="Bottom"
                            Command="{Binding ApplySearchCommand}"
                            Click="SearchButton_Click"
                            Style="{StaticResource LibraryToolbarIconButtonStyle}">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   FontSize="16"
                                   RenderTransformOrigin="0.5,0.5"
                                   Text="&#xE721;">
                            <TextBlock.RenderTransform>
                                <ScaleTransform ScaleX="-1" />
                            </TextBlock.RenderTransform>
                        </TextBlock>
                    </Button>
                    <Button Grid.Column="4"
                            VerticalAlignment="Bottom"
                            Command="{Binding ToggleSortDirectionCommand}"
                            Style="{StaticResource LibrarySortDirectionIconButtonStyle}"
                            ToolTip="{Binding SortDirectionButtonToolTip}">
                        <Viewbox Width="16" Height="16">
                            <Canvas Width="26" Height="24">
                                <Path Data="{Binding SortDirectionIconData}"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round" />
                            </Canvas>
                        </Viewbox>
                    </Button>
                    <Canvas x:Name="ToolbarRightButtonGrid"
                            Grid.Column="6"
                            Height="28"
                            VerticalAlignment="Bottom">
                        <Button x:Name="SortOptionFilterButton"
                                Canvas.Left="0"
                                Canvas.Top="0"
                                Content="{Binding SortButtonText}"
                                Click="OpenButtonContextMenu"
                                Tag="{Binding SelectedSortOption}"
                                Style="{StaticResource LibraryFilterButtonStyle}">
                            <Button.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                             Style="{StaticResource LibraryFilterContextMenuStyle}">
                                    <MenuItem Header="最近更新" Command="{Binding SelectSortOptionCommand}" CommandParameter="最近更新" Style="{StaticResource LibraryFilterMenuItemStyle}" />
                                    <MenuItem Header="标题" Command="{Binding SelectSortOptionCommand}" CommandParameter="标题" Style="{StaticResource LibraryFilterMenuItemStyle}" />
                                    <MenuItem Header="年份" Command="{Binding SelectSortOptionCommand}" CommandParameter="年份" Style="{StaticResource LibraryFilterMenuItemStyle}" />
                                    <MenuItem Header="评分" Command="{Binding SelectSortOptionCommand}" CommandParameter="评分" Style="{StaticResource LibraryFilterMenuItemStyle}" />
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                        <Button x:Name="ClearFiltersButton"
                                Canvas.Right="0"
                                Canvas.Top="0"
                                Content="清除筛选"
                                Command="{Binding ClearFiltersCommand}"
                                IsEnabled="{Binding CanClearFilters}"
                                Style="{StaticResource LibraryToolbarButtonStyle}" />
                    </Canvas>
                </Grid>

                <Grid x:Name="ToolbarSecondRowGrid"
                      Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button x:Name="PlaybackSourceFilterButton"
                            Grid.Column="0"
                            Content="{Binding PlaybackSourceButtonText}"
                            Click="OpenButtonContextMenu"
                            Tag="{Binding SelectedLibraryScope}"
                            Style="{StaticResource LibraryFilterButtonStyle}">
                        <Button.ContextMenu>
                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                         Style="{StaticResource LibraryFilterContextMenuStyle}">
                                <MenuItem Header="全部" Command="{Binding SelectLibraryScopeCommand}" CommandParameter="全部" Style="{StaticResource LibraryFilterMenuItemStyle}" />
                                <MenuItem Header="有播放源" Command="{Binding SelectLibraryScopeCommand}" CommandParameter="有播放源" Style="{StaticResource LibraryFilterMenuItemStyle}" />
                                <MenuItem Header="无播放源" Command="{Binding SelectLibraryScopeCommand}" CommandParameter="无播放源" Style="{StaticResource LibraryFilterMenuItemStyle}" />
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button x:Name="MediaSourceFilterButton"
                            Grid.Column="2"
                            Content="{Binding MediaSourceButtonText}"
                            Click="OpenButtonContextMenu"
                            Tag="{Binding SelectedSourceFilter}"
                            Style="{StaticResource LibraryFilterButtonStyle}">
                        <Button.ContextMenu>
                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
