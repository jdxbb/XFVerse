                                                   Canvas.Left="-84"
                                                   Canvas.Top="-84"
                                                   helpers:PosterCachedShadowBehavior.BlurRadius="14"
                                                   helpers:PosterCachedShadowBehavior.CardHeight="270"
                                                   helpers:PosterCachedShadowBehavior.CardWidth="180"
                                                   helpers:PosterCachedShadowBehavior.CornerRadius="12"
                                                   helpers:PosterCachedShadowBehavior.Direction="270"
                                                   helpers:PosterCachedShadowBehavior.IsEnabled="True"
                                                   helpers:PosterCachedShadowBehavior.Opacity="0.28"
                                                   helpers:PosterCachedShadowBehavior.Padding="84"
                                                   helpers:PosterCachedShadowBehavior.ShadowColor="#000000"
