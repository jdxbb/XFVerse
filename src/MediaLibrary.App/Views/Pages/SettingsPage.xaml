<UserControl x:Class="MediaLibrary.App.Views.Pages.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MediaLibrary.App.Controls"
             xmlns:helpers="clr-namespace:MediaLibrary.App.Helpers">
    <UserControl.Resources>
        <Style x:Key="SettingsDraftSectionCardStyle" TargetType="{x:Type helpers:CachedShadowBorder}" BasedOn="{StaticResource GlassPageCardStyle}">
            <Setter Property="Padding" Value="10" />
            <Setter Property="Cursor" Value="Arrow" />
        </Style>

        <Style x:Key="SettingsDraftPanelStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,2,0,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Arrow" />
        </Style>

        <Style x:Key="SettingsDraftRowStyle" TargetType="Border">
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="Margin" Value="6,0,6,0" />
            <Setter Property="Padding" Value="0,4" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Cursor" Value="Arrow" />
        </Style>

        <Style x:Key="SettingsDraftLastRowStyle" TargetType="Border" BasedOn="{StaticResource SettingsDraftRowStyle}">
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style x:Key="SettingsDraftLabelTextStyle" TargetType="TextBlock" BasedOn="{StaticResource LongFieldTextBlockStyle}">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
            <Setter Property="Foreground" Value="{DynamicResource BrushForegroundSecondary}" />
        </Style>

        <Style x:Key="SettingsDraftValueTextStyle" TargetType="TextBlock" BasedOn="{StaticResource LongFieldTextBlockStyle}">
            <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
        </Style>

        <Style x:Key="SettingsDraftMutedWrapTextStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="SettingsDraftMutedSingleLineTextStyle" TargetType="TextBlock" BasedOn="{StaticResource LongFieldTextBlockStyle}">
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
            <Setter Property="Foreground" Value="{DynamicResource BrushForegroundSecondary}" />
        </Style>

        <Style x:Key="SettingsDraftPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="MinWidth" Value="72" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="SettingsDraftSecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="MinWidth" Value="72" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="SettingsDraftDangerButtonStyle" TargetType="Button" BasedOn="{StaticResource DangerButtonStyle}">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="MinWidth" Value="72" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="SettingsDraftTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource FormTextBoxStyle}">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="12,5" />
        </Style>

        <Style x:Key="SettingsDraftComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource FormComboBoxStyle}">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="10,5" />
        </Style>

        <Style x:Key="SettingsSectionHeadingTextStyle" TargetType="TextBlock" BasedOn="{StaticResource SectionTitleTextStyle}">
            <Setter Property="MinHeight" Value="24" />
            <Setter Property="Margin" Value="6,5,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="SettingsSectionDividerStyle" TargetType="Border">
            <Setter Property="Height" Value="2" />
            <Setter Property="Margin" Value="0,6,0,0" />
            <Setter Property="Background" Value="{DynamicResource BrushForegroundPrimary}" />
            <Setter Property="Opacity" Value="0.24" />
        </Style>

        <Style x:Key="SettingsPosterLimitInputContainerStyle" TargetType="Border">
            <Setter Property="Width" Value="132" />
            <Setter Property="Height" Value="30" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Background" Value="{DynamicResource BrushSurfaceRaised}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Cursor" Value="IBeam" />
        </Style>

        <Style x:Key="SettingsPosterLimitTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="28" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="8,3,2,3" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CaretBrush" Value="{DynamicResource BrushAccent}" />
            <Setter Property="FontFamily" Value="{StaticResource FontFamilyBase}" />
            <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="SettingsApiTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource FormTextBoxStyle}">
            <Setter Property="Height" Value="28" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="10,3" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="SettingsApiComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource CorrectionDialogComboBoxStyle}">
            <Setter Property="Height" Value="28" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="10,3" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="SettingsApiRouteLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
            <Setter Property="Margin" Value="0,8,8,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="SettingsAboutRowButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="56" />
            <Setter Property="Padding" Value="37,8,38,8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="0,1,0,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="AboutRowChrome"
                                Margin="0.5,0,0,0"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="AboutRowChrome" Property="Background" Value="{DynamicResource BrushAccentSoft}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsSegmentHostStyle" TargetType="Border">
            <Setter Property="Padding" Value="2" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Background" Value="{DynamicResource BrushSurfaceAlt}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Cursor" Value="Arrow" />
        </Style>

        <Style x:Key="SettingsSegmentButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="28" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="MinWidth" Value="58" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource BrushForegroundSecondary}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="Transparent" />
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="Transparent" />
                                <Setter Property="Foreground" Value="{DynamicResource BrushDisabledForeground}" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsCloseExitSegmentButtonStyle" TargetType="Button" BasedOn="{StaticResource SettingsSegmentButtonStyle}">
            <Setter Property="MinWidth" Value="76" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCloseWindowExitSelected}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="Foreground" Value="{DynamicResource BrushOnAccent}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SettingsCloseTraySegmentButtonStyle" TargetType="Button" BasedOn="{StaticResource SettingsSegmentButtonStyle}">
            <Setter Property="MinWidth" Value="92" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCloseWindowTraySelected}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="Foreground" Value="{DynamicResource BrushOnAccent}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SettingsPlayerFullscreenOnSegmentButtonStyle" TargetType="Button" BasedOn="{StaticResource SettingsSegmentButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPlayerFullscreenOnPlayEnabled}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="Foreground" Value="{DynamicResource BrushOnAccent}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SettingsPlayerFullscreenOffSegmentButtonStyle" TargetType="Button" BasedOn="{StaticResource SettingsSegmentButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPlayerFullscreenOnPlayDisabled}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="Foreground" Value="{DynamicResource BrushOnAccent}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SettingsThemeSystemSegmentButtonStyle" TargetType="Button" BasedOn="{StaticResource SettingsSegmentButtonStyle}">
            <Setter Property="MinWidth" Value="78" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSystemThemeSelected}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="Foreground" Value="{DynamicResource BrushOnAccent}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SettingsThemeLightSegmentButtonStyle" TargetType="Button" BasedOn="{StaticResource SettingsSegmentButtonStyle}">
            <Setter Property="MinWidth" Value="58" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsLightThemeSelected}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="Foreground" Value="{DynamicResource BrushOnAccent}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SettingsThemeDarkSegmentButtonStyle" TargetType="Button" BasedOn="{StaticResource SettingsSegmentButtonStyle}">
            <Setter Property="MinWidth" Value="58" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDarkThemeSelected}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="Foreground" Value="{DynamicResource BrushOnAccent}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SettingsAutoWebDavOffSegmentButtonStyle" TargetType="Button" BasedOn="{StaticResource SettingsSegmentButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsAutoWebDavScanDisabled}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="Foreground" Value="{DynamicResource BrushOnAccent}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SettingsAutoWebDavOnSegmentButtonStyle" TargetType="Button" BasedOn="{StaticResource SettingsSegmentButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsAutoWebDavScanEnabled}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="Foreground" Value="{DynamicResource BrushOnAccent}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SettingsModernScrollBarThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border Width="6"
                                Background="{DynamicResource BrushForegroundMuted}"
                                CornerRadius="3"
                                Opacity="0.58" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsModernScrollRepeatButtonStyle" TargetType="{x:Type RepeatButton}">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsModernScrollBarStyle" TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="6" />
            <Setter Property="MinWidth" Value="6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Width="{TemplateBinding Width}" Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}"
                                                  Style="{StaticResource SettingsModernScrollRepeatButtonStyle}" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SettingsModernScrollBarThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}"
                                                  Style="{StaticResource SettingsModernScrollRepeatButtonStyle}" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
                <Trigger Property="IsMouseCaptureWithin" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=(helpers:ScrollBarAutoRevealBehavior.IsRevealed)}"
                             Value="True">
                    <Setter Property="Opacity" Value="1" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SettingsManualTabButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="104" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Margin" Value="0,0,28,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Width="{TemplateBinding Width}"
                              Height="{TemplateBinding Height}"
                              Background="{TemplateBinding Background}"
                              ClipToBounds="False"
                              SnapsToDevicePixels="True">
                            <TextBlock Width="{TemplateBinding Width}"
                                       Margin="0,0,0,8"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Bottom"
                                       FontFamily="{TemplateBinding FontFamily}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       Foreground="{TemplateBinding Foreground}"
                                       Text="{TemplateBinding Content}"
                                       TextAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />
                            <Border Width="{TemplateBinding Width}"
                                    Height="4"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Bottom"
                                    Background="{TemplateBinding BorderBrush}" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource BrushAccent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsGeneralTabButtonStyle" TargetType="Button" BasedOn="{StaticResource SettingsManualTabButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsGeneralSettingsTabSelected}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SettingsApiTabButtonStyle" TargetType="Button" BasedOn="{StaticResource SettingsManualTabButtonStyle}">
            <Setter Property="Margin" Value="0" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsApiSettingsTabSelected}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SettingsDiscoveryTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0,16,0,0" />
            <Setter Property="Margin" Value="0,-8,0,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid ClipToBounds="False"
                                  SnapsToDevicePixels="True">
                                <Border Height="2"
                                        VerticalAlignment="Bottom"
                                        Background="{DynamicResource BrushDivider}" />
                                <StackPanel Panel.ZIndex="2"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Bottom"
                                            ClipToBounds="False"
                                            Orientation="Horizontal">
                                    <Button Content="通用"
                                            Command="{Binding SelectSettingsTabCommand}"
                                            CommandParameter="0"
                                            Style="{StaticResource SettingsGeneralTabButtonStyle}" />
                                    <Button Content="API 配置"
                                            Command="{Binding SelectSettingsTabCommand}"
                                            CommandParameter="1"
                                            Style="{StaticResource SettingsApiTabButtonStyle}" />
                                </StackPanel>
                                <TabPanel x:Name="HeaderPanel"
                                          Panel.ZIndex="0"
                                          Height="0"
                                          HorizontalAlignment="Left"
                                          IsHitTestVisible="False"
                                          IsItemsHost="True"
                                          KeyboardNavigation.TabIndex="1"
                                          Opacity="0" />
                            </Grid>
                            <ContentPresenter x:Name="PART_SelectedContentHost"
                                              Grid.Row="1"
                                              Margin="{TemplateBinding Padding}"
                                              ContentSource="SelectedContent" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsDiscoveryTabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="MinWidth" Value="104" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,28,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid MinWidth="{TemplateBinding MinWidth}"
                              Height="{TemplateBinding Height}"
                              Background="Transparent">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Bottom">
                                <TextBlock Margin="0,0,0,7"
                                           HorizontalAlignment="Center"
                                           FontFamily="{TemplateBinding FontFamily}"
                                           FontSize="{TemplateBinding FontSize}"
                                           FontWeight="{TemplateBinding FontWeight}"
                                           Foreground="{TemplateBinding Foreground}"
                                           Text="{TemplateBinding Header}"
                                           TextAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />
                                <Border x:Name="SelectedUnderline"
                                        Width="104"
                                        Height="4"
                                        HorizontalAlignment="Center"
                                        Background="{DynamicResource BrushAccent}"
                                        Opacity="0" />
                            </StackPanel>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource BrushAccent}" />
                                <Setter TargetName="SelectedUnderline" Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource BrushAccent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="Transparent">
                <TabControl SelectedIndex="{Binding SelectedSettingsTabIndex, Mode=TwoWay}"
                            Style="{StaticResource SettingsDiscoveryTabControlStyle}"
                            ItemContainerStyle="{StaticResource SettingsDiscoveryTabItemStyle}">
                    <TabItem Header="通用">
                        <Grid Margin="-32,-12,-32,0" ClipToBounds="False" Cursor="Arrow">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Hidden" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsGeneralSettingsContentReady}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <helpers:CachedShadowBorder Grid.Row="0"
                                    Margin="32,24,32,0"
                                    Style="{StaticResource SettingsDraftSectionCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="缓存设置"
                                               Style="{StaticResource SettingsSectionHeadingTextStyle}" />
                                    <Border Style="{StaticResource SettingsSectionDividerStyle}" />

                                    <Border Style="{StaticResource SettingsDraftPanelStyle}">
                                        <StackPanel>
                                            <Border Style="{StaticResource SettingsDraftRowStyle}">
                                                <Grid>
