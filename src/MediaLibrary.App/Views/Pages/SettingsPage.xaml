<UserControl x:Class="MediaLibrary.App.Views.Pages.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <Border Style="{StaticResource PageCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="设置" Style="{StaticResource CardTitleTextStyle}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="管理通用设置与 API 配置。"
                               Style="{StaticResource BodyMutedTextStyle}" />
                </StackPanel>

                <TabControl Grid.Row="1"
                            Margin="0,22,0,0"
                            Style="{StaticResource ModernTabControlStyle}"
                            ItemContainerStyle="{StaticResource ModernTabItemStyle}">
                    <TabItem Header="通用">
                        <StackPanel Margin="0,18,0,0">
                            <Border Style="{StaticResource CompactCardStyle}">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="120" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="软件缓存" Style="{StaticResource SectionTitleTextStyle}" />
                                            <TextBlock Margin="0,10,0,0"
                                                       Text="管理可再生成的软件缓存。这里不清理视频缓存、用户配置、本地媒体、WebDAV 文件或人格海报。"
                                                       TextWrapping="Wrap"
                                                       Style="{StaticResource BodyTextStyle}" />
                                        </StackPanel>

                                        <Button Grid.Column="1"
                                                Width="100"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                Content="刷新状态"
                                                Command="{Binding RefreshSoftwareCacheCommand}"
                                                Style="{StaticResource SecondaryButtonStyle}" />
                                    </Grid>

                                    <TextBlock Margin="0,14,0,0"
                                               Text="{Binding SoftwareCacheStatusMessage}"
                                               TextWrapping="Wrap"
                                               Style="{StaticResource BodyMutedTextStyle}" />

                                    <Grid Margin="0,18,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="24" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Padding="16" CornerRadius="12" Background="{DynamicResource BrushSurfaceAlt}">
                                            <StackPanel>
                                                <TextBlock Text="海报缓存" Style="{StaticResource SectionTitleTextStyle}" />
                                                <TextBlock Margin="0,10,0,0"
                                                           Text="缓存远程影片海报。清理后会按需重新下载，不影响人格海报或影片数据。"
                                                           TextWrapping="Wrap"
                                                           Style="{StaticResource BodyTextStyle}" />

                                                <TextBlock Margin="0,18,0,0" Text="当前占用" Style="{StaticResource BodyTextStyle}" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="{Binding PosterCacheUsageText}"
                                                           TextWrapping="Wrap"
                                                           Style="{StaticResource SectionTitleTextStyle}" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="{Binding PosterCacheFileCountText}"
                                                           TextWrapping="Wrap"
                                                           Style="{StaticResource BodyMutedTextStyle}" />

                                                <TextBlock Margin="0,16,0,0" Text="容量上限（MB）" Style="{StaticResource BodyTextStyle}" />
                                                <TextBox Width="180"
                                                         HorizontalAlignment="Left"
                                                         Style="{StaticResource FormTextBoxStyle}"
                                                         Text="{Binding PosterCacheMaxMbText, UpdateSourceTrigger=PropertyChanged}" />

                                                <StackPanel Margin="0,18,0,0" Orientation="Horizontal">
                                                    <Button Content="保存上限"
                                                            Command="{Binding SavePosterCacheLimitCommand}"
                                                            Style="{StaticResource PrimaryButtonStyle}" />
                                                    <Button Margin="12,0,0,0"
                                                            Content="清理海报缓存"
                                                            Command="{Binding ClearPosterCacheCommand}"
                                                            Style="{StaticResource SecondaryButtonStyle}" />
                                                </StackPanel>

                                                <TextBlock Margin="0,14,0,0"
                                                           Text="{Binding PosterCacheStatusMessage}"
                                                           TextWrapping="Wrap"
                                                           Style="{StaticResource BodyMutedTextStyle}" />
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="2" Padding="16" CornerRadius="12" Background="{DynamicResource BrushSurfaceAlt}">
                                            <StackPanel>
                                                <TextBlock Text="其他缓存" Style="{StaticResource SectionTitleTextStyle}" />
                                                <TextBlock Margin="0,10,0,0"
                                                           Text="{Binding OtherCacheDescriptionText}"
                                                           TextWrapping="Wrap"
                                                           Style="{StaticResource BodyTextStyle}" />

                                                <TextBlock Margin="0,18,0,0" Text="当前可清理内容" Style="{StaticResource BodyTextStyle}" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="{Binding OtherCacheUsageText}"
                                                           TextWrapping="Wrap"
                                                           Style="{StaticResource SectionTitleTextStyle}" />
                                                <TextBlock Margin="0,8,0,0"
                                                           Text="不设置容量上限；SQLite 文件大小不一定会随缓存记录删除立即下降。"
                                                           TextWrapping="Wrap"
                                                           Style="{StaticResource BodyMutedTextStyle}" />

                                                <Button Margin="0,18,0,0"
                                                        Width="150"
                                                        HorizontalAlignment="Left"
                                                        Content="清理其他缓存"
                                                        Command="{Binding ClearOtherCacheCommand}"
                                                        IsEnabled="{Binding IsOtherCacheClearAvailable}"
                                                        Style="{StaticResource SecondaryButtonStyle}" />

                                                <TextBlock Margin="0,14,0,0"
                                                           Text="{Binding OtherCacheStatusMessage}"
                                                           TextWrapping="Wrap"
                                                           Style="{StaticResource BodyMutedTextStyle}" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Border Margin="0,18,0,0"
                                            Padding="16"
                                            CornerRadius="12"
                                            Background="{DynamicResource BrushSurfaceAlt}">
                                        <StackPanel>
                                            <TextBlock Text="在线字幕缓存" Style="{StaticResource SectionTitleTextStyle}" />
                                            <TextBlock Margin="0,10,0,0"
                                                       Text="管理 OpenSubtitles 下载到本机的字幕缓存。这里只清理未被绑定引用的孤立缓存，不会删除本地媒体、WebDAV 文件或扫描发现的外挂字幕。"
                                                       TextWrapping="Wrap"
                                                       Style="{StaticResource BodyTextStyle}" />

                                            <TextBlock Margin="0,18,0,0" Text="当前占用" Style="{StaticResource BodyTextStyle}" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Text="{Binding SubtitleCacheUsageText}"
                                                       TextWrapping="Wrap"
                                                       Style="{StaticResource SectionTitleTextStyle}" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Text="{Binding SubtitleCacheDetailText}"
                                                       TextWrapping="Wrap"
                                                       Style="{StaticResource BodyMutedTextStyle}" />

                                            <Button Margin="0,18,0,0"
                                                    Width="180"
                                                    HorizontalAlignment="Left"
                                                    Content="清理孤立字幕缓存"
                                                    Command="{Binding ClearSubtitleCacheCommand}"
                                                    IsEnabled="{Binding IsSubtitleCacheClearAvailable}"
                                                    Style="{StaticResource SecondaryButtonStyle}" />

                                            <TextBlock Margin="0,14,0,0"
                                                       Text="{Binding SubtitleCacheStatusMessage}"
                                                       TextWrapping="Wrap"
                                                       Style="{StaticResource BodyMutedTextStyle}" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border Margin="0,18,0,0" Style="{StaticResource CompactCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="420" />
                                        <ColumnDefinition Width="24" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="行为设置" Style="{StaticResource SectionTitleTextStyle}" />
                                        <TextBlock Margin="0,10,0,0"
                                                   Text="当前保留已有主题行为设置。"
                                                   TextWrapping="Wrap"
                                                   Style="{StaticResource BodyTextStyle}" />
                                        <TextBlock Margin="0,18,0,0" Text="外观主题" Style="{StaticResource BodyTextStyle}" />
                                        <ComboBox Margin="0,8,0,0"
                                                  ItemsSource="{Binding ThemeModes}"
                                                  SelectedItem="{Binding SelectedThemeMode}"
                                                  Style="{StaticResource FormComboBoxStyle}" />
                                        <Button Margin="0,18,0,0"
                                                Width="120"
                                                HorizontalAlignment="Left"
                                                Content="应用主题"
                                                Command="{Binding SaveThemeSettingsCommand}"
                                                Style="{StaticResource PrimaryButtonStyle}" />
                                        <TextBlock Margin="0,14,0,0"
                                                   Text="{Binding ThemeStatusMessage}"
                                                   TextWrapping="Wrap"
                                                   Style="{StaticResource BodyMutedTextStyle}" />
                                    </StackPanel>

                                    <Border Grid.Column="2" Padding="16" CornerRadius="12" Background="{DynamicResource BrushSurfaceAlt}">
                                        <TextBlock Text="更多行为设置将在后续阶段接入。"
                                                   TextWrapping="Wrap"
                                                   Style="{StaticResource BodyMutedTextStyle}" />
                                    </Border>
                                </Grid>
                            </Border>

                            <Border Margin="0,18,0,0" Style="{StaticResource CompactCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="72" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="110" />
                                    </Grid.ColumnDefinitions>

                                    <Border Width="56"
                                            Height="56"
                                            CornerRadius="14"
                                            Background="{DynamicResource BrushAccentSoft}">
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Text="XF"
                                                   FontSize="22"
                                                   FontWeight="Bold"
                                                   Style="{StaticResource BodyTextStyle}" />
                                    </Border>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="关于 XFVerse" Style="{StaticResource SectionTitleTextStyle}" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="{Binding AppVersionText}"
                                                   Style="{StaticResource BodyMutedTextStyle}" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="{Binding AboutStatusMessage}"
                                                   TextWrapping="Wrap"
                                                   Style="{StaticResource BodyMutedTextStyle}" />
                                    </StackPanel>

                                    <Button Grid.Column="2"
                                            Width="88"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Content="展开"
                                            Command="{Binding ToggleAboutDetailsCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </TabItem>

                    <TabItem Header="API 配置">
                        <StackPanel Margin="0,18,0,0">
                            <Border Style="{StaticResource CompactCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="TMDB 配置" Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Margin="0,10,0,0"
                                               Text="TMDB 用于影片识别和元数据。认证信息只保存在本地数据库。"
                                               TextWrapping="Wrap"
                                               Style="{StaticResource BodyTextStyle}" />
                                    <TextBlock Margin="0,18,0,0" Text="TMDB Read Access Token（优先）" Style="{StaticResource BodyTextStyle}" />
                                    <TextBox Style="{StaticResource FormTextBoxStyle}"
                                             Text="{Binding TmdbReadAccessToken, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Margin="0,10,0,0" Text="TMDB API Key（备用）" Style="{StaticResource BodyTextStyle}" />
                                    <TextBox Style="{StaticResource FormTextBoxStyle}"
                                             Text="{Binding TmdbApiKey, UpdateSourceTrigger=PropertyChanged}" />
                                    <StackPanel Margin="0,18,0,0" Orientation="Horizontal">
                                        <Button Width="120"
                                                Content="保存设置"
                                                Command="{Binding SaveTmdbSettingsCommand}"
                                                Style="{StaticResource PrimaryButtonStyle}" />
                                        <Button Margin="12,0,0,0"
                                                Width="120"
                                                Content="测试连接"
                                                Command="{Binding TestTmdbConnectionCommand}"
                                                Style="{StaticResource SecondaryButtonStyle}" />
                                    </StackPanel>
                                    <TextBlock Margin="0,14,0,0"
                                               Text="{Binding TmdbStatusMessage}"
                                               TextWrapping="Wrap"
                                               Style="{StaticResource BodyMutedTextStyle}" />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,18,0,0" Style="{StaticResource CompactCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="OMDb 配置" Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Margin="0,10,0,0"
                                               Text="OMDb 用于读取 IMDb 评分字段。"
                                               TextWrapping="Wrap"
                                               Style="{StaticResource BodyTextStyle}" />
                                    <TextBlock Margin="0,18,0,0" Text="OMDb API Key" Style="{StaticResource BodyTextStyle}" />
                                    <TextBox Style="{StaticResource FormTextBoxStyle}"
                                             Text="{Binding OmdbApiKey, UpdateSourceTrigger=PropertyChanged}" />
                                    <StackPanel Margin="0,18,0,0" Orientation="Horizontal">
                                        <Button Width="120"
                                                Content="保存设置"
                                                Command="{Binding SaveOmdbSettingsCommand}"
                                                Style="{StaticResource PrimaryButtonStyle}" />
                                        <Button Margin="12,0,0,0"
                                                Width="120"
                                                Content="测试连接"
                                                Command="{Binding TestOmdbConnectionCommand}"
                                                Style="{StaticResource SecondaryButtonStyle}" />
                                    </StackPanel>
                                    <TextBlock Margin="0,14,0,0"
                                               Text="{Binding OmdbStatusMessage}"
                                               TextWrapping="Wrap"
                                               Style="{StaticResource BodyMutedTextStyle}" />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,18,0,0" Style="{StaticResource CompactCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="在线字幕配置" Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Margin="0,10,0,0"
                                               Text="用于 OpenSubtitles 在线字幕搜索、下载能力探测和后续播放器下载流程。账号密码可选；仅 API key 也可以保存并测试。"
                                               TextWrapping="Wrap"
                                               Style="{StaticResource BodyTextStyle}" />

                                    <CheckBox Margin="0,18,0,0"
                                              Content="启用在线字幕"
                                              IsChecked="{Binding IsOpenSubtitlesEnabled}"
                                              Style="{StaticResource FormCheckBoxStyle}" />

                                    <TextBlock Margin="0,18,0,0" Text="Endpoint" Style="{StaticResource BodyTextStyle}" />
                                    <TextBox Style="{StaticResource FormTextBoxStyle}"
                                             Text="{Binding OpenSubtitlesEndpoint, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Margin="0,10,0,0" Text="API Key" Style="{StaticResource BodyTextStyle}" />
                                    <TextBox Style="{StaticResource FormTextBoxStyle}"
                                             Text="{Binding OpenSubtitlesApiKey, UpdateSourceTrigger=PropertyChanged}" />

                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="18" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Username（可选）" Style="{StaticResource BodyTextStyle}" />
                                            <TextBox Margin="0,6,0,0"
                                                     Style="{StaticResource FormTextBoxStyle}"
                                                     Text="{Binding OpenSubtitlesUsername, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Password（可选）" Style="{StaticResource BodyTextStyle}" />
                                            <PasswordBox x:Name="OpenSubtitlesPasswordBox"
                                                         Margin="0,6,0,0"
                                                         PasswordChanged="OpenSubtitlesPasswordBox_PasswordChanged" />
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Margin="0,10,0,0" Text="默认搜索语言" Style="{StaticResource BodyTextStyle}" />
                                    <ComboBox ItemsSource="{Binding OpenSubtitlesLanguages}"
                                              SelectedItem="{Binding SelectedOpenSubtitlesLanguage}"
                                              DisplayMemberPath="Name"
                                              Style="{StaticResource FormComboBoxStyle}" />

                                    <StackPanel Margin="0,18,0,0" Orientation="Horizontal">
                                        <Button Width="120"
                                                Content="保存配置"
                                                Command="{Binding SaveOpenSubtitlesSettingsCommand}"
                                                Style="{StaticResource PrimaryButtonStyle}" />
                                        <Button Margin="12,0,0,0"
                                                Width="150"
                                                Content="测试在线字幕"
                                                Command="{Binding TestOpenSubtitlesConnectionCommand}"
                                                Style="{StaticResource SecondaryButtonStyle}" />
                                    </StackPanel>

                                    <TextBlock Margin="0,14,0,0"
                                               Text="{Binding OpenSubtitlesStatusMessage}"
                                               TextWrapping="Wrap"
                                               Style="{StaticResource BodyMutedTextStyle}" />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,18,0,0" Style="{StaticResource CompactCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="大模型配置" Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Margin="0,10,0,0"
                                               Text="用于 AI 分类、推荐理由和辅助识别。接口不可用时会使用本地规则降级。"
                                               TextWrapping="Wrap"
                                               Style="{StaticResource BodyTextStyle}" />
                                    <TextBlock Margin="0,18,0,0" Text="Base URL" Style="{StaticResource BodyTextStyle}" />
                                    <TextBox Style="{StaticResource FormTextBoxStyle}"
                                             Text="{Binding AiBaseUrl, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Margin="0,10,0,0" Text="API Key" Style="{StaticResource BodyTextStyle}" />
                                    <TextBox Style="{StaticResource FormTextBoxStyle}"
                                             Text="{Binding AiApiKey, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Margin="0,16,0,0"
                                               Text="分项模型与超时"
                                               Style="{StaticResource BodyTextStyle}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Text="可按调用场景覆盖模型和超时时间；旧配置中的单一模型名仍会兼容读取。"
                                               TextWrapping="Wrap"
                                               Style="{StaticResource BodyMutedTextStyle}" />
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="170" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="96" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="模型" Style="{StaticResource BodyMutedTextStyle}" />
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="超时(秒)" Style="{StaticResource BodyMutedTextStyle}" />
                                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,10,0" Text="详情页修正" Style="{StaticResource BodyTextStyle}" />
                                        <TextBox Grid.Row="1" Grid.Column="1" Margin="0,6,8,0" Style="{StaticResource FormTextBoxStyle}" Text="{Binding AiDetailCorrectionModel, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBox Grid.Row="1" Grid.Column="2" Margin="0,6,0,0" Style="{StaticResource FormTextBoxStyle}" Text="{Binding AiDetailCorrectionTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8,10,0" Text="批量 AI 识别" Style="{StaticResource BodyTextStyle}" />
                                        <TextBox Grid.Row="2" Grid.Column="1" Margin="0,6,8,0" Style="{StaticResource FormTextBoxStyle}" Text="{Binding AiBatchCorrectionModel, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBox Grid.Row="2" Grid.Column="2" Margin="0,6,0,0" Style="{StaticResource FormTextBoxStyle}" Text="{Binding AiBatchCorrectionTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,8,10,0" Text="扫描 TV 不确定范围" Style="{StaticResource BodyTextStyle}" />
                                        <TextBox Grid.Row="3" Grid.Column="1" Margin="0,6,8,0" Style="{StaticResource FormTextBoxStyle}" Text="{Binding AiScanTvUncertainRangeModel, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBox Grid.Row="3" Grid.Column="2" Margin="0,6,0,0" Style="{StaticResource FormTextBoxStyle}" Text="{Binding AiScanTvUncertainRangeTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,8,10,0" Text="扫描 TV 全量范围" Style="{StaticResource BodyTextStyle}" />
                                        <TextBox Grid.Row="4" Grid.Column="1" Margin="0,6,8,0" Style="{StaticResource FormTextBoxStyle}" Text="{Binding AiScanTvFullRangeModel, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBox Grid.Row="4" Grid.Column="2" Margin="0,6,0,0" Style="{StaticResource FormTextBoxStyle}" Text="{Binding AiScanTvFullRangeTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,8,10,0" Text="扫描电影标签" Style="{StaticResource BodyTextStyle}" />
                                        <TextBox Grid.Row="5" Grid.Column="1" Margin="0,6,8,0" Style="{StaticResource FormTextBoxStyle}" Text="{Binding AiScanMovieTaggingModel, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBox Grid.Row="5" Grid.Column="2" Margin="0,6,0,0" Style="{StaticResource FormTextBoxStyle}" Text="{Binding AiScanMovieTaggingTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,8,10,0" Text="AI 推荐" Style="{StaticResource BodyTextStyle}" />
                                        <TextBox Grid.Row="6" Grid.Column="1" Margin="0,6,8,0" Style="{StaticResource FormTextBoxStyle}" Text="{Binding AiRecommendationModel, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBox Grid.Row="6" Grid.Column="2" Margin="0,6,0,0" Style="{StaticResource FormTextBoxStyle}" Text="{Binding AiRecommendationTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Grid.Row="7" Grid.Column="0" Margin="0,8,10,0" Text="观影画像" Style="{StaticResource BodyTextStyle}" />
                                        <TextBox Grid.Row="7" Grid.Column="1" Margin="0,6,8,0" Style="{StaticResource FormTextBoxStyle}" Text="{Binding AiWatchProfileModel, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBox Grid.Row="7" Grid.Column="2" Margin="0,6,0,0" Style="{StaticResource FormTextBoxStyle}" Text="{Binding AiWatchProfileTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                    <Button Margin="0,18,0,0"
                                            Width="150"
                                            HorizontalAlignment="Left"
                                            Content="保存大模型配置"
                                            Command="{Binding SaveAiSettingsCommand}"
                                            Style="{StaticResource PrimaryButtonStyle}" />
                                    <TextBlock Margin="0,14,0,0"
                                               Text="{Binding ApiStatusMessage}"
                                               TextWrapping="Wrap"
                                               Style="{StaticResource BodyMutedTextStyle}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </TabItem>
                </TabControl>
            </Grid>
        </Border>
    </ScrollViewer>
</UserControl>
