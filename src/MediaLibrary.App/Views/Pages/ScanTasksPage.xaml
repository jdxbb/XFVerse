<UserControl x:Class="MediaLibrary.App.Views.Pages.ScanTasksPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MediaLibrary.App.Controls"
             xmlns:helpers="clr-namespace:MediaLibrary.App.Helpers"
             xmlns:pages="clr-namespace:MediaLibrary.App.Views.Pages">
    <UserControl.Resources>
        <Style x:Key="ScanEmptyStateStyle" TargetType="Border" BasedOn="{StaticResource CompactCardStyle}">
            <Setter Property="Padding" Value="18" />
            <Setter Property="Visibility" Value="Collapsed" />
        </Style>

        <Style x:Key="ScanDraftPanelStyle" TargetType="Border">
            <Setter Property="Padding" Value="16" />
            <Setter Property="CornerRadius" Value="{StaticResource RadiusCompactCard}" />
            <Setter Property="Background" Value="{DynamicResource BrushSurfaceAlt}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="ScanDraftSubPanelStyle" TargetType="Border" BasedOn="{StaticResource ScanDraftPanelStyle}">
            <Setter Property="Padding" Value="14" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="7*" />
            <ColumnDefinition Width="24" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="18" />
                <RowDefinition Height="252" />
            </Grid.RowDefinitions>

            <Border Style="{StaticResource PageCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="112" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="扫描配置" Style="{StaticResource CardTitleTextStyle}" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="管理 WebDAV 与本地目录扫描来源。"
                                       Style="{StaticResource BodyMutedTextStyle}" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="刷新"
                                Command="{Binding RefreshCommand}"
                                Style="{StaticResource SecondaryButtonStyle}" />
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.1*" MinWidth="360" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="1.45*" MinWidth="520" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource ScanDraftPanelStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="16" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <DockPanel LastChildFill="False">
                                        <TextBlock Text="WebDAV 路径" Style="{StaticResource SectionTitleTextStyle}" />
                                        <Button DockPanel.Dock="Right"
                                                Content="添加路径"
                                                Command="{Binding BeginAddScanPathCommand}"
                                                Style="{StaticResource SecondaryButtonStyle}" />
                                    </DockPanel>
                                    <TextBlock Grid.Row="1"
                                               Margin="0,8,0,0"
                                               Text="{Binding ScanPathStatusMessage}"
                                               TextWrapping="Wrap"
                                               Style="{StaticResource BodyMutedTextStyle}" />

                                    <Grid Grid.Row="2" Margin="0,12,0,0">
                                        <Border>
                                            <Border.Style>
                                                <Style TargetType="Border" BasedOn="{StaticResource ScanEmptyStateStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasScanPaths}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="还没有 WebDAV 扫描路径。"
                                                       Style="{StaticResource BodyMutedTextStyle}" />
                                        </Border>

                                        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                                      VerticalScrollBarVisibility="Auto"
                                                      helpers:ScrollBarAutoRevealBehavior.IsEnabled="True">
                                            <ScrollViewer.Style>
                                                <Style TargetType="ScrollViewer">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasScanPaths}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ScrollViewer.Style>
                                            <ItemsControl ItemsSource="{Binding ScanPaths}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <controls:ScanPathCard Title="{Binding DisplayName}"
                                                                               PathText="{Binding Path}"
                                                                               DetailText="{Binding DetailText}">
                                                            <controls:ScanPathCard.ActionsContent>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Button Content="编辑"
                                                                            Command="{Binding DataContext.EditScanPathCommand, RelativeSource={RelativeSource AncestorType={x:Type pages:ScanTasksPage}}}"
                                                                            CommandParameter="{Binding}"
                                                                            Style="{StaticResource SecondaryButtonStyle}" />
                                                                    <Button Margin="8,0,0,0"
                                                                            Content="{Binding ToggleText}"
                                                                            Command="{Binding DataContext.ToggleScanPathCommand, RelativeSource={RelativeSource AncestorType={x:Type pages:ScanTasksPage}}}"
                                                                            CommandParameter="{Binding}"
                                                                            Style="{StaticResource SecondaryButtonStyle}" />
                                                                    <Button Margin="8,0,0,0"
                                                                            Content="删除"
                                                                            Command="{Binding DataContext.DeleteScanPathCommand, RelativeSource={RelativeSource AncestorType={x:Type pages:ScanTasksPage}}}"
                                                                            CommandParameter="{Binding}"
                                                                            Style="{StaticResource SecondaryButtonStyle}" />
                                                                </StackPanel>
                                                            </controls:ScanPathCard.ActionsContent>
                                                        </controls:ScanPathCard>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>

                                    <Border Grid.Row="3"
                                            Margin="0,12,0,0"
                                            Style="{StaticResource ScanDraftSubPanelStyle}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <DockPanel LastChildFill="False">
                                                <TextBlock Text="{Binding ScanPathEditorTitle}" Style="{StaticResource SectionTitleTextStyle}" />
                                                <Button DockPanel.Dock="Right"
                                                        Content="取消"
                                                        Command="{Binding CancelEditScanPathCommand}"
                                                        Style="{StaticResource SecondaryButtonStyle}" />
                                            </DockPanel>

                                            <Grid Grid.Row="1" Margin="0,12,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="84" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="10" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock VerticalAlignment="Center" Text="路径" Style="{StaticResource BodyTextStyle}" />
                                                <TextBox Grid.Column="1"
                                                         Margin="0"
                                                         MaxLength="1000"
                                                         Style="{StaticResource FormTextBoxStyle}"
                                                         Text="{Binding EditingScanPathValue, UpdateSourceTrigger=PropertyChanged}" />
                                                <Button Grid.Column="3"
                                                        Content="选择路径"
                                                        Command="{Binding PickWebDavScanPathCommand}"
                                                        Style="{StaticResource SecondaryButtonStyle}" />
                                            </Grid>

                                            <Grid Grid.Row="2" Margin="0,10,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="84" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock VerticalAlignment="Center" Text="显示名称" Style="{StaticResource BodyTextStyle}" />
                                                <TextBox Grid.Column="1"
                                                         Margin="0"
                                                         MaxLength="200"
                                                         Style="{StaticResource FormTextBoxStyle}"
                                                         Text="{Binding EditingScanPathDisplayName, UpdateSourceTrigger=PropertyChanged}" />
                                            </Grid>

                                            <Grid Grid.Row="3" Margin="0,10,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <WrapPanel>
                                                    <CheckBox Content="启用"
                                                              IsChecked="{Binding EditingScanPathEnabled}"
                                                              Style="{StaticResource FormCheckBoxStyle}" />
                                                    <CheckBox Margin="16,0,0,0"
                                                              Content="递归扫描子目录"
                                                              IsChecked="{Binding EditingScanPathRecursive}"
                                                              Style="{StaticResource FormCheckBoxStyle}" />
                                                </WrapPanel>
                                                <Button Grid.Column="1"
                                                        Content="{Binding ScanPathSubmitButtonText}"
                                                        Command="{Binding SaveScanPathCommand}"
                                                        Style="{StaticResource PrimaryButtonStyle}" />
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </Grid>

                                <Grid Grid.Row="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <DockPanel LastChildFill="False">
                                        <TextBlock Text="本地目录" Style="{StaticResource SectionTitleTextStyle}" />
                                        <Button DockPanel.Dock="Right"
                                                Content="添加目录"
                                                Command="{Binding BeginAddLocalScanPathCommand}"
                                                Style="{StaticResource SecondaryButtonStyle}" />
                                    </DockPanel>
                                    <TextBlock Grid.Row="1"
                                               Margin="0,8,0,0"
                                               Text="{Binding LocalScanPathStatusMessage}"
                                               TextWrapping="Wrap"
                                               Style="{StaticResource BodyMutedTextStyle}" />

                                    <Grid Grid.Row="2" Margin="0,12,0,0">
                                        <Border>
                                            <Border.Style>
                                                <Style TargetType="Border" BasedOn="{StaticResource ScanEmptyStateStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasLocalScanPaths}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="还没有本地目录配置。"
                                                       Style="{StaticResource BodyMutedTextStyle}" />
                                        </Border>

                                        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                                      VerticalScrollBarVisibility="Auto"
                                                      helpers:ScrollBarAutoRevealBehavior.IsEnabled="True">
                                            <ScrollViewer.Style>
                                                <Style TargetType="ScrollViewer">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasLocalScanPaths}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ScrollViewer.Style>
                                            <ItemsControl ItemsSource="{Binding LocalScanPaths}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <controls:ScanPathCard Title="{Binding DisplayName}"
                                                                               PathText="{Binding Path}"
                                                                               DetailText="{Binding DetailText}">
                                                            <controls:ScanPathCard.ActionsContent>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Button Content="编辑"
                                                                            Command="{Binding DataContext.EditLocalScanPathCommand, RelativeSource={RelativeSource AncestorType={x:Type pages:ScanTasksPage}}}"
                                                                            CommandParameter="{Binding}"
                                                                            Style="{StaticResource SecondaryButtonStyle}" />
                                                                    <Button Margin="8,0,0,0"
                                                                            Content="{Binding ToggleText}"
                                                                            Command="{Binding DataContext.ToggleLocalScanPathCommand, RelativeSource={RelativeSource AncestorType={x:Type pages:ScanTasksPage}}}"
                                                                            CommandParameter="{Binding}"
                                                                            Style="{StaticResource SecondaryButtonStyle}" />
                                                                    <controls:LocalScanPathRemovePopover Margin="8,0,0,0"
                                                                                                          ConfirmCommand="{Binding DataContext.DeleteLocalScanPathCommand, RelativeSource={RelativeSource AncestorType={x:Type pages:ScanTasksPage}}}"
                                                                                                          CommandParameter="{Binding}" />
                                                                </StackPanel>
                                                            </controls:ScanPathCard.ActionsContent>
                                                        </controls:ScanPathCard>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>

                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="1.65*" />
                                <RowDefinition Height="14" />
                                <RowDefinition Height="0.8*" />
                            </Grid.RowDefinitions>

                            <Border Style="{StaticResource ScanDraftPanelStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="WebDAV 配置" Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Grid.Row="1"
                                               Margin="0,8,0,0"
                                               Text="保存和测试是独立操作。"
                                               TextWrapping="Wrap"
                                               Style="{StaticResource BodyMutedTextStyle}" />

                                    <Grid Grid.Row="2" Margin="0,14,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock VerticalAlignment="Center" Text="连接名称" Style="{StaticResource BodyTextStyle}" />
                                        <TextBox Grid.Column="1"
                                                 Margin="0"
                                                 MaxLength="120"
                                                 Style="{StaticResource FormTextBoxStyle}"
                                                 Text="{Binding ConnectionName, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>

                                    <Grid Grid.Row="3" Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock VerticalAlignment="Center" Text="BaseUrl" Style="{StaticResource BodyTextStyle}" />
                                        <TextBox Grid.Column="1"
                                                 Margin="0"
                                                 MaxLength="500"
                                                 Style="{StaticResource FormTextBoxStyle}"
                                                 Text="{Binding BaseUrl, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>

                                    <Grid Grid.Row="4" Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock VerticalAlignment="Center" Text="用户名" Style="{StaticResource BodyTextStyle}" />
                                        <TextBox Grid.Column="1"
                                                 Margin="0"
                                                 MaxLength="200"
                                                 Style="{StaticResource FormTextBoxStyle}"
                                                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>

                                    <Grid Grid.Row="5" Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock VerticalAlignment="Center" Text="密码" Style="{StaticResource BodyTextStyle}" />
                                        <controls:SensitiveSettingInput Grid.Column="1"
                                                                        MaxLength="1000"
                                                                        Text="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>

                                    <Grid Grid.Row="6" Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox VerticalAlignment="Center"
                                                  Content="启用当前连接"
                                                  IsChecked="{Binding IsConnectionEnabled}"
                                                  Style="{StaticResource FormCheckBoxStyle}" />
                                        <WrapPanel Grid.Column="1">
                                            <Button Content="保存设置"
                                                    Command="{Binding SaveConnectionCommand}"
                                                    Style="{StaticResource PrimaryButtonStyle}" />
                                            <Button Margin="12,0,0,0"
                                                    Content="测试连接"
                                                    Command="{Binding TestConnectionCommand}"
                                                    Style="{StaticResource SecondaryButtonStyle}" />
                                        </WrapPanel>
                                    </Grid>
                                    <TextBlock Grid.Row="7"
                                               Margin="0,10,0,0"
                                               Text="{Binding ConnectionStatusMessage}"
                                               TextWrapping="Wrap"
                                               Style="{StaticResource BodyMutedTextStyle}" />
                                </Grid>
                            </Border>

                            <Border Grid.Row="2" Style="{StaticResource ScanDraftPanelStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <DockPanel LastChildFill="False">
                                        <TextBlock Text="{Binding LocalScanPathEditorTitle}" Style="{StaticResource SectionTitleTextStyle}" />
                                        <Button DockPanel.Dock="Right"
                                                Content="取消"
                                                Command="{Binding CancelEditLocalScanPathCommand}"
                                                Style="{StaticResource SecondaryButtonStyle}" />
                                    </DockPanel>

                                    <Grid Grid.Row="1" Margin="0,14,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="84" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock VerticalAlignment="Center" Text="目录路径" Style="{StaticResource BodyTextStyle}" />
                                        <TextBox Grid.Column="1"
                                                 Margin="0"
                                                 MaxLength="1000"
                                                 Style="{StaticResource FormTextBoxStyle}"
                                                 Text="{Binding EditingLocalScanPathValue, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button Grid.Column="3"
                                                Content="选择目录"
                                                Command="{Binding PickLocalScanPathCommand}"
                                                Style="{StaticResource SecondaryButtonStyle}" />
                                    </Grid>

                                    <Grid Grid.Row="2" Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="84" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock VerticalAlignment="Center" Text="显示名称" Style="{StaticResource BodyTextStyle}" />
                                        <TextBox Grid.Column="1"
                                                 Margin="0"
                                                 MaxLength="200"
                                                 Style="{StaticResource FormTextBoxStyle}"
                                                 Text="{Binding EditingLocalScanPathDisplayName, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>

                                    <Grid Grid.Row="3" Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <WrapPanel>
                                            <CheckBox Content="启用"
                                                      IsChecked="{Binding EditingLocalScanPathEnabled}"
                                                      Style="{StaticResource FormCheckBoxStyle}" />
                                            <CheckBox Margin="16,0,0,0"
                                                      Content="递归扫描子目录"
                                                      IsChecked="{Binding EditingLocalScanPathRecursive}"
                                                      Style="{StaticResource FormCheckBoxStyle}" />
                                        </WrapPanel>
                                        <Button Grid.Column="1"
                                                Content="{Binding LocalScanPathSubmitButtonText}"
                                                Command="{Binding SaveLocalScanPathCommand}"
                                                Style="{StaticResource PrimaryButtonStyle}" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource PageCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel LastChildFill="False">
                        <TextBlock Text="扫描进度" Style="{StaticResource CardTitleTextStyle}" />
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Content="{Binding RunScanButtonText}"
                                    Command="{Binding RunScanCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                            <Button Margin="12,0,0,0"
                                    Content="{Binding LocalRunScanButtonText}"
                                    Command="{Binding RunLocalScanCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Margin="12,0,0,0"
                                    Content="取消扫描"
                                    Command="{Binding CancelScanCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                        </StackPanel>
                    </DockPanel>

                    <StackPanel Grid.Row="1" Margin="0,14,0,0">
                        <ProgressBar Height="12"
                                     Minimum="0"
                                     Maximum="100"
                                     IsIndeterminate="{Binding IsProgressIndeterminate}" />
                        <TextBlock Margin="0,10,0,0"
                                   Text="{Binding CurrentStageText}"
                                   TextWrapping="Wrap"
                                   Style="{StaticResource BodyTextStyle}" />
                        <TextBlock Margin="0,4,0,0"
                                   helpers:TrimmedTextToolTipBehavior.FullText="{Binding CurrentFileText}"
                                   Text="{Binding CurrentFileText}"
                                   TextTrimming="CharacterEllipsis"
                                   Style="{StaticResource BodyMutedTextStyle}" />
                    </StackPanel>

                    <UniformGrid Grid.Row="2" Margin="0,14,0,0" Columns="6">
                        <StackPanel Margin="0,0,14,0">
                            <TextBlock Text="已扫描" Style="{StaticResource BodyMutedTextStyle}" />
                            <TextBlock Text="{Binding ScannedCount}" Style="{StaticResource SectionTitleTextStyle}" />
                        </StackPanel>
                        <StackPanel Margin="0,0,14,0">
                            <TextBlock Text="新增" Style="{StaticResource BodyMutedTextStyle}" />
                            <TextBlock Text="{Binding NewFileCount}" Style="{StaticResource SectionTitleTextStyle}" />
                        </StackPanel>
                        <StackPanel Margin="0,0,14,0">
                            <TextBlock Text="更新" Style="{StaticResource BodyMutedTextStyle}" />
                            <TextBlock Text="{Binding UpdatedFileCount}" Style="{StaticResource SectionTitleTextStyle}" />
                        </StackPanel>
                        <StackPanel Margin="0,0,14,0">
                            <TextBlock Text="忽略" Style="{StaticResource BodyMutedTextStyle}" />
                            <TextBlock Text="{Binding IgnoredFileCount}" Style="{StaticResource SectionTitleTextStyle}" />
                        </StackPanel>
                        <StackPanel Margin="0,0,14,0">
                            <TextBlock Text="错误" Style="{StaticResource BodyMutedTextStyle}" />
                            <TextBlock Text="{Binding ErrorCount}" Style="{StaticResource SectionTitleTextStyle}" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="耗时" Style="{StaticResource BodyMutedTextStyle}" />
                            <TextBlock Text="{Binding ElapsedText}" Style="{StaticResource SectionTitleTextStyle}" />
                        </StackPanel>
                    </UniformGrid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Column="2" Style="{StaticResource PageCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="扫描记录" Style="{StaticResource CardTitleTextStyle}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="最近扫描记录按时间倒序显示。"
                               Style="{StaticResource BodyMutedTextStyle}" />
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,18,0,0">
                    <Border>
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource ScanEmptyStateStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasRecentLogs}" Value="False">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="还没有扫描记录。"
                                   Style="{StaticResource BodyMutedTextStyle}" />
                    </Border>

                    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto"
                                  helpers:ScrollBarAutoRevealBehavior.IsEnabled="True">
                        <ScrollViewer.Style>
                            <Style TargetType="ScrollViewer">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasRecentLogs}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ScrollViewer.Style>
                        <ItemsControl ItemsSource="{Binding RecentLogs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <controls:ScanLogCard />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
