<UserControl x:Class="MediaLibrary.App.Views.Pages.ScanTasksPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:MediaLibrary.App.Helpers">
    <UserControl.Resources>
        <Style x:Key="ScanEmptyStateStyle" TargetType="Border" BasedOn="{StaticResource CompactCardStyle}">
            <Setter Property="Padding" Value="18" />
            <Setter Property="Visibility" Value="Collapsed" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="7*" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <Border Style="{StaticResource PageCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="100" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="扫描配置" Style="{StaticResource CardTitleTextStyle}" />
                                <TextBlock Margin="0,8,0,0"
                                           Text="管理 WebDAV 连接和远程扫描路径。"
                                           Style="{StaticResource BodyMutedTextStyle}" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="刷新"
                                    Command="{Binding RefreshCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                        </Grid>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="420" />
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource CompactCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="260" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <DockPanel>
                                        <TextBlock Text="已添加路径" Style="{StaticResource SectionTitleTextStyle}" />
                                        <Button DockPanel.Dock="Right"
                                                Content="添加路径"
                                                Command="{Binding BeginAddScanPathCommand}"
                                                Style="{StaticResource SecondaryButtonStyle}" />
                                    </DockPanel>
                                    <TextBlock Grid.Row="1"
                                               Margin="0,8,0,0"
                                               Text="{Binding ScanPathStatusMessage}"
                                               TextWrapping="Wrap"
                                               Style="{StaticResource BodyMutedTextStyle}" />

                                    <Border Grid.Row="2" Margin="0,14,0,0">
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource ScanEmptyStateStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasScanPaths}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="还没有 WebDAV 扫描路径。"
                                                   Style="{StaticResource BodyMutedTextStyle}" />
                                    </Border>

                                    <ScrollViewer Grid.Row="2"
                                                  Margin="0,14,0,0"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ScrollViewer.Style>
                                            <Style TargetType="ScrollViewer">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasScanPaths}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ScrollViewer.Style>
                                        <ItemsControl ItemsSource="{Binding ScanPaths}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,12" Padding="14" CornerRadius="12" Background="{DynamicResource BrushSurfaceAlt}">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding DisplayName}" Style="{StaticResource SectionTitleTextStyle}" />
                                                                <TextBlock Margin="0,6,0,0"
                                                                           Text="{Binding Path}"
                                                                           TextWrapping="Wrap"
                                                                           Style="{StaticResource BodyMutedTextStyle}" />
                                                                <WrapPanel Margin="0,8,0,0">
                                                                    <TextBlock Margin="0,0,14,0" Text="{Binding EnabledText}" Style="{StaticResource BodyTextStyle}" />
                                                                    <TextBlock Margin="0,0,14,0" Text="{Binding RecursiveText}" Style="{StaticResource BodyTextStyle}" />
                                                                    <TextBlock Text="{Binding LastScanAtText, StringFormat=最近：{0}}" Style="{StaticResource BodyMutedTextStyle}" />
                                                                </WrapPanel>
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                                <Button Content="编辑"
                                                                        Command="{Binding DataContext.EditScanPathCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        CommandParameter="{Binding}"
                                                                        Style="{StaticResource SecondaryButtonStyle}" />
                                                                <Button Margin="8,0,0,0"
                                                                        Content="{Binding ToggleText}"
                                                                        Command="{Binding DataContext.ToggleScanPathCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        CommandParameter="{Binding}"
                                                                        Style="{StaticResource SecondaryButtonStyle}" />
                                                                <Button Margin="8,0,0,0"
                                                                        Content="删除"
                                                                        Command="{Binding DataContext.DeleteScanPathCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        CommandParameter="{Binding}"
                                                                        Style="{StaticResource SecondaryButtonStyle}" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <Border Grid.Row="3" Margin="0,14,0,0" Padding="14" CornerRadius="12" Background="{DynamicResource BrushSurfaceAlt}">
                                        <StackPanel>
                                            <DockPanel>
                                                <TextBlock Text="{Binding ScanPathEditorTitle}" Style="{StaticResource SectionTitleTextStyle}" />
                                                <Button DockPanel.Dock="Right"
                                                        Content="取消"
                                                        Command="{Binding CancelEditScanPathCommand}"
                                                        Style="{StaticResource SecondaryButtonStyle}" />
                                            </DockPanel>
                                            <TextBlock Margin="0,12,0,0" Text="WebDAV 路径" Style="{StaticResource BodyTextStyle}" />
                                            <TextBox Style="{StaticResource FormTextBoxStyle}"
                                                     Text="{Binding EditingScanPathValue, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Margin="0,10,0,0" Text="显示名称" Style="{StaticResource BodyTextStyle}" />
                                            <TextBox Style="{StaticResource FormTextBoxStyle}"
                                                     Text="{Binding EditingScanPathDisplayName, UpdateSourceTrigger=PropertyChanged}" />
                                            <CheckBox Content="启用该扫描路径"
                                                      IsChecked="{Binding EditingScanPathEnabled}"
                                                      Style="{StaticResource FormCheckBoxStyle}" />
                                            <CheckBox Content="递归扫描子目录"
                                                      IsChecked="{Binding EditingScanPathRecursive}"
                                                      Style="{StaticResource FormCheckBoxStyle}" />
                                            <Button Margin="0,14,0,0"
                                                    Content="{Binding ScanPathSubmitButtonText}"
                                                    Command="{Binding SaveScanPathCommand}"
                                                    Style="{StaticResource PrimaryButtonStyle}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource CompactCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="WebDAV 配置" Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Margin="0,8,0,0"
                                               Text="扫描任务页现在是 WebDAV 扫描配置主入口。"
                                               TextWrapping="Wrap"
                                               Style="{StaticResource BodyMutedTextStyle}" />
                                    <TextBlock Margin="0,16,0,0" Text="URL" Style="{StaticResource BodyTextStyle}" />
                                    <TextBox Style="{StaticResource FormTextBoxStyle}"
                                             Text="{Binding BaseUrl, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Margin="0,10,0,0" Text="用户名" Style="{StaticResource BodyTextStyle}" />
                                    <TextBox Style="{StaticResource FormTextBoxStyle}"
                                             Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Margin="0,10,0,0" Text="密码" Style="{StaticResource BodyTextStyle}" />
                                    <PasswordBox Style="{StaticResource FormPasswordBoxStyle}"
                                                 helpers:PasswordBoxBindingHelper.BindPassword="True"
                                                 helpers:PasswordBoxBindingHelper.BoundPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <CheckBox Content="启用当前连接"
                                              IsChecked="{Binding IsConnectionEnabled}"
                                              Style="{StaticResource FormCheckBoxStyle}" />
                                    <StackPanel Margin="0,18,0,0" Orientation="Horizontal">
                                        <Button Content="保存设置"
                                                Command="{Binding SaveConnectionCommand}"
                                                Style="{StaticResource PrimaryButtonStyle}" />
                                        <Button Margin="12,0,0,0"
                                                Content="测试连接"
                                                Command="{Binding TestConnectionCommand}"
                                                Style="{StaticResource SecondaryButtonStyle}" />
                                    </StackPanel>
                                    <TextBlock Margin="0,14,0,0"
                                               Text="{Binding ConnectionStatusMessage}"
                                               TextWrapping="Wrap"
                                               Style="{StaticResource BodyMutedTextStyle}" />
                                    <TextBlock Margin="0,12,0,0"
                                               Text="{Binding LastScanAtText, StringFormat=最近扫描：{0}}"
                                               Style="{StaticResource BodyMutedTextStyle}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <Border Margin="0,20,0,0" Style="{StaticResource PageCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <DockPanel>
                            <TextBlock Text="扫描进度" Style="{StaticResource CardTitleTextStyle}" />
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <Button Content="{Binding RunScanButtonText}"
                                        Command="{Binding RunScanCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}" />
                                <Button Margin="12,0,0,0"
                                        Content="取消扫描"
                                        Command="{Binding CancelScanCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                            </StackPanel>
                        </DockPanel>

                        <StackPanel Grid.Row="1" Margin="0,18,0,0">
                            <ProgressBar Height="12"
                                         Minimum="0"
                                         Maximum="100"
                                         IsIndeterminate="{Binding IsProgressIndeterminate}" />
                            <TextBlock Margin="0,12,0,0"
                                       Text="{Binding CurrentFileText}"
                                       TextWrapping="Wrap"
                                       Style="{StaticResource BodyMutedTextStyle}" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="{Binding StatusMessage}"
                                       TextWrapping="Wrap"
                                       Style="{StaticResource BodyTextStyle}" />
                        </StackPanel>

                        <UniformGrid Grid.Row="2" Margin="0,18,0,0" Columns="4">
                            <StackPanel Margin="0,0,14,12">
                                <TextBlock Text="已扫描" Style="{StaticResource BodyMutedTextStyle}" />
                                <TextBlock Text="{Binding ScannedCount}" Style="{StaticResource SectionTitleTextStyle}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,14,12">
                                <TextBlock Text="已识别" Style="{StaticResource BodyMutedTextStyle}" />
                                <TextBlock Text="{Binding IdentifiedCountText}" Style="{StaticResource SectionTitleTextStyle}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,14,12">
                                <TextBlock Text="未识别" Style="{StaticResource BodyMutedTextStyle}" />
                                <TextBlock Text="{Binding UnidentifiedCountText}" Style="{StaticResource SectionTitleTextStyle}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,14,12">
                                <TextBlock Text="新增" Style="{StaticResource BodyMutedTextStyle}" />
                                <TextBlock Text="{Binding NewFileCount}" Style="{StaticResource SectionTitleTextStyle}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,14,0">
                                <TextBlock Text="更新" Style="{StaticResource BodyMutedTextStyle}" />
                                <TextBlock Text="{Binding UpdatedFileCount}" Style="{StaticResource SectionTitleTextStyle}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,14,0">
                                <TextBlock Text="忽略" Style="{StaticResource BodyMutedTextStyle}" />
                                <TextBlock Text="{Binding IgnoredFileCount}" Style="{StaticResource SectionTitleTextStyle}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,14,0">
                                <TextBlock Text="错误" Style="{StaticResource BodyMutedTextStyle}" />
                                <TextBlock Text="{Binding ErrorCount}" Style="{StaticResource SectionTitleTextStyle}" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="耗时" Style="{StaticResource BodyMutedTextStyle}" />
                                <TextBlock Text="{Binding ElapsedText}" Style="{StaticResource SectionTitleTextStyle}" />
                            </StackPanel>
                        </UniformGrid>
                    </Grid>
                </Border>
            </StackPanel>

            <Border Grid.Column="2" Style="{StaticResource PageCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="扫描记录" Style="{StaticResource CardTitleTextStyle}" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="最近扫描记录按时间倒序显示。"
                                   Style="{StaticResource BodyMutedTextStyle}" />
                    </StackPanel>

                    <Border Grid.Row="1" Margin="0,18,0,0">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource ScanEmptyStateStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasRecentLogs}" Value="False">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="还没有扫描记录。"
                                   Style="{StaticResource BodyMutedTextStyle}" />
                    </Border>

                    <ScrollViewer Grid.Row="1" Margin="0,18,0,0" VerticalScrollBarVisibility="Auto">
                        <ScrollViewer.Style>
                            <Style TargetType="ScrollViewer">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasRecentLogs}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ScrollViewer.Style>
                        <ItemsControl ItemsSource="{Binding RecentLogs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,14" Padding="14" CornerRadius="12" Background="{DynamicResource BrushSurfaceAlt}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding ScanPathDisplayName}" Style="{StaticResource SectionTitleTextStyle}" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Text="{Binding TargetText}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Style="{StaticResource BodyMutedTextStyle}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Text="{Binding UsernameText, StringFormat=用户：{0}}"
                                                       Style="{StaticResource BodyMutedTextStyle}" />
                                            <WrapPanel Margin="0,10,0,0">
                                                <TextBlock Margin="0,0,12,0" Text="{Binding StatusText}" Style="{StaticResource BodyTextStyle}" />
                                                <TextBlock Margin="0,0,12,0" Text="{Binding StartedAtText, StringFormat=开始：{0}}" Style="{StaticResource BodyMutedTextStyle}" />
                                                <TextBlock Text="{Binding EndedAtText, StringFormat=结束：{0}}" Style="{StaticResource BodyMutedTextStyle}" />
                                            </WrapPanel>
                                            <UniformGrid Margin="0,10,0,0" Columns="2">
                                                <TextBlock Text="{Binding ScannedCount, StringFormat=扫描：{0}}" Style="{StaticResource BodyTextStyle}" />
                                                <TextBlock Text="{Binding NewFileCount, StringFormat=新增：{0}}" Style="{StaticResource BodyTextStyle}" />
                                                <TextBlock Text="{Binding UpdatedFileCount, StringFormat=更新：{0}}" Style="{StaticResource BodyTextStyle}" />
                                                <TextBlock Text="{Binding ErrorCount, StringFormat=错误：{0}}" Style="{StaticResource BodyTextStyle}" />
                                                <TextBlock Text="{Binding IgnoredFileCount, StringFormat=忽略：{0}}" Style="{StaticResource BodyMutedTextStyle}" />
                                                <TextBlock Text="{Binding DurationText, StringFormat=耗时：{0}}" Style="{StaticResource BodyMutedTextStyle}" />
                                            </UniformGrid>
                                            <TextBlock Margin="0,8,0,0"
                                                       Text="{Binding ErrorMessage}"
                                                       TextWrapping="Wrap">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasErrorMessage}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
