<UserControl x:Class="MediaLibrary.App.Views.Pages.ScanTasksPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource PageCardStyle}">
        <TabControl Style="{StaticResource ModernTabControlStyle}" ItemContainerStyle="{StaticResource ModernTabItemStyle}">
            <TabItem Header="扫描任务">
                <Grid Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="420" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource HeroCardStyle}">
                        <StackPanel>
                            <TextBlock Text="扫描任务" FontSize="28" FontWeight="Bold" />
                            <TextBlock Margin="0,12,0,0" Text="{Binding StatusMessage}" TextWrapping="Wrap" Style="{StaticResource BodyTextStyle}" />
                            <Button Margin="0,22,0,0"
                                    Width="140"
                                    HorizontalAlignment="Left"
                                    Content="开始扫描"
                                    Command="{Binding RunScanCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                            <TextBlock Margin="0,28,0,0" Text="当前连接" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Margin="0,8,0,0" Text="{Binding ConnectionName}" Style="{StaticResource BodyTextStyle}" />
                            <TextBlock Margin="0,8,0,0" Text="{Binding BaseUrl}" TextWrapping="Wrap" Style="{StaticResource BodyMutedTextStyle}" />
                            <TextBlock Margin="0,18,0,0" Text="最近扫描" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Margin="0,8,0,0" Text="{Binding LastScanAtText}" Style="{StaticResource BodyMutedTextStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource CompactCardStyle}">
                        <StackPanel>
                            <TextBlock Text="已启用扫描路径" Style="{StaticResource CardTitleTextStyle}" />
                            <ListBox Margin="0,16,0,0" ItemsSource="{Binding EnabledScanPaths}" Style="{StaticResource SectionListBoxStyle}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="120" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding DisplayName}" Style="{StaticResource SectionTitleTextStyle}" />
                                                <TextBlock Margin="0,4,0,0" Text="{Binding Path}" TextWrapping="Wrap" Style="{StaticResource BodyMutedTextStyle}" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding IsRecursive, StringFormat=递归：{0}}" VerticalAlignment="Center" Style="{StaticResource BodyTextStyle}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="扫描日志">
                <ListBox Margin="0,18,0,0" ItemsSource="{Binding RecentLogs}" Style="{StaticResource SectionListBoxStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="170" />
                                    <ColumnDefinition Width="220" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Margin="0,0,16,0">
                                    <TextBlock Text="{Binding ScanPathDisplayName}" Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Margin="0,4,0,0" Text="{Binding ScanPath}" TextWrapping="Wrap" Style="{StaticResource BodyMutedTextStyle}" />
                                    <TextBlock Margin="0,6,0,0" Text="{Binding ErrorMessage}" TextWrapping="Wrap" Style="{StaticResource BodyMutedTextStyle}" />
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Status}" Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Margin="0,6,0,0" Text="{Binding StartedAt, StringFormat=开始：{0:yyyy-MM-dd HH:mm}}" Style="{StaticResource BodyTextStyle}" />
                                    <TextBlock Margin="0,4,0,0" Text="{Binding EndedAt, StringFormat=结束：{0:yyyy-MM-dd HH:mm}}" Style="{StaticResource BodyMutedTextStyle}" />
                                </StackPanel>

                                <UniformGrid Grid.Column="2" Columns="2">
                                    <TextBlock Text="{Binding ScannedCount, StringFormat=扫描：{0}}" Style="{StaticResource BodyTextStyle}" />
                                    <TextBlock Text="{Binding NewFileCount, StringFormat=新增：{0}}" Style="{StaticResource BodyTextStyle}" />
                                    <TextBlock Text="{Binding UpdatedFileCount, StringFormat=更新：{0}}" Style="{StaticResource BodyTextStyle}" />
                                    <TextBlock Text="{Binding ErrorCount, StringFormat=错误：{0}}" Style="{StaticResource BodyTextStyle}" />
                                </UniformGrid>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </TabItem>
        </TabControl>
    </Border>
</UserControl>
