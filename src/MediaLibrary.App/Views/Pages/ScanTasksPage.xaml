<UserControl x:Class="MediaLibrary.App.Views.Pages.ScanTasksPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MediaLibrary.App.Controls"
             xmlns:helpers="clr-namespace:MediaLibrary.App.Helpers"
             xmlns:pages="clr-namespace:MediaLibrary.App.Views.Pages">
    <UserControl.Resources>
        <Storyboard x:Key="ScanStatusLightStoryboard"
                    AutoReverse="True"
                    RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0.42"
                             To="1"
                             Duration="0:0:1.05" />
        </Storyboard>

        <Style x:Key="ScanPageScrollViewerStyle" TargetType="ScrollViewer">
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="helpers:ScrollBarAutoRevealBehavior.IsEnabled" Value="True" />
        </Style>

        <Style x:Key="ScanModernScrollBarThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border x:Name="ThumbChrome"
                                Background="{DynamicResource BrushForegroundMuted}"
                                CornerRadius="4"
                                Opacity="0.58" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbChrome" Property="Opacity" Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbChrome" Property="Opacity" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScanModernScrollBarStyle" TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="8" />
            <Setter Property="MinWidth" Value="8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}"
                                                  Opacity="0" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Margin="2,0"
                                           Style="{StaticResource ScanModernScrollBarThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}"
                                                  Opacity="0" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=(helpers:ScrollBarAutoRevealBehavior.IsRevealed)}"
                             Value="True">
                    <Setter Property="Opacity" Value="1" />
                </DataTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto" />
                    <Setter Property="MinWidth" Value="0" />
                    <Setter Property="Height" Value="8" />
                    <Setter Property="MinHeight" Value="8" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource ScanModernScrollBarStyle}" />

        <Style x:Key="ScanOuterCardStyle" TargetType="Border" BasedOn="{StaticResource PageCardStyle}">
            <Setter Property="Padding" Value="18" />
        </Style>

        <Style x:Key="ScanInnerCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="14" />
            <Setter Property="CornerRadius" Value="{StaticResource RadiusCompactCard}" />
            <Setter Property="Background" Value="{DynamicResource BrushSurfaceAlt}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="ScanSmallSectionTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource SectionTitleTextStyle}">
            <Setter Property="FontSize" Value="15" />
        </Style>

        <Style x:Key="ScanCompactTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource FormTextBoxStyle}">
            <Setter Property="Height" Value="28" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="10,3" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="ScanCompactPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Padding" Value="12,3" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="ScanCompactSecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Padding" Value="12,3" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="ScanFieldLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="ScanEmptyStateStyle" TargetType="Border" BasedOn="{StaticResource CompactCardStyle}">
            <Setter Property="Padding" Value="14" />
            <Setter Property="MinHeight" Value="86" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Visibility" Value="Collapsed" />
        </Style>

        <Style x:Key="ScanEmptyStateTextStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="ScanPathListScrollViewerStyle" TargetType="ScrollViewer" BasedOn="{StaticResource ScanPageScrollViewerStyle}">
            <Setter Property="MaxHeight" Value="186" />
        </Style>

        <Style x:Key="ScanAccountStatusBadgeStyle" TargetType="Border">
            <Setter Property="Padding" Value="11,5" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Background" Value="{DynamicResource BrushWarningBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushWarningBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ConnectionConfigStatusKind}" Value="success">
                    <Setter Property="Background" Value="{DynamicResource BrushSuccessBackground}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushSuccessBorder}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding ConnectionConfigStatusKind}" Value="failure">
                    <Setter Property="Background" Value="{DynamicResource BrushErrorBackground}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushErrorBorder}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ScanPathRowStyle" TargetType="Border">
            <Setter Property="Height" Value="38" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Background" Value="{DynamicResource BrushSurfaceRaised}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style x:Key="ScanRemoveIconButtonStyle" TargetType="Button" BasedOn="{StaticResource SmallIconButtonStyle}">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="28" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="ToolTip" Value="移除路径" />
        </Style>

        <Style x:Key="ScanMetricCardStyle" TargetType="Border" BasedOn="{StaticResource CompactCardStyle}">
            <Setter Property="Width" Value="150" />
            <Setter Property="MinHeight" Value="58" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="10" />
        </Style>

        <Style x:Key="ScanMetricStartCardStyle" TargetType="Border" BasedOn="{StaticResource ScanMetricCardStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                             Value="True">
                    <Setter Property="Margin" Value="0,0,6,0" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ScanMetricMiddleCardStyle" TargetType="Border" BasedOn="{StaticResource ScanMetricCardStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                             Value="True">
                    <Setter Property="Margin" Value="6,0,6,0" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ScanMetricEndCardStyle" TargetType="Border" BasedOn="{StaticResource ScanMetricCardStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                             Value="True">
                    <Setter Property="Margin" Value="6,0,0,0" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ScanMetricIconBoxStyle" TargetType="Border">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="ScanMetricIconPathStyle" TargetType="Path">
            <Setter Property="Fill" Value="{DynamicResource BrushAccent}" />
            <Setter Property="Stretch" Value="Uniform" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="ScanMetricIconStyle" TargetType="TextBlock">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="Foreground" Value="{DynamicResource BrushAccent}" />
            <Setter Property="LineHeight" Value="34" />
            <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>

        <Style x:Key="ScanMetricValueTextStyle" TargetType="TextBlock" BasedOn="{StaticResource SectionTitleTextStyle}">
            <Setter Property="Margin" Value="0,2,0,0" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="LineHeight" Value="22" />
        </Style>

        <Style x:Key="ScanIndeterminateProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="12" />
            <Setter Property="Background" Value="{DynamicResource BrushForegroundMuted}" />
            <Setter Property="Foreground" Value="{DynamicResource BrushInfo}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="ProgressRoot"
                              ClipToBounds="True"
                              Height="{TemplateBinding Height}">
                            <Border Background="{TemplateBinding Background}"
                                    Opacity="0.28"
                                    CornerRadius="5" />
                            <Border x:Name="AnimatedIndicator"
                                    Width="210"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="5"
                                    Opacity="0">
                                <Border.RenderTransform>
                                    <TranslateTransform X="-230" />
                                </Border.RenderTransform>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsIndeterminate" Value="True">
                                <Setter TargetName="AnimatedIndicator" Property="Opacity" Value="1" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard x:Name="ScanProgressStoryboard">
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetName="AnimatedIndicator"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                             From="-230"
                                                             To="920"
                                                             Duration="0:0:1.25" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <StopStoryboard BeginStoryboardName="ScanProgressStoryboard" />
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer x:Name="RootScrollViewer"
                  PreviewMouseWheel="RootScrollViewer_PreviewMouseWheel"
                  Style="{StaticResource ScanPageScrollViewerStyle}">
        <Grid MinWidth="1080">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="7*" MinWidth="700" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="3*" MinWidth="330" />
                </Grid.ColumnDefinitions>

                <StackPanel x:Name="LeftColumn">
                    <Border Style="{StaticResource ScanOuterCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="14" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="WebDAV配置" Style="{StaticResource CardTitleTextStyle}" />

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="1"
                                        Width="1"
                                        Margin="0,2,0,2"
                                        HorizontalAlignment="Center"
                                        Background="{DynamicResource BrushBorder}" />

                                <Border Grid.Column="0"
                                        Height="280"
                                        VerticalAlignment="Top"
                                        Style="{StaticResource ScanInnerCardStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="10" />
                                            <RowDefinition Height="186" />
                                        </Grid.RowDefinitions>

                                        <Grid MinHeight="30">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="添加路径"
                                                       VerticalAlignment="Center"
                                                       Style="{StaticResource ScanSmallSectionTitleStyle}" />
                                            <Button Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    Content="选择路径"
                                                    Command="{Binding AddWebDavScanPathFromPickerCommand}"
                                                    Style="{StaticResource ScanCompactSecondaryButtonStyle}" />
                                        </Grid>

                                        <TextBlock Grid.Row="2"
                                                   helpers:TrimmedTextToolTipBehavior.FullText="{Binding ScanPathStatusMessage}"
                                                   helpers:TrimmedTextToolTipBehavior.VisibleText="{Binding ScanPathStatusDisplayText}"
                                                   Text="{Binding ScanPathStatusDisplayText}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Style="{StaticResource BodyMutedTextStyle}" />

                                        <Grid Grid.Row="4">
                                            <Border HorizontalAlignment="Stretch"
                                                    VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasScanPaths}" Value="False">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="还没有 WebDAV 扫描路径。"
                                                           Style="{StaticResource ScanEmptyStateTextStyle}" />
                                            </Border>

                                            <ScrollViewer PreviewMouseWheel="NestedScrollViewer_PreviewMouseWheel">
                                                <ScrollViewer.Style>
                                                    <Style TargetType="ScrollViewer" BasedOn="{StaticResource ScanPathListScrollViewerStyle}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasScanPaths}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ScrollViewer.Style>
                                                <ItemsControl ItemsSource="{Binding ScanPaths}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Style="{StaticResource ScanPathRowStyle}">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="8" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock VerticalAlignment="Center"
                                                                               helpers:TrimmedTextToolTipBehavior.FullText="{Binding Path}"
                                                                               Style="{StaticResource LongFieldTextBlockStyle}"
                                                                               Text="{Binding Path}"
                                                                               TextTrimming="CharacterEllipsis" />
                                                                    <Button Grid.Column="2"
                                                                            Content="&#xE711;"
                                                                            Command="{Binding DataContext.DeleteScanPathCommand, RelativeSource={RelativeSource AncestorType={x:Type pages:ScanTasksPage}}}"
                                                                            CommandParameter="{Binding}"
                                                                            Style="{StaticResource ScanRemoveIconButtonStyle}" />
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="2"
                                        Height="280"
                                        VerticalAlignment="Top"
                                        Style="{StaticResource ScanInnerCardStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="18" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="24" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="24" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Grid MinHeight="30">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="账号配置" Style="{StaticResource ScanSmallSectionTitleStyle}" />
                                            <Border Grid.Column="1"
                                                    Margin="12,0,0,0"
                                                    ToolTip="{Binding ConnectionStatusMessage}"
                                                    Style="{StaticResource ScanAccountStatusBadgeStyle}">
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="10"
                                                             Height="10"
                                                             Margin="0,0,8,0"
                                                             VerticalAlignment="Center">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill" Value="#B7791F" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ConnectionConfigStatusKind}" Value="success">
                                                                        <Setter Property="Fill" Value="#15803D" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding ConnectionConfigStatusKind}" Value="failure">
                                                                        <Setter Property="Fill" Value="#B91C1C" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                        <Ellipse.Triggers>
                                                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                                                <BeginStoryboard Storyboard="{StaticResource ScanStatusLightStoryboard}" />
                                                            </EventTrigger>
                                                        </Ellipse.Triggers>
                                                    </Ellipse>
                                                    <TextBlock helpers:TrimmedTextToolTipBehavior.FullText="{Binding ConnectionConfigStatusText}"
                                                               FontSize="13"
                                                               Style="{StaticResource BadgeTextStyle}"
                                                               Text="{Binding ConnectionConfigStatusText}" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <TextBlock Grid.Row="2"
                                                   VerticalAlignment="Center"
                                                   helpers:TrimmedTextToolTipBehavior.FullText="{Binding ConnectionStatusMessage}"
                                                   Text="{Binding ConnectionStatusMessage}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Style="{StaticResource BodyMutedTextStyle}" />

                                        <Grid Grid.Row="4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="72" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="BaseUrl" Style="{StaticResource ScanFieldLabelStyle}" />
                                            <TextBox Grid.Column="1"
                                                     MaxLength="500"
                                                     Style="{StaticResource ScanCompactTextBoxStyle}"
                                                     Text="{Binding BaseUrl, UpdateSourceTrigger=PropertyChanged}" />
                                        </Grid>

                                        <Grid Grid.Row="6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="72" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="用户名" Style="{StaticResource ScanFieldLabelStyle}" />
                                            <TextBox Grid.Column="1"
                                                     MaxLength="200"
                                                     Style="{StaticResource ScanCompactTextBoxStyle}"
                                                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />
                                        </Grid>

                                        <Grid Grid.Row="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="72" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="密码" Style="{StaticResource ScanFieldLabelStyle}" />
                                            <controls:SensitiveSettingInput Grid.Column="1"
                                                                            MaxLength="1000"
                                                                            Text="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </Grid>

                                        <Grid Grid.Row="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Button HorizontalAlignment="Center"
                                                    Content="保存配置"
                                                    Command="{Binding SaveConnectionCommand}"
                                                    Style="{StaticResource ScanCompactPrimaryButtonStyle}" />
                                            <Button Grid.Column="1"
                                                    HorizontalAlignment="Center"
                                                    Content="测试连接"
                                                    Command="{Binding TestConnectionCommand}"
                                                    Style="{StaticResource ScanCompactSecondaryButtonStyle}" />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Margin="0,18,0,0"
                            MinHeight="262"
                            Style="{StaticResource ScanOuterCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="14" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="本地配置" Style="{StaticResource CardTitleTextStyle}" />
                                <TextBlock Grid.Column="1"
                                           Margin="16,0,12,0"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           helpers:TrimmedTextToolTipBehavior.FullText="{Binding LocalScanPathStatusMessage}"
                                           helpers:TrimmedTextToolTipBehavior.VisibleText="{Binding LocalScanPathStatusDisplayText}"
                                           Text="{Binding LocalScanPathStatusDisplayText}"
                                           TextTrimming="CharacterEllipsis"
                                           Style="{StaticResource BodyMutedTextStyle}" />
                                <Button Grid.Column="2"
                                        Content="选择路径"
                                        Command="{Binding AddLocalScanPathFromPickerCommand}"
                                        Style="{StaticResource ScanCompactSecondaryButtonStyle}" />
                            </Grid>

                            <Grid Grid.Row="2">
                                <ScrollViewer MaxHeight="186"
                                              PreviewMouseWheel="NestedScrollViewer_PreviewMouseWheel"
                                              Style="{StaticResource ScanPageScrollViewerStyle}">
                                    <ItemsControl VerticalAlignment="Top"
                                                  ItemsSource="{Binding LocalScanPaths}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="2" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="HorizontalAlignment" Value="Stretch" />
                                                <Setter Property="VerticalAlignment" Value="Top" />
                                                <Setter Property="Margin" Value="8,0,8,10" />
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource ScanPathRowStyle}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="8" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock VerticalAlignment="Center"
                                                                   helpers:TrimmedTextToolTipBehavior.FullText="{Binding Path}"
                                                                   Style="{StaticResource LongFieldTextBlockStyle}"
                                                                   Text="{Binding Path}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <Button Grid.Column="2"
                                                                Content="&#xE711;"
                                                                Command="{Binding DataContext.DeleteLocalScanPathCommand, RelativeSource={RelativeSource AncestorType={x:Type pages:ScanTasksPage}}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource ScanRemoveIconButtonStyle}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <Border Width="1"
                                        Margin="0,2,0,10"
                                        HorizontalAlignment="Center"
                                        Background="{DynamicResource BrushBorder}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasLocalScanPaths}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>

                                <Border Grid.ColumnSpan="3">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="MinHeight" Value="86" />
                                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasLocalScanPaths}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="还没有本地目录配置。"
                                               Style="{StaticResource ScanEmptyStateTextStyle}" />
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Margin="0,18,0,0" Style="{StaticResource ScanOuterCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="扫描进度" Style="{StaticResource CardTitleTextStyle}" />

                            <StackPanel Grid.Row="2">
                                <ProgressBar IsIndeterminate="{Binding IsProgressIndeterminate}"
                                             Style="{StaticResource ScanIndeterminateProgressBarStyle}" />
                                <TextBlock Margin="0,10,0,0"
                                           Text="{Binding CurrentStageText}"
                                           TextWrapping="Wrap"
                                           Style="{StaticResource BodyTextStyle}" />
                                <TextBlock Margin="0,5,0,0"
                                           helpers:TrimmedTextToolTipBehavior.FullText="{Binding CurrentFileText}"
                                           Text="{Binding CurrentFileText}"
                                           TextTrimming="CharacterEllipsis"
                                           Style="{StaticResource BodyMutedTextStyle}" />
                            </StackPanel>

                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="12" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="32" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="32" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Row="0"
                                            Grid.Column="0"
                                            HorizontalAlignment="Left"
                                            Style="{StaticResource ScanMetricStartCardStyle}">
                                        <Grid VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Style="{StaticResource ScanMetricIconBoxStyle}">
                                                <Viewbox Width="18" Height="18">
                                                    <Path Data="M9.55,17.2 L3.35,11 L4.95,9.4 L9.55,14 L19.05,4.5 L20.65,6.1 Z"
                                                          Style="{StaticResource ScanMetricIconPathStyle}" />
                                                </Viewbox>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="已扫描" Style="{StaticResource BodyMutedTextStyle}" />
                                                <TextBlock Text="{Binding ScannedCount}" Style="{StaticResource ScanMetricValueTextStyle}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <Border Grid.Row="0"
                                            Grid.Column="2"
                                            HorizontalAlignment="Left"
                                            Style="{StaticResource ScanMetricMiddleCardStyle}">
                                        <Grid VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Style="{StaticResource ScanMetricIconBoxStyle}">
                                                <Viewbox Width="18" Height="18">
                                                    <Path Data="M11,4 H13 V11 H20 V13 H13 V20 H11 V13 H4 V11 H11 Z"
                                                          Style="{StaticResource ScanMetricIconPathStyle}" />
                                                </Viewbox>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="新增" Style="{StaticResource BodyMutedTextStyle}" />
                                                <TextBlock Text="{Binding NewFileCount}" Style="{StaticResource ScanMetricValueTextStyle}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <Border Grid.Row="0"
                                            Grid.Column="4"
                                            HorizontalAlignment="Left"
                                            Style="{StaticResource ScanMetricEndCardStyle}">
                                        <Grid VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Style="{StaticResource ScanMetricIconBoxStyle}">
                                                <Viewbox Width="18" Height="18">
                                                    <Path Data="M7.6,7.2 C8.8,5.9 10.35,5.2 12,5.2 C15.25,5.2 17.9,7.85 17.9,11.1 H20.7 L16.8,15 L12.9,11.1 H15.7 C15.7,9.05 14.05,7.4 12,7.4 C10.95,7.4 9.95,7.85 9.25,8.6 Z M3.3,12.9 L7.2,9 L11.1,12.9 H8.3 C8.3,14.95 9.95,16.6 12,16.6 C13.05,16.6 14.05,16.15 14.75,15.4 L16.4,16.8 C15.2,18.1 13.65,18.8 12,18.8 C8.75,18.8 6.1,16.15 6.1,12.9 Z"
                                                          Style="{StaticResource ScanMetricIconPathStyle}" />
                                                </Viewbox>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="更新" Style="{StaticResource BodyMutedTextStyle}" />
                                                <TextBlock Text="{Binding UpdatedFileCount}" Style="{StaticResource ScanMetricValueTextStyle}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <Border Grid.Row="2"
                                            Grid.Column="0"
                                            HorizontalAlignment="Left"
                                            Style="{StaticResource ScanMetricStartCardStyle}">
                                        <Grid VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Style="{StaticResource ScanMetricIconBoxStyle}">
                                                <Viewbox Width="18" Height="18">
                                                    <Path Data="M5,11 H19 V13.4 H5 Z"
                                                          Style="{StaticResource ScanMetricIconPathStyle}" />
                                                </Viewbox>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="忽略" Style="{StaticResource BodyMutedTextStyle}" />
                                                <TextBlock Text="{Binding IgnoredFileCount}" Style="{StaticResource ScanMetricValueTextStyle}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <Border Grid.Row="2"
                                            Grid.Column="2"
                                            HorizontalAlignment="Left"
                                            Style="{StaticResource ScanMetricMiddleCardStyle}">
                                        <Grid VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Style="{StaticResource ScanMetricIconBoxStyle}">
                                                <Viewbox Width="18" Height="18">
                                                    <Path Data="M12,3 L22,20 H2 Z M11,9 H13 V14 H11 Z M11,16 H13 V18 H11 Z"
                                                          Style="{StaticResource ScanMetricIconPathStyle}" />
                                                </Viewbox>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="错误" Style="{StaticResource BodyMutedTextStyle}" />
                                                <TextBlock Text="{Binding ErrorCount}" Style="{StaticResource ScanMetricValueTextStyle}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <Border Grid.Row="2"
                                            Grid.Column="4"
                                            HorizontalAlignment="Left"
                                            Style="{StaticResource ScanMetricEndCardStyle}">
                                        <Grid VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Style="{StaticResource ScanMetricIconBoxStyle}">
                                                <Viewbox Width="18" Height="18">
                                                    <Path Data="M12,2 A10,10 0 1 0 12,22 A10,10 0 1 0 12,2 M11,6 H13 V11.3 L17,13.6 L15.8,15.6 L11,12.8 Z"
                                                          Style="{StaticResource ScanMetricIconPathStyle}" />
                                                </Viewbox>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="耗时" Style="{StaticResource BodyMutedTextStyle}" />
                                                <TextBlock Text="{Binding ElapsedText}" Style="{StaticResource ScanMetricValueTextStyle}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Grid>

                                <StackPanel Grid.Column="2"
                                            Width="112"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <Button Content="{Binding RunScanButtonText}"
                                            Command="{Binding RunScanCommand}"
                                            Style="{StaticResource ScanCompactPrimaryButtonStyle}" />
                                    <Button Margin="0,10,0,0"
                                            Content="{Binding LocalRunScanButtonText}"
                                            Command="{Binding RunLocalScanCommand}"
                                            Style="{StaticResource ScanCompactSecondaryButtonStyle}" />
                                    <Button Margin="0,10,0,0"
                                            Content="取消扫描"
                                            Command="{Binding CancelScanCommand}"
                                            Style="{StaticResource ScanCompactSecondaryButtonStyle}" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </StackPanel>

                <Border Grid.Column="2"
                        Height="{Binding ActualHeight, ElementName=LeftColumn}"
                        MinHeight="620"
                        Style="{StaticResource ScanOuterCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="扫描记录" Style="{StaticResource CardTitleTextStyle}" />
                        <TextBlock Grid.Row="2"
                                   Text="最近扫描记录按时间倒序显示。"
                                   Style="{StaticResource BodyMutedTextStyle}" />

                        <Grid Grid.Row="4">
                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource ScanEmptyStateStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasRecentLogs}" Value="False">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="还没有扫描记录。"
                                           Style="{StaticResource ScanEmptyStateTextStyle}" />
                            </Border>

                            <ScrollViewer PreviewMouseWheel="NestedScrollViewer_PreviewMouseWheel">
                                <ScrollViewer.Style>
                                    <Style TargetType="ScrollViewer" BasedOn="{StaticResource ScanPageScrollViewerStyle}">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasRecentLogs}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ScrollViewer.Style>
                                <ItemsControl ItemsSource="{Binding RecentLogs}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <controls:ScanLogCard />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
