                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding HasWantToWatchSeasonTag}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                    <TextBlock Text="想看" Style="{StaticResource DiscoveryBadgeTextStyle}" />
                                                                </Border>
                                                            </Grid>

                                                            <StackPanel Grid.Column="2" Margin="0,10,0,6">
                                                                <DockPanel>
                                                                    <TextBlock Text="{Binding RatingText}" FontWeight="SemiBold" Style="{StaticResource BodyTextStyle}" />
                                                                    <TextBlock DockPanel.Dock="Right" Text="{Binding YearText}" Style="{StaticResource BodyMutedTextStyle}" />
                                                                </DockPanel>
                                                                <TextBlock Margin="0,8,0,0"
                                                                           Text="{Binding TitleWithOriginalText}"
                                                                           TextWrapping="Wrap"
                                                                           Style="{StaticResource SectionTitleTextStyle}" />
                                                                <TextBlock Margin="0,6,0,0"
                                                                           Text="{Binding DisplayTags}"
                                                                           TextWrapping="Wrap"
                                                                           Style="{StaticResource BodyTextStyle}" />
                                                                <Button Margin="0,6,0,0"
                                                                        HorizontalAlignment="Left"
                                                                        Content="{Binding AddToLibraryButtonText}"
                                                                        Command="{Binding DataContext.AddTvSeriesToLibraryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        CommandParameter="{Binding}">
                                                                    <Button.Style>
                                                                        <Style TargetType="Button" BasedOn="{StaticResource DiscoveryWantButtonStyle}">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding CanAddToLibrary}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Button.Style>
                                                                </Button>
                                                                <TextBlock Margin="0,4,0,0"
                                                                           Text="{Binding SeasonCountText}"
                                                                           TextWrapping="Wrap"
                                                                           Style="{StaticResource BodyMutedTextStyle}" />
                                                                <TextBlock Margin="0,4,0,0"
                                                                           Text="{Binding LibraryStatusText}"
                                                                           TextWrapping="Wrap"
                                                                           Style="{StaticResource BodyMutedTextStyle}" />
                                                                <ScrollViewer Margin="0,8,0,0" Height="70" VerticalScrollBarVisibility="Auto">
                                                                    <TextBlock Text="{Binding OverviewText}"
                                                                               TextWrapping="Wrap"
                                                                               Style="{StaticResource BodyMutedTextStyle}" />
                                                                </ScrollViewer>
                                                            </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                        <Border Grid.Column="2"
                                                                DataContext="{Binding RightItem}"
                                                                Margin="14,0,0,0"
                                                                IsEnabled="{Binding DataContext.CanOpenTvSeries, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                                            <Border.Style>
                                                                <Style TargetType="Border" BasedOn="{StaticResource DiscoveryRankingItemCardStyle}">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding DataContext.HasRightItem, RelativeSource={RelativeSource AncestorType=Grid}}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <Border.InputBindings>
                                                                <MouseBinding MouseAction="LeftClick"
                                                                              Command="{Binding DataContext.OpenTvSeriesCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                              CommandParameter="{Binding}" />
                                                            </Border.InputBindings>
                                                            <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="136" />
                                                                <ColumnDefinition Width="12" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>

                                                            <Grid Height="196">
                                                                <Border Style="{StaticResource DiscoveryRankingPosterFrameStyle}">
                                                                    <Grid>
                                                                        <Control IsHitTestVisible="False"
                                                                                 Template="{StaticResource PosterPlaceholderTemplate}" />
                                                                        <Image helpers:PosterCacheImageBehavior.Source="{Binding PosterRemoteUrl}" Stretch="UniformToFill" />
                                                                    </Grid>
                                                                </Border>
                                                                <Border Style="{StaticResource DiscoveryRankingRankBadgeStyle}">
                                                                    <TextBlock Text="{Binding RankText}"
                                                                               Foreground="{DynamicResource BrushOnAccent}"
                                                                               Style="{StaticResource DiscoveryBadgeTextStyle}" />
