                                                        <TextBlock Margin="0,0,14,0"
                                                                   Text="{Binding YearText}"
                                                                   Style="{StaticResource BodyMutedTextStyle}" />
                                                        <TextBlock Margin="0,0,14,0"
                                                                   Text="{Binding SeasonCountText}"
                                                                   Style="{StaticResource BodyMutedTextStyle}" />
                                                        <TextBlock Text="{Binding LibraryStatusText}" Style="{StaticResource BodyMutedTextStyle}" />
                                                    </WrapPanel>
                                                    <TextBlock Margin="0,8,0,0"
                                                               Text="{Binding DisplayTags}"
                                                               TextWrapping="Wrap"
                                                               Style="{StaticResource BodyTextStyle}" />
                                                    <TextBlock Margin="0,6,0,0"
                                                               Text="{Binding SeasonStateSummaryText}"
                                                               TextWrapping="Wrap">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasSeasonStateSummary}" Value="False">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <ScrollViewer Margin="0,12,0,0"
                                                                  Height="128"
                                                                  VerticalScrollBarVisibility="Auto">
                                                        <TextBlock Text="{Binding OverviewText}"
                                                                   TextWrapping="Wrap"
                                                                   Style="{StaticResource BodyTextStyle}" />
                                                    </ScrollViewer>
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <ItemsControl ItemsSource="{Binding RankingTvRows}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,14" MinHeight="210">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="1" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>

                                                        <Grid DataContext="{Binding LeftItem}"
                                                              Margin="0,0,14,0"
                                                              IsEnabled="{Binding DataContext.CanOpenTvSeries, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                                            <Grid.InputBindings>
                                                                <MouseBinding MouseAction="LeftClick"
                                                                              Command="{Binding DataContext.OpenTvSeriesCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                              CommandParameter="{Binding}" />
                                                            </Grid.InputBindings>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="136" />
                                                                <ColumnDefinition Width="12" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>

                                                            <Grid Height="196">
                                                                <Border CornerRadius="14" Background="{DynamicResource BrushSurfaceAlt}">
                                                                    <Grid>
                                                                        <Control IsHitTestVisible="False"
                                                                                 Template="{StaticResource PosterPlaceholderTemplate}" />
                                                                        <Image helpers:PosterCacheImageBehavior.Source="{Binding PosterRemoteUrl}" Stretch="UniformToFill" />
                                                                    </Grid>
                                                                </Border>
                                                                <Border HorizontalAlignment="Left"
                                                                        VerticalAlignment="Top"
                                                                        Margin="8"
                                                                        Padding="8,4"
                                                                        CornerRadius="999"
                                                                        Background="{DynamicResource BrushAccent}">
                                                                    <TextBlock Text="{Binding RankText}"
                                                                               Foreground="{DynamicResource BrushOnAccent}"
                                                                               FontWeight="SemiBold" />
                                                                </Border>
                                                            </Grid>

                                                            <StackPanel Grid.Column="2" Margin="0,10,0,6">
                                                                <DockPanel>
                                                                    <TextBlock Text="{Binding RatingText}" FontWeight="SemiBold" Style="{StaticResource BodyTextStyle}" />
                                                                    <TextBlock DockPanel.Dock="Right" Text="{Binding YearText}" Style="{StaticResource BodyMutedTextStyle}" />
                                                                </DockPanel>
                                                                <TextBlock Margin="0,8,0,0"
                                                                           Text="{Binding TitleWithOriginalText}"
                                                                           TextWrapping="Wrap"
                                                                           Style="{StaticResource SectionTitleTextStyle}" />
                                                                <TextBlock Margin="0,6,0,0"
                                                                           Text="{Binding DisplayTags}"
                                                                           TextWrapping="Wrap"
                                                                           Style="{StaticResource BodyTextStyle}" />
                                                                <TextBlock Margin="0,4,0,0"
                                                                           Text="{Binding SeasonCountText}"
                                                                           TextWrapping="Wrap"
                                                                           Style="{StaticResource BodyMutedTextStyle}" />
                                                                <TextBlock Margin="0,4,0,0"
                                                                           Text="{Binding LibraryStatusText}"
                                                                           TextWrapping="Wrap"
                                                                           Style="{StaticResource BodyMutedTextStyle}" />
                                                                <ScrollViewer Margin="0,8,0,0" Height="70" VerticalScrollBarVisibility="Auto">
                                                                    <TextBlock Text="{Binding OverviewText}"
                                                                               TextWrapping="Wrap"
                                                                               Style="{StaticResource BodyMutedTextStyle}" />
                                                                </ScrollViewer>
                                                            </StackPanel>
                                                        </Grid>

                                                        <Border Grid.Column="1" Background="{DynamicResource BrushBorder}" />

                                                        <Grid Grid.Column="2"
                                                              DataContext="{Binding RightItem}"
                                                              Margin="14,0,0,0"
                                                              IsEnabled="{Binding DataContext.CanOpenTvSeries, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                                            <Grid.Style>
                                                                <Style TargetType="Grid">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding DataContext.HasRightItem, RelativeSource={RelativeSource AncestorType=Grid}}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Grid.Style>
                                                            <Grid.InputBindings>
                                                                <MouseBinding MouseAction="LeftClick"
                                                                              Command="{Binding DataContext.OpenTvSeriesCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                              CommandParameter="{Binding}" />
                                                            </Grid.InputBindings>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="136" />
                                                                <ColumnDefinition Width="12" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>

                                                            <Grid Height="196">
                                                                <Border CornerRadius="14" Background="{DynamicResource BrushSurfaceAlt}">
                                                                    <Grid>
                                                                        <Control IsHitTestVisible="False"
                                                                                 Template="{StaticResource PosterPlaceholderTemplate}" />
                                                                        <Image helpers:PosterCacheImageBehavior.Source="{Binding PosterRemoteUrl}" Stretch="UniformToFill" />
                                                                    </Grid>
                                                                </Border>
                                                                <Border HorizontalAlignment="Left"
                                                                        VerticalAlignment="Top"
                                                                        Margin="8"
                                                                        Padding="8,4"
                                                                        CornerRadius="999"
                                                                        Background="{DynamicResource BrushAccent}">
                                                                    <TextBlock Text="{Binding RankText}"
                                                                               Foreground="{DynamicResource BrushOnAccent}"
                                                                               FontWeight="SemiBold" />
                                                                </Border>
                                                            </Grid>

                                                            <StackPanel Grid.Column="2" Margin="0,10,0,6">
                                                                <DockPanel>
                                                                    <TextBlock Text="{Binding RatingText}" FontWeight="SemiBold" Style="{StaticResource BodyTextStyle}" />
                                                                    <TextBlock DockPanel.Dock="Right" Text="{Binding YearText}" Style="{StaticResource BodyMutedTextStyle}" />
                                                                </DockPanel>
                                                                <TextBlock Margin="0,8,0,0"
                                                                           Text="{Binding TitleWithOriginalText}"
