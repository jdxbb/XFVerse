<UserControl x:Class="MediaLibrary.App.Views.Pages.MovieDiscoveryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource PageCardStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="影片发现" Style="{StaticResource CardTitleTextStyle}" />
                <TextBlock Margin="0,8,0,0"
                           Text="影片搜索和榜单将在后续阶段接入，AI 推荐已承接当前功能。"
                           Style="{StaticResource BodyMutedTextStyle}" />
            </StackPanel>

            <TabControl Grid.Row="1"
                        Margin="0,22,0,0"
                        SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}"
                        Style="{StaticResource ModernTabControlStyle}">
                <TabItem Header="影片搜索" Style="{StaticResource ModernTabItemStyle}">
                    <Border Margin="0,18,0,0" Style="{StaticResource CompactCardStyle}">
                        <TextBlock Text="影片搜索功能将在后续阶段接入。"
                                   Style="{StaticResource BodyTextStyle}" />
                    </Border>
                </TabItem>
                <TabItem Header="榜单" Style="{StaticResource ModernTabItemStyle}">
                    <Border Margin="0,18,0,0" Style="{StaticResource CompactCardStyle}">
                        <TextBlock Text="榜单功能将在后续阶段接入。"
                                   Style="{StaticResource BodyTextStyle}" />
                    </Border>
                </TabItem>
                <TabItem Header="AI 推荐" Style="{StaticResource ModernTabItemStyle}">
                    <ContentControl Margin="0,18,0,0"
                                    Content="{Binding AiRecommendationViewModel}" />
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</UserControl>
