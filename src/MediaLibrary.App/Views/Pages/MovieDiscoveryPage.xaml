                                                                           Text="{Binding DisplayTags}"
                                                                           TextWrapping="Wrap"
                                                                           Style="{StaticResource BodyTextStyle}" />
                                                                <TextBlock Margin="0,4,0,0"
                                                                           Text="{Binding SeasonCountText}"
                                                                           TextWrapping="Wrap"
                                                                           Style="{StaticResource BodyMutedTextStyle}" />
                                                                <TextBlock Margin="0,4,0,0"
                                                                           Text="{Binding LibraryStatusText}"
                                                                           TextWrapping="Wrap"
                                                                           Style="{StaticResource BodyMutedTextStyle}" />
                                                                <ScrollViewer Margin="0,8,0,0" Height="70" VerticalScrollBarVisibility="Auto">
                                                                    <TextBlock Text="{Binding OverviewText}"
                                                                               TextWrapping="Wrap"
                                                                               Style="{StaticResource BodyMutedTextStyle}" />
                                                                </ScrollViewer>
                                                            </StackPanel>
                                                        </Grid>

                                                        <Border Grid.Column="1" Background="{DynamicResource BrushBorder}" />

                                                        <Grid Grid.Column="2"
                                                              DataContext="{Binding RightItem}"
                                                              Margin="14,0,0,0">
                                                            <Grid.Style>
                                                                <Style TargetType="Grid">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding DataContext.HasRightItem, RelativeSource={RelativeSource AncestorType=Grid}}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Grid.Style>
                                                            <Grid.InputBindings>
                                                                <MouseBinding MouseAction="LeftClick"
                                                                              Command="{Binding DataContext.OpenTvSeriesCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                              CommandParameter="{Binding}" />
                                                            </Grid.InputBindings>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="136" />
                                                                <ColumnDefinition Width="12" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>

                                                            <Grid Height="196">
                                                                <Border CornerRadius="14" Background="{DynamicResource BrushSurfaceAlt}">
                                                                    <Grid>
                                                                        <TextBlock HorizontalAlignment="Center"
                                                                                   VerticalAlignment="Center"
                                                                                   Text="无海报"
                                                                                   Style="{StaticResource BodyMutedTextStyle}" />
                                                                        <Image helpers:PosterCacheImageBehavior.Source="{Binding PosterRemoteUrl}" Stretch="UniformToFill" />
                                                                    </Grid>
                                                                </Border>
                                                                <Border HorizontalAlignment="Left"
                                                                        VerticalAlignment="Top"
                                                                        Margin="8"
                                                                        Padding="8,4"
                                                                        CornerRadius="999"
                                                                        Background="{DynamicResource BrushAccent}">
                                                                    <TextBlock Text="{Binding RankText}"
                                                                               Foreground="{DynamicResource BrushOnAccent}"
                                                                               FontWeight="SemiBold" />
                                                                </Border>
                                                            </Grid>

                                                            <StackPanel Grid.Column="2" Margin="0,10,0,6">
                                                                <DockPanel>
                                                                    <TextBlock Text="{Binding RatingText}" FontWeight="SemiBold" Style="{StaticResource BodyTextStyle}" />
                                                                    <TextBlock DockPanel.Dock="Right" Text="{Binding YearText}" Style="{StaticResource BodyMutedTextStyle}" />
                                                                </DockPanel>
                                                                <TextBlock Margin="0,8,0,0"
                                                                           Text="{Binding TitleWithOriginalText}"
                                                                           TextWrapping="Wrap"
                                                                           Style="{StaticResource SectionTitleTextStyle}" />
                                                                <TextBlock Margin="0,6,0,0"
                                                                           Text="{Binding DisplayTags}"
                                                                           TextWrapping="Wrap"
                                                                           Style="{StaticResource BodyTextStyle}" />
                                                                <TextBlock Margin="0,4,0,0"
                                                                           Text="{Binding SeasonCountText}"
                                                                           TextWrapping="Wrap"
                                                                           Style="{StaticResource BodyMutedTextStyle}" />
                                                                <TextBlock Margin="0,4,0,0"
                                                                           Text="{Binding LibraryStatusText}"
                                                                           TextWrapping="Wrap"
                                                                           Style="{StaticResource BodyMutedTextStyle}" />
                                                                <ScrollViewer Margin="0,8,0,0" Height="70" VerticalScrollBarVisibility="Auto">
                                                                    <TextBlock Text="{Binding OverviewText}"
                                                                               TextWrapping="Wrap"
                                                                               Style="{StaticResource BodyMutedTextStyle}" />
                                                                </ScrollViewer>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </ScrollViewer>
                                <StackPanel Grid.Row="1"
                                            Margin="0,14,0,0"
                                            HorizontalAlignment="Center"
                                            Orientation="Horizontal">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasRankingMovies}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsMovieRankingSelected}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <Button MinWidth="88"
                                            Content="上一页"
                                            Command="{Binding GoPreviousRankingPageCommand}"
                                            IsEnabled="{Binding CanGoPreviousRankingPage}"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                    <TextBlock Margin="14,0"
                                               VerticalAlignment="Center"
                                               Text="{Binding RankingPageStatusText}"
                                               Style="{StaticResource BodyTextStyle}" />
                                    <Button MinWidth="88"
                                            Content="下一页"
                                            Command="{Binding GoNextRankingPageCommand}"
                                            IsEnabled="{Binding CanGoNextRankingPage}"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Row="1"
                                            Margin="0,14,0,0"
                                            HorizontalAlignment="Center"
                                            Orientation="Horizontal">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasRankingTvSeries}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsTvRankingSelected}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <Button MinWidth="88"
                                            Content="上一页"
                                            Command="{Binding GoPreviousRankingPageCommand}"
                                            IsEnabled="{Binding CanGoPreviousTvRankingPage}"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                    <TextBlock Margin="14,0"
                                               VerticalAlignment="Center"
                                               Text="{Binding TvRankingPageStatusText}"
                                               Style="{StaticResource BodyTextStyle}" />
                                    <Button MinWidth="88"
                                            Content="下一页"
                                            Command="{Binding GoNextRankingPageCommand}"
                                            IsEnabled="{Binding CanGoNextTvRankingPage}"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>
                <TabItem Header="AI 推荐" Style="{StaticResource ModernTabItemStyle}">
                    <ContentControl Margin="0,18,0,0"
                                    Content="{Binding AiRecommendationViewModel}" />
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</UserControl>
