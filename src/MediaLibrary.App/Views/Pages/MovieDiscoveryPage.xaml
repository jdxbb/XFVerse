                                                <MouseBinding MouseAction="LeftClick"
                                                              Command="{Binding DataContext.OpenTvSeriesCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                              CommandParameter="{Binding}" />
                                            </Border.InputBindings>
                                            <Grid MinHeight="360">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="250" />
                                                    <ColumnDefinition Width="18" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Grid Height="340">
                                                    <Border CornerRadius="18" Background="{DynamicResource BrushSurfaceAlt}">
                                                        <Grid>
                                                            <Control IsHitTestVisible="False"
                                                                     Template="{StaticResource PosterPlaceholderTemplate}" />
                                                            <Image helpers:PosterCacheImageBehavior.Source="{Binding PosterRemoteUrl}" Stretch="UniformToFill" />
                                                        </Grid>
                                                    </Border>
                                                    <Border HorizontalAlignment="Left"
                                                            VerticalAlignment="Top"
                                                            Margin="12"
                                                            Padding="10,6"
                                                            CornerRadius="999"
                                                            Background="{DynamicResource BrushAccent}">
                                                        <TextBlock Text="{Binding RankText}"
                                                                   Foreground="{DynamicResource BrushOnAccent}"
                                                                   FontWeight="SemiBold" />
                                                    </Border>
                                                </Grid>

                                                <StackPanel Grid.Column="2" Margin="0,16,0,10">
                                                    <TextBlock Text="{Binding RatingText}" Style="{StaticResource MetricTextStyle}" />
