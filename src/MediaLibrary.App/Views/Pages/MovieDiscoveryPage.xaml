                                                            <Style TargetType="Button" BasedOn="{StaticResource DiscoveryWantButtonStyle}">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding CanAddToLibrary}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                    <TextBlock Margin="0,8,0,0"
                                                               Text="{Binding DisplayTags}"
                                                               TextWrapping="Wrap"
                                                               Style="{StaticResource BodyTextStyle}" />
                                                    <TextBlock Margin="0,6,0,0"
                                                               Text="{Binding SeasonStateSummaryText}"
                                                               TextWrapping="Wrap">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasSeasonStateSummary}" Value="False">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <ScrollViewer Margin="0,12,0,0"
                                                                  Height="128"
