                                                        <TextBlock Margin="0,0,14,0"
                                                                   Text="{Binding YearText}"
                                                                   Style="{StaticResource BodyMutedTextStyle}" />
                                                        <TextBlock Margin="0,0,14,0"
                                                                   Text="{Binding SeasonCountText}"
                                                                   Style="{StaticResource BodyMutedTextStyle}" />
                                                        <TextBlock Text="{Binding WatchStateText}" Style="{StaticResource BodyMutedTextStyle}" />
                                                    </WrapPanel>
                                                    <Button Margin="0,10,0,0"
                                                            HorizontalAlignment="Left"
                                                            Content="{Binding AddToLibraryButtonText}"
