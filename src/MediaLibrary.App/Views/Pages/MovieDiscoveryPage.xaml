<UserControl x:Class="MediaLibrary.App.Views.Pages.MovieDiscoveryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:MediaLibrary.App.Helpers"
             xmlns:viewModels="clr-namespace:MediaLibrary.App.ViewModels.Pages">
    <UserControl.Resources>
        <Style x:Key="DiscoverySearchBoxStyle" TargetType="TextBox" BasedOn="{StaticResource SearchBoxStyle}">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="10,3" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="DiscoveryFilterMenuItemStyle" TargetType="MenuItem" BasedOn="{StaticResource MenuItemStyle}">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="MinWidth" Value="86" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="ItemChrome"
                                MinWidth="{TemplateBinding MinWidth}"
                                MinHeight="{TemplateBinding MinHeight}"
                                Margin="{TemplateBinding Margin}"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource BrushGlassSelected}" />
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                                <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource BrushGlassSelected}" />
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                                <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource BrushDisabledForeground}" />
                                <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource BrushDisabledBackground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DiscoveryFilterContextMenuStyle" TargetType="ContextMenu" BasedOn="{StaticResource ContextMenuStyle}">
            <Setter Property="Padding" Value="7" />
            <Setter Property="MaxHeight" Value="420" />
            <Setter Property="Background" Value="{DynamicResource BrushPopupBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
            <Setter Property="HasDropShadow" Value="False" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}"
                                Effect="{StaticResource ShadowPopup}"
                                SnapsToDevicePixels="True">
                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DiscoveryModernScrollBarThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border Width="6"
                                Background="{DynamicResource BrushForegroundMuted}"
                                CornerRadius="3"
                                Opacity="0.58" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DiscoveryModernScrollRepeatButtonStyle" TargetType="{x:Type RepeatButton}">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DiscoveryModernScrollBarStyle" TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="6" />
            <Setter Property="MinWidth" Value="6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Width="{TemplateBinding Width}" Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}"
                                                  Style="{StaticResource DiscoveryModernScrollRepeatButtonStyle}" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource DiscoveryModernScrollBarThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}"
                                                  Style="{StaticResource DiscoveryModernScrollRepeatButtonStyle}" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
                <Trigger Property="IsMouseCaptureWithin" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=(helpers:ScrollBarAutoRevealBehavior.IsRevealed)}"
                             Value="True">
                    <Setter Property="Opacity" Value="1" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource DiscoveryModernScrollBarStyle}" />

        <Style x:Key="DiscoveryMultiFilterMenuItemStyle" TargetType="MenuItem" BasedOn="{StaticResource DiscoveryFilterMenuItemStyle}">
            <Setter Property="Header" Value="{Binding Label}" />
            <Setter Property="IsCheckable" Value="True" />
            <Setter Property="IsChecked" Value="{Binding IsSelected, Mode=OneWay}" />
            <Setter Property="CommandParameter" Value="{Binding Label}" />
            <Setter Property="StaysOpenOnClick" Value="True" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Label}" Value="全部">
                    <Setter Property="StaysOpenOnClick" Value="False" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DiscoveryToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource GlassSmallButtonStyle}">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="86" />
            <Setter Property="Padding" Value="12,4" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="MenuButton_PreviewMouseLeftButtonDown" />
        </Style>

        <Style x:Key="DiscoveryToolbarIconButtonStyle" TargetType="Button" BasedOn="{StaticResource SmallIconButtonStyle}">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="30" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>

        <Style x:Key="DiscoverySortDirectionIconButtonStyle" TargetType="Button" BasedOn="{StaticResource DiscoveryToolbarIconButtonStyle}">
            <Setter Property="Width" Value="28" />
            <Setter Property="MinWidth" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="{DynamicResource BrushGlassSurfaceAlt}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushGlassBorder}" />
        </Style>

        <Style x:Key="DiscoveryLayoutSegmentButtonStyle" TargetType="Button" BasedOn="{StaticResource GlassSmallButtonStyle}">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="54" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <Style x:Key="DiscoveryPosterLayoutSegmentButtonStyle" TargetType="Button" BasedOn="{StaticResource DiscoveryLayoutSegmentButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSearchPosterLayout}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="Foreground" Value="{DynamicResource BrushOnAccent}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DiscoveryListLayoutSegmentButtonStyle" TargetType="Button" BasedOn="{StaticResource DiscoveryLayoutSegmentButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSearchListLayout}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="Foreground" Value="{DynamicResource BrushOnAccent}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DiscoveryLayoutSegmentHostStyle" TargetType="Border">
            <Setter Property="Padding" Value="2" />
            <Setter Property="Background" Value="{DynamicResource BrushGlassSurfaceAlt}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style x:Key="DiscoverySearchClearButtonStyle" TargetType="Button" BasedOn="{StaticResource SmallIconButtonStyle}">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="MinWidth" Value="22" />
            <Setter Property="MinHeight" Value="22" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource BrushForegroundMuted}" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding SearchText}" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
                <DataTrigger Binding="{Binding SearchText}" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DiscoveryTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0,16,0,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid>
                                <Border Height="1"
                                        VerticalAlignment="Bottom"
                                        Background="{DynamicResource BrushDivider}" />
                                <TabPanel x:Name="HeaderPanel"
                                          Panel.ZIndex="1"
                                          HorizontalAlignment="Left"
                                          IsItemsHost="True"
                                          KeyboardNavigation.TabIndex="1" />
                            </Grid>
                            <ContentPresenter x:Name="PART_SelectedContentHost"
                                              Grid.Row="1"
                                              Margin="{TemplateBinding Padding}"
                                              ContentSource="SelectedContent" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DiscoveryTabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="0,0,0,10" />
            <Setter Property="Margin" Value="0,0,34,0" />
            <Setter Property="MinWidth" Value="76" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid MinWidth="{TemplateBinding MinWidth}"
                              Background="Transparent">
                            <ContentPresenter x:Name="HeaderContent"
                                              ContentSource="Header"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                            <Border x:Name="SelectedUnderline"
                                    Height="3"
                                    VerticalAlignment="Bottom"
                                    Background="{DynamicResource BrushAccent}"
                                    Opacity="0" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource BrushAccent}" />
                                <Setter TargetName="SelectedUnderline" Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource BrushAccent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DiscoveryWantButtonStyle" TargetType="Button" BasedOn="{StaticResource GlassSecondaryButtonStyle}">
            <Setter Property="MinWidth" Value="58" />
            <Setter Property="Height" Value="28" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="DiscoveryBadgeStyle" TargetType="Border">
            <Setter Property="MinHeight" Value="24" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="{DynamicResource BrushGlassSurfaceAlt}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushGlassBorder}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="DiscoveryAccentBadgeStyle" TargetType="Border" BasedOn="{StaticResource DiscoveryBadgeStyle}">
            <Setter Property="Background" Value="{DynamicResource BrushAccentSoft}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushAccentSoft}" />
        </Style>

        <Style x:Key="DiscoveryBadgeTextStyle" TargetType="TextBlock" BasedOn="{StaticResource CaptionTextStyle}">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="DiscoveryPosterCardStyle" TargetType="Border" BasedOn="{StaticResource GlassCompactCardStyle}">
            <Setter Property="Width" Value="180" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,14,18" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="ClipToBounds" Value="True" />
        </Style>

        <Style x:Key="DiscoveryListItemStyle" TargetType="Border" BasedOn="{StaticResource GlassCompactCardStyle}">
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <ItemsPanelTemplate x:Key="DiscoveryPosterItemsPanelTemplate">
            <WrapPanel />
        </ItemsPanelTemplate>

        <DataTemplate DataType="{x:Type viewModels:DiscoveryTvSeriesCardViewModel}">
            <Border IsEnabled="{Binding DataContext.CanOpenTvSeries, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    Style="{StaticResource DiscoveryPosterCardStyle}">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding DataContext.OpenTvSeriesCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  CommandParameter="{Binding}" />
                </Border.InputBindings>
                <Grid Height="270">
                    <Border Background="{DynamicResource BrushSurfaceAlt}">
                        <Grid>
                            <Control IsHitTestVisible="False"
                                     Template="{StaticResource PosterPlaceholderTemplate}" />
                            <Image helpers:PosterCacheImageBehavior.Source="{Binding PosterRemoteUrl}"
                                   Stretch="UniformToFill" />
                        </Grid>
                    </Border>

                    <Border HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Margin="10"
                            Style="{StaticResource DiscoveryAccentBadgeStyle}">
                        <TextBlock Text="电视剧" Style="{StaticResource DiscoveryBadgeTextStyle}" />
                    </Border>

                    <Border HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="10">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource DiscoveryAccentBadgeStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasWantToWatchSeasonTag}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="想看" Style="{StaticResource DiscoveryBadgeTextStyle}" />
                    </Border>

                    <Border VerticalAlignment="Bottom"
                            Padding="12,10"
                            Background="{DynamicResource BrushOverlay}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.ColumnSpan="3"
                                       Text="{Binding Title}"
                                       TextTrimming="CharacterEllipsis"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       Style="{StaticResource BodyTextStyle}" />
                            <TextBlock Grid.Row="1"
                                       Grid.ColumnSpan="3"
                                       Margin="0,3,0,0"
                                       Text="{Binding YearText}"
                                       Foreground="#D8FFFFFF"
                                       Style="{StaticResource CaptionTextStyle}" />
                            <TextBlock Grid.Row="2"
                                       Margin="0,5,0,0"
                                       Text="{Binding DisplayTags}"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="#D8FFFFFF"
                                       Style="{StaticResource CaptionTextStyle}" />
                            <Border Grid.Row="2"
                                    Grid.Column="2"
                                    Margin="0,2,0,0"
                                    Style="{StaticResource DiscoveryAccentBadgeStyle}">
                                <TextBlock Text="{Binding RatingBadgeText}" Style="{StaticResource DiscoveryBadgeTextStyle}" />
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>
    <Grid Background="Transparent" PreviewMouseDown="OnRootPreviewMouseDown">
        <TabControl SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}"
                    Style="{StaticResource DiscoveryTabControlStyle}">
                <TabItem Header="影片" Style="{StaticResource DiscoveryTabItemStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Padding="14" Style="{StaticResource GlassPageCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition x:Name="SearchToolbarColumn" Width="816" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="40" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0">
                                    <TextBox helpers:TextBoxPlaceholderBehavior.IsEnabled="True"
                                             helpers:TextBoxPlaceholderBehavior.PlaceholderText="{Binding SearchPlaceholderText}"
                                             ToolTip="{Binding SearchInputToolTip}"
                                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="10,3,30,3"
                                             Style="{StaticResource DiscoverySearchBoxStyle}">
                                        <TextBox.InputBindings>
                                            <KeyBinding Key="Enter" Command="{Binding SearchCommand}" />
                                        </TextBox.InputBindings>
                                    </TextBox>
                                    <Button HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Margin="0,0,4,0"
                                            Command="{Binding ClearSearchTextCommand}"
                                            Style="{StaticResource DiscoverySearchClearButtonStyle}">
                                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                                   FontSize="10"
                                                   Text="&#xE711;" />
                                    </Button>
                                </Grid>

                                <Button Grid.Column="2"
                                        VerticalAlignment="Bottom"
                                        Command="{Binding SearchCommand}"
                                        Style="{StaticResource DiscoveryToolbarIconButtonStyle}">
                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                               FontSize="16"
                                               RenderTransformOrigin="0.5,0.5"
                                               Text="&#xE721;">
                                        <TextBlock.RenderTransform>
                                            <ScaleTransform ScaleX="-1" />
                                        </TextBlock.RenderTransform>
                                    </TextBlock>
                                </Button>
                                <Grid Grid.Column="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button Command="{Binding ToggleSearchSortDirectionCommand}"
                                            Style="{StaticResource DiscoverySortDirectionIconButtonStyle}"
                                            ToolTip="{Binding SearchSortDirectionButtonToolTip}">
                                        <Viewbox Width="16" Height="16">
                                            <Canvas Width="26" Height="24">
                                                <Path Data="{Binding SearchSortDirectionIconData}"
                                                      Stroke="{DynamicResource BrushForegroundSecondary}"
                                                      StrokeThickness="2"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round" />
                                            </Canvas>
                                        </Viewbox>
                                    </Button>
                                    <Button Grid.Column="2"
                                            Content="{Binding SearchSortOptionButtonText}"
                                            Click="OpenButtonContextMenu"
                                            Style="{StaticResource DiscoveryToolbarButtonStyle}">
                                        <Button.ContextMenu>
                                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                                         ItemsSource="{Binding SortOptions}"
                                                         Style="{StaticResource DiscoveryFilterContextMenuStyle}">
                                                <ContextMenu.ItemContainerStyle>
                                                    <Style TargetType="MenuItem" BasedOn="{StaticResource DiscoveryFilterMenuItemStyle}">
                                                        <Setter Property="Header" Value="{Binding}" />
                                                        <Setter Property="Command" Value="{Binding PlacementTarget.DataContext.SelectSearchSortOptionCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                        <Setter Property="CommandParameter" Value="{Binding}" />
                                                    </Style>
                                                </ContextMenu.ItemContainerStyle>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                    </Button>
                                    <Button Grid.Column="4"
                                            HorizontalAlignment="Right"
                                            Content="清除筛选"
                                            Command="{Binding ClearSearchFiltersCommand}"
                                            Style="{StaticResource DiscoveryToolbarButtonStyle}" />
                                </Grid>
                            </Grid>

                            <WrapPanel Grid.Row="2">
                                    <WrapPanel.Style>
                                        <Style TargetType="WrapPanel">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMovieSearchSelected}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </WrapPanel.Style>

                                    <Button Margin="0,0,8,8"
                                            Content="{Binding SearchMediaTypeButtonText}"
                                            Click="OpenButtonContextMenu"
                                            Style="{StaticResource DiscoveryToolbarButtonStyle}">
                                        <Button.ContextMenu>
                                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                                         ItemsSource="{Binding SearchMediaTypeOptions}"
                                                         Style="{StaticResource DiscoveryFilterContextMenuStyle}">
                                                <ContextMenu.ItemContainerStyle>
                                                    <Style TargetType="MenuItem" BasedOn="{StaticResource DiscoveryFilterMenuItemStyle}">
                                                        <Setter Property="Header" Value="{Binding}" />
                                                        <Setter Property="Command" Value="{Binding PlacementTarget.DataContext.SelectSearchMediaTypeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                        <Setter Property="CommandParameter" Value="{Binding}" />
                                                    </Style>
                                                </ContextMenu.ItemContainerStyle>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                    </Button>

                                    <Button Margin="0,0,8,8"
                                            Content="{Binding SearchTypeButtonText}"
                                            Click="OpenButtonContextMenu"
                                            Style="{StaticResource DiscoveryToolbarButtonStyle}">
                                        <Button.ContextMenu>
                                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                                         ItemsSource="{Binding SearchTypeOptions}"
                                                         Style="{StaticResource DiscoveryFilterContextMenuStyle}">
                                                <ContextMenu.ItemContainerStyle>
                                                    <Style TargetType="MenuItem" BasedOn="{StaticResource DiscoveryFilterMenuItemStyle}">
                                                        <Setter Property="Header" Value="{Binding}" />
                                                        <Setter Property="Command" Value="{Binding PlacementTarget.DataContext.SelectSearchTypeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                        <Setter Property="CommandParameter" Value="{Binding}" />
                                                    </Style>
                                                </ContextMenu.ItemContainerStyle>
