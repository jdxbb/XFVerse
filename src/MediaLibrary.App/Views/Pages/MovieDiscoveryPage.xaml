                                                                           TextWrapping="Wrap"
                                                                           Style="{StaticResource BodyTextStyle}" />
                                                                <TextBlock Margin="0,4,0,0"
                                                                           Text="{Binding SeasonCountText}"
                                                                           TextWrapping="Wrap"
                                                                           Style="{StaticResource BodyMutedTextStyle}" />
                                                                <TextBlock Margin="0,4,0,0"
                                                                           Text="{Binding LibraryStatusText}"
                                                                           TextWrapping="Wrap"
                                                                           Style="{StaticResource BodyMutedTextStyle}" />
                                                                <ScrollViewer Margin="0,8,0,0" Height="70" VerticalScrollBarVisibility="Auto">
                                                                    <TextBlock Text="{Binding OverviewText}"
                                                                               TextWrapping="Wrap"
                                                                               Style="{StaticResource BodyMutedTextStyle}" />
                                                                </ScrollViewer>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </ScrollViewer>
                                <StackPanel Grid.Row="1"
                                            Margin="0,14,0,0"
                                            HorizontalAlignment="Center"
                                            Orientation="Horizontal">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasRankingMovies}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsMovieRankingSelected}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <Button MinWidth="88"
                                            Content="上一页"
                                            Command="{Binding GoPreviousRankingPageCommand}"
                                            IsEnabled="{Binding CanGoPreviousRankingPage}"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                    <TextBlock Margin="14,0"
                                               VerticalAlignment="Center"
                                               Text="{Binding RankingPageStatusText}"
                                               Style="{StaticResource BodyTextStyle}" />
                                    <Button MinWidth="88"
                                            Content="下一页"
                                            Command="{Binding GoNextRankingPageCommand}"
                                            IsEnabled="{Binding CanGoNextRankingPage}"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Row="1"
                                            Margin="0,14,0,0"
                                            HorizontalAlignment="Center"
                                            Orientation="Horizontal">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasRankingTvSeries}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsTvRankingSelected}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <Button MinWidth="88"
                                            Content="上一页"
                                            Command="{Binding GoPreviousRankingPageCommand}"
                                            IsEnabled="{Binding CanGoPreviousTvRankingPage}"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                    <TextBlock Margin="14,0"
                                               VerticalAlignment="Center"
                                               Text="{Binding TvRankingPageStatusText}"
                                               Style="{StaticResource BodyTextStyle}" />
                                    <Button MinWidth="88"
                                            Content="下一页"
                                            Command="{Binding GoNextRankingPageCommand}"
                                            IsEnabled="{Binding CanGoNextTvRankingPage}"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>
                <TabItem Header="AI" Style="{StaticResource DiscoveryTabItemStyle}">
                    <ContentControl
                                    Content="{Binding AiRecommendationViewModel}" />
                </TabItem>
        </TabControl>
    </Grid>
</UserControl>
