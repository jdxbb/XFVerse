<UserControl x:Class="MediaLibrary.App.Views.Pages.MovieDiscoveryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MediaLibrary.App.Controls"
             xmlns:helpers="clr-namespace:MediaLibrary.App.Helpers"
             xmlns:viewModels="clr-namespace:MediaLibrary.App.ViewModels.Pages">
    <UserControl.Resources>
        <SolidColorBrush x:Key="DiscoveryLibraryMediaCardBackgroundBrush" Color="{DynamicResource ColorCard}" />
        <SolidColorBrush x:Key="DiscoveryLibraryListMediaCardBackgroundBrush" Color="{DynamicResource ColorSidebar}" />
        <SolidColorBrush x:Key="DiscoveryLibraryMediaCardSurfaceBrush" Color="{DynamicResource ColorSurfaceAlt}" />
        <SolidColorBrush x:Key="DiscoveryLibraryMediaCardTextBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="DiscoveryLibraryMediaCardMutedTextBrush" Color="#D8DEE9" />
        <SolidColorBrush x:Key="DiscoveryLibraryMediaCardAccentBrush" Color="#E2E8F0" />
        <SolidColorBrush x:Key="DiscoveryLibraryMediaCardAccentTextBrush" Color="#111827" />
        <SolidColorBrush x:Key="DiscoveryLibraryTagDividerBrush" Color="#7DD3FC" />
        <SolidColorBrush x:Key="DiscoveryLibraryRatingGoldBrush" Color="{DynamicResource ColorWarning}" />
        <SolidColorBrush x:Key="DiscoveryWantAddBrush" Color="#E2E8F0" />
        <SolidColorBrush x:Key="DiscoveryWantRemoveBrush" Color="{DynamicResource ColorAccent}" />
        <SolidColorBrush x:Key="DiscoveryWantEmptyStarFillBrush" Color="#4DFFFFFF" />
        <SolidColorBrush x:Key="DiscoveryWantEmptyStarStrokeBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="DiscoveryToastInfoBackgroundBrush" Color="{DynamicResource ColorInfoBackground}" Opacity="0.88" />
        <SolidColorBrush x:Key="DiscoveryToastWarningBackgroundBrush" Color="{DynamicResource ColorWarningBackground}" Opacity="0.88" />
        <SolidColorBrush x:Key="DiscoveryToastErrorBackgroundBrush" Color="{DynamicResource ColorErrorBackground}" Opacity="0.88" />
        <SolidColorBrush x:Key="DiscoveryToastSuccessBackgroundBrush" Color="{DynamicResource ColorSuccessBackground}" Opacity="0.88" />

        <Style x:Key="DiscoveryLibraryMediaChipStyle" TargetType="Border">
            <Setter Property="Height" Value="20" />
            <Setter Property="Padding" Value="7,0" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="{StaticResource DiscoveryLibraryMediaCardAccentBrush}" />
            <Setter Property="Opacity" Value="0.9" />
        </Style>

        <Style x:Key="DiscoveryLibraryMediaChipTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource DiscoveryLibraryMediaCardAccentTextBrush}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="LineHeight" Value="12" />
            <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="DiscoveryLibraryMediaMutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource DiscoveryLibraryMediaCardMutedTextBrush}" />
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="DiscoveryLibraryTagLineContainerStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="450" />
            <Setter Property="ToolTipService.BetweenShowDelay" Value="0" />
            <Setter Property="ToolTipService.ShowDuration" Value="20000" />
        </Style>

        <Style x:Key="DiscoveryLibraryMediaTitleTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource DiscoveryLibraryMediaCardTextBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="DiscoverySearchRatingBadgeStyle" TargetType="Border">
            <Setter Property="MinWidth" Value="42" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="{StaticResource DiscoveryLibraryMediaCardAccentBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Opacity" Value="0.9" />
            <Setter Property="HorizontalAlignment" Value="Right" />
        </Style>

        <Style x:Key="DiscoverySearchRatingTextStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="LineHeight" Value="16" />
            <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
            <Setter Property="Foreground" Value="{StaticResource DiscoveryLibraryMediaCardAccentTextBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsHighWeightedAverageRating}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource DiscoveryLibraryRatingGoldBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DiscoverySearchWantChipButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="20" />
            <Setter Property="Height" Value="20" />
            <Setter Property="Padding" Value="7,0" />
            <Setter Property="Background" Value="{StaticResource DiscoveryWantAddBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource DiscoveryLibraryMediaCardAccentTextBrush}" />
            <Setter Property="Opacity" Value="0.92" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Opacity="{TemplateBinding Opacity}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.FontSize="{TemplateBinding FontSize}"
                                              TextElement.FontWeight="{TemplateBinding FontWeight}"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding CanToggleWantToWatch}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsWantToWatch}" Value="True">
                    <Setter Property="Background" Value="{StaticResource DiscoveryWantRemoveBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource BrushOnAccent}" />
                </DataTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DiscoverySearchWantIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="30" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource DiscoveryWantEmptyStarStrokeBrush}" />
            <Setter Property="Opacity" Value="0.96" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <Grid>
                                <TextBlock x:Name="WantIconStroke"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="20"
                                           Foreground="{StaticResource DiscoveryWantEmptyStarStrokeBrush}"
                                           IsHitTestVisible="False"
                                           Opacity="0"
                                           Text="&#xE735;">
                                    <TextBlock.Effect>
                                        <DropShadowEffect BlurRadius="3"
                                                          Color="#FFFFFFFF"
                                                          Direction="0"
                                                          Opacity="1"
                                                          ShadowDepth="0" />
                                    </TextBlock.Effect>
                                </TextBlock>
                                <TextBlock x:Name="WantIcon"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="20"
                                           Foreground="{TemplateBinding Foreground}"
                                           Text="&#xE734;" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="1" />
                            </Trigger>
                            <DataTrigger Binding="{Binding IsWantToWatch}" Value="True">
                                <Setter TargetName="WantIcon" Property="Text" Value="&#xE735;" />
                                <Setter TargetName="WantIcon" Property="Foreground" Value="{DynamicResource BrushRatingStarFill}" />
                                <Setter TargetName="WantIconStroke" Property="Opacity" Value="1" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsWatched}" Value="True">
                                <Setter TargetName="WantIcon" Property="Text" Value="&#xE734;" />
                                <Setter TargetName="WantIcon" Property="Foreground" Value="{StaticResource DiscoveryWantEmptyStarStrokeBrush}" />
                                <Setter TargetName="WantIconStroke" Property="Opacity" Value="0" />
                            </DataTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.42" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DiscoveryRankingWantChipButtonStyle" TargetType="Button" BasedOn="{StaticResource DiscoverySearchWantChipButtonStyle}">
            <Setter Property="MinHeight" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Padding" Value="5,0" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsWantToWatch}" Value="True">
                    <Setter Property="Padding" Value="7,0" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DiscoveryCurrentWantChipStyle" TargetType="Border" BasedOn="{StaticResource DiscoveryLibraryMediaChipStyle}">
            <Setter Property="Background" Value="{StaticResource DiscoveryWantRemoveBrush}" />
            <Setter Property="Height" Value="20" />
            <Setter Property="Padding" Value="7,0" />
        </Style>

        <Style x:Key="DiscoverySearchBoxStyle" TargetType="TextBox" BasedOn="{StaticResource SearchBoxStyle}">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="DiscoveryFilterMenuItemStyle" TargetType="MenuItem" BasedOn="{StaticResource MenuItemStyle}">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="MinWidth" Value="86" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="ItemChrome"
                                MinWidth="{TemplateBinding MinWidth}"
                                MinHeight="{TemplateBinding MinHeight}"
                                Margin="{TemplateBinding Margin}"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource BrushGlassSelected}" />
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                                <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource BrushGlassSelected}" />
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                                <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource BrushDisabledForeground}" />
                                <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource BrushDisabledBackground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DiscoveryFilterContextMenuStyle" TargetType="ContextMenu" BasedOn="{StaticResource ContextMenuStyle}">
            <Setter Property="Padding" Value="7" />
            <Setter Property="MaxHeight" Value="420" />
            <Setter Property="Background" Value="{DynamicResource BrushPopupBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
            <Setter Property="HasDropShadow" Value="False" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <EventSetter Event="PreviewMouseWheel" Handler="ContextMenu_PreviewMouseWheel" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ScrollViewer MaxHeight="{TemplateBinding MaxHeight}"
                                          HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto">
                                <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" />
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DiscoveryShortFilterContextMenuStyle" TargetType="ContextMenu" BasedOn="{StaticResource DiscoveryFilterContextMenuStyle}">
            <Setter Property="MaxHeight" Value="292" />
        </Style>

        <Style x:Key="DiscoveryFilterSubmenuItemStyle" TargetType="MenuItem">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="Padding" Value="18,5,8,5" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Grid>
                            <Border x:Name="ItemChrome"
                                    MinWidth="{TemplateBinding MinWidth}"
                                    MinHeight="{TemplateBinding MinHeight}"
                                    Margin="{TemplateBinding Margin}"
                                    Padding="{TemplateBinding Padding}"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="Transparent"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    SnapsToDevicePixels="True">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter ContentSource="Header"
                                                      HorizontalAlignment="Center"
                                                      RecognizesAccessKey="True"
                                                      VerticalAlignment="Center" />
                                    <TextBlock x:Name="SubmenuArrow"
                                               Grid.Column="1"
                                               Margin="4,0,0,0"
                                               VerticalAlignment="Center"
                                               Text="&#x203A;"
                                               Foreground="{DynamicResource BrushForegroundMuted}" />
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Custom"
                                   PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                   PopupAnimation="Fade"
                                   VerticalOffset="-7">
                                <Border Background="{DynamicResource BrushPopupBackground}"
                                        BorderBrush="{DynamicResource BrushBorder}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="10">
                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" />
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource BrushGlassSelected}" />
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                                <Setter TargetName="SubmenuArrow" Property="Foreground" Value="{DynamicResource BrushAccent}" />
                            </Trigger>
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource BrushGlassSelected}" />
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                                <Setter TargetName="SubmenuArrow" Property="Foreground" Value="{DynamicResource BrushAccent}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource BrushDisabledForeground}" />
                                <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource BrushDisabledBackground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DiscoveryModernScrollBarThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border Width="6"
                                Background="{DynamicResource BrushForegroundMuted}"
                                CornerRadius="3"
                                Opacity="0.58" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DiscoveryModernScrollRepeatButtonStyle" TargetType="{x:Type RepeatButton}">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DiscoveryModernScrollBarStyle" TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="6" />
            <Setter Property="MinWidth" Value="6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Width="{TemplateBinding Width}" Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}"
                                                  Style="{StaticResource DiscoveryModernScrollRepeatButtonStyle}" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource DiscoveryModernScrollBarThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}"
                                                  Style="{StaticResource DiscoveryModernScrollRepeatButtonStyle}" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
                <Trigger Property="IsMouseCaptureWithin" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=(helpers:ScrollBarAutoRevealBehavior.IsRevealed)}"
                             Value="True">
                    <Setter Property="Opacity" Value="1" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DiscoveryRankingOuterScrollBarStyle" TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource DiscoveryModernScrollBarStyle}">
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform X="4" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource DiscoveryModernScrollBarStyle}" />

        <Style x:Key="DiscoveryMultiFilterMenuItemStyle" TargetType="MenuItem" BasedOn="{StaticResource DiscoveryFilterMenuItemStyle}">
            <Setter Property="Header" Value="{Binding Label}" />
            <Setter Property="IsCheckable" Value="True" />
            <Setter Property="IsChecked" Value="{Binding IsSelected, Mode=OneWay}" />
            <Setter Property="CommandParameter" Value="{Binding Label}" />
            <Setter Property="StaysOpenOnClick" Value="True" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Label}" Value="全部">
                    <Setter Property="StaysOpenOnClick" Value="False" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DiscoveryManualTabButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="104" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Margin" Value="0,0,28,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Width="{TemplateBinding Width}"
                              Height="{TemplateBinding Height}"
                              Background="{TemplateBinding Background}"
                              ClipToBounds="False"
                              SnapsToDevicePixels="True">
                            <TextBlock Width="{TemplateBinding Width}"
                                       Margin="0,0,0,8"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Bottom"
                                       FontFamily="{TemplateBinding FontFamily}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       Foreground="{TemplateBinding Foreground}"
                                       Text="{TemplateBinding Content}"
                                       TextAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />
                            <Border Width="{TemplateBinding Width}"
                                    Height="4"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Bottom"
                                    Background="{TemplateBinding BorderBrush}" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource BrushAccent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding AiRecommendationViewModel.IsPreferenceDialogOpen}" Value="True">
                    <Setter Property="IsHitTestVisible" Value="False" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DiscoverySearchTabButtonStyle" TargetType="Button" BasedOn="{StaticResource DiscoveryManualTabButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSearchTabSelected}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DiscoveryRankingTabButtonStyle" TargetType="Button" BasedOn="{StaticResource DiscoveryManualTabButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsRankingTabSelected}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DiscoveryAiTabButtonStyle" TargetType="Button" BasedOn="{StaticResource DiscoveryManualTabButtonStyle}">
            <Setter Property="Margin" Value="0" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsAiRecommendationTabSelected}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DiscoveryToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource GlassSmallButtonStyle}">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="86" />
            <Setter Property="Padding" Value="12,4" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="MenuButton_PreviewMouseLeftButtonDown" />
        </Style>

        <Style x:Key="DiscoveryClearFiltersButtonStyle" TargetType="Button" BasedOn="{StaticResource DiscoveryToolbarButtonStyle}">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="10,4" />
        </Style>

        <Style x:Key="DiscoveryToolbarIconButtonStyle" TargetType="Button" BasedOn="{StaticResource SmallIconButtonStyle}">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="30" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="FontSize" Value="12" />
