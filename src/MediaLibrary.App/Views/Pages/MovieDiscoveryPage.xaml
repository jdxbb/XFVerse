                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <ContentControl Content="{Binding}"
                                                                            ContentTemplate="{StaticResource DiscoveryRankingMoviePosterTemplate}" />
                                                            <ContentControl Grid.Column="2"
                                                                            Content="{Binding}"
                                                                            ContentTemplate="{StaticResource DiscoveryRankingItemInfoTemplate}" />
                                                            </Grid>
                                                        </Border>
                                                        <Border Grid.Column="2"
                                                                DataContext="{Binding RightItem}"
                                                                Margin="14,0,0,0">
                                                            <Border.Style>
                                                                <Style TargetType="Border" BasedOn="{StaticResource DiscoveryRankingItemCardStyle}">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding DataContext.HasRightItem, RelativeSource={RelativeSource AncestorType=Grid}}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="180" />
                                                                <ColumnDefinition Width="16" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <ContentControl Content="{Binding}"
                                                                            ContentTemplate="{StaticResource DiscoveryRankingMoviePosterTemplate}" />
                                                            <ContentControl Grid.Column="2"
                                                                            Content="{Binding}"
                                                                            ContentTemplate="{StaticResource DiscoveryRankingItemInfoTemplate}" />
                                                            </Grid>
                                                        </Border>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1"
                                                Margin="0,4,0,26"
                                                HorizontalAlignment="Center"
                                                Orientation="Horizontal">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasRankingMovies}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsMovieRankingSelected}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsRankingLoading}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <Button Command="{Binding GoPreviousRankingPageCommand}"
                                                IsEnabled="{Binding CanGoPreviousRankingPage}"
                                                Style="{StaticResource DiscoveryPagerIconButtonStyle}">
                                            <Viewbox Width="16" Height="16">
                                                <Canvas Width="24" Height="24">
                                                    <Path Data="M 15 5 L 8 12 L 15 19"
                                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                          StrokeThickness="2.2"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          StrokeLineJoin="Round" />
                                                </Canvas>
                                            </Viewbox>
                                        </Button>
                                        <TextBlock Margin="14,0"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding RankingPageStatusText}"
                                                   Style="{StaticResource BodyTextStyle}" />
                                        <Button Command="{Binding GoNextRankingPageCommand}"
                                                IsEnabled="{Binding CanGoNextRankingPage}"
                                                PreviewMouseLeftButtonDown="RankingNextPageButton_PreviewMouseLeftButtonDown"
                                                Style="{StaticResource DiscoveryPagerIconButtonStyle}">
                                            <Viewbox Width="16" Height="16">
                                                <Canvas Width="24" Height="24">
                                                    <Path Data="M 9 5 L 16 12 L 9 19"
                                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                          StrokeThickness="2.2"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          StrokeLineJoin="Round" />
                                                </Canvas>
                                            </Viewbox>
                                        </Button>
                                    </StackPanel>
                                    </Grid>
                                </ScrollViewer>
                                <ScrollViewer x:Name="RankingTvScrollViewer"
                                              Grid.Row="0"
                                              Margin="-84,0,0,0"
                                              Loaded="DiscoveryScrollViewer_Loaded"
                                              ScrollChanged="DiscoveryScrollViewer_ScrollChanged"
                                              helpers:ScrollBarAutoRevealBehavior.IsEnabled="True"
                                              HorizontalScrollBarVisibility="Disabled"
                                              VerticalScrollBarVisibility="Auto">
                                    <ScrollViewer.Resources>
                                        <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource DiscoveryRankingOuterScrollBarStyle}" />
                                    </ScrollViewer.Resources>
                                    <ScrollViewer.Style>
                                        <Style TargetType="ScrollViewer">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTvRankingSelected}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding HasRankingTvSeries}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsTvRankingLoading}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ScrollViewer.Style>
                                    <Grid Margin="84,0,0,0"
                                          MinHeight="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=ScrollViewer}}">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0">
                                        <Border DataContext="{Binding TopRankingTvSeries}"
                                                IsEnabled="{Binding DataContext.CanOpenTvSeries, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                            <Border.Style>
                                                <Style TargetType="Border" BasedOn="{StaticResource DiscoveryRankingHeroCardStyle}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DataContext.ShowTopRankingTvSeries, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid MinHeight="324"
                                                  Margin="36,0,36,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="216" />
                                                    <ColumnDefinition Width="18" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <ContentControl Content="{Binding}"
                                                                ContentTemplate="{StaticResource DiscoveryRankingHeroTvPosterTemplate}" />
                                                <ContentControl Grid.Column="2"
                                                                Content="{Binding}"
                                                                ContentTemplate="{StaticResource DiscoveryRankingHeroInfoTemplate}" />
                                            </Grid>
                                        </Border>

                                        <Border Height="1"
                                                Margin="0,18,0,16"
                                                Background="{DynamicResource BrushBorder}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ShowTopRankingTvSeries}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>

                                        <ItemsControl ItemsSource="{Binding RankingTvRows}">
                                            <ItemsControl.Template>
                                                <ControlTemplate TargetType="ItemsControl">
                                                    <Grid>
                                                        <Border Width="1"
                                                                HorizontalAlignment="Center"
                                                                Background="{DynamicResource BrushBorder}" />
                                                        <ItemsPresenter />
                                                    </Grid>
                                                </ControlTemplate>
                                            </ItemsControl.Template>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,28" MinHeight="270">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="1" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>

                                                        <Border DataContext="{Binding LeftItem}"
                                                                Margin="0,0,14,0"
                                                                IsEnabled="{Binding DataContext.CanOpenTvSeries, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                Style="{StaticResource DiscoveryRankingItemCardStyle}">
                                                            <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="180" />
                                                                <ColumnDefinition Width="16" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <ContentControl Content="{Binding}"
                                                                            ContentTemplate="{StaticResource DiscoveryRankingTvPosterTemplate}" />
                                                            <ContentControl Grid.Column="2"
                                                                            Content="{Binding}"
                                                                            ContentTemplate="{StaticResource DiscoveryRankingItemInfoTemplate}" />
                                                            </Grid>
                                                        </Border>
                                                        <Border Grid.Column="2"
                                                                DataContext="{Binding RightItem}"
                                                                Margin="14,0,0,0"
                                                                IsEnabled="{Binding DataContext.CanOpenTvSeries, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                                            <Border.Style>
                                                                <Style TargetType="Border" BasedOn="{StaticResource DiscoveryRankingItemCardStyle}">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding DataContext.HasRightItem, RelativeSource={RelativeSource AncestorType=Grid}}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="180" />
                                                                <ColumnDefinition Width="16" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <ContentControl Content="{Binding}"
                                                                            ContentTemplate="{StaticResource DiscoveryRankingTvPosterTemplate}" />
                                                            <ContentControl Grid.Column="2"
                                                                            Content="{Binding}"
                                                                            ContentTemplate="{StaticResource DiscoveryRankingItemInfoTemplate}" />
                                                            </Grid>
                                                        </Border>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1"
                                                Margin="0,4,0,26"
                                                HorizontalAlignment="Center"
                                                Orientation="Horizontal">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasRankingTvSeries}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsTvRankingSelected}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsTvRankingLoading}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <Button Command="{Binding GoPreviousRankingPageCommand}"
                                                IsEnabled="{Binding CanGoPreviousTvRankingPage}"
                                                Style="{StaticResource DiscoveryPagerIconButtonStyle}">
                                            <Viewbox Width="16" Height="16">
                                                <Canvas Width="24" Height="24">
                                                    <Path Data="M 15 5 L 8 12 L 15 19"
                                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                          StrokeThickness="2.2"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          StrokeLineJoin="Round" />
                                                </Canvas>
                                            </Viewbox>
                                        </Button>
                                        <TextBlock Margin="14,0"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding TvRankingPageStatusText}"
                                                   Style="{StaticResource BodyTextStyle}" />
                                        <Button Command="{Binding GoNextRankingPageCommand}"
                                                IsEnabled="{Binding CanGoNextTvRankingPage}"
                                                PreviewMouseLeftButtonDown="RankingNextPageButton_PreviewMouseLeftButtonDown"
                                                Style="{StaticResource DiscoveryPagerIconButtonStyle}">
                                            <Viewbox Width="16" Height="16">
                                                <Canvas Width="24" Height="24">
                                                    <Path Data="M 9 5 L 16 12 L 9 19"
                                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                          StrokeThickness="2.2"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          StrokeLineJoin="Round" />
                                                </Canvas>
                                            </Viewbox>
                                        </Button>
                                    </StackPanel>
                                    </Grid>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>
                <TabItem Header="AI推荐" Style="{StaticResource DiscoveryTabItemStyle}">
                    <ContentControl
                                    Content="{Binding AiRecommendationViewModel}" />
                </TabItem>
        </TabControl>
        <Grid Panel.ZIndex="50"
              IsHitTestVisible="False">
            <Grid.RowDefinitions>
                <RowDefinition Height="2*" />
                <RowDefinition Height="8*" />
            </Grid.RowDefinitions>
            <Border Grid.Row="0"
                    MinHeight="34"
                    MaxWidth="420"
                    Margin="0,0,0,12"
                    Padding="16,9"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    BorderThickness="1"
                    CornerRadius="12"
                    SnapsToDevicePixels="True">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="22"
                                      Color="#000000"
                                      Direction="270"
                                      Opacity="0.20"
                                      ShadowDepth="8" />
                </Border.Effect>
                <Border.Style>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Setter Property="Background" Value="{StaticResource DiscoveryToastInfoBackgroundBrush}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource BrushInfoBorder}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsTransientPageMessageVisible}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding TransientPageMessageKind}" Value="Warning">
                                <Setter Property="Background" Value="{StaticResource DiscoveryToastWarningBackgroundBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource BrushWarningBorder}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding TransientPageMessageKind}" Value="Error">
                                <Setter Property="Background" Value="{StaticResource DiscoveryToastErrorBackgroundBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource BrushErrorBorder}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding TransientPageMessageKind}" Value="Success">
                                <Setter Property="Background" Value="{StaticResource DiscoveryToastSuccessBackgroundBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource BrushSuccessBorder}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock MaxWidth="380"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Text="{Binding TransientPageMessageText}"
                           TextAlignment="Center"
                           TextTrimming="CharacterEllipsis">
                    <TextBlock.Style>
                        <Style TargetType="{x:Type TextBlock}">
                            <Setter Property="Foreground" Value="{DynamicResource BrushInfoForeground}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding TransientPageMessageKind}" Value="Warning">
                                    <Setter Property="Foreground" Value="{DynamicResource BrushWarningForeground}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding TransientPageMessageKind}" Value="Error">
                                    <Setter Property="Foreground" Value="{DynamicResource BrushErrorForeground}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding TransientPageMessageKind}" Value="Success">
                                    <Setter Property="Foreground" Value="{DynamicResource BrushSuccessForeground}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>
        </Grid>
    </Grid>
</UserControl>
