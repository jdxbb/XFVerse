<UserControl x:Class="MediaLibrary.App.Views.Pages.MovieDiscoveryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:MediaLibrary.App.Helpers"
             xmlns:viewModels="clr-namespace:MediaLibrary.App.ViewModels.Pages">
    <UserControl.Resources>
        <DataTemplate DataType="{x:Type viewModels:DiscoveryTvSeriesCardViewModel}">
            <Border Width="232"
                    Margin="0,0,18,18"
                    Style="{StaticResource CompactCardStyle}">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding DataContext.OpenTvSeriesCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  CommandParameter="{Binding}" />
                </Border.InputBindings>
                <StackPanel>
                    <Grid Height="300">
                        <Border CornerRadius="18" Background="{DynamicResource BrushSurfaceAlt}">
                            <Grid>
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Text="无海报"
                                           Style="{StaticResource BodyMutedTextStyle}" />
                                <Image helpers:PosterCacheImageBehavior.Source="{Binding PosterRemoteUrl}" Stretch="UniformToFill" />
                            </Grid>
                        </Border>
                        <Border HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Margin="10"
                                Padding="9,5"
                                CornerRadius="999"
                                Background="{DynamicResource BrushAccent}">
                            <TextBlock Text="{Binding AvailabilityText}"
                                       Foreground="{DynamicResource BrushOnAccent}"
                                       FontWeight="SemiBold" />
                        </Border>
                        <Border HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="10"
                                Padding="9,5"
                                CornerRadius="999"
                                Background="{DynamicResource BrushSurfaceAlt}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasRank}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding RankText}" Style="{StaticResource BodyTextStyle}" />
                        </Border>
                    </Grid>

                    <TextBlock Margin="0,14,0,0"
                               Text="{Binding Title}"
                               TextWrapping="Wrap"
                               TextTrimming="CharacterEllipsis"
                               Style="{StaticResource SectionTitleTextStyle}" />
                    <TextBlock Margin="0,4,0,0"
                               Text="{Binding OriginalTitleText}"
                               TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding OriginalTitleText}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <DockPanel Margin="0,8,0,0">
                        <TextBlock Text="{Binding YearText}" Style="{StaticResource BodyMutedTextStyle}" />
                        <TextBlock DockPanel.Dock="Right"
                                   Text="{Binding RatingText}"
                                   FontWeight="SemiBold"
                                   Style="{StaticResource BodyTextStyle}" />
                    </DockPanel>

                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding DisplayTags}"
                               TextWrapping="Wrap"
                               Style="{StaticResource BodyTextStyle}" />
                    <TextBlock Margin="0,6,0,0"
                               Text="{Binding OverviewText}"
                               TextWrapping="Wrap"
                               MaxHeight="72"
                               Style="{StaticResource BodyMutedTextStyle}" />

                    <WrapPanel Margin="0,10,0,0">
                        <Border Margin="0,0,8,8"
                                Padding="8,4"
                                CornerRadius="999"
                                Background="{DynamicResource BrushSurfaceAlt}">
                            <TextBlock Text="{Binding SeasonCountText}" Style="{StaticResource BodyMutedTextStyle}" />
                        </Border>
                        <Border Margin="0,0,8,8"
                                Padding="8,4"
                                CornerRadius="999"
                                Background="{DynamicResource BrushSurfaceAlt}">
                            <TextBlock Text="{Binding LibraryStatusText}" Style="{StaticResource BodyMutedTextStyle}" />
                        </Border>
                        <Border Margin="0,0,8,8"
                                Padding="8,4"
                                CornerRadius="999"
                                Background="{DynamicResource BrushAccentSoft}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasSeasonStateSummary}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding SeasonStateSummaryText}" Style="{StaticResource BodyMutedTextStyle}" />
                        </Border>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>
    <Border Style="{StaticResource PageCardStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="影片发现" Style="{StaticResource CardTitleTextStyle}" />
                <TextBlock Margin="0,8,0,0"
                           Text="通过 TMDB 搜索影片、电视剧和电影人物作品；AI 推荐继续使用现有推荐流程。"
                           Style="{StaticResource BodyMutedTextStyle}" />
            </StackPanel>

            <TabControl Grid.Row="1"
                        Margin="0,22,0,0"
                        SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}"
                        Style="{StaticResource ModernTabControlStyle}">
                <TabItem Header="影片搜索" Style="{StaticResource ModernTabItemStyle}">
                    <Grid Margin="0,18,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="132" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="媒介" Style="{StaticResource BodyMutedTextStyle}" />
                                    <ComboBox ItemsSource="{Binding SearchMediaTypeOptions}"
                                              SelectedItem="{Binding SelectedSearchMediaType}"
                                              Style="{StaticResource FormComboBoxStyle}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMovieSearchSelected}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="搜索类型" Style="{StaticResource BodyMutedTextStyle}" />
                                    <ComboBox ItemsSource="{Binding SearchTypeOptions}"
                                              SelectedItem="{Binding SelectedSearchType}"
                                              Style="{StaticResource FormComboBoxStyle}" />
                                </StackPanel>

                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="关键词" Style="{StaticResource BodyMutedTextStyle}" />
                                    <TextBox MinWidth="320"
                                             ToolTip="输入影片名、剧名或原名；电影模式支持人物名"
                                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource FormTextBoxStyle}">
                                        <TextBox.InputBindings>
                                            <KeyBinding Key="Enter" Command="{Binding SearchCommand}" />
                                        </TextBox.InputBindings>
                                    </TextBox>
                                </StackPanel>

                                <Button Grid.Column="6"
                                        MinWidth="96"
                                        VerticalAlignment="Bottom"
                                        Content="搜索"
                                        Command="{Binding SearchCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}" />
                            </Grid>

                            <WrapPanel Margin="0,14,0,0">
                                <WrapPanel.Style>
                                    <Style TargetType="WrapPanel">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMovieSearchSelected}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </WrapPanel.Style>
                                <StackPanel Width="132" Margin="0,0,12,12">
                                    <TextBlock Text="类型" Style="{StaticResource BodyMutedTextStyle}" />
                                    <ComboBox ItemsSource="{Binding GenreFilterOptions}"
                                              SelectedItem="{Binding SelectedGenreFilter}"
                                              Style="{StaticResource FormComboBoxStyle}" />
                                </StackPanel>

                                <StackPanel Width="132" Margin="0,0,12,12">
                                    <TextBlock Text="地区" Style="{StaticResource BodyMutedTextStyle}" />
                                    <ComboBox ItemsSource="{Binding RegionFilterOptions}"
                                              SelectedItem="{Binding SelectedRegionFilter}"
                                              Style="{StaticResource FormComboBoxStyle}" />
                                </StackPanel>

                                <StackPanel Width="132" Margin="0,0,12,12">
                                    <TextBlock Text="观看状态" Style="{StaticResource BodyMutedTextStyle}" />
                                    <ComboBox ItemsSource="{Binding WatchStatusFilterOptions}"
                                              SelectedItem="{Binding SelectedWatchStatusFilter}"
                                              Style="{StaticResource FormComboBoxStyle}" />
                                </StackPanel>

                                <StackPanel Width="116" Margin="0,0,12,12">
                                    <TextBlock Text="顺序" Style="{StaticResource BodyMutedTextStyle}" />
                                    <ComboBox ItemsSource="{Binding SortDirectionOptions}"
                                              SelectedItem="{Binding SelectedSortDirection}"
                                              Style="{StaticResource FormComboBoxStyle}" />
                                </StackPanel>

                                <StackPanel Width="132" Margin="0,0,12,12">
                                    <TextBlock Text="排序" Style="{StaticResource BodyMutedTextStyle}" />
                                    <ComboBox ItemsSource="{Binding SortOptions}"
                                              SelectedItem="{Binding SelectedSortOption}"
                                              Style="{StaticResource FormComboBoxStyle}" />
                                </StackPanel>

                                <StackPanel Width="116" Margin="0,0,12,12">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="年代" Style="{StaticResource BodyMutedTextStyle}" />
                                    <ComboBox ItemsSource="{Binding DecadeFilterOptions}"
                                              SelectedItem="{Binding SelectedDecadeFilter}"
                                              Style="{StaticResource FormComboBoxStyle}" />
                                </StackPanel>

                                <StackPanel Width="116" Margin="0,0,12,12">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="语言" Style="{StaticResource BodyMutedTextStyle}" />
                                    <ComboBox ItemsSource="{Binding LanguageFilterOptions}"
                                              SelectedItem="{Binding SelectedLanguageFilter}"
                                              Style="{StaticResource FormComboBoxStyle}" />
                                </StackPanel>

                                <Button MinWidth="96"
                                        Margin="0,20,12,12"
                                        Content="清除筛选"
                                        Command="{Binding ClearSearchFiltersCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}" />

                                <Button MinWidth="96"
                                        Margin="0,20,0,12"
                                        Content="切布局"
                                        Command="{Binding ShowLayoutSwitchPlaceholderCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                            </WrapPanel>

                            <WrapPanel Margin="0,14,0,0">
                                <WrapPanel.Style>
                                    <Style TargetType="WrapPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTvSearchSelected}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </WrapPanel.Style>
                                <StackPanel Width="132" Margin="0,0,12,12">
                                    <TextBlock Text="类型" Style="{StaticResource BodyMutedTextStyle}" />
                                    <ComboBox ItemsSource="{Binding TvGenreFilterOptions}"
                                              SelectedItem="{Binding SelectedTvGenreFilter}"
                                              Style="{StaticResource FormComboBoxStyle}" />
                                </StackPanel>

                                <StackPanel Width="132" Margin="0,0,12,12">
                                    <TextBlock Text="地区" Style="{StaticResource BodyMutedTextStyle}" />
                                    <ComboBox ItemsSource="{Binding RegionFilterOptions}"
                                              SelectedItem="{Binding SelectedTvRegionFilter}"
                                              Style="{StaticResource FormComboBoxStyle}" />
                                </StackPanel>

                                <StackPanel Width="150" Margin="0,0,12,12">
                                    <TextBlock Text="入库状态" Style="{StaticResource BodyMutedTextStyle}" />
                                    <ComboBox ItemsSource="{Binding TvWatchStatusFilterOptions}"
                                              SelectedItem="{Binding SelectedTvWatchStatusFilter}"
                                              Style="{StaticResource FormComboBoxStyle}" />
                                </StackPanel>

                                <StackPanel Width="116" Margin="0,0,12,12">
                                    <TextBlock Text="顺序" Style="{StaticResource BodyMutedTextStyle}" />
                                    <ComboBox ItemsSource="{Binding SortDirectionOptions}"
                                              SelectedItem="{Binding SelectedTvSortDirection}"
                                              Style="{StaticResource FormComboBoxStyle}" />
                                </StackPanel>

                                <StackPanel Width="132" Margin="0,0,12,12">
                                    <TextBlock Text="排序" Style="{StaticResource BodyMutedTextStyle}" />
                                    <ComboBox ItemsSource="{Binding TvSortOptions}"
                                              SelectedItem="{Binding SelectedTvSortOption}"
                                              Style="{StaticResource FormComboBoxStyle}" />
                                </StackPanel>

                                <StackPanel Width="116" Margin="0,0,12,12">
                                    <TextBlock Text="年代" Style="{StaticResource BodyMutedTextStyle}" />
                                    <ComboBox ItemsSource="{Binding DecadeFilterOptions}"
                                              SelectedItem="{Binding SelectedTvDecadeFilter}"
                                              Style="{StaticResource FormComboBoxStyle}" />
                                </StackPanel>

                                <StackPanel Width="116" Margin="0,0,12,12">
                                    <TextBlock Text="语言" Style="{StaticResource BodyMutedTextStyle}" />
                                    <ComboBox ItemsSource="{Binding LanguageFilterOptions}"
                                              SelectedItem="{Binding SelectedTvLanguageFilter}"
                                              Style="{StaticResource FormComboBoxStyle}" />
                                </StackPanel>

                                <Button MinWidth="96"
                                        Margin="0,20,12,12"
                                        Content="清除筛选"
                                        Command="{Binding ClearSearchFiltersCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                            </WrapPanel>
                        </StackPanel>

                        <Border Grid.Row="2" Style="{StaticResource CompactCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <DockPanel>
                                    <StackPanel>
                                        <TextBlock Text="{Binding ActiveSearchStatusMessage}"
                                                   TextWrapping="Wrap"
                                                   Style="{StaticResource BodyMutedTextStyle}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Text="{Binding ActiveSearchSummaryText}"
                                                   TextWrapping="Wrap"
                                                   Style="{StaticResource BodyTextStyle}" />
                                    </StackPanel>
                                </DockPanel>

                                <Grid Grid.Row="1" Margin="0,16,0,0">
                                    <TextBlock HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Panel.ZIndex="1"
                                               Text="{Binding ActiveSearchStatusOverlayText}"
                                               TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ShowActiveSearchStatusOverlay}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ScrollViewer.Style>
                                            <Style TargetType="ScrollViewer">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasSearchMovies}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                <DataTrigger Binding="{Binding IsSearchLoading}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsMovieSearchSelected}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ScrollViewer.Style>
                                        <StackPanel>
                                            <ItemsControl ItemsSource="{Binding SearchMovies}">
                                                <ItemsControl.Style>
                                                    <Style TargetType="ItemsControl">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasSearchMovies}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ItemsControl.Style>
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Width="232"
                                                                Margin="0,0,18,18"
                                                                Style="{StaticResource CompactCardStyle}">
                                                            <Border.InputBindings>
                                                                <MouseBinding MouseAction="LeftClick"
                                                                              Command="{Binding DataContext.OpenSearchMovieCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                              CommandParameter="{Binding}" />
                                                            </Border.InputBindings>
                                                            <StackPanel>
                                                                <Grid Height="300">
                                                                    <Border CornerRadius="18" Background="{DynamicResource BrushSurfaceAlt}">
                                                                        <Grid>
                                                                            <TextBlock HorizontalAlignment="Center"
                                                                                       VerticalAlignment="Center"
                                                                                       Text="无海报"
                                                                                       Style="{StaticResource BodyMutedTextStyle}" />
                                                                            <Image helpers:PosterCacheImageBehavior.Source="{Binding PosterRemoteUrl}" Stretch="UniformToFill" />
                                                                        </Grid>
                                                                    </Border>

                                                                    <Border HorizontalAlignment="Left"
                                                                            VerticalAlignment="Top"
                                                                            Margin="10"
                                                                            Padding="9,5"
                                                                            CornerRadius="999"
                                                                            Background="{DynamicResource BrushAccent}">
                                                                        <TextBlock Text="{Binding AvailabilityText}"
                                                                                   Foreground="{DynamicResource BrushOnAccent}"
                                                                                   FontWeight="SemiBold" />
                                                                    </Border>

                                                                    <Button HorizontalAlignment="Right"
                                                                            VerticalAlignment="Top"
                                                                            Margin="10"
                                                                            Content="{Binding WantToWatchButtonText}"
                                                                            Command="{Binding DataContext.ToggleSearchWantToWatchCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                            CommandParameter="{Binding}">
                                                                        <Button.Style>
                                                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding CanToggleWantToWatch}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Button.Style>
                                                                    </Button>
                                                                </Grid>

                                                                <TextBlock Margin="0,14,0,0"
                                                                           Text="{Binding Title}"
                                                                           TextWrapping="Wrap"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           Style="{StaticResource SectionTitleTextStyle}" />
                                                                <TextBlock Margin="0,4,0,0"
                                                                           Text="{Binding OriginalTitleText}"
                                                                           TextWrapping="Wrap">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding OriginalTitleText}" Value="">
                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>

                                                                <DockPanel Margin="0,8,0,0">
                                                                    <TextBlock Text="{Binding YearText}" Style="{StaticResource BodyMutedTextStyle}" />
                                                                    <TextBlock DockPanel.Dock="Right"
                                                                               Text="{Binding RatingText}"
                                                                               FontWeight="SemiBold"
                                                                               Style="{StaticResource BodyTextStyle}" />
                                                                </DockPanel>

                                                                <TextBlock Margin="0,8,0,0"
                                                                           Text="{Binding DisplayTags}"
                                                                           TextWrapping="Wrap"
                                                                           Style="{StaticResource BodyTextStyle}" />
                                                                <TextBlock Margin="0,6,0,0"
                                                                           Text="{Binding EmotionTagsText}"
                                                                           TextWrapping="Wrap">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding EmotionTagsText}" Value="">
                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>

                                                                <WrapPanel Margin="0,10,0,0">
                                                                    <Border Margin="0,0,8,8"
                                                                            Padding="8,4"
                                                                            CornerRadius="999"
                                                                            Background="{DynamicResource BrushSurfaceAlt}">
                                                                        <TextBlock Text="{Binding WatchStateText}" Style="{StaticResource BodyMutedTextStyle}" />
                                                                    </Border>
                                                                    <Border Margin="0,0,8,8"
                                                                            Padding="8,4"
                                                                            CornerRadius="999"
                                                                            Background="{DynamicResource BrushAccentSoft}">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsWantToWatch}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <TextBlock Text="想看" Style="{StaticResource BodyMutedTextStyle}" />
                                                                    </Border>
                                                                    <Border Margin="0,0,8,8"
                                                                            Padding="8,4"
                                                                            CornerRadius="999"
                                                                            Background="{DynamicResource BrushSurfaceAlt}">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <TextBlock Text="喜爱" Style="{StaticResource BodyMutedTextStyle}" />
                                                                    </Border>
                                                                    <Border Margin="0,0,8,8"
                                                                            Padding="8,4"
                                                                            CornerRadius="999"
                                                                            Background="{DynamicResource BrushSurfaceAlt}">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsNotInterested}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <TextBlock Text="不想看" Style="{StaticResource BodyMutedTextStyle}" />
                                                                    </Border>
                                                                </WrapPanel>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <StackPanel Margin="0,4,0,0"
                                                        HorizontalAlignment="Center"
                                                        Orientation="Horizontal">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasSearchMovies}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <Button MinWidth="88"
                                                        Content="上一页"
                                                        Command="{Binding GoPreviousSearchPageCommand}"
                                                        Style="{StaticResource SecondaryButtonStyle}" />
                                                <TextBlock Margin="14,0"
                                                           VerticalAlignment="Center"
                                                           Text="{Binding SearchPageStatusText}"
                                                           Style="{StaticResource BodyTextStyle}" />
                                                <Button MinWidth="88"
                                                        Content="下一页"
                                                        Command="{Binding GoNextSearchPageCommand}"
                                                        Style="{StaticResource SecondaryButtonStyle}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </ScrollViewer>

                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ScrollViewer.Style>
                                            <Style TargetType="ScrollViewer">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsTvSearchSelected}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding HasSearchTvSeries}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
