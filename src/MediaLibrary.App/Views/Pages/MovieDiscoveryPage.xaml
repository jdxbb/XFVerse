                                                                           Style="{StaticResource BodyMutedTextStyle}" />
                                                                <ScrollViewer Margin="0,8,0,0" Height="70" VerticalScrollBarVisibility="Auto">
                                                                    <TextBlock Text="{Binding OverviewText}"
                                                                               TextWrapping="Wrap"
                                                                               Style="{StaticResource BodyMutedTextStyle}" />
                                                                </ScrollViewer>
                                                            </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </ScrollViewer>
                                <StackPanel Grid.Row="1"
                                            Margin="0,4,0,0"
                                            HorizontalAlignment="Center"
                                            Orientation="Horizontal">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasRankingMovies}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsMovieRankingSelected}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <Button Command="{Binding GoPreviousRankingPageCommand}"
                                            IsEnabled="{Binding CanGoPreviousRankingPage}"
                                            Style="{StaticResource DiscoveryPagerIconButtonStyle}"
                                            ToolTip="上一页">
                                        <Viewbox Width="16" Height="16">
                                            <Canvas Width="24" Height="24">
                                                <Path Data="M 15 5 L 8 12 L 15 19"
                                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                      StrokeThickness="2.2"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round" />
                                            </Canvas>
                                        </Viewbox>
                                    </Button>
                                    <TextBlock Margin="14,0"
                                               VerticalAlignment="Center"
                                               Text="{Binding RankingPageStatusText}"
                                               Style="{StaticResource BodyTextStyle}" />
                                    <Button Command="{Binding GoNextRankingPageCommand}"
                                            IsEnabled="{Binding CanGoNextRankingPage}"
                                            Style="{StaticResource DiscoveryPagerIconButtonStyle}"
                                            ToolTip="下一页">
                                        <Viewbox Width="16" Height="16">
                                            <Canvas Width="24" Height="24">
                                                <Path Data="M 9 5 L 16 12 L 9 19"
                                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                      StrokeThickness="2.2"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round" />
                                            </Canvas>
                                        </Viewbox>
                                    </Button>
                                </StackPanel>
                                <StackPanel Grid.Row="1"
                                            Margin="0,4,0,0"
                                            HorizontalAlignment="Center"
                                            Orientation="Horizontal">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasRankingTvSeries}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsTvRankingSelected}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <Button Command="{Binding GoPreviousRankingPageCommand}"
                                            IsEnabled="{Binding CanGoPreviousTvRankingPage}"
                                            Style="{StaticResource DiscoveryPagerIconButtonStyle}"
                                            ToolTip="上一页">
                                        <Viewbox Width="16" Height="16">
                                            <Canvas Width="24" Height="24">
                                                <Path Data="M 15 5 L 8 12 L 15 19"
                                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                      StrokeThickness="2.2"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round" />
                                            </Canvas>
                                        </Viewbox>
                                    </Button>
                                    <TextBlock Margin="14,0"
                                               VerticalAlignment="Center"
                                               Text="{Binding TvRankingPageStatusText}"
                                               Style="{StaticResource BodyTextStyle}" />
                                    <Button Command="{Binding GoNextRankingPageCommand}"
                                            IsEnabled="{Binding CanGoNextTvRankingPage}"
                                            Style="{StaticResource DiscoveryPagerIconButtonStyle}"
                                            ToolTip="下一页">
                                        <Viewbox Width="16" Height="16">
                                            <Canvas Width="24" Height="24">
                                                <Path Data="M 9 5 L 16 12 L 9 19"
                                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                      StrokeThickness="2.2"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round" />
                                            </Canvas>
                                        </Viewbox>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>
                <TabItem Header="AI推荐" Style="{StaticResource DiscoveryTabItemStyle}">
                    <ContentControl
                                    Content="{Binding AiRecommendationViewModel}" />
                </TabItem>
        </TabControl>
    </Grid>
</UserControl>
