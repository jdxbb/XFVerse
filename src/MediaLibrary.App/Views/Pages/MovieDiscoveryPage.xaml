                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding HasWantToWatchSeasonTag}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
