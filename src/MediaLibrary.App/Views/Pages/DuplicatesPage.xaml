<UserControl x:Class="MediaLibrary.App.Views.Pages.DuplicatesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource PageCardStyle}">
        <StackPanel>
            <TextBlock Text="重复资源" Style="{StaticResource CardTitleTextStyle}" />
            <TextBlock Margin="0,10,0,0"
                       Text="当前版本已经支持同一影片多个播放源和默认源管理。高级重复合并建议保留为后续扩展，不影响第三轮答辩主线。"
                       TextWrapping="Wrap"
                       Style="{StaticResource BodyTextStyle}" />
        </StackPanel>
    </Border>
</UserControl>
