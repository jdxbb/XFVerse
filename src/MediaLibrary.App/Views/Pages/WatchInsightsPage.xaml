<UserControl x:Class="MediaLibrary.App.Views.Pages.WatchInsightsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="InsightTabButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="MinWidth" Value="116" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>

        <Style x:Key="InsightCardHeaderStyle" TargetType="TextBlock" BasedOn="{StaticResource CardTitleTextStyle}">
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="InsightChipBorderStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Background" Value="{DynamicResource BrushAccentSoft}" />
        </Style>

        <Style x:Key="InsightEmptyBorderStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,14,0,0" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Background" Value="{DynamicResource BrushSurfaceAlt}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="CalendarDayButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="46" />
            <Setter Property="Margin" Value="3" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="Background" Value="{DynamicResource BrushSurfaceAlt}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="DayBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="DayBorder" Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPlaceholder}" Value="True">
                    <Setter Property="Visibility" Value="Hidden" />
                    <Setter Property="IsEnabled" Value="False" />
                </DataTrigger>
                <DataTrigger Binding="{Binding HeatLevel}" Value="1">
                    <Setter Property="Background" Value="#F6E2E7" />
                </DataTrigger>
                <DataTrigger Binding="{Binding HeatLevel}" Value="2">
                    <Setter Property="Background" Value="#F0BEC9" />
                </DataTrigger>
                <DataTrigger Binding="{Binding HeatLevel}" Value="3">
                    <Setter Property="Background" Value="#DD879B" />
                </DataTrigger>
                <DataTrigger Binding="{Binding HeatLevel}" Value="4">
                    <Setter Property="Background" Value="#B94D67" />
                    <Setter Property="Foreground" Value="White" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BubbleBorderStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,12,12" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Background" Value="{DynamicResource BrushAccentSoft}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Kind}" Value="场景">
                    <Setter Property="Background" Value="{DynamicResource BrushSurfaceAlt}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="ChipTemplate">
            <Border Style="{StaticResource InsightChipBorderStyle}">
                <TextBlock Text="{Binding Label}" Style="{StaticResource BodyTextStyle}" />
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal">
                <Button Content="画像分析"
                        Command="{Binding SelectProfileTabCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource InsightTabButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsProfileTabSelected}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource BrushAccent}" />
                                    <Setter Property="Foreground" Value="{DynamicResource BrushOnAccent}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="观影统计"
                        Command="{Binding SelectStatisticsTabCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource InsightTabButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStatisticsTabSelected}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource BrushAccent}" />
                                    <Setter Property="Foreground" Value="{DynamicResource BrushOnAccent}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

        </Grid>

        <StackPanel Grid.Row="1" Margin="0,14,0,0">
            <Border Padding="12"
                    CornerRadius="12"
                    Background="{DynamicResource BrushSurfaceAlt}"
                    BorderBrush="{DynamicResource BrushBorder}"
                    BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasStatisticsError}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding StatisticsErrorMessage}" TextWrapping="Wrap" Style="{StaticResource BodyTextStyle}" />
            </Border>

            <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding WarningMessages}">
                <ItemsControl.Style>
                    <Style TargetType="ItemsControl">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasWarningMessages}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ItemsControl.Style>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,8,8" Padding="10,5" CornerRadius="999" Background="{DynamicResource BrushSurfaceAlt}">
                            <TextBlock Text="{Binding Text}" Style="{StaticResource BodyMutedTextStyle}" />
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <Grid Grid.Row="2" Margin="0,16,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsProfileTabSelected}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <StackPanel>
                    <Border Style="{StaticResource PageCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="观影画像概览" Style="{StaticResource InsightCardHeaderStyle}" />
                                <Border Margin="0,12,0,0"
                                        Padding="16"
                                        CornerRadius="14"
                                        Background="{DynamicResource BrushAccentSoft}"
                                        BorderBrush="{DynamicResource BrushBorder}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding ProfileHeroTitle}"
                                                   TextWrapping="Wrap"
                                                   Style="{StaticResource SectionTitleTextStyle}" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="{Binding ProfileHeroSubtitle}"
                                                   TextWrapping="Wrap"
                                                   Style="{StaticResource BodyTextStyle}" />
                                    </StackPanel>
                                </Border>
                                <TextBlock Margin="0,8,0,0"
                                           Text="基于已看、喜爱、想看、不想看和观影历史生成；不包含自定义推荐偏好，也不会影响推荐结果。"
                                           TextWrapping="Wrap"
                                           Style="{StaticResource BodyMutedTextStyle}" />
                                <WrapPanel Margin="0,14,0,0">
                                    <Border Style="{StaticResource InsightChipBorderStyle}">
                                        <TextBlock Text="{Binding ProfileStatusText}" Style="{StaticResource BodyTextStyle}" />
                                    </Border>
                                    <Border Style="{StaticResource InsightChipBorderStyle}">
                                        <TextBlock Text="{Binding LastProfileRefreshedAtText}" Style="{StaticResource BodyTextStyle}" />
                                    </Border>
                                    <Border Style="{StaticResource InsightChipBorderStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="样本 " Style="{StaticResource BodyTextStyle}" />
                                            <TextBlock Text="{Binding Profile.Meta.SignalMovieCount}" Style="{StaticResource BodyTextStyle}" />
                                        </StackPanel>
                                    </Border>
                                </WrapPanel>
                                <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding ProfileWarnings}">
                                    <ItemsControl.Style>
                                        <Style TargetType="ItemsControl">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasProfileWarnings}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ItemsControl.Style>
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,8,6" Padding="10,5" CornerRadius="999" Background="{DynamicResource BrushSurfaceAlt}">
                                                <TextBlock Text="{Binding Text}" TextWrapping="Wrap" Style="{StaticResource BodyMutedTextStyle}" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Width="120"
                                    VerticalAlignment="Top"
                                    Content="{Binding ProfileRefreshButtonText}"
                                    Command="{Binding RefreshProfileCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                        </Grid>
                    </Border>

                    <Border>
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource InsightEmptyBorderStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowProfileEmptyState}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock Text="{Binding ProfileStatusText}" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="{Binding ProfileInsufficientReason}"
                                       TextWrapping="Wrap"
                                       Style="{StaticResource BodyMutedTextStyle}" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="{Binding ProfileErrorMessage}"
                                       TextWrapping="Wrap"
                                       Style="{StaticResource BodyMutedTextStyle}" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="继续观看、标记喜爱/想看/不想看，或稍后手动刷新画像。"
                                       TextWrapping="Wrap"
                                       Style="{StaticResource BodyMutedTextStyle}" />
                        </StackPanel>
                    </Border>

                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasProfile}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <Border Margin="0,18,0,0" Style="{StaticResource PageCardStyle}">
                            <StackPanel>
                                <TextBlock Text="口味总结" Style="{StaticResource InsightCardHeaderStyle}" />
                                <TextBlock Margin="0,12,0,0"
                                           Text="{Binding ProfileSummaryText}"
                                           TextWrapping="Wrap"
                                           Style="{StaticResource BodyTextStyle}" />
                                <ItemsControl Margin="0,14,0,0" ItemsSource="{Binding ProfileKeywords}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource InsightChipBorderStyle}">
                                                <TextBlock Text="{Binding Label}" Style="{StaticResource BodyTextStyle}" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Margin="0,18,0,0" Style="{StaticResource PageCardStyle}">
                            <StackPanel>
                                <TextBlock Text="观影人格" Style="{StaticResource InsightCardHeaderStyle}" />
                                <Grid Margin="0,14,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="210" />
                                        <ColumnDefinition Width="18" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Width="210"
                                            Height="280"
                                            CornerRadius="10"
                                            ClipToBounds="True"
                                            Background="{DynamicResource BrushAccentSoft}">
                                        <Grid>
                                            <Image Source="{Binding PersonaPosterImageUri}"
                                                   Stretch="UniformToFill">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasPersonaPoster}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                            <Image Source="{Binding PersonaPosterFrameUri}"
                                                   Stretch="Fill"
                                                   IsHitTestVisible="False">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasPersonaPosterFrame}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                            <TextBlock HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Text="人格海报待接入">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasPersonaPoster}" Value="False">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <Border Padding="14" CornerRadius="12" Background="{DynamicResource BrushAccentSoft}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding ProfilePersonaType}" Style="{StaticResource SectionTitleTextStyle}" />
                                                <TextBlock Margin="0,6,0,0" Text="{Binding ProfilePersonaTitle}" Style="{StaticResource BodyTextStyle}" />
                                            </StackPanel>
                                        </Border>
                                        <TextBlock Margin="0,14,0,0"
                                                   Text="{Binding ProfilePersonaDescription}"
                                                   TextWrapping="Wrap"
                                                   Style="{StaticResource BodyMutedTextStyle}" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Margin="0,18,0,0" Style="{StaticResource PageCardStyle}">
                            <StackPanel>
                                <TextBlock Text="观影 DNA" Style="{StaticResource InsightCardHeaderStyle}" />
                                <TextBlock Margin="0,8,0,0"
                                           Text="六个维度一起解释你的口味，不是单独打分。"
                                           TextWrapping="Wrap"
                                           Style="{StaticResource BodyMutedTextStyle}" />
                                <ItemsControl Margin="0,16,0,0" ItemsSource="{Binding ProfileDnaItems}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="3" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,14,14" Style="{StaticResource CompactCardStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Gene}" Style="{StaticResource SectionTitleTextStyle}" />
                                                    <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding Tags}" ItemTemplate="{StaticResource ChipTemplate}">
                                                        <ItemsControl.Style>
                                                            <Style TargetType="ItemsControl">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasTags}" Value="False">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ItemsControl.Style>
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <WrapPanel />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                    </ItemsControl>
                                                    <Grid Margin="0,10,0,0">
                                                        <Grid.Style>
                                                            <Style TargetType="Grid">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsProgressGene}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Grid.Style>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <ProgressBar Height="8" Maximum="100" Value="{Binding Score, Mode=OneWay}" />
                                                        <Grid Grid.Row="1" Margin="0,6,0,0">
                                                            <TextBlock Text="{Binding LeftLabel}" Style="{StaticResource BodyMutedTextStyle}" />
                                                            <TextBlock HorizontalAlignment="Right" Text="{Binding RightLabel}" Style="{StaticResource BodyMutedTextStyle}" />
                                                        </Grid>
                                                    </Grid>
                                                    <TextBlock Margin="0,10,0,0" Text="{Binding Description}" TextWrapping="Wrap" Style="{StaticResource BodyMutedTextStyle}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Margin="0,18,0,0" Style="{StaticResource PageCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.4*" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="口味定位图" Style="{StaticResource InsightCardHeaderStyle}" />
                                    <TextBlock Margin="0,8,0,0" Text="定位只表达倾向，不是精确分数。" TextWrapping="Wrap" Style="{StaticResource BodyMutedTextStyle}" />
                                    <Canvas Margin="0,18,0,0" Width="400" Height="260" Background="{DynamicResource BrushSurfaceAlt}">
                                        <Border Canvas.Left="20" Canvas.Top="20" Width="170" Height="95" Padding="10" Background="{DynamicResource BrushSurface}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" CornerRadius="12">
                                            <TextBlock Text="熟悉安全 × 情绪沉浸" TextWrapping="Wrap" Style="{StaticResource BodyMutedTextStyle}" />
                                        </Border>
                                        <Border Canvas.Left="210" Canvas.Top="20" Width="170" Height="95" Padding="10" Background="{DynamicResource BrushAccentSoft}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" CornerRadius="12">
                                            <TextBlock Text="新鲜探索 × 情绪沉浸" TextWrapping="Wrap" Style="{StaticResource BodyMutedTextStyle}" />
                                        </Border>
                                        <Border Canvas.Left="20" Canvas.Top="135" Width="170" Height="95" Padding="10" Background="{DynamicResource BrushSurface}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" CornerRadius="12">
                                            <TextBlock Text="熟悉安全 × 轻松消遣" TextWrapping="Wrap" Style="{StaticResource BodyMutedTextStyle}" />
                                        </Border>
                                        <Border Canvas.Left="210" Canvas.Top="135" Width="170" Height="95" Padding="10" Background="{DynamicResource BrushSurface}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" CornerRadius="12">
                                            <TextBlock Text="新鲜探索 × 轻松消遣" TextWrapping="Wrap" Style="{StaticResource BodyMutedTextStyle}" />
                                        </Border>
                                        <Line X1="200" Y1="18" X2="200" Y2="232" Stroke="#66B94D67" StrokeThickness="1" />
                                        <Line X1="18" Y1="125" X2="382" Y2="125" Stroke="#66B94D67" StrokeThickness="1" />
                                        <Border Canvas.Left="{Binding ProfileQuadrantPointX}"
                                                Canvas.Top="{Binding ProfileQuadrantPointY}"
                                                Padding="8,4"
                                                CornerRadius="999"
                                                Background="{DynamicResource BrushAccent}"
                                                BorderBrush="{DynamicResource BrushOnAccent}"
                                                BorderThickness="2">
                                            <TextBlock Text="你在这里" Foreground="{DynamicResource BrushOnAccent}" Style="{StaticResource BodyTextStyle}" />
                                        </Border>
                                    </Canvas>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="当前定位" Style="{StaticResource BodyMutedTextStyle}" />
                                    <TextBlock Margin="0,6,0,0" Text="{Binding ProfileQuadrantName}" Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Margin="0,10,0,0" Text="{Binding ProfileQuadrantDescription}" TextWrapping="Wrap" Style="{StaticResource BodyMutedTextStyle}" />
                                    <Border Margin="0,14,0,0" Padding="10" CornerRadius="12" Background="{DynamicResource BrushSurfaceAlt}">
                                        <StackPanel>
                                            <TextBlock Text="横向：熟悉安全 ↔ 新鲜探索" Style="{StaticResource BodyTextStyle}" />
                                            <TextBlock Margin="0,6,0,0" Text="纵向：轻松消遣 ↔ 情绪沉浸" Style="{StaticResource BodyTextStyle}" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Margin="0,18,0,0" Style="{StaticResource PageCardStyle}">
                            <StackPanel>
                                <TextBlock Text="看得多 vs 真喜欢" Style="{StaticResource InsightCardHeaderStyle}" />
                                <TextBlock Margin="0,8,0,0" Text="{Binding ProfileWatchVsLikeConclusion}" TextWrapping="Wrap" Style="{StaticResource BodyMutedTextStyle}" />
                                <ItemsControl Margin="0,16,0,0" ItemsSource="{Binding ProfileWatchLikeGroups}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="3" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,14,0" Style="{StaticResource CompactCardStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}" Style="{StaticResource SectionTitleTextStyle}" />
                                                    <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding Items}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                                    <Border Width="22" Height="22" CornerRadius="999" Background="{DynamicResource BrushAccentSoft}">
                                                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="{Binding Rank}" Style="{StaticResource BodyTextStyle}" />
                                                                    </Border>
                                                                    <TextBlock Margin="8,0,0,0" Text="{Binding Label}" Style="{StaticResource BodyTextStyle}" />
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                    </StackPanel>

                    <ItemsControl Visibility="Collapsed" ItemsSource="{Binding ProfileEmptyCards}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="360" MinHeight="150" Margin="0,0,16,16" Style="{StaticResource PageCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" Style="{StaticResource InsightCardHeaderStyle}" />
                                        <Border Margin="0,14,0,0" Padding="10,5" CornerRadius="999" Background="{DynamicResource BrushAccentSoft}" HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding State}" Style="{StaticResource BodyTextStyle}" />
                                        </Border>
                                        <TextBlock Margin="0,14,0,0"
                                                   Text="{Binding Description}"
                                                   TextWrapping="Wrap"
                                                   Style="{StaticResource BodyMutedTextStyle}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Visibility="Collapsed" Style="{StaticResource PageCardStyle}">
                        <StackPanel>
                            <TextBlock Text="看得多 vs 真喜欢" Style="{StaticResource InsightCardHeaderStyle}" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="这部分使用本地统计 Top3，不调用 AI。"
                                       Style="{StaticResource BodyMutedTextStyle}" />
                            <Grid Margin="0,16,0,0">
                                <ItemsControl ItemsSource="{Binding WatchLikeGroups}">
                                    <ItemsControl.Style>
                                        <Style TargetType="ItemsControl">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasWatchLikeData}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ItemsControl.Style>
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="3" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,14,0" Style="{StaticResource CompactCardStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}" Style="{StaticResource SectionTitleTextStyle}" />
                                                    <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding Items}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid Margin="0,0,0,10">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="28" />
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="58" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <Border Width="22" Height="22" CornerRadius="999" Background="{DynamicResource BrushAccentSoft}">
                                                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="{Binding Rank}" Style="{StaticResource BodyTextStyle}" />
                                                                    </Border>
                                                                    <StackPanel Grid.Column="1" Margin="8,0">
                                                                        <TextBlock Text="{Binding Label}" TextTrimming="CharacterEllipsis" Style="{StaticResource BodyTextStyle}" />
                                                                        <ProgressBar Margin="0,6,0,0" Height="6" Maximum="100" Value="{Binding ProgressValue, Mode=OneWay}" />
                                                                    </StackPanel>
                                                                    <TextBlock Grid.Column="2" Text="{Binding DetailText}" HorizontalAlignment="Right" Style="{StaticResource BodyMutedTextStyle}" />
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Border>
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource InsightEmptyBorderStyle}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasWatchLikeData}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="暂无足够数据" Style="{StaticResource SectionTitleTextStyle}" />
                                        <TextBlock Margin="0,8,0,0" Text="继续观看、标记喜爱或加入想看后，这里会展示真实 Top3。" TextWrapping="Wrap" Style="{StaticResource BodyMutedTextStyle}" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsStatisticsTabSelected}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <StackPanel>
                    <Border Style="{StaticResource PageCardStyle}">
                        <StackPanel>
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock Text="{Binding OverviewTitle}" Style="{StaticResource InsightCardHeaderStyle}" />
                                    <TextBlock Margin="0,8,0,0" Text="{Binding OverviewSubtitle}" Style="{StaticResource BodyMutedTextStyle}" />
                                </StackPanel>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                                    <Button MinWidth="64"
                                            Margin="0,0,8,0"
                                            Content="本月"
                                            Command="{Binding SelectMonthRangeCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMonthRangeSelected}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource BrushAccent}" />
                                                        <Setter Property="Foreground" Value="{DynamicResource BrushOnAccent}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button MinWidth="64"
                                            Margin="0,0,12,0"
                                            Content="全部"
                                            Command="{Binding SelectAllRangeCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAllRangeSelected}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource BrushAccent}" />
                                                        <Setter Property="Foreground" Value="{DynamicResource BrushOnAccent}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <TextBlock Margin="0,0,12,0"
                                               VerticalAlignment="Center"
                                               Text="{Binding LastStatisticsRefreshedAtText}"
                                               Style="{StaticResource BodyMutedTextStyle}" />
                                    <Button MinWidth="110"
                                            Content="{Binding RefreshButtonText}"
                                            Command="{Binding RefreshStatisticsCommand}"
                                            Style="{StaticResource PrimaryButtonStyle}" />
                                </StackPanel>
                            </DockPanel>
                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource InsightEmptyBorderStyle}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasAnyStatisticsData}" Value="False">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="暂无可统计的已识别影片，状态数量会在识别或标记后显示。" TextWrapping="Wrap" Style="{StaticResource BodyMutedTextStyle}" />
                            </Border>

                            <ItemsControl Margin="0,16,0,0" ItemsSource="{Binding OverviewCards}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="4" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,10,0" Style="{StaticResource CompactCardStyle}">
                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="34" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="28" Height="28" CornerRadius="8" Background="{DynamicResource BrushAccentSoft}">
                                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="{Binding IconText}" Style="{StaticResource BodyTextStyle}" />
                                                    </Border>
                                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding Title}" Style="{StaticResource BodyMutedTextStyle}" />
                                                </Grid>
                                                <StackPanel Margin="0,12,0,0" Orientation="Horizontal" VerticalAlignment="Bottom">
                                                    <TextBlock Text="{Binding ValueText}" Style="{StaticResource MetricTextStyle}" />
                                                    <TextBlock Margin="6,12,0,0" Text="{Binding UnitText}" Style="{StaticResource BodyMutedTextStyle}" />
                                                </StackPanel>
                                                <TextBlock Margin="0,8,0,0" Text="{Binding DeltaText}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasDelta}" Value="False">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <UniformGrid Margin="0,16,0,0" Columns="3">
                                <Border Margin="0,0,10,0" Style="{StaticResource CompactCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding TotalWatchTimeTitle}" Style="{StaticResource BodyMutedTextStyle}" />
                                        <TextBlock Margin="0,8,0,0" Text="{Binding TotalWatchTimeText}" Style="{StaticResource SectionTitleTextStyle}" />
                                    </StackPanel>
                                </Border>
                                <Border Margin="0,0,10,0" Style="{StaticResource CompactCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding WatchCountTitle}" Style="{StaticResource BodyMutedTextStyle}" />
                                        <TextBlock Margin="0,8,0,0" Text="{Binding MonthlyWatchCountText}" Style="{StaticResource SectionTitleTextStyle}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource CompactCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding FrequentTagsTitle}" Style="{StaticResource BodyMutedTextStyle}" />
                                        <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding MonthlyFrequentTags}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource InsightChipBorderStyle}">
                                                        <TextBlock Text="{Binding Label}" Style="{StaticResource BodyTextStyle}" />
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock Text="暂无当前范围标签数据">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasMonthlyFrequentTags}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,18,0,0" Style="{StaticResource PageCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="300" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Left">
                                        <TextBlock Text="观影日历" Style="{StaticResource InsightCardHeaderStyle}" />
                                        <TextBlock Margin="0,8,0,0" Text="独立按月份查看，不受统计时间范围影响。" Style="{StaticResource BodyMutedTextStyle}" />
                                    </StackPanel>
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="上一月" Command="{Binding PreviousCalendarMonthCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                                        <TextBlock Margin="12,0" VerticalAlignment="Center" Text="{Binding CalendarMonthText}" Style="{StaticResource SectionTitleTextStyle}" />
                                        <Button Content="下一月" Command="{Binding NextCalendarMonthCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                                        <Button Margin="8,0,0,0" Content="回到当前月" Command="{Binding ReturnToCurrentCalendarMonthCommand}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ShowReturnToCurrentMonth}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </DockPanel>

                                <UniformGrid Margin="0,18,0,6" Columns="7">
                                    <TextBlock HorizontalAlignment="Center" Text="一" Style="{StaticResource BodyMutedTextStyle}" />
                                    <TextBlock HorizontalAlignment="Center" Text="二" Style="{StaticResource BodyMutedTextStyle}" />
                                    <TextBlock HorizontalAlignment="Center" Text="三" Style="{StaticResource BodyMutedTextStyle}" />
                                    <TextBlock HorizontalAlignment="Center" Text="四" Style="{StaticResource BodyMutedTextStyle}" />
                                    <TextBlock HorizontalAlignment="Center" Text="五" Style="{StaticResource BodyMutedTextStyle}" />
                                    <TextBlock HorizontalAlignment="Center" Text="六" Style="{StaticResource BodyMutedTextStyle}" />
                                    <TextBlock HorizontalAlignment="Center" Text="日" Style="{StaticResource BodyMutedTextStyle}" />
                                </UniformGrid>

                                <ItemsControl ItemsSource="{Binding CalendarCells}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="7" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.OpenWatchHistoryByDateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    IsEnabled="{Binding IsClickable}"
                                                    Style="{StaticResource CalendarDayButtonStyle}">
                                                <Grid>
                                                    <TextBlock Margin="6,4,0,0" Text="{Binding DayText}" Style="{StaticResource BodyTextStyle}" />
                                                    <TextBlock Margin="0,0,6,4"
                                                               HorizontalAlignment="Right"
                                                               VerticalAlignment="Bottom"
                                                               Text="{Binding WatchCount}"
                                                               Style="{StaticResource BodyMutedTextStyle}" />
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <StackPanel Margin="0,10,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock Margin="0,0,8,0" Text="无" Style="{StaticResource BodyMutedTextStyle}" />
                                    <TextBlock Margin="0,0,8,0" Text="&lt;30分钟" Style="{StaticResource BodyMutedTextStyle}" />
                                    <TextBlock Margin="0,0,8,0" Text="30-60分钟" Style="{StaticResource BodyMutedTextStyle}" />
                                    <TextBlock Margin="0,0,8,0" Text="1-2小时" Style="{StaticResource BodyMutedTextStyle}" />
                                    <TextBlock Text="2小时+" Style="{StaticResource BodyMutedTextStyle}" />
                                </StackPanel>

                                <TextBlock Margin="0,10,0,0" Text="{Binding CalendarNoticeMessage}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasCalendarNotice}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <Border Style="{StaticResource CompactCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding MonthlyWatchDaysTitle}" Style="{StaticResource BodyMutedTextStyle}" />
                                        <TextBlock Margin="0,8,0,0" Text="{Binding MonthlyWatchDaysText}" Style="{StaticResource SectionTitleTextStyle}" />
                                    </StackPanel>
                                </Border>
                                <Border Margin="0,12,0,0" Style="{StaticResource CompactCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding ContinuousWatchDaysTitle}" Style="{StaticResource BodyMutedTextStyle}" />
                                        <TextBlock Margin="0,8,0,0" Text="{Binding ContinuousWatchDaysText}" Style="{StaticResource SectionTitleTextStyle}" />
                                    </StackPanel>
                                </Border>
                                <Border Margin="0,12,0,0" Style="{StaticResource CompactCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding MostActiveDateTitle}" Style="{StaticResource BodyMutedTextStyle}" />
                                        <TextBlock Margin="0,8,0,0" Text="{Binding MostActiveDateText}" Style="{StaticResource SectionTitleTextStyle}" />
                                        <TextBlock Margin="0,4,0,0" Text="{Binding MostActiveDateWatchText}" Style="{StaticResource BodyMutedTextStyle}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource PageCardStyle}">
                            <StackPanel>
                                <TextBlock Text="{Binding PreferenceGraphTitle}" Style="{StaticResource InsightCardHeaderStyle}" />
                                <TextBlock Margin="0,8,0,0" Text="当前范围内看过影片的情绪 / 场景标签。" Style="{StaticResource BodyMutedTextStyle}" />
                                <ItemsControl Margin="0,16,0,0" ItemsSource="{Binding PreferenceBubbles}">
                                    <ItemsControl.Style>
                                        <Style TargetType="ItemsControl">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasPreferenceBubbles}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ItemsControl.Style>
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="{Binding Size}" Height="{Binding Size}" Style="{StaticResource BubbleBorderStyle}">
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock HorizontalAlignment="Center" Text="{Binding Label}" TextWrapping="Wrap" Style="{StaticResource BodyTextStyle}" />
                                                    <TextBlock HorizontalAlignment="Center" Text="{Binding Kind}" Style="{StaticResource BodyMutedTextStyle}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Border>
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource InsightEmptyBorderStyle}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasPreferenceBubbles}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="暂无情绪或场景标签数据。" Style="{StaticResource BodyMutedTextStyle}" />
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource PageCardStyle}">
                            <StackPanel>
                                <TextBlock Text="{Binding TagRankingTitle}" Style="{StaticResource InsightCardHeaderStyle}" />
                                <ItemsControl Margin="0,16,0,0" ItemsSource="{Binding MonthlyRankingGroups}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,12" Style="{StaticResource CompactCardStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}" Style="{StaticResource SectionTitleTextStyle}" />
                                                    <Border>
                                                        <Border.Style>
                                                            <Style TargetType="Border" BasedOn="{StaticResource InsightEmptyBorderStyle}">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Setter Property="Margin" Value="0,10,0,0" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasItems}" Value="False">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="暂无当前范围标签数据。" Style="{StaticResource BodyMutedTextStyle}" />
                                                    </Border>
                                                    <ItemsControl Margin="0,10,0,0" ItemsSource="{Binding Items}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid Margin="0,0,0,10">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="30" />
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="58" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <Border Width="24" Height="24" CornerRadius="999" Background="{DynamicResource BrushAccentSoft}">
                                                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="{Binding Rank}" Style="{StaticResource BodyTextStyle}" />
                                                                    </Border>
                                                                    <StackPanel Grid.Column="1" Margin="8,0">
                                                                        <TextBlock Text="{Binding Label}" TextTrimming="CharacterEllipsis" Style="{StaticResource BodyTextStyle}" />
                                                                        <ProgressBar Margin="0,6,0,0" Height="6" Maximum="100" Value="{Binding ProgressValue, Mode=OneWay}" />
                                                                    </StackPanel>
                                                                    <TextBlock Grid.Column="2" Text="{Binding DetailText}" HorizontalAlignment="Right" Style="{StaticResource BodyMutedTextStyle}" />
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Margin="0,18,0,0" Style="{StaticResource PageCardStyle}">
                        <StackPanel>
                            <TextBlock Text="观影节奏" Style="{StaticResource InsightCardHeaderStyle}" />
                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource InsightEmptyBorderStyle}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasRhythmData}" Value="False">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="暂无有效观影记录，时间段、周内周末和片长分布会在观影后显示。" TextWrapping="Wrap" Style="{StaticResource BodyMutedTextStyle}" />
                            </Border>
                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource CompactCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding ViewingTimeTitle}" Style="{StaticResource SectionTitleTextStyle}" />
                                        <ItemsControl Margin="0,14,0,0" ItemsSource="{Binding ViewingTimeBuckets}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,10">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="70" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="100" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Label}" Style="{StaticResource BodyTextStyle}" />
                                                        <ProgressBar Grid.Column="1" Height="8" Maximum="100" Value="{Binding ProgressValue, Mode=OneWay}" />
                                                        <TextBlock Grid.Column="2" HorizontalAlignment="Right" Text="{Binding WatchText}" Style="{StaticResource BodyMutedTextStyle}" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <StackPanel Grid.Column="2">
                                    <Border Style="{StaticResource CompactCardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="周内 / 周末差异" Style="{StaticResource SectionTitleTextStyle}" />
                                            <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding WeekPartItems}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,10">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="54" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="54" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding Title}" Style="{StaticResource BodyTextStyle}" />
                                                            <StackPanel Grid.Column="1">
                                                                <TextBlock Text="{Binding TotalText}" Style="{StaticResource BodyTextStyle}" />
                                                                <TextBlock Text="{Binding AverageText}" Style="{StaticResource BodyMutedTextStyle}" />
                                                                <ProgressBar Margin="0,6,0,0" Height="6" Maximum="100" Value="{Binding ProgressValue, Mode=OneWay}" />
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="2" HorizontalAlignment="Right" Text="{Binding RatioText}" Style="{StaticResource BodyMutedTextStyle}" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>

                                    <Border Margin="0,14,0,0" Style="{StaticResource CompactCardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding DurationDistributionTitle}" Style="{StaticResource SectionTitleTextStyle}" />
                                            <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding DurationBuckets}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,10">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="120" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="54" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding Label}" TextTrimming="CharacterEllipsis" Style="{StaticResource BodyTextStyle}" />
                                                            <ProgressBar Grid.Column="1" Height="8" Maximum="100" Value="{Binding ProgressValue, Mode=OneWay}" />
                                                            <TextBlock Grid.Column="2" HorizontalAlignment="Right" Text="{Binding CountText}" Style="{StaticResource BodyMutedTextStyle}" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,18,0,0" Style="{StaticResource PageCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding TasteCombinationTitle}" Style="{StaticResource InsightCardHeaderStyle}" />
                                <TextBlock Margin="0,8,0,0" Text="当前范围内看过影片的类型 x 情绪 x 场景共现关系。" Style="{StaticResource BodyMutedTextStyle}" />
                                <Border>
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource InsightEmptyBorderStyle}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasTasteCombinationData}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="暂无可组合的类型、情绪和场景标签。" TextWrapping="Wrap" Style="{StaticResource BodyMutedTextStyle}" />
                                </Border>
                                <Canvas Margin="0,18,0,0" MinWidth="640" Height="340" Background="{DynamicResource BrushSurfaceAlt}">
                                    <TextBlock Canvas.Left="20" Canvas.Top="16" Text="类型" Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Canvas.Left="250" Canvas.Top="16" Text="情绪" Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Canvas.Left="480" Canvas.Top="16" Text="场景" Style="{StaticResource SectionTitleTextStyle}" />
                                    <ItemsControl ItemsSource="{Binding TasteGraphLinks}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Canvas />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Line X1="{Binding X1}"
                                                      Y1="{Binding Y1}"
                                                      X2="{Binding X2}"
                                                      Y2="{Binding Y2}"
                                                      Stroke="{DynamicResource BrushAccent}"
                                                      StrokeThickness="{Binding StrokeThickness}"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      Opacity="0.58" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <ItemsControl ItemsSource="{Binding TasteGraphNodes}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Canvas />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="Canvas.Left" Value="{Binding X}" />
                                                <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="{Binding Width}"
                                                        Height="{Binding Height}"
                                                        Padding="10,0"
                                                        CornerRadius="999"
                                                        Background="{DynamicResource BrushSurface}"
                                                        BorderBrush="{DynamicResource BrushBorder}"
                                                        BorderThickness="1">
                                                    <Grid VerticalAlignment="Center">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Label}" TextTrimming="CharacterEllipsis" Style="{StaticResource BodyTextStyle}" />
                                                        <TextBlock Grid.Column="1" Margin="8,0,0,0" Text="{Binding CountText}" Style="{StaticResource BodyMutedTextStyle}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Canvas.Left="20" Canvas.Top="312" Text="组合出现次数越多，线越粗；节点表示参与组合的标签出现次数。" Style="{StaticResource BodyMutedTextStyle}" />
                                </Canvas>
                            </StackPanel>

                            <Border Grid.Column="2" Style="{StaticResource CompactCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="高频组合 Top10" Style="{StaticResource SectionTitleTextStyle}" />
                                    <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding TasteCombinationTop10}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="30" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="54" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="24" Height="24" CornerRadius="999" Background="{DynamicResource BrushAccentSoft}">
                                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="{Binding Rank}" Style="{StaticResource BodyTextStyle}" />
                                                    </Border>
                                                    <StackPanel Grid.Column="1" Margin="8,0">
                                                        <WrapPanel>
                                                            <Border Margin="0,0,6,6" Padding="8,4" CornerRadius="999" Background="{DynamicResource BrushSurfaceAlt}">
                                                                <TextBlock Text="{Binding TypeLabel}" TextTrimming="CharacterEllipsis" Style="{StaticResource BodyTextStyle}" />
                                                            </Border>
                                                            <TextBlock Margin="0,2,6,0" Text="→" Style="{StaticResource BodyMutedTextStyle}" />
                                                            <Border Margin="0,0,6,6" Padding="8,4" CornerRadius="999" Background="{DynamicResource BrushAccentSoft}">
                                                                <TextBlock Text="{Binding EmotionLabel}" TextTrimming="CharacterEllipsis" Style="{StaticResource BodyTextStyle}" />
                                                            </Border>
                                                            <TextBlock Margin="0,2,6,0" Text="→" Style="{StaticResource BodyMutedTextStyle}" />
                                                            <Border Margin="0,0,0,6" Padding="8,4" CornerRadius="999" Background="{DynamicResource BrushSurfaceAlt}">
                                                                <TextBlock Text="{Binding SceneLabel}" TextTrimming="CharacterEllipsis" Style="{StaticResource BodyTextStyle}" />
                                                            </Border>
                                                        </WrapPanel>
                                                        <ProgressBar Margin="0,2,0,0" Height="6" Maximum="100" Value="{Binding ProgressValue, Mode=OneWay}" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2" HorizontalAlignment="Right" Text="{Binding OccurrenceText}" Style="{StaticResource BodyMutedTextStyle}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
