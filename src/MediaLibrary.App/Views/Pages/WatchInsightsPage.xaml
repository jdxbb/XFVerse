        <DataTemplate x:Key="StatisticsRankRowTemplate">
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="34" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="64" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource StatisticsRankBadgeStyle}">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Text="{Binding Rank}"
                               Style="{StaticResource BodyTextStyle}" />
                </Border>
                <StackPanel Grid.Column="1" Margin="10,0,10,0">
                    <TextBlock helpers:TrimmedTextToolTipBehavior.FullText="{Binding Label}"
                               Text="{Binding Label}"
                               TextTrimming="CharacterEllipsis"
                               Style="{StaticResource BodyTextStyle}" />
                    <ProgressBar Margin="0,7,0,0"
                                 Style="{StaticResource InsightMediaProgressBarStyle}"
                                 Value="{Binding ProgressValue, Mode=OneWay}" />
                </StackPanel>
                <TextBlock Grid.Column="2"
                           HorizontalAlignment="Right"
