                                                            <helpers:CachedShadowBorder x:Name="StatisticsKeywordChip"
                                                                                        ToolTip="{Binding DetailText}"
                                                                                        Style="{StaticResource ProfileKeywordChipBorderStyle}">
                                                                <helpers:CachedShadowBorder.Triggers>
                                                                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                                                        <BeginStoryboard>
                                                                            <Storyboard AutoReverse="True"
                                                                                        RepeatBehavior="Forever"
                                                                                        Timeline.DesiredFrameRate="60">
                                                                                <DoubleAnimation Storyboard.TargetName="StatisticsKeywordChip"
                                                                                                 Storyboard.TargetProperty="Opacity"
                                                                                                 From="0.92"
                                                                                                 To="1"
                                                                                                 Duration="0:0:1.9">
                                                                                    <DoubleAnimation.EasingFunction>
                                                                                        <SineEase EasingMode="EaseInOut" />
                                                                                    </DoubleAnimation.EasingFunction>
                                                                                </DoubleAnimation>
                                                                                <DoubleAnimation Storyboard.TargetName="StatisticsKeywordChip"
                                                                                                 Storyboard.TargetProperty="ShadowVisualOpacity"
                                                                                                 From="0.48"
                                                                                                 To="1"
                                                                                                 Duration="0:0:1.9">
                                                                                    <DoubleAnimation.EasingFunction>
                                                                                        <SineEase EasingMode="EaseInOut" />
                                                                                    </DoubleAnimation.EasingFunction>
                                                                                </DoubleAnimation>
                                                                                <DoubleAnimation Storyboard.TargetName="StatisticsKeywordChip"
                                                                                                 Storyboard.TargetProperty="ShadowVisualScale"
                                                                                                 From="0.93"
                                                                                                 To="1.12"
                                                                                                 Duration="0:0:1.9">
                                                                                    <DoubleAnimation.EasingFunction>
                                                                                        <SineEase EasingMode="EaseInOut" />
                                                                                    </DoubleAnimation.EasingFunction>
                                                                                </DoubleAnimation>
                                                                                <DoubleAnimation Storyboard.TargetName="StatisticsKeywordChip"
                                                                                                 Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                                                                 From="0.98"
                                                                                                 To="1.045"
                                                                                                 Duration="0:0:1.9">
                                                                                    <DoubleAnimation.EasingFunction>
                                                                                        <SineEase EasingMode="EaseInOut" />
                                                                                    </DoubleAnimation.EasingFunction>
                                                                                </DoubleAnimation>
                                                                                <DoubleAnimation Storyboard.TargetName="StatisticsKeywordChip"
                                                                                                 Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                                                                 From="0.98"
                                                                                                 To="1.045"
                                                                                                 Duration="0:0:1.9">
                                                                                    <DoubleAnimation.EasingFunction>
                                                                                        <SineEase EasingMode="EaseInOut" />
                                                                                    </DoubleAnimation.EasingFunction>
                                                                                </DoubleAnimation>
                                                                            </Storyboard>
                                                                        </BeginStoryboard>
                                                                    </EventTrigger>
                                                                </helpers:CachedShadowBorder.Triggers>
                                                                <TextBlock helpers:TrimmedTextToolTipBehavior.FullText="{Binding Label}"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           Text="{Binding Label}"
                                                                           TextAlignment="Center"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           Style="{StaticResource BodyTextStyle}" />
                                                            </helpers:CachedShadowBorder>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="暂无当前范围标签数据">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasMonthlyFrequentTags}" Value="False">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                        </Grid>
                                    </Grid>
                                </helpers:CachedShadowBorder>
                            </Grid>
                        </Grid>
                    </helpers:CachedShadowBorder>
        </DataTemplate>

