                                            <StackPanel Margin="0,0,12,6" Orientation="Horizontal">
                                                <Border Style="{StaticResource StatisticsLegendSwatchStyle}" Background="{DynamicResource BrushSurfaceAlt}" />
                                                <TextBlock Text="无" Style="{StaticResource BodyMutedTextStyle}" />
                                            </StackPanel>
                                            <StackPanel Margin="0,0,12,6" Orientation="Horizontal">
                                                <Border Style="{StaticResource StatisticsLegendSwatchStyle}" Background="{DynamicResource BrushInfoBackground}" BorderBrush="{DynamicResource BrushInfoBorder}" />
                                                <TextBlock Text="&lt;30分钟" Style="{StaticResource BodyMutedTextStyle}" />
                                            </StackPanel>
                                            <StackPanel Margin="0,0,12,6" Orientation="Horizontal">
                                                <Border Style="{StaticResource StatisticsLegendSwatchStyle}" Background="{DynamicResource BrushAccentSoft}" BorderBrush="{DynamicResource BrushAccent}" />
                                                <TextBlock Text="30-60分钟" Style="{StaticResource BodyMutedTextStyle}" />
                                            </StackPanel>
                                            <StackPanel Margin="0,0,12,6" Orientation="Horizontal">
                                                <Border Style="{StaticResource StatisticsLegendSwatchStyle}" Background="{DynamicResource BrushWarningBackground}" BorderBrush="{DynamicResource BrushWarningBorder}" />
                                                <TextBlock Text="1-2小时" Style="{StaticResource BodyMutedTextStyle}" />
                                            </StackPanel>
                                            <StackPanel Margin="0,0,0,6" Orientation="Horizontal">
                                                <Border Style="{StaticResource StatisticsLegendSwatchStyle}" Background="{DynamicResource BrushAccent}" BorderBrush="{DynamicResource BrushAccent}" />
                                                <TextBlock Text="2小时+" Style="{StaticResource BodyMutedTextStyle}" />
                                            </StackPanel>
                                        </WrapPanel>
                                    </StackPanel>
                                </Grid>

                                <UniformGrid Grid.Row="1" Margin="0,18,0,6" Columns="7">
                                    <TextBlock HorizontalAlignment="Center" Text="一" Style="{StaticResource BodyMutedTextStyle}" />
                                    <TextBlock HorizontalAlignment="Center" Text="二" Style="{StaticResource BodyMutedTextStyle}" />
                                    <TextBlock HorizontalAlignment="Center" Text="三" Style="{StaticResource BodyMutedTextStyle}" />
                                    <TextBlock HorizontalAlignment="Center" Text="四" Style="{StaticResource BodyMutedTextStyle}" />
                                    <TextBlock HorizontalAlignment="Center" Text="五" Style="{StaticResource BodyMutedTextStyle}" />
                                    <TextBlock HorizontalAlignment="Center" Text="六" Style="{StaticResource BodyMutedTextStyle}" />
                                    <TextBlock HorizontalAlignment="Center" Text="日" Style="{StaticResource BodyMutedTextStyle}" />
                                </UniformGrid>

                                <ItemsControl Grid.Row="2" ItemsSource="{Binding CalendarCells}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="7" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.OpenWatchHistoryByDateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    IsEnabled="{Binding IsClickable}"
                                                    Style="{StaticResource CalendarDayButtonStyle}">
                                                <Grid>
                                                    <TextBlock Margin="6,4,0,0"
                                                               Text="{Binding DayText}"
                                                               Style="{StaticResource BodyTextStyle}" />
                                                    <TextBlock Margin="0,0,6,4"
                                                               HorizontalAlignment="Right"
                                                               VerticalAlignment="Bottom"
                                                               Text="{Binding WatchCountText}"
                                                               TextTrimming="CharacterEllipsis"
                                                               Style="{StaticResource BodyMutedTextStyle}" />
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Grid.Row="3" Margin="0,10,0,0" Text="{Binding CalendarNoticeMessage}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasCalendarNotice}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>

                            <StackPanel Grid.Column="2">
                                <Border Style="{StaticResource StatisticsMetricPanelStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="44" Height="44" CornerRadius="14" Background="{DynamicResource BrushInfoBackground}" BorderBrush="{DynamicResource BrushInfoBorder}" BorderThickness="1">
                                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="天" Style="{StaticResource BodyTextStyle}" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                            <TextBlock Text="{Binding MonthlyWatchDaysTitle}" Style="{StaticResource BodyMutedTextStyle}" />
                                            <TextBlock Margin="0,8,0,0" Text="{Binding MonthlyWatchDaysText}" Style="{StaticResource SectionTitleTextStyle}" />
                                            <TextBlock Margin="0,4,0,0" Text="有观影记录的自然日" Style="{StaticResource BodyMutedTextStyle}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <Border Margin="0,12,0,0" Style="{StaticResource StatisticsMetricPanelStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="44" Height="44" CornerRadius="14" Background="{DynamicResource BrushAccentSoft}" BorderBrush="{DynamicResource BrushAccent}" BorderThickness="1">
                                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="连" Style="{StaticResource BodyTextStyle}" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                            <TextBlock Text="{Binding ContinuousWatchDaysTitle}" Style="{StaticResource BodyMutedTextStyle}" />
                                            <TextBlock Margin="0,8,0,0" Text="{Binding ContinuousWatchDaysText}" Style="{StaticResource SectionTitleTextStyle}" />
                                            <TextBlock Margin="0,4,0,0" Text="本月连续观影天数峰值" Style="{StaticResource BodyMutedTextStyle}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <Border Margin="0,12,0,0" Style="{StaticResource StatisticsMetricPanelStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="44" Height="44" CornerRadius="14" Background="{DynamicResource BrushWarningBackground}" BorderBrush="{DynamicResource BrushWarningBorder}" BorderThickness="1">
                                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="活" Style="{StaticResource BodyTextStyle}" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                            <TextBlock Text="{Binding MostActiveDateTitle}" Style="{StaticResource BodyMutedTextStyle}" />
                                            <TextBlock Margin="0,8,0,0" Text="{Binding MostActiveDateText}" Style="{StaticResource SectionTitleTextStyle}" />
                                            <TextBlock Margin="0,4,0,0" Text="{Binding MostActiveDateWatchText}" Style="{StaticResource BodyMutedTextStyle}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource PageCardStyle}">
                            <StackPanel>
                                <TextBlock Text="{Binding PreferenceGraphTitle}" Style="{StaticResource InsightCardHeaderStyle}" />
                                <TextBlock Margin="0,8,0,0" Text="当前范围内看过影片的情绪 / 场景标签。" Style="{StaticResource BodyMutedTextStyle}" />
                                <ItemsControl Margin="0,16,0,0" ItemsSource="{Binding PreferenceBubbles}">
                                    <ItemsControl.Style>
                                        <Style TargetType="ItemsControl">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasPreferenceBubbles}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ItemsControl.Style>
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="{Binding Size}" Height="{Binding Size}" Style="{StaticResource BubbleBorderStyle}">
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock HorizontalAlignment="Center" Text="{Binding Label}" TextWrapping="Wrap" Style="{StaticResource BodyTextStyle}" />
                                                    <TextBlock HorizontalAlignment="Center" Text="{Binding Kind}" Style="{StaticResource BodyMutedTextStyle}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Border>
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource InsightEmptyBorderStyle}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasPreferenceBubbles}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="暂无情绪或场景标签数据。" Style="{StaticResource BodyMutedTextStyle}" />
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource PageCardStyle}">
                            <StackPanel>
                                <TextBlock Text="{Binding TagRankingTitle}" Style="{StaticResource InsightCardHeaderStyle}" />
                                <ItemsControl Margin="0,16,0,0" ItemsSource="{Binding MonthlyRankingGroups}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,12" Style="{StaticResource CompactCardStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}" Style="{StaticResource SectionTitleTextStyle}" />
                                                    <Border>
                                                        <Border.Style>
                                                            <Style TargetType="Border" BasedOn="{StaticResource InsightEmptyBorderStyle}">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Setter Property="Margin" Value="0,10,0,0" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasItems}" Value="False">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="暂无当前范围标签数据。" Style="{StaticResource BodyMutedTextStyle}" />
                                                    </Border>
                                                    <ItemsControl Margin="0,10,0,0" ItemsSource="{Binding Items}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid Margin="0,0,0,10">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="30" />
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="58" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <Border Width="24" Height="24" CornerRadius="999" Background="{DynamicResource BrushAccentSoft}">
                                                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="{Binding Rank}" Style="{StaticResource BodyTextStyle}" />
                                                                    </Border>
                                                                    <StackPanel Grid.Column="1" Margin="8,0">
                                                                        <TextBlock Text="{Binding Label}" TextTrimming="CharacterEllipsis" Style="{StaticResource BodyTextStyle}" />
                                                                        <ProgressBar Margin="0,6,0,0" Height="6" Maximum="100" Value="{Binding ProgressValue, Mode=OneWay}" />
                                                                    </StackPanel>
                                                                    <TextBlock Grid.Column="2" Text="{Binding DetailText}" HorizontalAlignment="Right" Style="{StaticResource BodyMutedTextStyle}" />
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Margin="0,18,0,0" Style="{StaticResource PageCardStyle}">
                        <StackPanel>
                            <TextBlock Text="观影节奏" Style="{StaticResource InsightCardHeaderStyle}" />
                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource InsightEmptyBorderStyle}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasRhythmData}" Value="False">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="暂无有效观影记录，时间段、周内周末和片长分布会在观影后显示。" TextWrapping="Wrap" Style="{StaticResource BodyMutedTextStyle}" />
                            </Border>
                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource CompactCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding ViewingTimeTitle}" Style="{StaticResource SectionTitleTextStyle}" />
                                        <ItemsControl Margin="0,14,0,0" ItemsSource="{Binding ViewingTimeBuckets}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,10">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="70" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="100" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Label}" Style="{StaticResource BodyTextStyle}" />
                                                        <ProgressBar Grid.Column="1" Height="8" Maximum="100" Value="{Binding ProgressValue, Mode=OneWay}" />
                                                        <TextBlock Grid.Column="2" HorizontalAlignment="Right" Text="{Binding WatchText}" Style="{StaticResource BodyMutedTextStyle}" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <StackPanel Grid.Column="2">
                                    <Border Style="{StaticResource CompactCardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="周内 / 周末差异" Style="{StaticResource SectionTitleTextStyle}" />
                                            <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding WeekPartItems}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,10">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="54" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="54" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding Title}" Style="{StaticResource BodyTextStyle}" />
                                                            <StackPanel Grid.Column="1">
                                                                <TextBlock Text="{Binding TotalText}" Style="{StaticResource BodyTextStyle}" />
                                                                <TextBlock Text="{Binding AverageText}" Style="{StaticResource BodyMutedTextStyle}" />
                                                                <ProgressBar Margin="0,6,0,0" Height="6" Maximum="100" Value="{Binding ProgressValue, Mode=OneWay}" />
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="2" HorizontalAlignment="Right" Text="{Binding RatioText}" Style="{StaticResource BodyMutedTextStyle}" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>

                                    <Border Margin="0,14,0,0" Style="{StaticResource CompactCardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding DurationDistributionTitle}" Style="{StaticResource SectionTitleTextStyle}" />
                                            <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding DurationBuckets}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,10">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="120" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="54" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding Label}" TextTrimming="CharacterEllipsis" Style="{StaticResource BodyTextStyle}" />
                                                            <ProgressBar Grid.Column="1" Height="8" Maximum="100" Value="{Binding ProgressValue, Mode=OneWay}" />
                                                            <TextBlock Grid.Column="2" HorizontalAlignment="Right" Text="{Binding CountText}" Style="{StaticResource BodyMutedTextStyle}" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,18,0,0" Style="{StaticResource PageCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding TasteCombinationTitle}" Style="{StaticResource InsightCardHeaderStyle}" />
                                <TextBlock Margin="0,8,0,0" Text="当前范围内看过影片的类型 x 情绪 x 场景共现关系。" Style="{StaticResource BodyMutedTextStyle}" />
                                <Border>
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource InsightEmptyBorderStyle}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasTasteCombinationData}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="暂无可组合的类型、情绪和场景标签。" TextWrapping="Wrap" Style="{StaticResource BodyMutedTextStyle}" />
                                </Border>
                                <Canvas Margin="0,18,0,0" MinWidth="640" Height="340" Background="{DynamicResource BrushSurfaceAlt}">
                                    <TextBlock Canvas.Left="20" Canvas.Top="16" Text="类型" Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Canvas.Left="250" Canvas.Top="16" Text="情绪" Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Canvas.Left="480" Canvas.Top="16" Text="场景" Style="{StaticResource SectionTitleTextStyle}" />
                                    <ItemsControl ItemsSource="{Binding TasteGraphLinks}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Canvas />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Line X1="{Binding X1}"
                                                      Y1="{Binding Y1}"
                                                      X2="{Binding X2}"
                                                      Y2="{Binding Y2}"
                                                      Stroke="{DynamicResource BrushAccent}"
                                                      StrokeThickness="{Binding StrokeThickness}"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      Opacity="0.58" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <ItemsControl ItemsSource="{Binding TasteGraphNodes}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Canvas />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="Canvas.Left" Value="{Binding X}" />
                                                <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="{Binding Width}"
                                                        Height="{Binding Height}"
                                                        Padding="10,0"
                                                        CornerRadius="999"
                                                        Background="{DynamicResource BrushSurface}"
                                                        BorderBrush="{DynamicResource BrushBorder}"
                                                        BorderThickness="1">
                                                    <Grid VerticalAlignment="Center">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Label}" TextTrimming="CharacterEllipsis" Style="{StaticResource BodyTextStyle}" />
                                                        <TextBlock Grid.Column="1" Margin="8,0,0,0" Text="{Binding CountText}" Style="{StaticResource BodyMutedTextStyle}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Canvas.Left="20" Canvas.Top="312" Text="组合出现次数越多，线越粗；节点表示参与组合的标签出现次数。" Style="{StaticResource BodyMutedTextStyle}" />
                                </Canvas>
                            </StackPanel>

                            <Border Grid.Column="2" Style="{StaticResource CompactCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="高频组合 Top10" Style="{StaticResource SectionTitleTextStyle}" />
                                    <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding TasteCombinationTop10}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="30" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="54" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="24" Height="24" CornerRadius="999" Background="{DynamicResource BrushAccentSoft}">
                                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="{Binding Rank}" Style="{StaticResource BodyTextStyle}" />
                                                    </Border>
                                                    <StackPanel Grid.Column="1" Margin="8,0">
                                                        <WrapPanel>
                                                            <Border Margin="0,0,6,6" Padding="8,4" CornerRadius="999" Background="{DynamicResource BrushSurfaceAlt}">
                                                                <TextBlock Text="{Binding TypeLabel}" TextTrimming="CharacterEllipsis" Style="{StaticResource BodyTextStyle}" />
                                                            </Border>
                                                            <TextBlock Margin="0,2,6,0" Text="→" Style="{StaticResource BodyMutedTextStyle}" />
                                                            <Border Margin="0,0,6,6" Padding="8,4" CornerRadius="999" Background="{DynamicResource BrushAccentSoft}">
                                                                <TextBlock Text="{Binding EmotionLabel}" TextTrimming="CharacterEllipsis" Style="{StaticResource BodyTextStyle}" />
                                                            </Border>
                                                            <TextBlock Margin="0,2,6,0" Text="→" Style="{StaticResource BodyMutedTextStyle}" />
                                                            <Border Margin="0,0,0,6" Padding="8,4" CornerRadius="999" Background="{DynamicResource BrushSurfaceAlt}">
                                                                <TextBlock Text="{Binding SceneLabel}" TextTrimming="CharacterEllipsis" Style="{StaticResource BodyTextStyle}" />
                                                            </Border>
                                                        </WrapPanel>
                                                        <ProgressBar Margin="0,2,0,0" Height="6" Maximum="100" Value="{Binding ProgressValue, Mode=OneWay}" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2" HorizontalAlignment="Right" Text="{Binding OccurrenceText}" Style="{StaticResource BodyMutedTextStyle}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
