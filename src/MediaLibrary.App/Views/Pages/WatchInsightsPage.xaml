        <DataTemplate x:Key="TasteGraphNodeTemplate">
            <Border x:Name="TasteNodeRoot"
                    Tag="TasteGraphNode"
                    Width="{Binding Width}"
                    Height="{Binding Height}"
                    Padding="7"
                    CornerRadius="999"
                    Background="{DynamicResource BrushSurface}"
                    BorderBrush="{DynamicResource BrushBorder}"
                    BorderThickness="1.2"
                    Cursor="Hand"
                    MouseEnter="TasteGraphNode_MouseEnter"
                    MouseLeave="TasteGraphNode_MouseLeave"
                    MouseLeftButtonUp="TasteGraphNode_MouseLeftButtonUp"
                    ToolTip="{Binding RichToolTipText}"
                    ToolTipService.BetweenShowDelay="0"
                    ToolTipService.InitialShowDelay="120"
                    ToolTipService.ShowDuration="16000">
                <TextBlock HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource BrushForegroundPrimary}"
                           Text="{Binding Label}"
                           TextAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           TextWrapping="Wrap" />
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding Kind}" Value="type">
                    <Setter TargetName="TasteNodeRoot" Property="Background" Value="{DynamicResource BrushInfoBackground}" />
                    <Setter TargetName="TasteNodeRoot" Property="BorderBrush" Value="{DynamicResource BrushInfoBorder}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="emotion">
                    <Setter TargetName="TasteNodeRoot" Property="Background" Value="{DynamicResource BrushAccentSoft}" />
                    <Setter TargetName="TasteNodeRoot" Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="scene">
                    <Setter TargetName="TasteNodeRoot" Property="Background" Value="{DynamicResource BrushWatchInsightsDnaSceneBackground}" />
                    <Setter TargetName="TasteNodeRoot" Property="BorderBrush" Value="{DynamicResource BrushWatchInsightsDnaSceneBorder}" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate x:Key="ChipTemplate">
            <helpers:CachedShadowBorder Style="{StaticResource InsightChipBorderStyle}">
                <TextBlock Text="{Binding Label}" Style="{StaticResource BodyTextStyle}" />
            </helpers:CachedShadowBorder>
        </DataTemplate>

        <DataTemplate x:Key="StatisticsOverviewCardTemplate">
            <helpers:CachedShadowBorder Height="{Binding CardHeight}"
                                        Style="{StaticResource StatisticsMetricPanelStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border x:Name="StatusIcon"
                                Width="38"
                                Height="38"
                                CornerRadius="12"
                                Background="{DynamicResource BrushAccentSoft}"
                                BorderBrush="{DynamicResource BrushBorder}"
                                BorderThickness="1">
                            <controls:PhosphorIcon x:Name="StatusIconText"
                                                   Width="18"
                                                   Height="18"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource BrushForegroundPrimary}"
                                                   Icon="{Binding IconText}" />
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Title}" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Margin="0,2,0,0"
                                       Text="{Binding Subtitle}"
                                       TextWrapping="Wrap"
                                       Style="{StaticResource BodyMutedTextStyle}" />
                        </StackPanel>
                    </Grid>

                    <StackPanel x:Name="MetricValuePanel"
                                Grid.Row="1"
                                Margin="0,16,0,0"
                                HorizontalAlignment="Center"
                                Orientation="Horizontal"
                                VerticalAlignment="Bottom">
                        <TextBlock Margin="0,12,6,0"
                                   Text="{Binding PrefixText}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCompact}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding ValueText}" Style="{StaticResource StatisticsMetricValueTextStyle}" />
                        <TextBlock Margin="6,12,0,0"
                                   Text="{Binding UnitText}"
                                   Style="{StaticResource BodyMutedTextStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Row="2"
                                Margin="0,10,0,0"
                                HorizontalAlignment="Center"
                                Orientation="Horizontal">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasDelta}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="{Binding DeltaText}" Style="{StaticResource BodyMutedTextStyle}" />
                        <TextBlock Margin="4,0,0,0"
                                   Text="{Binding DeltaArrowText}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                                    <Setter Property="FontSize" Value="14" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasDeltaArrow}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </helpers:CachedShadowBorder>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsCompact}" Value="True">
                    <Setter TargetName="MetricValuePanel" Property="Margin" Value="0,8,0,0" />
                    <Setter TargetName="MetricValuePanel" Property="VerticalAlignment" Value="Center" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="watched">
                    <Setter TargetName="StatusIcon" Property="Background" Value="{DynamicResource BrushInfoBackground}" />
                    <Setter TargetName="StatusIcon" Property="BorderBrush" Value="{DynamicResource BrushInfoBorder}" />
                    <Setter TargetName="StatusIconText" Property="Foreground" Value="{DynamicResource BrushAccent}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="favorite">
                    <Setter TargetName="StatusIcon" Property="Background" Value="{DynamicResource BrushAccentSoft}" />
                    <Setter TargetName="StatusIcon" Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                    <Setter TargetName="StatusIconText" Property="Foreground" Value="{DynamicResource BrushRatingStarFill}" />
                    <Setter TargetName="StatusIconText" Property="Icon" Value="heart-fill" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="want">
                    <Setter TargetName="StatusIcon" Property="Background" Value="{DynamicResource BrushSuccessBackground}" />
                    <Setter TargetName="StatusIcon" Property="BorderBrush" Value="{DynamicResource BrushSuccessBorder}" />
                    <Setter TargetName="StatusIconText" Property="Foreground" Value="{DynamicResource BrushRatingStarFill}" />
                    <Setter TargetName="StatusIconText" Property="Icon" Value="star-fill" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="negative">
                    <Setter TargetName="StatusIcon" Property="Background" Value="{DynamicResource BrushWarningBackground}" />
                    <Setter TargetName="StatusIcon" Property="BorderBrush" Value="{DynamicResource BrushWarningBorder}" />
                    <Setter TargetName="StatusIconText" Property="Foreground" Value="{DynamicResource BrushAccent}" />
                    <Setter TargetName="StatusIconText" Property="Icon" Value="prohibit" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate x:Key="ProfileDnaCardTemplate">
            <helpers:CachedShadowBorder Loaded="ProfileDnaCard_Loaded"
                    RenderTransformOrigin="0.5,0.5"
                    Style="{StaticResource ProfileDnaCardStyle}">
                <helpers:CachedShadowBorder.RenderTransform>
                    <TransformGroup>
                        <TranslateTransform Y="0" />
                        <ScaleTransform ScaleX="1" ScaleY="1" />
                    </TransformGroup>
                </helpers:CachedShadowBorder.RenderTransform>
                    <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="54" />
                        <RowDefinition Height="48" />
                        <RowDefinition Height="94" />
                    </Grid.RowDefinitions>

                    <Grid VerticalAlignment="Top">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource ProfileDnaIconStyle}">
                            <Grid>
                                <controls:PhosphorIcon x:Name="DnaTicketIcon"
                                                       Foreground="{DynamicResource BrushWatchInsightsDnaTypeBorder}"
                                                       Icon="ticket"
                                                       Style="{StaticResource ProfileDnaGlyphStyle}" />
                                <controls:PhosphorIcon x:Name="DnaHeartIcon"
                                                       Foreground="{DynamicResource BrushWatchInsightsDnaEmotionBorder}"
                                                       Icon="heartbeat"
                                                       Style="{StaticResource ProfileDnaGlyphStyle}" />
                                <controls:PhosphorIcon x:Name="DnaSofaIcon"
                                                       Foreground="{DynamicResource BrushWatchInsightsDnaSceneBorder}"
                                                       Icon="armchair"
                                                       Style="{StaticResource ProfileDnaGlyphStyle}" />
                                <controls:PhosphorIcon x:Name="DnaRouteIcon"
                                                       Foreground="{DynamicResource BrushWatchInsightsKeywordMediumBorder}"
                                                       Icon="git-branch"
                                                       Style="{StaticResource ProfileDnaGlyphStyle}" />
                                <controls:PhosphorIcon x:Name="DnaWaveIcon"
                                                       Foreground="{DynamicResource BrushWatchInsightsDnaRhythmIcon}"
                                                       Icon="wave-sine"
                                                       Style="{StaticResource ProfileDnaGlyphStyle}" />
                                <controls:PhosphorIcon x:Name="DnaCompassIcon"
                                                       Foreground="{DynamicResource BrushWatchInsightsDnaExplorationIcon}"
                                                       Icon="compass"
                                                       Style="{StaticResource ProfileDnaGlyphStyle}" />
                            </Grid>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Gene}" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Margin="0,4,0,0"
                                       Text="{Binding Subtitle}"
                                       TextWrapping="Wrap"
                                       Style="{StaticResource BodyMutedTextStyle}" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1" VerticalAlignment="Center">
                        <Grid.Style>
                            <Style TargetType="{x:Type Grid}">
                                <Setter Property="Margin" Value="0,-8,0,0" />
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsProgressGene}" Value="False" />
                                            <Condition Binding="{Binding DataContext.IsProfileDnaTextScrollable, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Margin" Value="0,0,0,0" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <ItemsControl AlternationCount="3"
                                      ItemsSource="{Binding Tags}">
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasTags}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1" Columns="3" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <helpers:CachedShadowBorder Style="{StaticResource ProfileDnaTagBorderStyle}">
                                        <TextBlock helpers:TrimmedTextToolTipBehavior.FullText="{Binding Label}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding Label}"
                                                   TextAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   Style="{StaticResource BodyTextStyle}" />
                                    </helpers:CachedShadowBorder>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Grid Height="42" Margin="0,4,0,0" VerticalAlignment="Center">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsProgressGene}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <ProgressBar Style="{StaticResource ProfileDnaProgressStyle}"
                                         Value="{Binding Score, Mode=OneWay}" />
                            <Grid Grid.Row="1" Margin="0,5,0,0">
                                <TextBlock Text="{Binding LeftLabel}" Style="{StaticResource BodyMutedTextStyle}" />
                                <TextBlock HorizontalAlignment="Right"
                                           Text="{Binding RightLabel}"
                                           Style="{StaticResource BodyMutedTextStyle}" />
                            </Grid>
                        </Grid>
                    </Grid>

                    <ScrollViewer Grid.Row="2"
                                  Loaded="ProfileDnaDescriptionScrollViewer_Loaded"
                                  SizeChanged="ProfileDnaDescriptionScrollViewer_SizeChanged"
                                  Tag="ProfileDnaDescription"
                                  VerticalAlignment="Top"
                                  CanContentScroll="False"
                                  helpers:ScrollBarAutoRevealBehavior.IsEnabled="True"
                                  HorizontalScrollBarVisibility="Disabled"
                                  PanningMode="VerticalOnly"
                                  PreviewMouseWheel="ProfileSummaryScrollViewer_PreviewMouseWheel"
                                  VerticalScrollBarVisibility="Auto">
                        <ScrollViewer.Style>
                            <Style TargetType="{x:Type ScrollViewer}">
                                <Setter Property="Height" Value="84" />
                                <Setter Property="Margin" Value="0,6,0,0" />
                            </Style>
                        </ScrollViewer.Style>
                        <ScrollViewer.Resources>
                            <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource InsightModernScrollBarStyle}" />
                        </ScrollViewer.Resources>
                        <TextBlock Padding="0,0,10,8"
                                   LineHeight="23"
                                   LineStackingStrategy="BlockLineHeight"
                                   Text="{Binding Description}"
                                   TextWrapping="Wrap"
                                   Style="{StaticResource BodyMutedTextStyle}" />
                    </ScrollViewer>
                </Grid>
            </helpers:CachedShadowBorder>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IconKind}" Value="type">
                    <Setter TargetName="DnaTicketIcon" Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IconKind}" Value="emotion">
                    <Setter TargetName="DnaHeartIcon" Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IconKind}" Value="scene">
                    <Setter TargetName="DnaSofaIcon" Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IconKind}" Value="narrative">
                    <Setter TargetName="DnaRouteIcon" Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IconKind}" Value="rhythm">
                    <Setter TargetName="DnaWaveIcon" Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IconKind}" Value="exploration">
                    <Setter TargetName="DnaCompassIcon" Property="Visibility" Value="Visible" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate x:Key="ProfileWatchLikeGroupTemplate">
            <helpers:CachedShadowBorder MinHeight="224"
                                        ShadowOpacity="0.38">
                <helpers:CachedShadowBorder.Style>
                    <Style TargetType="{x:Type helpers:CachedShadowBorder}"
                           BasedOn="{StaticResource ProfileInnerPanelStyle}">
                        <Setter Property="ShadowVisualOpacity" Value="0.48" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType={x:Type ContentControl}}}"
                                         Value="center">
                                <Setter Property="ShadowVisualOpacity" Value="1" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </helpers:CachedShadowBorder.Style>
                <StackPanel>
                    <TextBlock Text="{Binding Title}" Style="{StaticResource SectionTitleTextStyle}" />
                    <TextBlock Margin="0,4,0,0"
                               Text="{Binding Subtitle}"
                               TextWrapping="Wrap"
                               Style="{StaticResource BodyMutedTextStyle}" />
                    <ItemsControl Margin="0,16,0,0" ItemsSource="{Binding Items}">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasItems}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="34" />
