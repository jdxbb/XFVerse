<UserControl x:Class="MediaLibrary.App.Views.Pages.WatchInsightsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:MediaLibrary.App.Helpers"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="InsightModernScrollBarThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border x:Name="ThumbRoot"
                                Width="6"
                                Background="{DynamicResource BrushForegroundMuted}"
                                CornerRadius="3"
                                Opacity="0.58" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbRoot" Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbRoot" Property="Opacity" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InsightModernScrollRepeatButtonStyle" TargetType="{x:Type RepeatButton}">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InsightModernScrollBarStyle" TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="6" />
            <Setter Property="MinWidth" Value="6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Width="{TemplateBinding Width}" Background="Transparent">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Style="{StaticResource InsightModernScrollRepeatButtonStyle}" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource InsightModernScrollBarThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Style="{StaticResource InsightModernScrollRepeatButtonStyle}" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=(helpers:ScrollBarAutoRevealBehavior.IsRevealed)}" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WatchInsightsManualProfileTabButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource PageTopManualTabButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsProfileTabSelected, RelativeSource={RelativeSource AncestorType=TabControl}}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WatchInsightsManualStatisticsTabButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource PageTopManualLastTabButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsStatisticsTabSelected, RelativeSource={RelativeSource AncestorType=TabControl}}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WatchInsightsProfileTabActionPanelStyle" TargetType="{x:Type StackPanel}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsProfileTabSelected, RelativeSource={RelativeSource AncestorType=TabControl}}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WatchInsightsStatisticsTabActionPanelStyle" TargetType="{x:Type StackPanel}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsStatisticsTabSelected, RelativeSource={RelativeSource AncestorType=TabControl}}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WatchInsightsRefreshIconButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
            <Setter Property="ToolTip" Value="刷新画像" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource BrushAccent}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.72" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Cursor" Value="Arrow" />
                                <Setter Property="Opacity" Value="0.72" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WatchInsightsRefreshGlyphStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Text" Value="&#xE72C;" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <RotateTransform Angle="0" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsProfileRefreshAnimating, RelativeSource={RelativeSource AncestorType=TabControl}}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard x:Name="ProfileRefreshSpinStoryboard">
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                 From="0"
                                                 To="360"
                                                 Duration="0:0:0.9" />
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <StopStoryboard BeginStoryboardName="ProfileRefreshSpinStoryboard" />
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WatchInsightsStatisticsRefreshGlyphStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource WatchInsightsRefreshGlyphStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsStatisticsRefreshAnimating, RelativeSource={RelativeSource AncestorType=TabControl}}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard x:Name="StatisticsRefreshSpinStoryboard">
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                 From="0"
                                                 To="360"
                                                 Duration="0:0:0.9" />
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <StopStoryboard BeginStoryboardName="StatisticsRefreshSpinStoryboard" />
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WatchInsightsHiddenHeaderTabControlStyle" TargetType="{x:Type TabControl}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0,16,0,0" />
            <Setter Property="Margin" Value="0,-8,0,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabControl}">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0"
                                  ClipToBounds="False"
                                  SnapsToDevicePixels="True">
                                <Border Style="{StaticResource PageTopTabDividerStyle}" />
                                <StackPanel Panel.ZIndex="2"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Bottom"
                                            ClipToBounds="False"
                                            Orientation="Horizontal">
                                    <Button Content="画像分析"
                                            Command="{Binding DataContext.SelectTabCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                            CommandParameter="0"
                                            Style="{StaticResource WatchInsightsManualProfileTabButtonStyle}" />
                                     <Button Content="观影统计"
                                            Command="{Binding DataContext.SelectTabCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                            CommandParameter="1"
                                            Style="{StaticResource WatchInsightsManualStatisticsTabButtonStyle}" />
                                </StackPanel>
                                <StackPanel Panel.ZIndex="3"
                                            Margin="0,0,28,4"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom"
                                            ClipToBounds="False"
                                            Orientation="Horizontal"
                                            Style="{StaticResource WatchInsightsProfileTabActionPanelStyle}">
                                    <TextBlock Margin="0,0,10,0"
                                               MaxWidth="260"
                                               VerticalAlignment="Center"
                                               Text="{Binding DataContext.ProfileRefreshStatusText, RelativeSource={RelativeSource TemplatedParent}}"
                                               TextTrimming="CharacterEllipsis"
                                               Style="{StaticResource BodyMutedTextStyle}" />
                                    <Button Command="{Binding DataContext.RefreshProfileCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                            Style="{StaticResource WatchInsightsRefreshIconButtonStyle}">
                                        <TextBlock Style="{StaticResource WatchInsightsRefreshGlyphStyle}" />
                                    </Button>
                                </StackPanel>
                                <StackPanel Panel.ZIndex="3"
                                            Margin="0,0,28,4"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom"
                                            ClipToBounds="False"
                                            Orientation="Horizontal"
                                            Style="{StaticResource WatchInsightsStatisticsTabActionPanelStyle}">
                                    <TextBlock Margin="0,0,10,0"
                                               MaxWidth="260"
                                               VerticalAlignment="Center"
                                               Text="{Binding DataContext.StatisticsRefreshStatusText, RelativeSource={RelativeSource TemplatedParent}}"
                                               TextTrimming="CharacterEllipsis"
                                               Style="{StaticResource BodyMutedTextStyle}" />
                                    <Button Command="{Binding DataContext.RefreshStatisticsCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                            Style="{StaticResource WatchInsightsRefreshIconButtonStyle}"
                                            ToolTip="刷新统计">
                                        <TextBlock Style="{StaticResource WatchInsightsStatisticsRefreshGlyphStyle}" />
                                    </Button>
                                </StackPanel>
                                <TabPanel x:Name="HeaderPanel"
                                          Panel.ZIndex="0"
                                          Height="0"
                                          HorizontalAlignment="Left"
                                          IsHitTestVisible="False"
                                          IsItemsHost="True"
                                          KeyboardNavigation.TabIndex="1"
                                          Opacity="0" />
                            </Grid>

                            <ContentPresenter x:Name="PART_SelectedContentHost"
                                              Grid.Row="1"
                                              Margin="{TemplateBinding Padding}"
                                              ContentSource="SelectedContent" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InsightCardHeaderStyle" TargetType="TextBlock" BasedOn="{StaticResource CardTitleTextStyle}">
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="InsightChipBorderStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Background" Value="{DynamicResource BrushAccentSoft}" />
            <Setter Property="Effect" Value="{DynamicResource ShadowInlineCard}" />
        </Style>

        <Style x:Key="InsightEmptyBorderStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,14,0,0" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Background" Value="{DynamicResource BrushSurfaceAlt}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Effect" Value="{DynamicResource ShadowInlineCard}" />
        </Style>

        <Style x:Key="CalendarDayButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="52" />
            <Setter Property="Margin" Value="3" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="Background" Value="{DynamicResource BrushSurfaceAlt}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="DayBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Effect="{DynamicResource ShadowInlineCard}">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="DayBorder" Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPlaceholder}" Value="True">
                    <Setter Property="Visibility" Value="Hidden" />
                    <Setter Property="IsEnabled" Value="False" />
                </DataTrigger>
                <DataTrigger Binding="{Binding HeatLevel}" Value="1">
                    <Setter Property="Background" Value="{DynamicResource BrushInfoBackground}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushInfoBorder}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding HeatLevel}" Value="2">
                    <Setter Property="Background" Value="{DynamicResource BrushAccentSoft}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding HeatLevel}" Value="3">
                    <Setter Property="Background" Value="{DynamicResource BrushWarningBackground}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushWarningBorder}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding HeatLevel}" Value="4">
                    <Setter Property="Background" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="Foreground" Value="{DynamicResource BrushOnAccent}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BubbleBorderStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,12,12" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Background" Value="{DynamicResource BrushAccentSoft}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Effect" Value="{DynamicResource ShadowInlineCard}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Kind}" Value="场景">
                    <Setter Property="Background" Value="{DynamicResource BrushSurfaceAlt}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ProfileInnerPanelStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource GlassInlinePanelStyle}">
            <Setter Property="Padding" Value="16" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <Style x:Key="WatchInsightsModuleCardStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource GlassPageCardStyle}">
            <Setter Property="Margin" Value="0,0,0,34" />
            <Setter Property="ClipToBounds" Value="False" />
        </Style>

        <Style x:Key="ProfileTasteSummaryCardStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource WatchInsightsModuleCardStyle}">
            <Setter Property="Height" Value="360" />
        </Style>

        <Style x:Key="ProfileSummaryContentPanelStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource ProfileInnerPanelStyle}">
            <Setter Property="MinHeight" Value="230" />
            <Setter Property="ClipToBounds" Value="False" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="ProfileKeywordPanelStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource ProfileInnerPanelStyle}">
            <Setter Property="MinHeight" Value="230" />
            <Setter Property="ClipToBounds" Value="False" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="ProfileKeywordChipBorderStyle" TargetType="{x:Type Border}">
            <Setter Property="Height" Value="48" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="{DynamicResource BrushGlassButton}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushGlassBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Effect" Value="{DynamicResource ShadowInlineCard}" />
        </Style>

        <Style x:Key="ProfileKeywordSlotBorderStyle" TargetType="{x:Type Border}">
            <Setter Property="Height" Value="48" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="{DynamicResource BrushGlassButton}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushGlassBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Opacity" Value="0.16" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Effect" Value="{DynamicResource ShadowInlineCard}" />
        </Style>

        <Style x:Key="ProfileSummaryQuoteTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontFamily" Value="Georgia" />
            <Setter Property="FontSize" Value="48" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource BrushForegroundMuted}" />
            <Setter Property="Opacity" Value="0.32" />
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>

        <Style x:Key="ProfileSummaryBodyTextStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource BodyTextStyle}">
            <Setter Property="LineHeight" Value="24" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextTrimming" Value="None" />
        </Style>

        <Style x:Key="ProfileSummaryScrollViewerStyle" TargetType="{x:Type ScrollViewer}">
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="CanContentScroll" Value="False" />
            <Setter Property="PanningMode" Value="VerticalOnly" />
            <Setter Property="helpers:ScrollBarAutoRevealBehavior.IsEnabled" Value="True" />
        </Style>

        <Style x:Key="ProfileDnaIconStyle" TargetType="{x:Type Border}">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="48" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Background" Value="{DynamicResource BrushAccentSoft}" />
        </Style>

        <Style x:Key="ProfileSmallRankStyle" TargetType="{x:Type Border}">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Background" Value="{DynamicResource BrushAccentSoft}" />
        </Style>

        <Style x:Key="ProfileInlineProgressStyle" TargetType="{x:Type ProgressBar}">
            <Setter Property="Height" Value="7" />
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="100" />
        </Style>

        <Style x:Key="StatisticsRangeButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="MinWidth" Value="72" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="14,0" />
        </Style>

        <Style x:Key="StatisticsMonthRangeButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource StatisticsRangeButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMonthRangeSelected}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="Foreground" Value="{DynamicResource BrushOnAccent}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StatisticsAllRangeButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource StatisticsRangeButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsAllRangeSelected}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="Foreground" Value="{DynamicResource BrushOnAccent}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StatisticsMetricPanelStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource ProfileInnerPanelStyle}">
            <Setter Property="MinHeight" Value="116" />
        </Style>

        <Style x:Key="StatisticsLegendSwatchStyle" TargetType="{x:Type Border}">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="12" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Background" Value="{DynamicResource BrushSurfaceAlt}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="StatisticsChartPanelStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource ProfileInnerPanelStyle}">
            <Setter Property="MinHeight" Value="168" />
            <Setter Property="Padding" Value="18" />
        </Style>

        <Style x:Key="StatisticsRankBadgeStyle" TargetType="{x:Type Border}">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Background" Value="{DynamicResource BrushAccentSoft}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="StatisticsLegendDotStyle" TargetType="{x:Type Border}">
            <Setter Property="Width" Value="10" />
            <Setter Property="Height" Value="10" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Background" Value="{DynamicResource BrushAccentSoft}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <DataTemplate x:Key="StatisticsRankRowTemplate">
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="34" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="64" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource StatisticsRankBadgeStyle}">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Text="{Binding Rank}"
                               Style="{StaticResource BodyTextStyle}" />
                </Border>
                <StackPanel Grid.Column="1" Margin="10,0,10,0">
                    <TextBlock helpers:TrimmedTextToolTipBehavior.FullText="{Binding Label}"
                               Text="{Binding Label}"
                               TextTrimming="CharacterEllipsis"
                               Style="{StaticResource BodyTextStyle}" />
                    <ProgressBar Margin="0,7,0,0"
                                 Height="7"
                                 Maximum="100"
                                 Value="{Binding ProgressValue, Mode=OneWay}" />
                </StackPanel>
                <TextBlock Grid.Column="2"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Top"
                           Text="{Binding DetailText}"
                           Style="{StaticResource BodyMutedTextStyle}" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="PreferenceBubbleTemplate">
            <Border x:Name="BubbleRoot"
                    Width="{Binding Size}"
                    Height="{Binding Size}"
                    CornerRadius="999"
                    Background="{DynamicResource BrushAccentSoft}"
                    BorderBrush="{DynamicResource BrushAccent}"
                    BorderThickness="1"
                    Effect="{DynamicResource ShadowInlineCard}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border Width="28"
                            Height="28"
                            HorizontalAlignment="Center"
                            CornerRadius="999"
                            Background="{DynamicResource BrushSurface}">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="{Binding KindIcon}"
                                   Style="{StaticResource BodyMutedTextStyle}" />
                    </Border>
                    <TextBlock Margin="0,7,0,0"
                               MaxWidth="{Binding LabelMaxWidth}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Text="{Binding Label}"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="Wrap"
                               helpers:TrimmedTextToolTipBehavior.FullText="{Binding Label}"
                               Style="{StaticResource BodyTextStyle}" />
                    <TextBlock Margin="0,3,0,0"
                               HorizontalAlignment="Center"
                               Text="{Binding CountText}"
