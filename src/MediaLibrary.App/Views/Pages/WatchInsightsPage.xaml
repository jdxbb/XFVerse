                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Setter Property="Margin" Value="0,12,0,0" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasItems}" Value="False">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="暂无当前范围标签数据。" TextWrapping="Wrap" Style="{StaticResource BodyMutedTextStyle}" />
                                                    </Border>
                                                    <ItemsControl Margin="0,14,0,0"
                                                                  ItemTemplate="{StaticResource StatisticsRankRowTemplate}"
                                                                  ItemsSource="{Binding Items}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Style="{StaticResource WatchInsightsModuleCardStyle}">
                        <StackPanel>
                            <TextBlock Text="观影节奏" Style="{StaticResource InsightCardHeaderStyle}" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="你的观影时间分布与节奏"
                                       TextWrapping="Wrap"
                                       Style="{StaticResource BodyMutedTextStyle}" />
                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource InsightEmptyBorderStyle}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasRhythmData}" Value="False">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="暂无有效观影记录，时间段、周内周末和片长分布会在观影后显示。" TextWrapping="Wrap" Style="{StaticResource BodyMutedTextStyle}" />
                            </Border>
                            <Grid Margin="0,16,0,0">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasRhythmData}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="1.1*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource StatisticsChartPanelStyle}">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding ViewingTimeTitle}" Style="{StaticResource SectionTitleTextStyle}" />
                                            <TextBlock Grid.Column="1" Margin="16,0,0,0" Text="{Binding PeakViewingTimeText}" Style="{StaticResource BodyMutedTextStyle}" />
                                        </Grid>
                                        <Grid Margin="0,18,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="42" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Stretch">
                                                <TextBlock Text="高" Style="{StaticResource BodyMutedTextStyle}" />
                                                <TextBlock Margin="0,62,0,0" Text="中" Style="{StaticResource BodyMutedTextStyle}" />
                                                <TextBlock Margin="0,62,0,0" Text="低" Style="{StaticResource BodyMutedTextStyle}" />
                                            </StackPanel>
                                            <ItemsControl Grid.Column="1" ItemsSource="{Binding ViewingTimeBuckets}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <UniformGrid Rows="1" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="5,0">
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="174" />
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                            </Grid.RowDefinitions>
                                                            <Border Grid.Row="0"
                                                                    Width="28"
                                                                    Height="{Binding BarHeight}"
                                                                    VerticalAlignment="Bottom"
                                                                    HorizontalAlignment="Center"
                                                                    CornerRadius="8"
                                                                    Background="{DynamicResource BrushAccent}" />
                                                            <TextBlock Grid.Row="1"
                                                                       Margin="0,10,0,0"
                                                                       HorizontalAlignment="Center"
                                                                       Text="{Binding Label}"
                                                                       TextAlignment="Center"
                                                                       Style="{StaticResource BodyTextStyle}" />
                                                            <TextBlock Grid.Row="2"
                                                                       Margin="0,4,0,0"
                                                                       HorizontalAlignment="Center"
                                                                       Text="{Binding WatchText}"
                                                                       TextAlignment="Center"
                                                                       Style="{StaticResource BodyMutedTextStyle}" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <StackPanel Grid.Column="2">
                                    <Border Style="{StaticResource StatisticsChartPanelStyle}">
                                        <StackPanel>
                                            <TextBlock Text="周内 / 周末差异" Style="{StaticResource SectionTitleTextStyle}" />
                                            <ItemsControl Margin="0,14,0,0" ItemsSource="{Binding WeekPartItems}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,14">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="52" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="64" />
                                                            </Grid.ColumnDefinitions>
                                                            <Border Width="40" Height="40" CornerRadius="12" Background="{DynamicResource BrushSurface}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1">
                                                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="{Binding Title}" Style="{StaticResource BodyTextStyle}" />
                                                            </Border>
                                                            <StackPanel Grid.Column="1" Margin="10,0">
                                                                <TextBlock Text="{Binding TotalText}" Style="{StaticResource SectionTitleTextStyle}" />
                                                                <TextBlock Margin="0,3,0,0" Text="{Binding AverageText}" Style="{StaticResource BodyMutedTextStyle}" />
                                                                <ProgressBar Margin="0,8,0,0" Height="7" Maximum="100" Value="{Binding ProgressValue, Mode=OneWay}" />
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="2" HorizontalAlignment="Right" Text="{Binding RatioText}" Style="{StaticResource BodyMutedTextStyle}" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>

                                    <Border Margin="0,14,0,0" Style="{StaticResource StatisticsChartPanelStyle}">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding DurationDistributionTitle}" Style="{StaticResource SectionTitleTextStyle}" />
                                                <TextBlock Grid.Column="1" Margin="16,0,0,0" Text="{Binding DominantDurationText}" Style="{StaticResource BodyMutedTextStyle}" />
                                            </Grid>
                                            <ItemsControl Margin="0,14,0,0" ItemsSource="{Binding DurationBuckets}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,12">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="118" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="58" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock helpers:TrimmedTextToolTipBehavior.FullText="{Binding Label}"
                                                                       Text="{Binding Label}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Style="{StaticResource BodyTextStyle}" />
                                                            <ProgressBar Grid.Column="1" Height="8" Maximum="100" Value="{Binding ProgressValue, Mode=OneWay}" />
                                                            <TextBlock Grid.Column="2" HorizontalAlignment="Right" Text="{Binding PercentText}" Style="{StaticResource BodyMutedTextStyle}" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource WatchInsightsModuleCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="1.05*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding TasteCombinationTitle}" Style="{StaticResource InsightCardHeaderStyle}" />
                                <TextBlock Margin="0,8,0,0" Text="探索你的类型 x 情绪 x 场景足迹。" Style="{StaticResource BodyMutedTextStyle}" />
                                <Border>
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource InsightEmptyBorderStyle}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasTasteCombinationData}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="暂无可组合的类型、情绪和场景标签。" TextWrapping="Wrap" Style="{StaticResource BodyMutedTextStyle}" />
                                </Border>
                                <Border Margin="0,18,0,0">
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource StatisticsChartPanelStyle}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasTasteCombinationData}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Viewbox Height="430" Stretch="Uniform">
                                        <Canvas Width="720" Height="430">
                                            <TextBlock Canvas.Left="52" Canvas.Top="18" Text="类型" Style="{StaticResource SectionTitleTextStyle}" />
                                            <TextBlock Canvas.Left="286" Canvas.Top="18" Text="情绪" Style="{StaticResource SectionTitleTextStyle}" />
                                            <TextBlock Canvas.Left="516" Canvas.Top="18" Text="场景" Style="{StaticResource SectionTitleTextStyle}" />
                                            <ItemsControl ItemsSource="{Binding TasteGraphLinks}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <Canvas />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Line X1="{Binding X1}"
                                                              Y1="{Binding Y1}"
                                                              X2="{Binding X2}"
                                                              Y2="{Binding Y2}"
                                                              Stroke="{DynamicResource BrushAccent}"
                                                              StrokeThickness="{Binding StrokeThickness}"
                                                              StrokeStartLineCap="Round"
                                                              StrokeEndLineCap="Round"
                                                              Opacity="0.55" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <ItemsControl ItemTemplate="{StaticResource TasteGraphNodeTemplate}" ItemsSource="{Binding TasteGraphNodes}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <Canvas />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemContainerStyle>
                                                    <Style TargetType="ContentPresenter">
                                                        <Setter Property="Canvas.Left" Value="{Binding X}" />
                                                        <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                                    </Style>
                                                </ItemsControl.ItemContainerStyle>
                                            </ItemsControl>
                                            <StackPanel Canvas.Left="24" Canvas.Top="392" Orientation="Horizontal">
                                                <TextBlock Text="出现频率" Style="{StaticResource BodyMutedTextStyle}" />
                                                <Border Width="92" Height="4" Margin="12,8,8,0" CornerRadius="999" Background="{DynamicResource BrushAccentSoft}" />
                                                <Border Width="92" Height="7" Margin="0,6,8,0" CornerRadius="999" Background="{DynamicResource BrushAccent}" />
                                                <TextBlock Text="{Binding TasteGraphLegendText}" Style="{StaticResource BodyMutedTextStyle}" />
                                            </StackPanel>
                                        </Canvas>
                                    </Viewbox>
                                </Border>
                            </StackPanel>

                            <Border Grid.Column="2" Style="{StaticResource StatisticsChartPanelStyle}">
                                <StackPanel>
                                    <TextBlock Text="高频组合 Top10" Style="{StaticResource SectionTitleTextStyle}" />
                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource InsightEmptyBorderStyle}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Setter Property="Margin" Value="0,12,0,0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasTasteCombinationData}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="暂无高频口味组合。" TextWrapping="Wrap" Style="{StaticResource BodyMutedTextStyle}" />
                                    </Border>
                                    <ItemsControl Margin="0,14,0,0" ItemsSource="{Binding TasteCombinationTop10}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="34" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="72" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Style="{StaticResource StatisticsRankBadgeStyle}">
                                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="{Binding Rank}" Style="{StaticResource BodyTextStyle}" />
                                                    </Border>
                                                    <StackPanel Grid.Column="1" Margin="10,0">
                                                        <WrapPanel>
                                                            <Border Margin="0,0,6,6" Padding="8,4" CornerRadius="999" Background="{DynamicResource BrushInfoBackground}" BorderBrush="{DynamicResource BrushInfoBorder}" BorderThickness="1">
                                                                <TextBlock MaxWidth="92" helpers:TrimmedTextToolTipBehavior.FullText="{Binding TypeLabel}" Text="{Binding TypeLabel}" TextTrimming="CharacterEllipsis" Style="{StaticResource BodyTextStyle}" />
                                                            </Border>
                                                            <Border Margin="0,0,6,6" Padding="8,4" CornerRadius="999" Background="{DynamicResource BrushAccentSoft}" BorderBrush="{DynamicResource BrushAccent}" BorderThickness="1">
                                                                <TextBlock MaxWidth="92" helpers:TrimmedTextToolTipBehavior.FullText="{Binding EmotionLabel}" Text="{Binding EmotionLabel}" TextTrimming="CharacterEllipsis" Style="{StaticResource BodyTextStyle}" />
                                                            </Border>
                                                            <Border Margin="0,0,0,6" Padding="8,4" CornerRadius="999" Background="{DynamicResource BrushSuccessBackground}" BorderBrush="{DynamicResource BrushSuccessBorder}" BorderThickness="1">
                                                                <TextBlock MaxWidth="92" helpers:TrimmedTextToolTipBehavior.FullText="{Binding SceneLabel}" Text="{Binding SceneLabel}" TextTrimming="CharacterEllipsis" Style="{StaticResource BodyTextStyle}" />
                                                            </Border>
                                                        </WrapPanel>
                                                        <ProgressBar Margin="0,2,0,0" Height="7" Maximum="100" Value="{Binding ProgressValue, Mode=OneWay}" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2" HorizontalAlignment="Right" Text="{Binding OccurrenceText}" Style="{StaticResource BodyMutedTextStyle}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>
                </Grid>
            </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
