<UserControl x:Class="MediaLibrary.App.Views.Pages.WatchInsightsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:MediaLibrary.App.Helpers"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="InsightModernScrollBarThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border x:Name="ThumbRoot"
                                Margin="3"
                                Background="#66FFFFFF"
                                CornerRadius="4"
                                Opacity="0.75" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbRoot" Property="Opacity" Value="1" />
                                <Setter TargetName="ThumbRoot" Property="Background" Value="#99FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbRoot" Property="Opacity" Value="1" />
                                <Setter TargetName="ThumbRoot" Property="Background" Value="#CCFFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InsightModernScrollRepeatButtonStyle" TargetType="{x:Type RepeatButton}">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InsightModernScrollBarStyle" TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="10" />
            <Setter Property="MinWidth" Value="10" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Style="{StaticResource InsightModernScrollRepeatButtonStyle}" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource InsightModernScrollBarThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Style="{StaticResource InsightModernScrollRepeatButtonStyle}" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=(helpers:ScrollBarAutoRevealBehavior.IsRevealed)}" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WatchInsightsManualProfileTabButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource PageTopManualTabButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsProfileTabSelected, RelativeSource={RelativeSource AncestorType=TabControl}}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WatchInsightsManualStatisticsTabButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource PageTopManualLastTabButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsStatisticsTabSelected, RelativeSource={RelativeSource AncestorType=TabControl}}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WatchInsightsHiddenHeaderTabControlStyle" TargetType="{x:Type TabControl}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabControl}">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Border Style="{StaticResource PageTopTabDividerStyle}" />
                                <StackPanel HorizontalAlignment="Left"
                                            VerticalAlignment="Bottom"
                                            Orientation="Horizontal">
                                    <Button Content="画像分析"
                                            Command="{Binding DataContext.SelectTabCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                            CommandParameter="0"
                                            Style="{StaticResource WatchInsightsManualProfileTabButtonStyle}" />
                                    <Button Content="观影统计"
                                            Command="{Binding DataContext.SelectTabCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                            CommandParameter="1"
                                            Style="{StaticResource WatchInsightsManualStatisticsTabButtonStyle}" />
                                </StackPanel>
                                <TabPanel x:Name="HeaderPanel"
                                          Height="0"
                                          HorizontalAlignment="Left"
                                          IsHitTestVisible="False"
                                          IsItemsHost="True"
                                          KeyboardNavigation.TabIndex="1"
                                          Opacity="0" />
                            </Grid>

                            <ContentPresenter x:Name="PART_SelectedContentHost"
                                              Grid.Row="1"
                                              Margin="0,22,0,0"
                                              ContentSource="SelectedContent" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InsightCardHeaderStyle" TargetType="TextBlock" BasedOn="{StaticResource CardTitleTextStyle}">
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="InsightChipBorderStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Background" Value="{DynamicResource BrushAccentSoft}" />
        </Style>

        <Style x:Key="InsightEmptyBorderStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,14,0,0" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Background" Value="{DynamicResource BrushSurfaceAlt}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="CalendarDayButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="52" />
            <Setter Property="Margin" Value="3" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="Background" Value="{DynamicResource BrushSurfaceAlt}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="DayBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="DayBorder" Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPlaceholder}" Value="True">
                    <Setter Property="Visibility" Value="Hidden" />
                    <Setter Property="IsEnabled" Value="False" />
                </DataTrigger>
                <DataTrigger Binding="{Binding HeatLevel}" Value="1">
                    <Setter Property="Background" Value="{DynamicResource BrushInfoBackground}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushInfoBorder}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding HeatLevel}" Value="2">
                    <Setter Property="Background" Value="{DynamicResource BrushAccentSoft}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding HeatLevel}" Value="3">
                    <Setter Property="Background" Value="{DynamicResource BrushWarningBackground}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushWarningBorder}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding HeatLevel}" Value="4">
                    <Setter Property="Background" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="Foreground" Value="{DynamicResource BrushOnAccent}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BubbleBorderStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,12,12" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Background" Value="{DynamicResource BrushAccentSoft}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Kind}" Value="场景">
                    <Setter Property="Background" Value="{DynamicResource BrushSurfaceAlt}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ProfileInnerPanelStyle" TargetType="{x:Type Border}">
            <Setter Property="Padding" Value="16" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Background" Value="{DynamicResource BrushSurfaceAlt}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="ProfileDnaIconStyle" TargetType="{x:Type Border}">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="48" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Background" Value="{DynamicResource BrushAccentSoft}" />
        </Style>

        <Style x:Key="ProfileSmallRankStyle" TargetType="{x:Type Border}">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Background" Value="{DynamicResource BrushAccentSoft}" />
        </Style>

        <Style x:Key="ProfileInlineProgressStyle" TargetType="{x:Type ProgressBar}">
            <Setter Property="Height" Value="7" />
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="100" />
        </Style>

        <Style x:Key="StatisticsRangeButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="MinWidth" Value="72" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="14,0" />
        </Style>

        <Style x:Key="StatisticsMonthRangeButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource StatisticsRangeButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMonthRangeSelected}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="Foreground" Value="{DynamicResource BrushOnAccent}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StatisticsAllRangeButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource StatisticsRangeButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsAllRangeSelected}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="Foreground" Value="{DynamicResource BrushOnAccent}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StatisticsMetricPanelStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource ProfileInnerPanelStyle}">
            <Setter Property="MinHeight" Value="116" />
        </Style>

        <Style x:Key="StatisticsLegendSwatchStyle" TargetType="{x:Type Border}">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="12" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Background" Value="{DynamicResource BrushSurfaceAlt}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <DataTemplate x:Key="ChipTemplate">
            <Border Style="{StaticResource InsightChipBorderStyle}">
                <TextBlock Text="{Binding Label}" Style="{StaticResource BodyTextStyle}" />
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="StatisticsOverviewCardTemplate">
            <Border Margin="0,0,12,12"
                    MinHeight="156"
                    Style="{StaticResource StatisticsMetricPanelStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border x:Name="StatusIcon"
                                Width="38"
                                Height="38"
                                CornerRadius="12"
                                Background="{DynamicResource BrushAccentSoft}"
                                BorderBrush="{DynamicResource BrushBorder}"
                                BorderThickness="1">
                            <TextBlock x:Name="StatusIconText"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Text="{Binding IconText}"
                                       Style="{StaticResource BodyTextStyle}" />
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Title}" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Margin="0,2,0,0"
                                       Text="{Binding Subtitle}"
                                       TextWrapping="Wrap"
                                       Style="{StaticResource BodyMutedTextStyle}" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Row="1"
                                Margin="0,16,0,0"
                                Orientation="Horizontal"
                                VerticalAlignment="Bottom">
                        <TextBlock Text="{Binding ValueText}" Style="{StaticResource MetricTextStyle}" />
                        <TextBlock Margin="6,12,0,0"
                                   Text="{Binding UnitText}"
                                   Style="{StaticResource BodyMutedTextStyle}" />
                    </StackPanel>

                    <TextBlock Grid.Row="2"
                               Margin="0,10,0,0"
                               Text="{Binding DeltaText}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasDelta}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding Kind}" Value="watched">
                    <Setter TargetName="StatusIcon" Property="Background" Value="{DynamicResource BrushInfoBackground}" />
                    <Setter TargetName="StatusIcon" Property="BorderBrush" Value="{DynamicResource BrushInfoBorder}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="favorite">
                    <Setter TargetName="StatusIcon" Property="Background" Value="{DynamicResource BrushAccentSoft}" />
                    <Setter TargetName="StatusIcon" Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="want">
                    <Setter TargetName="StatusIcon" Property="Background" Value="{DynamicResource BrushSuccessBackground}" />
                    <Setter TargetName="StatusIcon" Property="BorderBrush" Value="{DynamicResource BrushSuccessBorder}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="negative">
                    <Setter TargetName="StatusIcon" Property="Background" Value="{DynamicResource BrushWarningBackground}" />
                    <Setter TargetName="StatusIcon" Property="BorderBrush" Value="{DynamicResource BrushWarningBorder}" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate x:Key="ProfileDnaCardTemplate">
            <Border Margin="0,0,14,14"
                    MinHeight="184"
                    Style="{StaticResource ProfileInnerPanelStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource ProfileDnaIconStyle}">
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Text="{Binding IconText}"
                                       Style="{StaticResource SectionTitleTextStyle}" />
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Gene}" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Margin="0,4,0,0"
                                       Text="{Binding Subtitle}"
                                       TextWrapping="Wrap"
                                       Style="{StaticResource BodyMutedTextStyle}" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,14,0,0">
                        <ItemsControl ItemsSource="{Binding Tags}" ItemTemplate="{StaticResource ChipTemplate}">
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasTags}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>

                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsProgressGene}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <ProgressBar Style="{StaticResource ProfileInlineProgressStyle}"
                                         Value="{Binding Score, Mode=OneWay}" />
                            <Grid Grid.Row="1" Margin="0,7,0,0">
                                <TextBlock Text="{Binding LeftLabel}" Style="{StaticResource BodyMutedTextStyle}" />
                                <TextBlock HorizontalAlignment="Right"
                                           Text="{Binding RightLabel}"
                                           Style="{StaticResource BodyMutedTextStyle}" />
                            </Grid>
                        </Grid>
                    </Grid>

                    <TextBlock Grid.Row="2"
                               Margin="0,12,0,0"
                               Text="{Binding Description}"
                               TextWrapping="Wrap"
                               Style="{StaticResource BodyMutedTextStyle}" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="ProfileWatchLikeGroupTemplate">
            <Border Margin="0,0,14,0"
                    MinHeight="214"
                    Style="{StaticResource ProfileInnerPanelStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding Title}" Style="{StaticResource SectionTitleTextStyle}" />
                    <TextBlock Margin="0,4,0,0"
                               Text="{Binding Subtitle}"
                               TextWrapping="Wrap"
                               Style="{StaticResource BodyMutedTextStyle}" />
                    <ItemsControl Margin="0,16,0,0" ItemsSource="{Binding Items}">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasItems}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="34" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource ProfileSmallRankStyle}">
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding Rank}"
                                                   Style="{StaticResource BodyTextStyle}" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                        <TextBlock Text="{Binding Label}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Style="{StaticResource BodyTextStyle}" />
                                        <ProgressBar Margin="0,7,0,0"
                                                     Style="{StaticResource ProfileInlineProgressStyle}"
                                                     Value="{Binding ProgressValue, Mode=OneWay}" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="暂无足够数据">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasItems}" Value="False">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="InsightModuleStateTemplate">
            <Border Margin="0,0,0,16"
                    Padding="16"
                    CornerRadius="12"
                    Background="{DynamicResource BrushSurfaceAlt}"
                    BorderBrush="{DynamicResource BrushBorder}"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border MinWidth="86"
                            Height="28"
                            Padding="10,0"
                            CornerRadius="999"
                            Background="{DynamicResource BrushAccentSoft}">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="{Binding Kind}"
                                   TextTrimming="CharacterEllipsis"
                                   Style="{StaticResource BodyTextStyle}" />
                    </Border>

                    <StackPanel Grid.Column="1" Margin="14,0,0,0">
                        <TextBlock Text="{Binding Title}"
                                   TextWrapping="Wrap"
                                   Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="{Binding Message}"
                                   TextWrapping="Wrap"
                                   Style="{StaticResource BodyMutedTextStyle}" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <TabControl SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}"
                    ItemContainerStyle="{StaticResource PageTopTabItemStyle}"
                    Style="{StaticResource WatchInsightsHiddenHeaderTabControlStyle}">
            <TabItem Header="画像分析">
                <ScrollViewer Padding="0,0,8,0"
                              helpers:ScrollBarAutoRevealBehavior.IsEnabled="True"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <ScrollViewer.Resources>
                        <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource InsightModernScrollBarStyle}" />
                    </ScrollViewer.Resources>
                    <StackPanel>
                        <ContentControl Content="{Binding ProfileModuleState}"
                                        ContentTemplate="{StaticResource InsightModuleStateTemplate}"
                                        Visibility="{Binding ShowProfileModuleState, Converter={StaticResource BooleanToVisibilityConverter}}" />

                    <Border Style="{StaticResource PageCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="340" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Left">
                                        <TextBlock Text="观影口味总结" Style="{StaticResource InsightCardHeaderStyle}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Text="根据你的标记影片生成"
                                                   TextWrapping="Wrap"
                                                   Style="{StaticResource BodyMutedTextStyle}" />
                                    </StackPanel>
                                    <Button DockPanel.Dock="Right"
                                            Width="120"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Content="{Binding ProfileRefreshButtonText}"
                                            Command="{Binding RefreshProfileCommand}"
                                            Style="{StaticResource PrimaryButtonStyle}" />
                                </DockPanel>

                                <Border Margin="0,16,0,0"
                                        MinHeight="142"
                                        Style="{StaticResource ProfileInnerPanelStyle}">
                                    <Grid>
                                        <TextBlock Text="{Binding ProfileSummaryText}"
                                                   TextWrapping="Wrap">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource BodyTextStyle}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasProfileSummary}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding ProfileHeroSubtitle}"
                                                   TextWrapping="Wrap">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasProfileSummary}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Border>

                                <WrapPanel Margin="0,14,0,0">
                                    <Border Style="{StaticResource InsightChipBorderStyle}">
