                        <Grid Height="18" ClipToBounds="False" SnapsToDevicePixels="True">
                            <Border x:Name="PART_Track"
                                    Height="4"
                                    VerticalAlignment="Center"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="2" />
                            <Grid x:Name="PART_Indicator"
                                  Height="18"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Center"
                                  ClipToBounds="False">
                                <Border Height="4"
                                        VerticalAlignment="Center"
                                        Background="{TemplateBinding Foreground}"
                                        CornerRadius="2" />
                                <Grid Width="14"
                                      Height="14"
                                      Margin="0,0,-7,0"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      Panel.ZIndex="2"
                                      RenderTransformOrigin="0.5,0.5">
                                    <Grid.RenderTransform>
                                        <ScaleTransform ScaleX="1" ScaleY="1" />
                                    </Grid.RenderTransform>
                                    <Ellipse Width="12"
                                             Height="12"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Opacity="0.24">
                                        <Ellipse.Fill>
                                            <RadialGradientBrush>
                                                <GradientStop Offset="0" Color="{DynamicResource ColorWatchInsightsDnaIndicatorGlow}" />
                                                <GradientStop Offset="0.32" Color="{DynamicResource ColorWatchInsightsDnaIndicatorGlow}" />
                                                <GradientStop Offset="1" Color="{DynamicResource ColorWatchInsightsDnaIndicatorGlowEdge}" />
                                            </RadialGradientBrush>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                    <Ellipse Width="7"
                                             Height="7"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Fill="{DynamicResource BrushWatchInsightsDnaIndicator}" />
                                    <Grid.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard AutoReverse="True"
                                                            RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="0.78"
                                                                     To="1"
                                                                     Duration="0:0:1.35" />
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                     From="0.90"
                                                                     To="1.12"
                                                                     Duration="0:0:1.35" />
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                     From="0.90"
                                                                     To="1.12"
                                                                     Duration="0:0:1.35" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Grid.Triggers>
                                </Grid>
                            </Grid>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

