<UserControl x:Class="MediaLibrary.App.Views.Pages.WatchInsightsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MediaLibrary.App.Controls"
             xmlns:helpers="clr-namespace:MediaLibrary.App.Helpers"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <SolidColorBrush x:Key="InsightMediaProgressFillBrush" Color="{DynamicResource ColorWatchProgressFill}" />
        <SolidColorBrush x:Key="InsightMediaProgressTrackBrush" Color="{DynamicResource ColorWatchInsightsProgressTrack}" />
        <LinearGradientBrush x:Key="TasteGraphTypeEmotionLinkBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Offset="0" Color="{DynamicResource ColorInfoBorder}" />
            <GradientStop Offset="1" Color="{DynamicResource ColorAccent}" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="TasteGraphEmotionSceneLinkBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Offset="0" Color="{DynamicResource ColorAccent}" />
            <GradientStop Offset="1" Color="{DynamicResource ColorWatchInsightsDnaSceneBorder}" />
        </LinearGradientBrush>
        <Style x:Key="TasteGraphLinkPathStyle" TargetType="{x:Type Path}">
            <Setter Property="Fill" Value="{x:Null}" />
            <Setter Property="IsHitTestVisible" Value="False" />
            <Setter Property="Stroke" Value="{StaticResource TasteGraphTypeEmotionLinkBrush}" />
            <Setter Property="StrokeStartLineCap" Value="Round" />
            <Setter Property="StrokeEndLineCap" Value="Round" />
            <Setter Property="StrokeLineJoin" Value="Round" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding SourceKind}" Value="emotion">
                    <Setter Property="Stroke" Value="{StaticResource TasteGraphEmotionSceneLinkBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <BlurEffect x:Key="TasteGraphSelectedLinkGlowEffect"
                    Radius="5"
                    RenderingBias="Performance" />
        <SolidColorBrush x:Key="ProfileLeadBracketBrush"
                         Color="{DynamicResource ColorWatchInsightsProfileLeadBracket}" />

        <Style x:Key="ProfileLeadBracketRunStyle" TargetType="{x:Type Run}">
            <Setter Property="Foreground" Value="{StaticResource ProfileLeadBracketBrush}" />
            <Setter Property="FontSize" Value="30" />
            <Setter Property="FontWeight" Value="ExtraBold" />
        </Style>

        <Style x:Key="ProfileLeadRightBracketRunStyle" TargetType="{x:Type Run}" BasedOn="{StaticResource ProfileLeadBracketRunStyle}">
            <Setter Property="BaselineAlignment" Value="TextBottom" />
        </Style>

        <Style x:Key="ProfileLeadBracketTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource ProfileLeadBracketBrush}" />
            <Setter Property="FontSize" Value="30" />
            <Setter Property="FontWeight" Value="ExtraBold" />
            <Setter Property="LineHeight" Value="34" />
            <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}}"
                             Value="False">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ProfileLeadRightBracketTextStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource ProfileLeadBracketTextStyle}">
            <Setter Property="Margin" Value="4,11,0,0" />
        </Style>

        <Style x:Key="InsightMediaProgressBarStyle" TargetType="{x:Type ProgressBar}">
            <Setter Property="Height" Value="4" />
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="Background" Value="{StaticResource InsightMediaProgressTrackBrush}" />
            <Setter Property="Foreground" Value="{StaticResource InsightMediaProgressFillBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ProgressBar}">
                        <Grid Height="{TemplateBinding Height}" SnapsToDevicePixels="True">
                            <Border x:Name="PART_Track"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="2" />
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="2" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InsightModernScrollBarThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border x:Name="ThumbRoot"
                                Width="6"
                                Background="{DynamicResource BrushForegroundMuted}"
                                CornerRadius="3"
                                Opacity="0.58" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbRoot" Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbRoot" Property="Opacity" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InsightModernScrollRepeatButtonStyle" TargetType="{x:Type RepeatButton}">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InsightModernScrollBarStyle" TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="18" />
            <Setter Property="MinWidth" Value="18" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Width="{TemplateBinding Width}" Background="Transparent">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True"
                                   Maximum="{TemplateBinding Maximum}"
                                   Minimum="{TemplateBinding Minimum}"
                                   Orientation="{TemplateBinding Orientation}"
                                   Value="{TemplateBinding Value}"
                                   ViewportSize="{TemplateBinding ViewportSize}">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Style="{StaticResource InsightModernScrollRepeatButtonStyle}" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource InsightModernScrollBarThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Style="{StaticResource InsightModernScrollRepeatButtonStyle}" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
                <Trigger Property="IsMouseCaptureWithin" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType={x:Type ScrollViewer}}}" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </DataTrigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=(helpers:ScrollBarAutoRevealBehavior.IsRevealed)}" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WatchInsightsManualTabButtonBaseStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource PageTopManualTabButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid Width="{TemplateBinding Width}"
                              Height="{TemplateBinding Height}"
                              Background="{TemplateBinding Background}"
                              ClipToBounds="False"
                              SnapsToDevicePixels="True">
                            <TextBlock x:Name="TabLabel"
                                       Width="{TemplateBinding Width}"
                                       Margin="0,0,0,8"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Bottom"
                                       FontFamily="{TemplateBinding FontFamily}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       Foreground="{TemplateBinding Foreground}"
                                       Text="{TemplateBinding Content}"
                                       TextAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />
                            <Border Width="{TemplateBinding Width}"
                                    Height="4"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Bottom"
                                    Background="{TemplateBinding BorderBrush}" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource BrushWatchInsightsChromeAccentForeground}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                                <Setter TargetName="TabLabel" Property="Effect" Value="{StaticResource WatchInsightsTabChromeTextEffect}" />
                            </Trigger>
                            <Trigger Property="Tag" Value="Selected">
                                <Setter Property="Foreground" Value="{DynamicResource BrushWatchInsightsChromeAccentForeground}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                                <Setter TargetName="TabLabel" Property="Effect" Value="{StaticResource WatchInsightsTabChromeTextEffect}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Cursor" Value="Arrow" />
                                <Setter Property="Opacity" Value="0.48" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WatchInsightsManualProfileTabButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource WatchInsightsManualTabButtonBaseStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsProfileTabSelected, RelativeSource={RelativeSource AncestorType=TabControl}}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource BrushWatchInsightsChromeAccentForeground}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="Tag" Value="Selected" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WatchInsightsManualStatisticsTabButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource WatchInsightsManualTabButtonBaseStyle}">
            <Setter Property="Margin" Value="0" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsStatisticsTabSelected, RelativeSource={RelativeSource AncestorType=TabControl}}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource BrushWatchInsightsChromeAccentForeground}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="Tag" Value="Selected" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WatchInsightsTabStatusTextStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource BodyMutedTextStyle}">
            <Setter Property="Foreground" Value="{DynamicResource BrushWatchInsightsChromeMutedForeground}" />
            <Setter Property="Effect" Value="{StaticResource WatchInsightsChromeTextEffect}" />
        </Style>

        <Style x:Key="WatchInsightsProfileTabActionPanelStyle" TargetType="{x:Type StackPanel}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsProfileTabSelected, RelativeSource={RelativeSource AncestorType=TabControl}}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WatchInsightsStatisticsTabActionPanelStyle" TargetType="{x:Type StackPanel}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsStatisticsTabSelected, RelativeSource={RelativeSource AncestorType=TabControl}}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WatchInsightsRefreshIconButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
            <Setter Property="ToolTip" Value="刷新画像" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource BrushAccent}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.72" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Cursor" Value="Arrow" />
                                <Setter Property="Opacity" Value="0.72" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WatchInsightsRefreshGlyphBaseStyle" TargetType="{x:Type controls:PhosphorIcon}">
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
            <Setter Property="Icon" Value="arrows-clockwise" />
            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <RotateTransform Angle="0" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WatchInsightsRefreshGlyphStyle" TargetType="{x:Type controls:PhosphorIcon}" BasedOn="{StaticResource WatchInsightsRefreshGlyphBaseStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsProfileRefreshAnimating, RelativeSource={RelativeSource AncestorType=TabControl}}" Value="True">
                    <Setter Property="Icon" Value="spinner-gap" />
                    <DataTrigger.EnterActions>
                        <BeginStoryboard Name="ProfileRefreshSpinStoryboard">
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                 From="0"
                                                 To="360"
                                                 Duration="0:0:0.9" />
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <StopStoryboard BeginStoryboardName="ProfileRefreshSpinStoryboard" />
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WatchInsightsStatisticsRefreshGlyphStyle" TargetType="{x:Type controls:PhosphorIcon}" BasedOn="{StaticResource WatchInsightsRefreshGlyphBaseStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsStatisticsRefreshAnimating, RelativeSource={RelativeSource AncestorType=TabControl}}" Value="True">
                    <Setter Property="Icon" Value="spinner-gap" />
                    <DataTrigger.EnterActions>
                        <BeginStoryboard Name="StatisticsRefreshSpinStoryboard">
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                 From="0"
                                                 To="360"
                                                 Duration="0:0:0.9" />
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <StopStoryboard BeginStoryboardName="StatisticsRefreshSpinStoryboard" />
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WatchInsightsHiddenHeaderTabControlStyle" TargetType="{x:Type TabControl}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0,16,0,0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabControl}">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="48" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0"
                                  ClipToBounds="False"
                                  Panel.ZIndex="2"
                                  SnapsToDevicePixels="True">
                                <Border Height="2"
                                        VerticalAlignment="Bottom"
                                        Background="{DynamicResource BrushWatchInsightsChromeLine}"
                                        IsHitTestVisible="False"
                                        Panel.ZIndex="1" />
                                <StackPanel Panel.ZIndex="2"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Bottom"
                                            ClipToBounds="False"
                                            Orientation="Horizontal">
                                    <Button Content="画像分析"
                                            Command="{Binding DataContext.SelectTabCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                            CommandParameter="0"
                                            Style="{StaticResource WatchInsightsManualProfileTabButtonStyle}" />
                                     <Button Content="观影统计"
                                            Command="{Binding DataContext.SelectTabCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                            CommandParameter="1"
                                            Style="{StaticResource WatchInsightsManualStatisticsTabButtonStyle}" />
                                </StackPanel>
                                <StackPanel Panel.ZIndex="3"
                                            Margin="0,0,28,4"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom"
                                            ClipToBounds="False"
                                            Orientation="Horizontal"
                                            Style="{StaticResource WatchInsightsProfileTabActionPanelStyle}">
                                    <TextBlock Width="420"
                                               Margin="0,0,10,0"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               TextAlignment="Right"
                                               Text="{Binding DataContext.ProfileRefreshStatusText, RelativeSource={RelativeSource TemplatedParent}}"
                                               TextWrapping="NoWrap"
                                               Style="{StaticResource WatchInsightsTabStatusTextStyle}" />
                                    <Button Command="{Binding DataContext.RefreshProfileCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                            Style="{StaticResource WatchInsightsRefreshIconButtonStyle}">
                                        <controls:PhosphorIcon Style="{StaticResource WatchInsightsRefreshGlyphStyle}" />
                                    </Button>
                                </StackPanel>
                                <StackPanel Panel.ZIndex="3"
                                            Margin="0,0,28,4"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom"
                                            ClipToBounds="False"
                                            Orientation="Horizontal"
                                            Style="{StaticResource WatchInsightsStatisticsTabActionPanelStyle}">
                                    <TextBlock Width="420"
                                               Margin="0,0,10,0"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               TextAlignment="Right"
                                               Text="{Binding DataContext.StatisticsRefreshStatusText, RelativeSource={RelativeSource TemplatedParent}}"
                                               TextWrapping="NoWrap"
                                               Style="{StaticResource WatchInsightsTabStatusTextStyle}" />
                                    <Button Command="{Binding DataContext.RefreshStatisticsCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                            Style="{StaticResource WatchInsightsRefreshIconButtonStyle}"
                                            ToolTip="刷新统计">
                                        <controls:PhosphorIcon Style="{StaticResource WatchInsightsStatisticsRefreshGlyphStyle}" />
                                    </Button>
                                </StackPanel>
                                <TabPanel x:Name="HeaderPanel"
                                          Panel.ZIndex="0"
                                          Height="0"
                                          HorizontalAlignment="Left"
                                          IsHitTestVisible="False"
                                          IsItemsHost="True"
                                          KeyboardNavigation.TabIndex="1"
                                          Opacity="0" />
                            </Grid>

                            <ContentPresenter x:Name="PART_SelectedContentHost"
                                              Grid.Row="1"
                                              Panel.ZIndex="0"
                                              Margin="{TemplateBinding Padding}"
                                              ContentSource="SelectedContent" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InsightCardHeaderStyle" TargetType="TextBlock" BasedOn="{StaticResource CardTitleTextStyle}">
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="InsightChipBorderStyle" TargetType="{x:Type helpers:CachedShadowBorder}">
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Background" Value="{DynamicResource BrushAccentSoft}" />
            <Setter Property="Effect" Value="{x:Null}" />
            <Setter Property="ClipToBounds" Value="False" />
            <Setter Property="ShadowPadding" Value="20" />
            <Setter Property="ShadowBlurRadius" Value="18" />
            <Setter Property="ShadowOpacity" Value="0.26" />
            <Setter Property="ShadowColor" Value="{DynamicResource ColorCachedShadowInline}" />
            <Setter Property="ShadowDepth" Value="{DynamicResource CachedShadowInlineDepth}" />
        </Style>

        <Style x:Key="InsightEmptyBorderStyle" TargetType="{x:Type helpers:CachedShadowBorder}">
            <Setter Property="Margin" Value="0,14,0,0" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Background" Value="{DynamicResource BrushSurfaceAlt}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Effect" Value="{x:Null}" />
            <Setter Property="ClipToBounds" Value="False" />
            <Setter Property="ShadowPadding" Value="32" />
            <Setter Property="ShadowBlurRadius" Value="{DynamicResource CachedShadowInlineBlurRadius}" />
            <Setter Property="ShadowOpacity" Value="{DynamicResource CachedShadowInlineOpacity}" />
            <Setter Property="ShadowColor" Value="{DynamicResource ColorCachedShadowInline}" />
            <Setter Property="ShadowDepth" Value="{DynamicResource CachedShadowInlineDepth}" />
        </Style>

        <Style x:Key="CalendarDayButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="54" />
            <Setter Property="Margin" Value="10,5" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="Background" Value="{DynamicResource BrushSurfaceAlt}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <helpers:CachedShadowBorder x:Name="DayBorder"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    ClipToBounds="False"
                                                    CornerRadius="10"
                                                    Effect="{x:Null}"
                                                    ShadowBlurRadius="18"
                                                    ShadowColor="{DynamicResource ColorCachedShadowInline}"
                                              ShadowDepth="{DynamicResource CachedShadowInlineDepth}"
                                                    ShadowOpacity="0.24"
                                                    ShadowPadding="20">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                        </helpers:CachedShadowBorder>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="DayBorder" Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding HeatLevel}" Value="1">
                    <Setter Property="Background" Value="{DynamicResource BrushWatchInsightsCalendarLowBackground}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushWatchInsightsCalendarLowBorder}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding HeatLevel}" Value="2">
                    <Setter Property="Background" Value="{DynamicResource BrushAccentSoft}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding HeatLevel}" Value="3">
                    <Setter Property="Background" Value="{DynamicResource BrushWarningBackground}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushWarningBorder}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding HeatLevel}" Value="4">
                    <Setter Property="Background" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                    <Setter Property="Foreground" Value="{DynamicResource BrushOnAccent}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsCurrentMonth}" Value="False">
                    <Setter Property="Background" Value="{DynamicResource BrushSurfaceAlt}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
                    <Setter Property="Foreground" Value="{DynamicResource BrushForegroundMuted}" />
                    <Setter Property="Opacity" Value="0.42" />
                    <Setter Property="Cursor" Value="Arrow" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BubbleBorderStyle" TargetType="{x:Type helpers:CachedShadowBorder}">
            <Setter Property="Margin" Value="0,0,12,12" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Background" Value="{DynamicResource BrushAccentSoft}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Effect" Value="{x:Null}" />
            <Setter Property="ClipToBounds" Value="False" />
            <Setter Property="ShadowPadding" Value="24" />
            <Setter Property="ShadowBlurRadius" Value="{DynamicResource CachedShadowInlineBlurRadius}" />
            <Setter Property="ShadowOpacity" Value="0.26" />
            <Setter Property="ShadowColor" Value="{DynamicResource ColorCachedShadowInline}" />
            <Setter Property="ShadowDepth" Value="{DynamicResource CachedShadowInlineDepth}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Kind}" Value="场景">
                    <Setter Property="Background" Value="{DynamicResource BrushSurfaceAlt}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ProfileInnerPanelStyle" TargetType="{x:Type helpers:CachedShadowBorder}" BasedOn="{StaticResource GlassInlinePanelStyle}">
            <Setter Property="Padding" Value="16" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Effect" Value="{x:Null}" />
            <Setter Property="ClipToBounds" Value="False" />
            <Setter Property="ShadowPadding" Value="34" />
            <Setter Property="ShadowBlurRadius" Value="{DynamicResource CachedShadowInlineBlurRadius}" />
            <Setter Property="ShadowOpacity" Value="{DynamicResource CachedShadowInlineOpacity}" />
