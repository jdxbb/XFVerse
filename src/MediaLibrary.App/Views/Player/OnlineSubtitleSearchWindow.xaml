<Window x:Class="MediaLibrary.App.Views.Player.OnlineSubtitleSearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="{Binding WindowTitle}"
        Width="980"
        Height="720"
        MinWidth="820"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="False"
        Background="{DynamicResource BrushPlayerBackground}"
        Foreground="{DynamicResource BrushPlayerTextPrimary}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="BrushBackground" Color="{StaticResource ColorPlayerBackground}" />
        <SolidColorBrush x:Key="BrushSurface" Color="{StaticResource ColorPlayerDialogBackground}" />
        <SolidColorBrush x:Key="BrushSurfaceAlt" Color="{StaticResource ColorPlayerSurface}" />
        <SolidColorBrush x:Key="BrushSurfaceRaised" Color="{StaticResource ColorPlayerSurfaceElevated}" />
        <SolidColorBrush x:Key="BrushBorder" Color="{StaticResource ColorPlayerBorder}" />
        <SolidColorBrush x:Key="BrushDivider" Color="{StaticResource ColorPlayerBorder}" />
        <SolidColorBrush x:Key="BrushForegroundPrimary" Color="{StaticResource ColorPlayerTextPrimary}" />
        <SolidColorBrush x:Key="BrushForegroundSecondary" Color="{StaticResource ColorPlayerTextSecondary}" />
        <SolidColorBrush x:Key="BrushForegroundMuted" Color="{StaticResource ColorPlayerTextMuted}" />
        <SolidColorBrush x:Key="BrushAccent" Color="{StaticResource ColorPlayerAccent}" />
        <SolidColorBrush x:Key="BrushAccentHover" Color="{StaticResource ColorPlayerBuffering}" />
        <SolidColorBrush x:Key="BrushAccentPressed" Color="{StaticResource ColorPlayerAccent}" />
        <SolidColorBrush x:Key="BrushOnAccent" Color="{StaticResource ColorPlayerBackground}" />
        <SolidColorBrush x:Key="BrushDisabledBackground" Color="{StaticResource ColorPlayerSurface}" />
        <SolidColorBrush x:Key="BrushDisabledBorder" Color="{StaticResource ColorPlayerBorder}" />
        <SolidColorBrush x:Key="BrushDisabledForeground" Color="{StaticResource ColorPlayerDisabled}" />
        <SolidColorBrush x:Key="BrushHoverBackground" Color="{StaticResource ColorPlayerSurfaceElevated}" />
        <SolidColorBrush x:Key="BrushPressedBackground" Color="{StaticResource ColorPlayerSurface}" />
        <SolidColorBrush x:Key="BrushInputBackground" Color="{StaticResource ColorPlayerSurface}" />
        <SolidColorBrush x:Key="BrushInputBorder" Color="{StaticResource ColorPlayerBorder}" />
        <SolidColorBrush x:Key="BrushInputFocusBorder" Color="{StaticResource ColorPlayerAccent}" />
    </Window.Resources>

    <Grid Background="{DynamicResource BrushPlayerDialogBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource PlayerWindowCaptionStyle}"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid Margin="14,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding WindowTitle}"
                           Style="{StaticResource PlayerWindowCaptionTextStyle}" />
                <Button Grid.Column="1"
                        Content="&#xE8BB;"
                        ToolTip="关闭"
                        Click="CloseButton_Click"
                        Style="{StaticResource PlayerWindowCaptionCloseButtonStyle}" />
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Padding="22"
                Background="{DynamicResource BrushSurface}"
                BorderBrush="{DynamicResource BrushBorder}"
                BorderThickness="1,0,1,1">
            <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <StackPanel>
                    <TextBlock Text="搜索在线字幕"
                               Style="{StaticResource CardTitleTextStyle}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding ContextSummary}"
                               Style="{StaticResource BodyMutedTextStyle}" />
                    <TextBlock Margin="0,4,0,0"
                               Text="{Binding SafeFileNameHint}"
                               TextTrimming="CharacterEllipsis"
                               Style="{StaticResource BodyMutedTextStyle}" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="0,22,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="136" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="语言" Style="{StaticResource BodyTextStyle}" />
                    <ComboBox ItemsSource="{Binding Languages}"
                              SelectedItem="{Binding SelectedLanguage}"
                              DisplayMemberPath="Name"
                              Style="{StaticResource FormComboBoxStyle}" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="类型" Style="{StaticResource BodyTextStyle}" />
                    <ComboBox ItemsSource="{Binding Types}"
                              SelectedItem="{Binding SelectedType}"
                              DisplayMemberPath="DisplayName"
                              Style="{StaticResource FormComboBoxStyle}" />
                </StackPanel>

                <StackPanel Grid.Column="4">
                    <TextBlock Text="搜索关键词" Style="{StaticResource BodyTextStyle}" />
                    <TextBox x:Name="SearchTextBox"
                             Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             KeyDown="SearchTextBox_KeyDown"
                             Style="{StaticResource FormTextBoxStyle}" />
                </StackPanel>

                <Button Grid.Column="6"
                        Margin="0,27,0,0"
                        Height="40"
                        Content="搜索"
                        Command="{Binding SearchCommand}"
                        Style="{StaticResource PrimaryButtonStyle}" />
            </Grid>

            <Grid Grid.Row="2" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="排序" Style="{StaticResource BodyTextStyle}" />
                    <ComboBox ItemsSource="{Binding SortOptions}"
                              SelectedItem="{Binding SelectedSort}"
                              DisplayMemberPath="DisplayName"
                              Style="{StaticResource FormComboBoxStyle}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="18,24,0,0">
                    <TextBlock Text="{Binding QuotaHint}"
                               TextWrapping="Wrap"
                               Style="{StaticResource BodyMutedTextStyle}" />
                    <TextBlock Margin="0,6,0,0"
                               Text="{Binding StatusMessage}"
                               TextWrapping="Wrap"
                               Style="{StaticResource BodyMutedTextStyle}" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="3" Margin="0,18,0,0">
                <ProgressBar Height="4"
                             VerticalAlignment="Top"
                             IsIndeterminate="True">
                    <ProgressBar.Style>
                        <Style TargetType="ProgressBar">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ProgressBar.Style>
                </ProgressBar>

                <ListBox Margin="0,12,0,0"
                         ItemsSource="{Binding Results}">
                    <ListBox.Style>
                        <Style TargetType="ListBox" BasedOn="{StaticResource SectionListBoxStyle}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasResults}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.Style>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="150" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{Binding PrimaryText}"
                                           TextWrapping="Wrap"
                                           Style="{StaticResource SectionTitleTextStyle}" />
                                <StackPanel Grid.Column="1"
                                            HorizontalAlignment="Right">
                                    <TextBlock HorizontalAlignment="Right"
                                               Text="{Binding MatchScoreText}"
                                               Style="{StaticResource BodyMutedTextStyle}" />
                                    <Button Margin="0,8,0,0"
                                            MinWidth="92"
                                            Height="34"
                                            Content="{Binding DownloadButtonText}"
                                            Command="{Binding DownloadCommand}"
                                            Style="{StaticResource PrimaryButtonStyle}" />
                                    <TextBlock Margin="0,6,0,0"
                                               MaxWidth="150"
                                               Text="{Binding DownloadStatus}"
                                               TextAlignment="Right"
                                               TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDownloadStatusVisible}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>

                                <TextBlock Grid.Row="1"
                                           Grid.ColumnSpan="2"
                                           Margin="0,7,0,0"
                                           Text="{Binding SecondaryText}"
                                           TextWrapping="Wrap"
                                           Style="{StaticResource BodyMutedTextStyle}" />

                                <TextBlock Grid.Row="2"
                                           Grid.ColumnSpan="2"
                                           Margin="0,7,0,0"
                                           Text="{Binding MetricsText}"
                                           TextWrapping="Wrap"
                                           Style="{StaticResource BodyMutedTextStyle}" />

                                <StackPanel Grid.Row="3"
                                            Grid.ColumnSpan="2"
                                            Margin="0,10,0,0">
                                    <TextBlock Text="{Binding UploadedAtText}"
                                               Style="{StaticResource BodyMutedTextStyle}" />
                                    <ItemsControl Margin="0,8,0,0"
                                                  ItemsSource="{Binding Tags}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,8,6"
                                                        Padding="8,4"
                                                        CornerRadius="10"
                                                        Background="{DynamicResource BrushSurfaceRaised}"
                                                        BorderBrush="{DynamicResource BrushBorder}"
                                                        BorderThickness="1">
                                                    <TextBlock Text="{Binding}"
                                                               Style="{StaticResource BodyMutedTextStyle}" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <TextBlock Grid.Row="4"
                       Margin="0,12,0,0"
                       Text="{Binding TotalCount, StringFormat=OpenSubtitles 返回总数：{0}}"
                       Style="{StaticResource BodyMutedTextStyle}" />
            </Grid>
        </Border>
    </Grid>
</Window>
