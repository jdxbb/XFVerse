<Window x:Class="MediaLibrary.App.Views.Player.PlayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:MediaLibrary.App.Helpers"
        xmlns:player="clr-namespace:MediaLibrary.App.Views.Player"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="{Binding MovieTitle}"
        Width="1180"
        Height="760"
        MinWidth="900"
        MinHeight="600"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="False"
        Background="{DynamicResource BrushPlayerBackground}"
        Foreground="White"
        Focusable="True"
        KeyDown="Window_KeyDown"
        PreviewKeyDown="Window_KeyDown"
        PreviewMouseWheel="Window_PreviewMouseWheel"
        MouseMove="Window_MouseMove">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <helpers:PlayerMeterBrushConverter x:Key="PlayerMeterBrushConverter" />
    </Window.Resources>

    <Grid Background="{DynamicResource BrushPlayerBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border x:Name="PlayerTitleBar"
                Grid.Row="0"
                Style="{StaticResource PlayerWindowCaptionStyle}"
                MouseLeftButtonDown="PlayerTitleBar_MouseLeftButtonDown">
            <Grid Margin="22,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding MovieTitle}"
                           Style="{StaticResource PlayerWindowCaptionTextStyle}" />

                <StackPanel Grid.Column="1"
                             Margin="0,0,8,0"
                             Orientation="Horizontal"
                             VerticalAlignment="Center">
                    <Button x:Name="PlayerMinimizeButton"
                            Content="&#xE921;"
                            Click="PlayerMinimizeButton_Click"
                            Style="{StaticResource PlayerWindowCaptionButtonStyle}" />
                    <Button x:Name="PlayerMaximizeRestoreButton"
                            Content="&#xE922;"
                            Click="PlayerMaximizeRestoreButton_Click"
                            Style="{StaticResource PlayerWindowCaptionButtonStyle}" />
                    <Button x:Name="PlayerCloseButton"
                            Content="&#xE8BB;"
                            Click="PlayerCloseButton_Click"
                            Style="{StaticResource PlayerWindowCaptionCloseButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid x:Name="RootLayout"
              Grid.Row="1"
              Background="Transparent"
              PreviewMouseWheel="Window_PreviewMouseWheel"
              PreviewMouseMove="Window_MouseMove"
              PreviewMouseLeftButtonDown="VideoSurface_PreviewMouseLeftButtonDown"
              PreviewMouseRightButtonDown="PlayerSurface_PreviewMouseRightButton"
              PreviewMouseRightButtonUp="PlayerSurface_PreviewMouseRightButton">
        <Border Background="#05070A"
                PreviewMouseWheel="Window_PreviewMouseWheel"
                MouseMove="Window_MouseMove"
                PreviewMouseMove="Window_MouseMove"
                PreviewMouseLeftButtonDown="VideoSurface_PreviewMouseLeftButtonDown"
                PreviewMouseRightButtonDown="PlayerSurface_PreviewMouseRightButton"
                PreviewMouseRightButtonUp="PlayerSurface_PreviewMouseRightButton">
            <player:PlaybackHostView x:Name="PlaybackHost"
                                     PreviewMouseWheel="Window_PreviewMouseWheel"
                                     MouseMove="Window_MouseMove"
                                     PreviewMouseMove="Window_MouseMove"
                                     PreviewMouseLeftButtonDown="VideoSurface_PreviewMouseLeftButtonDown"
                                     PreviewMouseRightButtonDown="PlayerSurface_PreviewMouseRightButton"
                                     PreviewMouseRightButtonUp="PlayerSurface_PreviewMouseRightButton" />
        </Border>

        <Popup x:Name="PlayerTitleBarPopup"
               AllowsTransparency="True"
               Placement="Relative"
               PlacementTarget="{Binding ElementName=RootLayout}"
               StaysOpen="True">
            <Border x:Name="FullscreenPlayerTitleBar"
                    Width="{Binding ActualWidth, ElementName=RootLayout}"
                    Style="{StaticResource PlayerWindowCaptionStyle}"
                    MouseMove="Window_MouseMove"
                    PreviewMouseMove="Window_MouseMove"
                    MouseLeftButtonDown="PlayerTitleBar_MouseLeftButtonDown">
                <Grid Margin="22,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding MovieTitle}"
                               Style="{StaticResource PlayerWindowCaptionTextStyle}" />

                    <StackPanel Grid.Column="1"
                                 Margin="0,0,8,0"
                                 Orientation="Horizontal"
                                 VerticalAlignment="Center">
                        <Button x:Name="FullscreenPlayerMinimizeButton"
                                Content="&#xE921;"
                                Click="PlayerMinimizeButton_Click"
                                Style="{StaticResource PlayerWindowCaptionButtonStyle}" />
                        <Button x:Name="FullscreenPlayerMaximizeRestoreButton"
                                Content="&#xE922;"
                                Click="PlayerMaximizeRestoreButton_Click"
                                Style="{StaticResource PlayerWindowCaptionButtonStyle}" />
                        <Button x:Name="FullscreenPlayerCloseButton"
                                Content="&#xE8BB;"
                                Click="PlayerCloseButton_Click"
                                Style="{StaticResource PlayerWindowCaptionCloseButtonStyle}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Popup>

        <Popup x:Name="BufferingOverlayPopup"
               AllowsTransparency="True"
               DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
               IsHitTestVisible="False"
               IsOpen="{Binding IsBufferingOverlayVisible, Mode=OneWay}"
               Opened="PromptOverlayPopup_Opened"
               Placement="Relative"
               PlacementTarget="{Binding ElementName=RootLayout}"
               StaysOpen="True">
            <Grid x:Name="BufferingOverlayLayer"
                  Background="Transparent"
                  IsHitTestVisible="False">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsHitTestVisible="False">
                        <Grid Width="34"
                              Height="34"
                              HorizontalAlignment="Center">
                            <Ellipse Stroke="{DynamicResource BrushPlayerSliderTrack}"
                                     StrokeThickness="3" />
                            <Path Data="M17,2 A15,15 0 0 1 32,17"
                                  Stroke="{DynamicResource BrushPlayerAccent}"
                                  StrokeThickness="3"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round">
                                <Path.RenderTransform>
                                    <RotateTransform CenterX="17"
                                                     CenterY="17" />
                                </Path.RenderTransform>
                                <Path.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetProperty="(Path.RenderTransform).(RotateTransform.Angle)"
                                                                 From="0"
                                                                 To="360"
                                                                 Duration="0:0:0.9" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Path.Triggers>
                            </Path>
                        </Grid>
                        <TextBlock Margin="0,10,0,0"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource BrushPlayerTextPrimary}"
                                   FontFamily="{StaticResource FontFamilyBase}"
                                   FontSize="{StaticResource FontSizeBody}"
                                   FontWeight="SemiBold"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Text="{Binding BufferingOverlayText}" />
                </StackPanel>
            </Grid>
        </Popup>

        <Popup x:Name="OperationNoticePopup"
               AllowsTransparency="True"
               DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
               IsHitTestVisible="False"
               IsOpen="{Binding IsNoticeVisible, Mode=OneWay}"
               Opened="PromptOverlayPopup_Opened"
               Placement="Relative"
               PlacementTarget="{Binding ElementName=RootLayout}"
               StaysOpen="True">
            <Grid x:Name="OperationNoticeLayer"
                  Background="Transparent"
                  IsHitTestVisible="False">
                <Border HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,112"
                        Style="{StaticResource PlayerOverlayPanelStyle}"
                        IsHitTestVisible="False">
                    <TextBlock HorizontalAlignment="Center"
                               Foreground="{DynamicResource BrushPlayerTextPrimary}"
                               FontFamily="{StaticResource FontFamilyBase}"
                               FontSize="{StaticResource FontSizeBody}"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Text="{Binding DisplayNoticeText}" />
                </Border>
            </Grid>
        </Popup>

        <Popup x:Name="InteractionFeedbackPopup"
               AllowsTransparency="True"
               IsHitTestVisible="False"
               Placement="Relative"
               PlacementTarget="{Binding ElementName=RootLayout}"
               StaysOpen="True">
            <Grid x:Name="InteractionFeedbackLayer"
                  Background="Transparent"
                  IsHitTestVisible="False">
                <Border x:Name="BrightnessFeedback"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Margin="42,0,0,0"
                        Style="{StaticResource PlayerFeedbackPanelStyle}"
                        Visibility="Collapsed"
                        IsHitTestVisible="False">
                    <StackPanel HorizontalAlignment="Center">
                        <Viewbox Width="18" Height="18" HorizontalAlignment="Center">
                            <Canvas Width="24" Height="24">
                                <Ellipse Width="8" Height="8" Canvas.Left="8" Canvas.Top="8" Fill="{DynamicResource BrushPlayerTextPrimary}" />
                                <Path Stroke="{DynamicResource BrushPlayerTextPrimary}"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Data="M12,2 L12,4 M12,20 L12,22 M4.93,4.93 L6.34,6.34 M17.66,17.66 L19.07,19.07 M2,12 L4,12 M20,12 L22,12 M4.93,19.07 L6.34,17.66 M17.66,6.34 L19.07,4.93" />
                            </Canvas>
                        </Viewbox>
                        <TextBlock x:Name="BrightnessFeedbackText"
                                   Margin="0,10,0,0"
                                   Style="{StaticResource PlayerFeedbackPercentTextStyle}" />
                        <ProgressBar x:Name="BrightnessFeedbackBar"
                                     Margin="0,12,0,0"
                                     HorizontalAlignment="Center"
                                     Minimum="0"
                                     Maximum="100"
                                     Orientation="Vertical"
                                     Style="{StaticResource PlayerVerticalMeterStyle}" />
                    </StackPanel>
                </Border>

                <Border x:Name="VolumeFeedback"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,42,0"
                        Style="{StaticResource PlayerFeedbackPanelStyle}"
                        Visibility="Collapsed"
                        IsHitTestVisible="False">
                    <StackPanel HorizontalAlignment="Center">
                        <Viewbox Width="18" Height="18" HorizontalAlignment="Center">
                            <Canvas Width="24" Height="24">
                                <Path Fill="{DynamicResource BrushPlayerTextPrimary}"
                                      Data="M4,9 L8,9 L13,5 L13,19 L8,15 L4,15 Z" />
                                <Path Stroke="{DynamicResource BrushPlayerTextPrimary}"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Fill="Transparent"
                                      Data="M16,9 C17.2,10.5 17.2,13.5 16,15 M18.5,6.5 C21.5,9.5 21.5,14.5 18.5,17.5" />
                            </Canvas>
                        </Viewbox>
                        <TextBlock x:Name="VolumeFeedbackText"
                                   Margin="0,10,0,0"
                                   Style="{StaticResource PlayerFeedbackPercentTextStyle}" />
                        <Grid Margin="0,12,0,0"
                              Width="34"
                              Height="116"
                              HorizontalAlignment="Center">
                            <ProgressBar x:Name="VolumeFeedbackBar"
                                          HorizontalAlignment="Center"
                                          Minimum="0"
                                          Maximum="200"
                                          Orientation="Vertical"
                                          Style="{StaticResource PlayerVerticalMeterStyle}" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Popup>

        <Popup x:Name="ControlBarPopup"
               AllowsTransparency="True"
               DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
               Placement="Relative"
               PlacementTarget="{Binding ElementName=RootLayout}"
               StaysOpen="True">
            <Border x:Name="ControlBar"
                    Padding="16,7,16,17"
                    Background="{DynamicResource BrushPlayerControlBarBackground}"
                    BorderBrush="{DynamicResource BrushPlayerBorder}"
                    BorderThickness="1"
                    CornerRadius="14"
                    MouseMove="Window_MouseMove"
                    PreviewMouseLeftButtonDown="ControlBar_PreviewMouseLeftButtonDown"
                    PreviewMouseMove="Window_MouseMove"
                    PreviewMouseRightButtonDown="ControlBar_PreviewMouseRightButton"
                    PreviewMouseRightButtonUp="ControlBar_PreviewMouseRightButton"
                    SizeChanged="ControlBar_SizeChanged">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="6" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center">
                        <StackPanel.RenderTransform>
                            <TranslateTransform Y="-3" />
                        </StackPanel.RenderTransform>
                        <TextBlock x:Name="DisplayStatusTextBlock"
                                   MaxWidth="280"
                                   SizeChanged="DisplayStatusTextBlock_SizeChanged"
                                   TargetUpdated="DisplayStatusTextBlock_TargetUpdated"
                                   Text="{Binding DisplayStatusText, NotifyOnTargetUpdated=True}"
                                   Style="{StaticResource PlayerControlBarStatusTextStyle}" />
                        <TextBlock Margin="12,0,0,0"
                                   MaxWidth="320"
                                   Text="{Binding ResumeMessage}"
                                   Style="{StaticResource PlayerControlBarResumeTextStyle}" />
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Command="{Binding GoPreviousEpisodeCommand}"
                                Style="{StaticResource PlayerControlIconButtonStyle}">
                            <TextBlock Text="&#xE892;"
                                       Style="{StaticResource PlayerControlGlyphTextStyle}" />
                        </Button>
                        <Button Grid.Column="2"
                                Command="{Binding TogglePlayPauseCommand}"
                                Style="{StaticResource PlayerControlIconButtonStyle}">
                            <Grid Width="18" Height="18">
                                <TextBlock Text="&#xE768;">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource PlayerControlGlyphTextStyle}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding PlayPauseText}" Value="播放">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="&#xE769;">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource PlayerControlGlyphTextStyle}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding PlayPauseText}" Value="暂停">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Button>
                        <Button Grid.Column="4"
                                Command="{Binding GoNextEpisodeCommand}"
                                Style="{StaticResource PlayerControlIconButtonStyle}">
                            <TextBlock Text="&#xE893;"
                                       Style="{StaticResource PlayerControlGlyphTextStyle}" />
                        </Button>
                        <Grid Grid.Column="6"
                              Margin="0"
                              VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding PositionText}"
                                       Style="{StaticResource PlayerControlTimeTextStyle}" />
                            <Grid Grid.Column="1"
                                  Margin="8,0"
                                  MinWidth="90"
                                  VerticalAlignment="Center">
                                <ProgressBar IsHitTestVisible="False"
                                             Minimum="0"
                                             Maximum="{Binding DurationSeconds}"
                                             Value="{Binding PositionSeconds}"
                                             Style="{StaticResource PlayerHorizontalProgressBarStyle}" />
                                <Slider x:Name="ProgressSlider"
                                        VerticalAlignment="Center"
                                        Minimum="0"
                                        Maximum="{Binding DurationSeconds}"
                                        PreviewMouseLeftButtonDown="ProgressSlider_PreviewMouseLeftButtonDown"
                                        Value="{Binding PositionSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Style="{StaticResource PlayerSliderStyle}" />
                            </Grid>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding DurationText}"
                                       Style="{StaticResource PlayerControlTimeTextStyle}" />
                        </Grid>
                        <StackPanel x:Name="VolumeHoverAnchor"
                                      Grid.Column="8"
                                      Margin="0"
                                      Orientation="Horizontal"
                                      VerticalAlignment="Center"
                                     MouseEnter="VolumeArea_MouseEnter"
                                     MouseLeave="VolumeArea_MouseLeave">
                            <Button Click="VolumeButton_Click"
                                    Style="{StaticResource PlayerControlIconButtonStyle}">
                                <TextBlock Text="&#xE767;"
                                           Style="{StaticResource PlayerControlGlyphTextStyle}" />
                            </Button>
                        </StackPanel>
                        <Button x:Name="SourceMenuButton"
                                 Grid.Column="10"
                                 Margin="0"
                                 Click="SourceMenuButton_Click"
                                 PreviewMouseLeftButtonDown="MenuButton_PreviewMouseLeftButtonDown"
                                 Style="{StaticResource PlayerControlIconButtonStyle}">
                            <TextBlock Text="&#xE8B2;"
                                       Style="{StaticResource PlayerControlGlyphTextStyle}" />
                        </Button>
                        <Button x:Name="SubtitleMenuButton"
                                 Grid.Column="12"
                                 Margin="0"
                                 Click="SubtitleMenuButton_Click"
                                 PreviewMouseLeftButtonDown="MenuButton_PreviewMouseLeftButtonDown"
                                 Style="{StaticResource PlayerControlIconButtonStyle}">
                            <TextBlock Text="&#xE7F0;"
                                       Style="{StaticResource PlayerControlGlyphTextStyle}" />
                        </Button>
                        <Button x:Name="AudioTrackMenuButton"
                                 Grid.Column="14"
                                 Margin="0"
                                 Click="AudioTrackMenuButton_Click"
                                 PreviewMouseLeftButtonDown="MenuButton_PreviewMouseLeftButtonDown"
                                 Style="{StaticResource PlayerControlIconButtonStyle}">
                            <TextBlock Text="&#xE8D6;"
                                       Style="{StaticResource PlayerControlGlyphTextStyle}" />
                        </Button>
                        <Button Grid.Column="16"
                                Margin="0"
                                Click="ToggleFullScreen_Click"
                                Style="{StaticResource PlayerControlIconButtonStyle}">
                            <TextBlock Text="&#xE740;"
                                       Style="{StaticResource PlayerControlGlyphTextStyle}" />
                        </Button>
                    </Grid>
                </Grid>
            </Border>
        </Popup>

        <Popup x:Name="VolumeHoverPopup"
               AllowsTransparency="True"
               CustomPopupPlacementCallback="VolumeHoverPopup_PlacementCallback"
               DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
               Placement="Custom"
               PlacementTarget="{Binding ElementName=VolumeHoverAnchor}"
               StaysOpen="True">
            <Border x:Name="VolumeHoverPopupSurface"
                    Width="58"
                    Style="{StaticResource PlayerFeedbackPanelStyle}"
                    MouseEnter="VolumeHoverPopup_MouseEnter"
                    MouseLeave="VolumeHoverPopup_MouseLeave">
                <StackPanel HorizontalAlignment="Center">
                    <Viewbox Width="18" Height="18" HorizontalAlignment="Center">
                        <Canvas Width="24" Height="24">
                            <Path Fill="{DynamicResource BrushPlayerTextPrimary}"
                                  Data="M4,9 L8,9 L13,5 L13,19 L8,15 L4,15 Z" />
                            <Path Stroke="{DynamicResource BrushPlayerTextPrimary}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Fill="Transparent"
                                  Data="M16,9 C17.2,10.5 17.2,13.5 16,15 M18.5,6.5 C21.5,9.5 21.5,14.5 18.5,17.5" />
                        </Canvas>
                    </Viewbox>
                    <Grid Margin="0,12,0,0"
                          Width="28"
                          Height="126"
                          HorizontalAlignment="Center">
                        <Slider Width="28"
                                Height="124"
                                HorizontalAlignment="Center"
                                IsMoveToPointEnabled="True"
                                Minimum="0"
                                Maximum="200"
                                Orientation="Vertical"
                                Value="{Binding Volume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Foreground="{Binding Volume, Converter={StaticResource PlayerMeterBrushConverter}, ConverterParameter=200}"
                                Style="{StaticResource PlayerVerticalSliderStyle}" />
                    </Grid>
                    <TextBlock Margin="0,10,0,0"
                               Text="{Binding VolumeFeedbackText}"
                               Style="{StaticResource PlayerFeedbackPercentTextStyle}" />
                </StackPanel>
            </Border>
        </Popup>
        </Grid>
    </Grid>
</Window>
