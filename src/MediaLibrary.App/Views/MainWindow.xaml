<Window x:Class="MediaLibrary.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="智能影音库"
        Width="1440"
        Height="920"
        MinWidth="1180"
        MinHeight="760"
        WindowStartupLocation="CenterScreen">
    <Grid Background="{DynamicResource BrushBackground}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="248" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource SidebarBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Margin="24,30,24,24">
                    <TextBlock Text="智能影音库" Style="{StaticResource SidebarBrandTextStyle}" />
                    <TextBlock Text="WebDAV 路径 · Metadata 识别 · AI"
                               Style="{StaticResource SidebarHintTextStyle}" />
                </StackPanel>

                <ListBox Grid.Row="1"
                         Margin="14,0,14,16"
                         ItemsSource="{Binding NavigationItems}"
                         SelectedItem="{Binding SelectedNavigationItem, Mode=TwoWay}"
                         Style="{StaticResource NavigationListBoxStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Title}" Style="{StaticResource NavigationItemTextStyle}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Grid.Row="2" Margin="16,0,16,22" Style="{StaticResource SidebarFooterCardStyle}">
                    <StackPanel>
                        <TextBlock Text="第三轮目标" Foreground="{DynamicResource BrushSidebarForeground}" FontWeight="SemiBold" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="播放、续播、AI 推荐、统计首页和成品级界面。"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource BrushSidebarMuted}"
                                   FontSize="12" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource TopBarBorderStyle}">
                <Grid Margin="30,22">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="{Binding CurrentPageTitle}" Style="{StaticResource PageTitleTextStyle}" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="{Binding CurrentPageSubtitle}"
                                   Style="{StaticResource BodyMutedTextStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="切换主题"
                                Command="{Binding ToggleThemeCommand}"
                                Style="{StaticResource SecondaryButtonStyle}" />
                    </StackPanel>
                </Grid>
            </Border>

            <ContentControl Grid.Row="1"
                            Margin="30,24,30,30"
                            Content="{Binding CurrentPageViewModel}" />
        </Grid>
    </Grid>
</Window>
