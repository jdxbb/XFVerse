<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:MediaLibrary.App.Controls">
    <Style x:Key="PhosphorIconStyle" TargetType="{x:Type controls:PhosphorIcon}">
        <Setter Property="Width" Value="18" />
        <Setter Property="Height" Value="18" />
        <Setter Property="Foreground" Value="{DynamicResource BrushForegroundSecondary}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

    <Style x:Key="PhosphorSmallIconStyle" TargetType="{x:Type controls:PhosphorIcon}" BasedOn="{StaticResource PhosphorIconStyle}">
        <Setter Property="Width" Value="16" />
        <Setter Property="Height" Value="16" />
    </Style>

    <Style x:Key="PhosphorCaptionIconStyle" TargetType="{x:Type controls:PhosphorIcon}" BasedOn="{StaticResource PhosphorIconStyle}">
        <Setter Property="Width" Value="14" />
        <Setter Property="Height" Value="14" />
    </Style>

    <Style x:Key="PhosphorNavIconStyle" TargetType="{x:Type controls:PhosphorIcon}" BasedOn="{StaticResource PhosphorIconStyle}">
        <Setter Property="Width" Value="20" />
        <Setter Property="Height" Value="20" />
    </Style>

    <DataTemplate x:Key="PhosphorIconContentTemplate">
        <controls:PhosphorIcon Icon="{Binding}"
                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Control}}}"
                               Style="{StaticResource PhosphorIconStyle}" />
    </DataTemplate>

    <DataTemplate x:Key="PhosphorSmallIconContentTemplate">
        <controls:PhosphorIcon Icon="{Binding}"
                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Control}}}"
                               Style="{StaticResource PhosphorSmallIconStyle}" />
    </DataTemplate>

    <DataTemplate x:Key="PhosphorCaptionIconContentTemplate">
        <controls:PhosphorIcon Icon="{Binding}"
                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Control}}}"
                               Style="{StaticResource PhosphorCaptionIconStyle}" />
    </DataTemplate>

    <DataTemplate x:Key="PhosphorNavIconContentTemplate">
        <controls:PhosphorIcon Icon="{Binding}"
                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Control}}}"
                               Style="{StaticResource PhosphorNavIconStyle}" />
    </DataTemplate>

    <ControlTemplate x:Key="PhosphorLoadingSpinnerTemplate" TargetType="{x:Type Control}">
        <controls:PhosphorIcon x:Name="SpinnerIcon"
                               Icon="spinner-gap"
                               Width="{TemplateBinding Width}"
                               Height="{TemplateBinding Height}"
                               Foreground="{DynamicResource BrushAccent}"
                               RenderTransformOrigin="0.5,0.5">
            <controls:PhosphorIcon.RenderTransform>
                <RotateTransform />
            </controls:PhosphorIcon.RenderTransform>
        </controls:PhosphorIcon>
        <ControlTemplate.Triggers>
            <Trigger Property="Visibility" Value="Visible">
                <Trigger.EnterActions>
                    <BeginStoryboard x:Name="PhosphorSpinnerRotationStoryboard">
                        <Storyboard RepeatBehavior="Forever">
                            <DoubleAnimation Storyboard.TargetName="SpinnerIcon"
                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                             From="0"
                                             To="360"
                                             Duration="0:0:0.9" />
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <StopStoryboard BeginStoryboardName="PhosphorSpinnerRotationStoryboard" />
                </Trigger.ExitActions>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>
</ResourceDictionary>
