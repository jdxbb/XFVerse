<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:helpers="clr-namespace:MediaLibrary.App.Helpers">
    <Style x:Key="TruncatedTextBlockStyle" TargetType="TextBlock">
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="TextWrapping" Value="NoWrap" />
        <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
    </Style>

    <Style x:Key="MetadataTextStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
        <Setter Property="FontSize" Value="{StaticResource FontSizeMetadata}" />
        <Setter Property="LineHeight" Value="{StaticResource LineHeightMetadata}" />
    </Style>

    <Style x:Key="MutedTextStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}" />

    <Style x:Key="CaptionTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource BrushForegroundMuted}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}" />
        <Setter Property="LineHeight" Value="{StaticResource LineHeightCaption}" />
    </Style>

    <Style x:Key="PosterPlaceholderLabelTextStyle" TargetType="TextBlock" BasedOn="{StaticResource CaptionTextStyle}">
        <Setter Property="Foreground" Value="#F7F7F5" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Opacity" Value="0.9" />
    </Style>

    <ControlTemplate x:Key="PosterLoadingSpinnerTemplate" TargetType="{x:Type Control}">
        <Viewbox Width="{TemplateBinding Width}"
                 Height="{TemplateBinding Height}">
            <Grid Width="34"
                  Height="34">
                <Ellipse Stroke="#66F7F7F5"
                         StrokeThickness="3" />
                <Path Data="M17,2 A15,15 0 0 1 32,17"
                      Stroke="{DynamicResource BrushAccent}"
                      StrokeThickness="3"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round">
                    <Path.RenderTransform>
                        <RotateTransform CenterX="17"
                                         CenterY="17" />
                    </Path.RenderTransform>
                    <Path.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="(Path.RenderTransform).(RotateTransform.Angle)"
                                                     From="0"
                                                     To="360"
                                                     Duration="0:0:0.9" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Path.Triggers>
                </Path>
            </Grid>
        </Viewbox>
    </ControlTemplate>

    <Style x:Key="PosterPlaceholderLoadingIndicatorStyle" TargetType="Control">
        <Setter Property="Visibility" Value="Visible" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=(helpers:PosterCacheImageBehavior.LoadState)}" Value="Loaded">
                <Setter Property="Visibility" Value="Collapsed" />
            </DataTrigger>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=(helpers:PosterCacheImageBehavior.LoadState)}" Value="Empty">
                <Setter Property="Visibility" Value="Collapsed" />
            </DataTrigger>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=(helpers:PosterCacheImageBehavior.LoadState)}" Value="Failed">
                <Setter Property="Visibility" Value="Collapsed" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="PosterPlaceholderNoPosterLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource PosterPlaceholderLabelTextStyle}">
        <Setter Property="Visibility" Value="Collapsed" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=(helpers:PosterCacheImageBehavior.LoadState)}" Value="Empty">
                <Setter Property="Visibility" Value="Visible" />
            </DataTrigger>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=(helpers:PosterCacheImageBehavior.LoadState)}" Value="Failed">
                <Setter Property="Visibility" Value="Visible" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <ControlTemplate x:Key="PosterPlaceholderTemplate" TargetType="{x:Type Control}">
        <Grid ClipToBounds="True"
              SnapsToDevicePixels="True">
            <Image Source="pack://application:,,,/MediaLibrary.App;component/Assets/poster-placeholder.png"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   SnapsToDevicePixels="True"
                   Stretch="UniformToFill" />
            <Grid IsHitTestVisible="False">
                <Grid.RowDefinitions>
                    <RowDefinition Height="0.4*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="0.6*" />
                </Grid.RowDefinitions>
                <Control Grid.Row="1"
                         Width="28"
                         Height="28"
                         HorizontalAlignment="Center"
                         Style="{StaticResource PosterPlaceholderLoadingIndicatorStyle}"
                         Template="{StaticResource PosterLoadingSpinnerTemplate}" />
                <TextBlock Grid.Row="1"
                           HorizontalAlignment="Center"
                           Text="无海报"
                           Style="{StaticResource PosterPlaceholderNoPosterLabelStyle}" />
            </Grid>
        </Grid>
    </ControlTemplate>

    <ControlTemplate x:Key="PosterPlaceholderLargeTemplate" TargetType="{x:Type Control}">
        <Grid ClipToBounds="True" SnapsToDevicePixels="True">
            <Image Source="pack://application:,,,/MediaLibrary.App;component/Assets/poster-placeholder.png"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   SnapsToDevicePixels="True"
                   Stretch="UniformToFill" />
            <Grid IsHitTestVisible="False">
                <Grid.RowDefinitions>
                    <RowDefinition Height="0.36*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="0.64*" />
                </Grid.RowDefinitions>
                <Control Grid.Row="1"
                         Width="34"
                         Height="34"
                         HorizontalAlignment="Center"
                         Style="{StaticResource PosterPlaceholderLoadingIndicatorStyle}"
                         Template="{StaticResource PosterLoadingSpinnerTemplate}" />
                <TextBlock Grid.Row="1"
                           HorizontalAlignment="Center"
                           FontSize="22"
                           Text="无海报"
                           Style="{StaticResource PosterPlaceholderNoPosterLabelStyle}" />
            </Grid>
        </Grid>
    </ControlTemplate>

    <ControlTemplate x:Key="PosterPlaceholderWideTemplate" TargetType="{x:Type Control}">
        <Grid ClipToBounds="True" SnapsToDevicePixels="True">
            <Image Source="pack://application:,,,/MediaLibrary.App;component/Assets/poster-placeholder.png"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   SnapsToDevicePixels="True"
                   Stretch="UniformToFill" />
            <Grid IsHitTestVisible="False">
                <Control Width="34"
                         Height="34"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Style="{StaticResource PosterPlaceholderLoadingIndicatorStyle}"
                         Template="{StaticResource PosterLoadingSpinnerTemplate}" />
                <TextBlock HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="26"
                           Text="无海报"
                           Style="{StaticResource PosterPlaceholderNoPosterLabelStyle}" />
            </Grid>
        </Grid>
    </ControlTemplate>

    <Style x:Key="MonospacePathTextStyle" TargetType="TextBlock" BasedOn="{StaticResource TruncatedTextBlockStyle}">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyMono}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeMetadata}" />
        <Setter Property="Foreground" Value="{DynamicResource BrushForegroundSecondary}" />
    </Style>

    <Style x:Key="LongFieldTextBlockStyle" TargetType="TextBlock" BasedOn="{StaticResource TruncatedTextBlockStyle}">
        <Setter Property="ToolTipService.ShowDuration" Value="30000" />
    </Style>
</ResourceDictionary>
