<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="ColorBackground">#0F141D</Color>
    <Color x:Key="ColorBackgroundAccent">#182033</Color>
    <Color x:Key="ColorSidebar">#111827</Color>
    <Color x:Key="ColorTopBar">#141B27</Color>
    <Color x:Key="ColorSurface">#192231</Color>
    <Color x:Key="ColorSurfaceAlt">#223047</Color>
    <Color x:Key="ColorSurfaceRaised">#202B3D</Color>
    <Color x:Key="ColorBorder">#334156</Color>
    <Color x:Key="ColorAccent">#72D2C5</Color>
    <Color x:Key="ColorAccentSoft">#254C50</Color>
    <Color x:Key="ColorSuccess">#58C78A</Color>
    <Color x:Key="ColorWarning">#E6B75F</Color>
    <Color x:Key="ColorDanger">#EF7B7B</Color>
    <Color x:Key="ColorForegroundPrimary">#F5F7FB</Color>
    <Color x:Key="ColorForegroundSecondary">#C1CBDA</Color>
    <Color x:Key="ColorForegroundMuted">#8996A9</Color>
    <Color x:Key="ColorOnAccent">#102028</Color>
    <Color x:Key="ColorSidebarForeground">#F5F7FB</Color>
    <Color x:Key="ColorSidebarMuted">#8D99AA</Color>

    <SolidColorBrush x:Key="BrushBackground" Color="{StaticResource ColorBackground}" />
    <SolidColorBrush x:Key="BrushBackgroundAccent" Color="{StaticResource ColorBackgroundAccent}" />
    <SolidColorBrush x:Key="BrushSidebar" Color="{StaticResource ColorSidebar}" />
    <SolidColorBrush x:Key="BrushTopBar" Color="{StaticResource ColorTopBar}" />
    <SolidColorBrush x:Key="BrushSurface" Color="{StaticResource ColorSurface}" />
    <SolidColorBrush x:Key="BrushSurfaceAlt" Color="{StaticResource ColorSurfaceAlt}" />
    <SolidColorBrush x:Key="BrushSurfaceRaised" Color="{StaticResource ColorSurfaceRaised}" />
    <SolidColorBrush x:Key="BrushBorder" Color="{StaticResource ColorBorder}" />
    <SolidColorBrush x:Key="BrushAccent" Color="{StaticResource ColorAccent}" />
    <SolidColorBrush x:Key="BrushAccentSoft" Color="{StaticResource ColorAccentSoft}" />
    <SolidColorBrush x:Key="BrushSuccess" Color="{StaticResource ColorSuccess}" />
    <SolidColorBrush x:Key="BrushWarning" Color="{StaticResource ColorWarning}" />
    <SolidColorBrush x:Key="BrushDanger" Color="{StaticResource ColorDanger}" />
    <SolidColorBrush x:Key="BrushForegroundPrimary" Color="{StaticResource ColorForegroundPrimary}" />
    <SolidColorBrush x:Key="BrushForegroundSecondary" Color="{StaticResource ColorForegroundSecondary}" />
    <SolidColorBrush x:Key="BrushForegroundMuted" Color="{StaticResource ColorForegroundMuted}" />
    <SolidColorBrush x:Key="BrushOnAccent" Color="{StaticResource ColorOnAccent}" />
    <SolidColorBrush x:Key="BrushSidebarForeground" Color="{StaticResource ColorSidebarForeground}" />
    <SolidColorBrush x:Key="BrushSidebarMuted" Color="{StaticResource ColorSidebarMuted}" />

    <LinearGradientBrush x:Key="BrushHeroGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#1A2435" Offset="0" />
        <GradientStop Color="#223F4B" Offset="0.55" />
        <GradientStop Color="#2B253F" Offset="1" />
    </LinearGradientBrush>
</ResourceDictionary>
