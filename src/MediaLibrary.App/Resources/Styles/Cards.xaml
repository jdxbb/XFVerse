<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="SectionCardStyle" TargetType="Border" BasedOn="{StaticResource PageCardStyle}">
        <Setter Property="Padding" Value="{StaticResource CardPadding}" />
        <Setter Property="Margin" Value="{StaticResource PageSectionGap}" />
    </Style>

    <Style x:Key="ListItemCardStyle" TargetType="Border" BasedOn="{StaticResource CompactCardStyle}">
        <Setter Property="Padding" Value="{StaticResource CompactCardPadding}" />
        <Setter Property="Margin" Value="{StaticResource ListItemGap}" />
    </Style>

    <Style x:Key="PosterCardStyle" TargetType="Border" BasedOn="{StaticResource CompactCardStyle}">
        <Setter Property="Width" Value="{StaticResource PosterCardWidth}" />
        <Setter Property="MinHeight" Value="{StaticResource PosterCardHeight}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="ClipToBounds" Value="True" />
    </Style>

    <Style x:Key="ElevatedSurfaceStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource BrushSurfaceElevated}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusCard}" />
        <Setter Property="Padding" Value="{StaticResource CardPadding}" />
        <Setter Property="Effect" Value="{StaticResource ShadowCard}" />
    </Style>

    <Style x:Key="InlinePanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource BrushSurfaceAlt}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusCompactCard}" />
        <Setter Property="Padding" Value="{StaticResource CompactCardPadding}" />
    </Style>
</ResourceDictionary>
