<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="ColorPlayerBackground">#05070A</Color>
    <Color x:Key="ColorPlayerSurface">#0B1018</Color>
    <Color x:Key="ColorPlayerSurfaceElevated">#121A27</Color>
    <Color x:Key="ColorPlayerControlBarBackground">#D90B1018</Color>
    <Color x:Key="ColorPlayerOverlayBackground">#9905070A</Color>
    <Color x:Key="ColorPlayerMenuBackground">#151D2A</Color>
    <Color x:Key="ColorPlayerPopupBackground">#121A27</Color>
    <Color x:Key="ColorPlayerDialogBackground">#151D2A</Color>
    <Color x:Key="ColorPlayerBorder">#2C3747</Color>
    <Color x:Key="ColorPlayerTextPrimary">#F6F8FB</Color>
    <Color x:Key="ColorPlayerTextSecondary">#C4CDD9</Color>
    <Color x:Key="ColorPlayerTextMuted">#8A94A5</Color>
    <Color x:Key="ColorPlayerAccent">#72D2C5</Color>
    <Color x:Key="ColorPlayerDanger">#EF7B7B</Color>
    <Color x:Key="ColorPlayerWarning">#E6B75F</Color>
    <Color x:Key="ColorPlayerSuccess">#58C78A</Color>
    <Color x:Key="ColorPlayerFocusRing">#9972D2C5</Color>
    <Color x:Key="ColorPlayerSliderTrack">#334156</Color>
    <Color x:Key="ColorPlayerSliderProgress">#72D2C5</Color>
    <Color x:Key="ColorPlayerBuffering">#B6F1EA</Color>
    <Color x:Key="ColorPlayerDisabled">#586474</Color>

    <SolidColorBrush x:Key="BrushPlayerBackground" Color="{StaticResource ColorPlayerBackground}" />
    <SolidColorBrush x:Key="BrushPlayerSurface" Color="{StaticResource ColorPlayerSurface}" />
    <SolidColorBrush x:Key="BrushPlayerSurfaceElevated" Color="{StaticResource ColorPlayerSurfaceElevated}" />
    <SolidColorBrush x:Key="BrushPlayerControlBarBackground" Color="{StaticResource ColorPlayerControlBarBackground}" />
    <SolidColorBrush x:Key="BrushPlayerOverlayBackground" Color="{StaticResource ColorPlayerOverlayBackground}" />
    <SolidColorBrush x:Key="BrushPlayerMenuBackground" Color="{StaticResource ColorPlayerMenuBackground}" />
    <SolidColorBrush x:Key="BrushPlayerPopupBackground" Color="{StaticResource ColorPlayerPopupBackground}" />
    <SolidColorBrush x:Key="BrushPlayerDialogBackground" Color="{StaticResource ColorPlayerDialogBackground}" />
    <SolidColorBrush x:Key="BrushPlayerBorder" Color="{StaticResource ColorPlayerBorder}" />
    <SolidColorBrush x:Key="BrushPlayerTextPrimary" Color="{StaticResource ColorPlayerTextPrimary}" />
    <SolidColorBrush x:Key="BrushPlayerTextSecondary" Color="{StaticResource ColorPlayerTextSecondary}" />
    <SolidColorBrush x:Key="BrushPlayerTextMuted" Color="{StaticResource ColorPlayerTextMuted}" />
    <SolidColorBrush x:Key="BrushPlayerAccent" Color="{StaticResource ColorPlayerAccent}" />
    <SolidColorBrush x:Key="BrushPlayerDanger" Color="{StaticResource ColorPlayerDanger}" />
    <SolidColorBrush x:Key="BrushPlayerWarning" Color="{StaticResource ColorPlayerWarning}" />
    <SolidColorBrush x:Key="BrushPlayerSuccess" Color="{StaticResource ColorPlayerSuccess}" />
    <SolidColorBrush x:Key="BrushPlayerFocusRing" Color="{StaticResource ColorPlayerFocusRing}" />
    <SolidColorBrush x:Key="BrushPlayerSliderTrack" Color="{StaticResource ColorPlayerSliderTrack}" />
    <SolidColorBrush x:Key="BrushPlayerSliderProgress" Color="{StaticResource ColorPlayerSliderProgress}" />
    <SolidColorBrush x:Key="BrushPlayerBuffering" Color="{StaticResource ColorPlayerBuffering}" />
    <SolidColorBrush x:Key="BrushPlayerDisabled" Color="{StaticResource ColorPlayerDisabled}" />
</ResourceDictionary>
