<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="GlassPageCardStyle" TargetType="Border" BasedOn="{StaticResource PageCardStyle}">
        <Setter Property="Background" Value="{DynamicResource BrushGlassSurface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushGlassBorder}" />
        <Setter Property="Effect" Value="{StaticResource ShadowGlassCard}" />
    </Style>

    <Style x:Key="GlassCompactCardStyle" TargetType="Border" BasedOn="{StaticResource CompactCardStyle}">
        <Setter Property="Background" Value="{DynamicResource BrushGlassSurfaceAlt}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushGlassBorder}" />
        <Setter Property="Effect" Value="{StaticResource ShadowCard}" />
    </Style>

    <Style x:Key="GlassInlinePanelStyle" TargetType="Border" BasedOn="{StaticResource InlinePanelStyle}">
        <Setter Property="Background" Value="{DynamicResource BrushGlassSurfaceAlt}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushGlassBorder}" />
    </Style>

    <Style x:Key="GlassHomeMetricCardStyle" TargetType="Border" BasedOn="{StaticResource HomeMetricCardStyle}">
        <Setter Property="Background" Value="{DynamicResource BrushGlassSurfaceAlt}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushGlassBorder}" />
    </Style>

    <Style x:Key="GlassHomeAiPanelStyle" TargetType="Border" BasedOn="{StaticResource HomeAiPanelStyle}">
        <Setter Property="Background" Value="{DynamicResource BrushGlassSurface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushGlassBorder}" />
        <Setter Property="Effect" Value="{StaticResource ShadowGlassCard}" />
    </Style>

    <Style x:Key="GlassHomeAiCardStyle" TargetType="Border" BasedOn="{StaticResource HomeAiCardStyle}">
        <Setter Property="Background" Value="{DynamicResource BrushGlassSurfaceAlt}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushGlassBorder}" />
    </Style>

    <Style x:Key="GlassPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
        <Setter Property="Background" Value="{DynamicResource BrushGlassAccent}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushGlassAccent}" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource BrushGlassAccentHover}" />
                <Setter Property="BorderBrush" Value="{DynamicResource BrushGlassAccentHover}" />
                <Setter Property="Foreground" Value="White" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource BrushGlassAccentPressed}" />
                <Setter Property="BorderBrush" Value="{DynamicResource BrushGlassAccentPressed}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="GlassSecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
        <Setter Property="Background" Value="{DynamicResource BrushGlassButton}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushGlassBorder}" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource BrushGlassButtonHover}" />
                <Setter Property="BorderBrush" Value="{DynamicResource BrushGlassAccentHover}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource BrushGlassButtonPressed}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="GlassSmallButtonStyle" TargetType="Button" BasedOn="{StaticResource GlassSecondaryButtonStyle}">
        <Setter Property="MinHeight" Value="{StaticResource SmallButtonHeight}" />
        <Setter Property="Padding" Value="14,7" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}" />
    </Style>
</ResourceDictionary>
