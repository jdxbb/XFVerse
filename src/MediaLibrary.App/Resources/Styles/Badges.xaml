<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:helpers="clr-namespace:MediaLibrary.App.Helpers">
    <Style x:Key="BadgeBaseStyle" TargetType="Border">
        <Setter Property="MinHeight" Value="{StaticResource TagHeight}" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="Background" Value="{DynamicResource BrushSurfaceAlt}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusPill}" />
    </Style>

    <Style x:Key="TagStyle" TargetType="Border" BasedOn="{StaticResource BadgeBaseStyle}">
        <Setter Property="Background" Value="{DynamicResource BrushAccentSoft}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushAccentSoft}" />
    </Style>

    <Style x:Key="BadgeStyle" TargetType="Border" BasedOn="{StaticResource BadgeBaseStyle}" />
    <Style x:Key="StatusBadgeStyle" TargetType="Border" BasedOn="{StaticResource BadgeBaseStyle}" />

    <Style x:Key="DangerBadgeStyle" TargetType="Border" BasedOn="{StaticResource BadgeBaseStyle}">
        <Setter Property="Background" Value="{DynamicResource BrushErrorBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushErrorBorder}" />
    </Style>

    <Style x:Key="WarningBadgeStyle" TargetType="Border" BasedOn="{StaticResource BadgeBaseStyle}">
        <Setter Property="Background" Value="{DynamicResource BrushWarningBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushWarningBorder}" />
    </Style>

    <Style x:Key="SuccessBadgeStyle" TargetType="Border" BasedOn="{StaticResource BadgeBaseStyle}">
        <Setter Property="Background" Value="{DynamicResource BrushSuccessBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushSuccessBorder}" />
    </Style>

    <Style x:Key="InfoBadgeStyle" TargetType="Border" BasedOn="{StaticResource BadgeBaseStyle}">
        <Setter Property="Background" Value="{DynamicResource BrushInfoBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushInfoBorder}" />
    </Style>

    <Style x:Key="NoSourceBadgeStyle" TargetType="Border" BasedOn="{StaticResource BadgeBaseStyle}">
        <Setter Property="Background" Value="{DynamicResource BrushNoSourceBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushNoSourceBorder}" />
    </Style>

    <Style x:Key="ConfigMissingBadgeStyle" TargetType="Border" BasedOn="{StaticResource BadgeBaseStyle}">
        <Setter Property="Background" Value="{DynamicResource BrushConfigMissingBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushConfigMissingBorder}" />
    </Style>

    <Style x:Key="CacheProtectedBadgeStyle" TargetType="Border" BasedOn="{StaticResource BadgeBaseStyle}">
        <Setter Property="Background" Value="{DynamicResource BrushCacheProtectedBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushCacheProtectedBorder}" />
    </Style>

    <Style x:Key="SmallPillStyle" TargetType="Border" BasedOn="{StaticResource BadgeBaseStyle}">
        <Setter Property="MinHeight" Value="22" />
        <Setter Property="Padding" Value="8,3" />
    </Style>

    <Style x:Key="BadgeTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource BrushForegroundSecondary}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeTag}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="RankingRatingBadgeStyle" TargetType="{x:Type helpers:CachedShadowBorder}">
        <Setter Property="MinWidth" Value="54" />
        <Setter Property="Height" Value="34" />
        <Setter Property="Padding" Value="10,2" />
        <Setter Property="CornerRadius" Value="9" />
        <Setter Property="Background" Value="{DynamicResource BrushGlassSurfaceAlt}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
        <Setter Property="BorderThickness" Value="1.2" />
        <Setter Property="Effect" Value="{x:Null}" />
        <Setter Property="ClipToBounds" Value="False" />
        <Setter Property="ShadowPadding" Value="24" />
        <Setter Property="ShadowBlurRadius" Value="{DynamicResource CachedShadowScoreBadgeBlurRadius}" />
        <Setter Property="ShadowOpacity" Value="{DynamicResource CachedShadowScoreBadgeOpacity}" />
        <Setter Property="ShadowColor" Value="{DynamicResource ColorCachedShadowScoreBadge}" />
        <Setter Property="ShadowDepth" Value="{DynamicResource CachedShadowScoreBadgeDepth}" />
    </Style>

    <Style x:Key="RankingHeroRatingBadgeStyle"
           TargetType="{x:Type helpers:CachedShadowBorder}"
           BasedOn="{StaticResource RankingRatingBadgeStyle}">
        <Setter Property="MinWidth" Value="68" />
        <Setter Property="Height" Value="44" />
        <Setter Property="Padding" Value="12,3" />
        <Setter Property="CornerRadius" Value="11" />
    </Style>

    <Style x:Key="RankingRatingTextStyle" TargetType="TextBlock">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FontSize" Value="14.4" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsHighWeightedAverageRating}" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource BrushRatingGold}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="RankingHeroRatingTextStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource RankingRatingTextStyle}">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="Bold" />
    </Style>
</ResourceDictionary>
