<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="StatusBannerStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource BrushInfoBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushInfoBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusCompactCard}" />
        <Setter Property="Padding" Value="{StaticResource CompactCardPadding}" />
    </Style>

    <Style x:Key="InfoBannerStyle" TargetType="Border" BasedOn="{StaticResource StatusBannerStyle}" />

    <Style x:Key="WarningBannerStyle" TargetType="Border" BasedOn="{StaticResource StatusBannerStyle}">
        <Setter Property="Background" Value="{DynamicResource BrushWarningBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushWarningBorder}" />
    </Style>

    <Style x:Key="ErrorBannerStyle" TargetType="Border" BasedOn="{StaticResource StatusBannerStyle}">
        <Setter Property="Background" Value="{DynamicResource BrushErrorBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushErrorBorder}" />
    </Style>

    <Style x:Key="SuccessBannerStyle" TargetType="Border" BasedOn="{StaticResource StatusBannerStyle}">
        <Setter Property="Background" Value="{DynamicResource BrushSuccessBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushSuccessBorder}" />
    </Style>

    <Style x:Key="ConfigMissingBannerStyle" TargetType="Border" BasedOn="{StaticResource StatusBannerStyle}">
        <Setter Property="Background" Value="{DynamicResource BrushConfigMissingBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushConfigMissingBorder}" />
    </Style>

    <Style x:Key="NoSourceBannerStyle" TargetType="Border" BasedOn="{StaticResource StatusBannerStyle}">
        <Setter Property="Background" Value="{DynamicResource BrushNoSourceBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushNoSourceBorder}" />
    </Style>

    <Style x:Key="DataInsufficientBannerStyle" TargetType="Border" BasedOn="{StaticResource StatusBannerStyle}">
        <Setter Property="Background" Value="{DynamicResource BrushDataInsufficientBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushDataInsufficientBorder}" />
    </Style>

    <Style x:Key="CacheProtectedStatusStyle" TargetType="Border" BasedOn="{StaticResource StatusBannerStyle}">
        <Setter Property="Background" Value="{DynamicResource BrushCacheProtectedBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushCacheProtectedBorder}" />
    </Style>

    <Style x:Key="ScanRunningStatusStyle" TargetType="Border" BasedOn="{StaticResource StatusBannerStyle}">
        <Setter Property="Background" Value="{DynamicResource BrushScanRunningBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushScanRunningBorder}" />
    </Style>

    <Style x:Key="PartialFailureStatusStyle" TargetType="Border" BasedOn="{StaticResource WarningBannerStyle}" />

    <Style x:Key="EmptyStateContainerStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource BrushSurfaceAlt}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusCard}" />
        <Setter Property="Padding" Value="{StaticResource CardPadding}" />
    </Style>

    <Style x:Key="EmptyStateTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource CardTitleTextStyle}">
        <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
    </Style>

    <Style x:Key="EmptyStateDescriptionStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
        <Setter Property="Foreground" Value="{DynamicResource BrushEmptyForeground}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="LoadingStateStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource BrushSurfaceAlt}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusCompactCard}" />
        <Setter Property="Padding" Value="{StaticResource CompactCardPadding}" />
    </Style>

    <Style x:Key="InlineLoadingStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource BrushLoadingForeground}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeMetadata}" />
    </Style>

    <ControlTemplate x:Key="LoadingSpinnerTemplate" TargetType="{x:Type Control}">
        <Viewbox Width="{TemplateBinding Width}"
                 Height="{TemplateBinding Height}"
                 Stretch="Uniform">
            <Canvas Width="34"
                    Height="34">
                <Ellipse Width="30"
                         Height="30"
                         Canvas.Left="2"
                         Canvas.Top="2"
                         Stroke="{DynamicResource BrushBorder}"
                         StrokeThickness="3" />
                <Path x:Name="SpinnerArc"
                      Data="M17,2 A15,15 0 0 1 32,17"
                      Stroke="{DynamicResource BrushAccent}"
                      StrokeThickness="3"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round">
                    <Path.RenderTransform>
                        <RotateTransform CenterX="17"
                                         CenterY="17" />
                    </Path.RenderTransform>
                </Path>
            </Canvas>
        </Viewbox>
        <ControlTemplate.Triggers>
            <Trigger Property="Visibility" Value="Visible">
                <Trigger.EnterActions>
                    <BeginStoryboard x:Name="LoadingSpinnerRotationStoryboard">
                        <Storyboard RepeatBehavior="Forever">
                            <DoubleAnimation Storyboard.TargetName="SpinnerArc"
                                             Storyboard.TargetProperty="(Path.RenderTransform).(RotateTransform.Angle)"
                                             From="0"
                                             To="360"
                                             Duration="0:0:0.9" />
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <StopStoryboard BeginStoryboardName="LoadingSpinnerRotationStoryboard" />
                </Trigger.ExitActions>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="PageLoadingHostStyle" TargetType="StackPanel">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="WidgetLoadingHostStyle" TargetType="StackPanel" BasedOn="{StaticResource PageLoadingHostStyle}" />

    <Style x:Key="DialogLoadingHostStyle" TargetType="StackPanel" BasedOn="{StaticResource PageLoadingHostStyle}" />

    <Style x:Key="PageLoadingSpinnerStyle" TargetType="{x:Type Control}">
        <Setter Property="Width" Value="38" />
        <Setter Property="Height" Value="38" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Template" Value="{StaticResource LoadingSpinnerTemplate}" />
    </Style>

    <Style x:Key="WidgetLoadingSpinnerStyle" TargetType="{x:Type Control}">
        <Setter Property="Width" Value="34" />
        <Setter Property="Height" Value="34" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Template" Value="{StaticResource LoadingSpinnerTemplate}" />
    </Style>

    <Style x:Key="DialogLoadingSpinnerStyle" TargetType="{x:Type Control}">
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="32" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Template" Value="{StaticResource LoadingSpinnerTemplate}" />
    </Style>

    <Style x:Key="PageLoadingTextStyle" TargetType="TextBlock" BasedOn="{StaticResource InlineLoadingStyle}">
        <Setter Property="Margin" Value="0,14,0,0" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="MaxWidth" Value="420" />
    </Style>

    <Style x:Key="WidgetLoadingTextStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
        <Setter Property="Margin" Value="0,10,0,0" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="MaxWidth" Value="320" />
    </Style>

    <Style x:Key="DialogLoadingTextStyle" TargetType="TextBlock" BasedOn="{StaticResource InlineLoadingStyle}">
        <Setter Property="Margin" Value="0,12,0,0" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="MaxWidth" Value="360" />
    </Style>

    <Style x:Key="SkeletonPlaceholderStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource BrushHoverBackground}" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusCompactCard}" />
        <Setter Property="MinHeight" Value="16" />
        <Setter Property="Opacity" Value="0.7" />
    </Style>
</ResourceDictionary>
