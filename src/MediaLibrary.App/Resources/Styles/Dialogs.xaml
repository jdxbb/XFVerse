<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="DialogWindowStyle" TargetType="Window">
        <Setter Property="Background" Value="{DynamicResource BrushDialogBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyBase}" />
    </Style>

    <Style x:Key="DialogSurfaceStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource BrushDialogBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusDialog}" />
        <Setter Property="Padding" Value="{StaticResource DialogPadding}" />
        <Setter Property="Effect" Value="{StaticResource ShadowDialog}" />
    </Style>

    <Style x:Key="DialogTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource CardTitleTextStyle}">
        <Setter Property="FontSize" Value="{StaticResource FontSizeCardTitle}" />
    </Style>

    <Style x:Key="DialogBodyStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyMutedTextStyle}">
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="DialogButtonRowStyle" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Horizontal" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="Margin" Value="0,22,0,0" />
    </Style>

    <Style x:Key="PopoverSurfaceStyle" TargetType="Border" BasedOn="{StaticResource PopupSurfaceStyle}" />

    <Style x:Key="LightweightConfirmPopoverStyle" TargetType="Border" BasedOn="{StaticResource PopupSurfaceStyle}">
        <Setter Property="MaxWidth" Value="360" />
    </Style>

    <Style x:Key="DangerConfirmDialogStyle" TargetType="Border" BasedOn="{StaticResource DialogSurfaceStyle}">
        <Setter Property="BorderBrush" Value="{DynamicResource BrushErrorBorder}" />
    </Style>

    <Style x:Key="ScrimOverlayStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource BrushScrim}" />
    </Style>
</ResourceDictionary>
