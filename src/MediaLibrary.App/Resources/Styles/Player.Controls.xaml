<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="PlayerButtonStyle" TargetType="Button">
        <Setter Property="MinHeight" Value="{StaticResource ButtonHeight}" />
        <Setter Property="Padding" Value="{StaticResource ButtonPadding}" />
        <Setter Property="Background" Value="{DynamicResource BrushPlayerSurfaceElevated}" />
        <Setter Property="Foreground" Value="{DynamicResource BrushPlayerTextPrimary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushPlayerBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyBase}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeButton}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="PlayerButtonChrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource RadiusButton}">
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="PlayerButtonChrome" Property="BorderBrush" Value="{DynamicResource BrushPlayerAccent}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="PlayerButtonChrome" Property="Opacity" Value="0.78" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="PlayerButtonChrome" Property="Background" Value="{DynamicResource BrushPlayerSurface}" />
                            <Setter TargetName="PlayerButtonChrome" Property="BorderBrush" Value="{DynamicResource BrushPlayerBorder}" />
                            <Setter Property="Foreground" Value="{DynamicResource BrushPlayerDisabled}" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PlayerIconButtonStyle" TargetType="Button" BasedOn="{StaticResource PlayerButtonStyle}">
        <Setter Property="Width" Value="{StaticResource IconButtonSize}" />
        <Setter Property="Height" Value="{StaticResource IconButtonSize}" />
        <Setter Property="MinWidth" Value="{StaticResource IconButtonSize}" />
        <Setter Property="MinHeight" Value="{StaticResource IconButtonSize}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
    </Style>

    <Style x:Key="PlayerWindowCaptionStyle" TargetType="Border">
        <Setter Property="Height" Value="{StaticResource WindowCaptionHeight}" />
        <Setter Property="Background" Value="{DynamicResource BrushPlayerSurface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushPlayerBorder}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <Style x:Key="PlayerWindowCaptionTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource BrushPlayerTextPrimary}" />
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyBase}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="PlayerWindowCaptionButtonStyle" TargetType="Button" BasedOn="{StaticResource PlayerIconButtonStyle}">
        <Setter Property="Width" Value="48" />
        <Setter Property="Height" Value="{StaticResource WindowCaptionHeight}" />
        <Setter Property="MinWidth" Value="48" />
        <Setter Property="MinHeight" Value="{StaticResource WindowCaptionHeight}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{DynamicResource BrushPlayerTextSecondary}" />
    </Style>

    <Style x:Key="PlayerWindowCaptionCloseButtonStyle" TargetType="Button" BasedOn="{StaticResource PlayerWindowCaptionButtonStyle}">
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource BrushPlayerDanger}" />
                <Setter Property="BorderBrush" Value="{DynamicResource BrushPlayerDanger}" />
                <Setter Property="Foreground" Value="{DynamicResource BrushPlayerBackground}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Opacity" Value="0.78" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="PlayerMenuStyle" TargetType="ContextMenu">
        <Setter Property="Background" Value="{DynamicResource BrushPlayerMenuBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushPlayerBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource BrushPlayerTextPrimary}" />
        <Setter Property="Padding" Value="6" />
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyBase}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
    </Style>

    <Style x:Key="PlayerMenuItemStyle" TargetType="MenuItem">
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Padding" Value="12,7" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource BrushPlayerTextPrimary}" />
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyBase}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
    </Style>

    <Style x:Key="PlayerTooltipStyle" TargetType="ToolTip">
        <Setter Property="Background" Value="{DynamicResource BrushPlayerPopupBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource BrushPlayerTextPrimary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushPlayerBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyBase}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}" />
    </Style>

    <Style x:Key="PlayerPopoverStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource BrushPlayerPopupBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushPlayerBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusPopup}" />
        <Setter Property="Padding" Value="{StaticResource PopupPadding}" />
        <Setter Property="Effect" Value="{StaticResource ShadowPopup}" />
    </Style>

    <Style x:Key="PlayerDialogSurfaceStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource BrushPlayerDialogBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushPlayerBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusDialog}" />
        <Setter Property="Padding" Value="{StaticResource DialogPadding}" />
        <Setter Property="Effect" Value="{StaticResource ShadowDialog}" />
    </Style>

    <Style x:Key="PlayerStatusBannerStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource BrushPlayerSurfaceElevated}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushPlayerBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusCompactCard}" />
        <Setter Property="Padding" Value="{StaticResource CompactCardPadding}" />
    </Style>

    <Style x:Key="PlayerProgressBarStyle" TargetType="ProgressBar">
        <Setter Property="Height" Value="6" />
        <Setter Property="Background" Value="{DynamicResource BrushPlayerSliderTrack}" />
        <Setter Property="Foreground" Value="{DynamicResource BrushPlayerSliderProgress}" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style x:Key="PlayerSliderStyle" TargetType="Slider">
        <Setter Property="Foreground" Value="{DynamicResource BrushPlayerSliderProgress}" />
        <Setter Property="Background" Value="{DynamicResource BrushPlayerSliderTrack}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushPlayerBorder}" />
        <Setter Property="Height" Value="28" />
    </Style>
</ResourceDictionary>
