<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:helpers="clr-namespace:MediaLibrary.App.Helpers">
    <Style TargetType="Window">
        <Setter Property="Background" Value="{DynamicResource BrushBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyBase}" />
        <Setter Property="ToolTipService.InitialShowDelay" Value="200" />
        <Setter Property="ToolTipService.BetweenShowDelay" Value="0" />
        <Setter Property="ToolTipService.ShowDuration" Value="30000" />
    </Style>

    <Style x:Key="PageCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource BrushSurface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusCard}" />
        <Setter Property="Padding" Value="{StaticResource CardPadding}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="CompactCardStyle" TargetType="Border" BasedOn="{StaticResource PageCardStyle}">
        <Setter Property="CornerRadius" Value="{StaticResource RadiusCompactCard}" />
        <Setter Property="Padding" Value="{StaticResource CompactCardPadding}" />
    </Style>

    <Style x:Key="HeroCardStyle" TargetType="{x:Type helpers:CachedShadowBorder}" BasedOn="{StaticResource PageCardStyle}">
        <Setter Property="Background" Value="{DynamicResource BrushGlassSurface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushGlassBorder}" />
        <Setter Property="Effect" Value="{x:Null}" />
        <Setter Property="ClipToBounds" Value="False" />
        <Setter Property="ShadowPadding" Value="54" />
        <Setter Property="ShadowBlurRadius" Value="{DynamicResource CachedShadowLargeBlurRadius}" />
        <Setter Property="ShadowOpacity" Value="{DynamicResource CachedShadowLargeOpacity}" />
        <Setter Property="ShadowColor" Value="{DynamicResource ColorCachedShadowLarge}" />
        <Setter Property="ShadowDepth" Value="{DynamicResource CachedShadowLargeDepth}" />
        <Setter Property="Padding" Value="{StaticResource HeroCardPadding}" />
    </Style>

    <Style x:Key="RatingCardDividerStyle" TargetType="Border">
        <Setter Property="Width" Value="2" />
        <Setter Property="Margin" Value="0,3" />
        <Setter Property="Background" Value="{DynamicResource BrushRatingCardDivider}" />
        <Setter Property="CornerRadius" Value="1" />
    </Style>

    <Style x:Key="SidebarBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource BrushSidebar}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushSidebarRightBorder}" />
        <Setter Property="BorderThickness" Value="0,0,1,0" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style x:Key="TopBarBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource BrushTopBar}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <Style x:Key="SidebarFooterCardStyle" TargetType="Border">
        <Setter Property="Background" Value="#223047" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusCompactCard}" />
        <Setter Property="Padding" Value="{StaticResource CompactCardPadding}" />
    </Style>

    <Style x:Key="SearchBoxBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource BrushSurfaceAlt}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusInput}" />
        <Setter Property="Padding" Value="{StaticResource InputPadding}" />
    </Style>

    <Style x:Key="PageTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource FontSizePageTitle}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
    </Style>

    <Style x:Key="SidebarBrandTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource FontSizeBrandTitle}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource BrushSidebarForeground}" />
    </Style>

    <Style x:Key="SidebarHintTextStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,8,0,0" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}" />
        <Setter Property="Foreground" Value="{DynamicResource BrushSidebarMuted}" />
    </Style>

    <Style x:Key="CardTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource FontSizeCardTitle}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
    </Style>

    <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource FontSizeSectionTitle}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
    </Style>

    <Style x:Key="MetricTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource FontSizeMetric}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
    </Style>

    <Style x:Key="BodyTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
        <Setter Property="Foreground" Value="{DynamicResource BrushForegroundSecondary}" />
    </Style>

    <Style x:Key="BodyMutedTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource FontSizeMetadata}" />
        <Setter Property="Foreground" Value="{DynamicResource BrushForegroundMuted}" />
    </Style>

    <Style x:Key="NavigationItemTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource FontSizeNavigation}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}" />
    </Style>
</ResourceDictionary>
