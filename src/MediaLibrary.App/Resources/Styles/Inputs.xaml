<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="InputFocusVisualStyle" TargetType="Control">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Control">
                    <Rectangle Margin="1"
                               RadiusX="12"
                               RadiusY="12"
                               Stroke="{DynamicResource BrushFocusRing}"
                               StrokeThickness="2" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="TextBoxStyle" TargetType="TextBox">
        <Setter Property="MinHeight" Value="{StaticResource InputHeight}" />
        <Setter Property="Padding" Value="{StaticResource InputPadding}" />
        <Setter Property="Background" Value="{DynamicResource BrushInputBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushInputBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CaretBrush" Value="{DynamicResource BrushAccent}" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource InputFocusVisualStyle}" />
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyBase}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="InputChrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource RadiusInput}">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="InputChrome" Property="BorderBrush" Value="{DynamicResource BrushInputFocusBorder}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="InputChrome" Property="Background" Value="{DynamicResource BrushDisabledBackground}" />
                            <Setter TargetName="InputChrome" Property="BorderBrush" Value="{DynamicResource BrushDisabledBorder}" />
                            <Setter Property="Foreground" Value="{DynamicResource BrushDisabledForeground}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SearchBoxStyle" TargetType="TextBox" BasedOn="{StaticResource TextBoxStyle}">
        <Setter Property="MinHeight" Value="{StaticResource ToolbarHeight}" />
    </Style>

    <Style x:Key="InputErrorTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource TextBoxStyle}">
        <Setter Property="BorderBrush" Value="{DynamicResource BrushErrorBorder}" />
        <Setter Property="Background" Value="{DynamicResource BrushErrorBackground}" />
    </Style>

    <Style x:Key="PasswordBoxStyle" TargetType="PasswordBox">
        <Setter Property="MinHeight" Value="{StaticResource InputHeight}" />
        <Setter Property="Padding" Value="{StaticResource InputPadding}" />
        <Setter Property="Background" Value="{DynamicResource BrushInputBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushInputBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource InputFocusVisualStyle}" />
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyBase}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="PasswordBox">
                    <Border x:Name="InputChrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource RadiusInput}">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="InputChrome" Property="BorderBrush" Value="{DynamicResource BrushInputFocusBorder}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="InputChrome" Property="Background" Value="{DynamicResource BrushDisabledBackground}" />
                            <Setter TargetName="InputChrome" Property="BorderBrush" Value="{DynamicResource BrushDisabledBorder}" />
                            <Setter Property="Foreground" Value="{DynamicResource BrushDisabledForeground}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="InputErrorPasswordBoxStyle" TargetType="PasswordBox" BasedOn="{StaticResource PasswordBoxStyle}">
        <Setter Property="BorderBrush" Value="{DynamicResource BrushErrorBorder}" />
        <Setter Property="Background" Value="{DynamicResource BrushErrorBackground}" />
    </Style>

    <Style x:Key="SensitiveFieldContainerStyle" TargetType="Border">
        <Setter Property="MinHeight" Value="{StaticResource InputHeight}" />
        <Setter Property="Background" Value="{DynamicResource BrushInputBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushInputBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusInput}" />
    </Style>

    <Style x:Key="SensitiveInputTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource TextBoxStyle}" />
    <Style x:Key="SensitiveInputPasswordBoxStyle" TargetType="PasswordBox" BasedOn="{StaticResource PasswordBoxStyle}" />

    <Style x:Key="EyeIconButtonStyle" TargetType="Button" BasedOn="{StaticResource SmallIconButtonStyle}">
        <Setter Property="Foreground" Value="{DynamicResource BrushForegroundMuted}" />
    </Style>

    <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
        <Setter Property="MinHeight" Value="{StaticResource InputHeight}" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="Background" Value="{DynamicResource BrushInputBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushInputBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyBase}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
        <Style.Triggers>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource BrushInputFocusBorder}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="{DynamicResource BrushDisabledBackground}" />
                <Setter Property="BorderBrush" Value="{DynamicResource BrushDisabledBorder}" />
                <Setter Property="Foreground" Value="{DynamicResource BrushDisabledForeground}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="CheckBoxStyle" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource BrushForegroundSecondary}" />
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyBase}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style x:Key="DatePickerStyle" TargetType="DatePicker">
        <Setter Property="MinHeight" Value="{StaticResource InputHeight}" />
        <Setter Property="Background" Value="{DynamicResource BrushInputBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource BrushForegroundPrimary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrushInputBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,8" />
    </Style>

    <Style x:Key="InputHelperTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource BrushForegroundMuted}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}" />
        <Setter Property="LineHeight" Value="{StaticResource LineHeightCaption}" />
        <Setter Property="Margin" Value="0,6,0,0" />
    </Style>

    <Style x:Key="InputErrorTextStyle" TargetType="TextBlock" BasedOn="{StaticResource InputHelperTextStyle}">
        <Setter Property="Foreground" Value="{DynamicResource BrushErrorForeground}" />
    </Style>

    <Style x:Key="PlaceholderTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource BrushForegroundMuted}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
        <Setter Property="IsHitTestVisible" Value="False" />
    </Style>
</ResourceDictionary>
